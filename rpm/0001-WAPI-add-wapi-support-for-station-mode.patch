+		beta = byteorder_inv(beta);
+		gamm = byteorder_inv(gamm);
+		zeta = byteorder_inv(zeta);
+	}
+
+	ua = alp ^ gn_sys_parm[0];
+	ub = beta ^ gn_sys_parm[1];
+	uc = gamm ^ gn_sys_parm[2];
+	ud = zeta ^ gn_sys_parm[3];
+
+	for (i = 0; i < 32; i = i + 4)
+	{
+		delta = ub ^ uc ^ ud ^ gn_fix_parm[i + 0];
+		delta = com_xy_trsform(delta);
+		ua = ua ^ delta;
+		rk[i + 0] = ua;
+
+		delta = uc ^ ud ^ ua ^ gn_fix_parm[i + 1];
+		delta = com_xy_trsform(delta);
+		ub = ub ^ delta;
+		rk[i + 1] = ub;
+
+		delta = ud ^ ua ^ ub ^ gn_fix_parm[i + 2];
+		delta = com_xy_trsform(delta);
+		uc = uc ^ delta;
+		rk[i + 2] = uc;
+
+		delta = ua ^ ub ^ uc ^ gn_fix_parm[i + 3];
+		delta = com_xy_trsform(delta);
+		ud = ud ^ delta;
+		rk[i + 3] = ud;
+	}
+
+	return 0;
+}
+
+void sm4alg(unsigned int *endek, const unsigned char *pd, unsigned char *ped)
+{
+	unsigned int *v = NULL;
+	unsigned int alp = 0;
+	unsigned int beta = 0;
+	unsigned int gamm = 0;
+	unsigned int zeta = 0;
+	unsigned int delta = 0;
+	unsigned int i = 0;
+	union _a
+	{
+		int m;
+		char n;
+	}a;
+
+	a.m = 1;
+
+	if (endek == NULL)
+	{
+		return;
+	}
+
+	if (pd == NULL)
+	{
+		return;
+	}
+
+	v = (unsigned int *)pd;
+	alp = v[0];
+	beta = v[1];
+	gamm = v[2];
+	zeta = v[3];
+
+	if (a.n == 1)
+	{
+		alp = byteorder_inv(alp);
+		beta = byteorder_inv(beta);
+		gamm = byteorder_inv(gamm);
+		zeta = byteorder_inv(zeta);
+	}
+
+	for (i = 0; i < 32; i = i + 4)
+	{
+		delta = beta ^ gamm ^ zeta ^ endek[i + 0];
+		delta = com_xx_trsform(delta);
+		alp = alp ^ delta;
+
+		delta = gamm ^ zeta ^ alp ^ endek[i + 1];
+		delta = com_xx_trsform(delta);
+		beta = beta ^ delta;
+
+		delta = zeta ^ alp ^ beta ^ endek[i + 2];
+		delta = com_xx_trsform(delta);
+		gamm = gamm ^ delta;
+
+		delta = alp ^ beta ^ gamm ^ endek[i + 3];
+		delta = com_xx_trsform(delta);
+		zeta = zeta ^ delta;
+	}
+
+	v = (unsigned int *)ped;
+	if (a.n == 1)
+	{
+		alp = byteorder_inv(alp);
+		beta = byteorder_inv(beta);
+		gamm = byteorder_inv(gamm);
+		zeta = byteorder_inv(zeta);
+	}
+
+	v[3] = alp;
+	v[2] = beta;
+	v[1] = gamm;
+	v[0] = zeta;
+}
+
+void SMS4Crypt(unsigned char *Input, unsigned char *Output, unsigned int *rk)
+{
+	sm4alg(rk, (const unsigned char *)Input, Output);
+}
+
+void SMS4KeyExt(unsigned char *Key, unsigned int *rk, unsigned int CryptFlag)
+{
+	if (ext_rkey_sm4alg(rk, (const unsigned char *)Key, 16))
+		wpa_printf(MSG_ERROR, "WAPI: SMS4KeyExt alg failed\n");
+}
