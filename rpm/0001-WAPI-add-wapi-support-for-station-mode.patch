+static boolean  VerifyPacketHMACData(uint8 * buffer, uint16 bufflen,
+		uint8 *pMAK, uint8 *pHMAC)
+{
+	boolean bVerify = FALSE;
+	uint8	bWAIHMAC[HMAC_LEN];
+
+	int	nLenHMAC = 20;
+
+	int nReturnLen = wapi_hmac_sha256(
+		(uint8 *)buffer,
+		bufflen,
+		pMAK,
+		16,
+		bWAIHMAC,
+		nLenHMAC);
+
+	if (nReturnLen == 0)
+	{
+		return FALSE;
+	}
+	else
+	{
+		if (memcmp(bWAIHMAC, pHMAC, HMAC_LEN) == 0)
+		{
+			bVerify = TRUE;
+		}
+		else
+			bVerify = FALSE;
+	}
+
+	return bVerify;
+
+}
