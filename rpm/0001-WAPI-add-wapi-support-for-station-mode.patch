+int PointToEcFpPoint(const Point *sour, EcFpPoint *dest )
+{
+	int i;
+	for (i = PARABUFFER-1; i >= 0; i--)
+		if (sour->x[i] != 0)
+			break;
+	dest->x.length = i + 1;
+	for (; i >= 0; i--)
+		dest->x.value[i] = sour->x[i];
+
+	for (i = PARABUFFER-1; i >= 0; i--)
+		if (sour->y[i] != 0)
+			break;
+	dest->y.length = i + 1;
+	for(; i >= 0; i--)
+		dest->y.value[i] = sour->y[i];
+
+	if((dest->x.length == 0)&&(dest->y.length == 0))
+		dest->isInfinite = 1;
+	else
+		dest->isInfinite = 0;
+
+	return 0;
+}
