+	p_akm_auit_cnt = ie_hdr + (WAPIIE_ELEMENT_ID_LEN +
+				   WAPIIE_LENGTH_LEN + WAPIIE_VERSION_LEN);
+	if (p_akm_auit_cnt + 2 >= ie_end)
+		goto err;
+
+	akm_suit_cnt = ((*p_akm_auit_cnt) | ((*(p_akm_auit_cnt + 1))
+					     << 8 & 0xff00)) & 0xffff;
+	p_akm = (p_akm_auit_cnt + WAPIIE_AKM_CNT_LEN);
+	for (i = 0; i < akm_suit_cnt; i++) {
+		if (p_akm + 4 >= ie_end)
+			goto err;
+		if (WAPIIE_AKM_SUIT_PSK == MY_GET32(p_akm)) {
+			wpa_printf(MSG_DEBUG, "[WAPI-PSK]");
+			ret = snprintf(pos, end - pos, "[WAPI-KEY]");
+			if (ret < 0 || ret >= end - pos)
