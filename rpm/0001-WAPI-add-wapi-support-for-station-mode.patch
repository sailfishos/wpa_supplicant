+	const struct wapi_ie_hdr *hdr;
+
+	if (!wapi_ie || !wapi_ie_len || !data) {
+		wpa_printf(MSG_ERROR, "Invalid WAPI IE");
+		return -1;
+	}
+
+	wpa_hexdump(MSG_DEBUG, "WAPI IE:", wapi_ie, wapi_ie_len);
+	hdr = (const struct wapi_ie_hdr *)wapi_ie;
