+		return -1;
+
+	if (wapi_ie_len < sizeof(struct wapi_ie_hdr)) {
+		wpa_printf(MSG_INFO, "%s: ie len too short %lu",
+			   __func__, (unsigned long) wapi_ie_len);
+		return -1;
