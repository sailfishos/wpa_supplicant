+	pos += data->singlecodenumber * WAPI_OUI_SIZE;
+	data->multicode = *(u32 *)pos;
+	pos += sizeof(data->multicode);
+	data->wapiability = WPA_GET_LE16(pos);
+	pos += sizeof(data->wapiability);
+
+	if ((pos - wapi_ie) < (data->len + 2)) {
+		data->bkidnumber = WPA_GET_LE16(pos);
+		pos += sizeof(data->bkidnumber);
+		data->bkidlist = (bkid *)pos;
+	}
+
+	wpa_printf(MSG_DEBUG, "WAPI IE Data element ID 0x%02x, length %d "
+		   "version %x", data->elem_id, data->len, data->version);
+	wpa_printf(MSG_DEBUG, "WAPI IE Data AKM num %d list %x "
+		   "Unicast num %d list %08x Multicast list %x "
+		   "capability %x BKID num %d",
+		   data->akmnumber, *(u32 *)(data->akmlist),
+		   data->singlecodenumber, *(u32 *)(data->singlecodelist),
+		   data->multicode, data->wapiability, data->bkidnumber);
+
+	return 0;
+}
