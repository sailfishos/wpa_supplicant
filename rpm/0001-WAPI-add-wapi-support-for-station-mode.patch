+	if( -1 == wlan_wapi_iface_fseek(fd,0,WLAN_WAPI_IFACE_SEEK_SET) )
+	{
+		wlan_wapi_iface_fclose(fd);
+		return eWAI_CERT_FSEEKERROR;
+	}
+
+	if( -1 == wlan_wapi_iface_fread(fd,strdata,filesize) )
+	{
+		wlan_wapi_iface_fclose(fd);
+		return eWAI_CERT_FSEEKERROR;
+	}
+
+	wlan_wapi_iface_fclose(fd);
+
+	pStrData = strdata;
+
+	//FIND CERTIFICATE
+	while(TRUE)
+	{
+		if (TRUE == parse_flag)
+		{
+			token = strtok((char*)(pStrData + pos), seps);
+			parse_flag = FALSE;
+		}
+		else
+		{
+			token = strtok(NULL, seps);
+		}
+		if(token == NULL)
+		{
+			return eWAI_CERT_FILEFORMATERROR;
+		}
+
+		len = strlen(token);
+		pos += len + 1;
+
+		if (strncmp(token, "-----BEGIN ASU CERTIFICATE-----", len)
+				== 0)
+		{
+			bAsu = TRUE;
+		}
+		else if (strncmp(token, "-----END ASU CERTIFICATE-----", len)
+				== 0)
+		{
+			bAsu = FALSE;
+		}
+		else if (strncmp(token, "-----BEGIN USER CERTIFICATE-----", len)
+				== 0)
+		{
+			bUser = TRUE;
+		}
+		else if (strncmp(token, "-----END USER CERTIFICATE-----", len)
+				== 0)
+		{
+			bUser = FALSE;
+		}
+		else if (strncmp(token, "-----BEGIN EC PRIVATE KEY-----", len)
+				== 0)
+		{
+			bPrivateKey = TRUE;
+		}
+		else if (strncmp(token, "-----END EC PRIVATE KEY-----", len)
+				== 0)
+		{
+			bPrivateKey = FALSE;
+			break;
+		}
+		else
+		{
+			//finded bAsu certificate
+			if (bAsu)
+			{
+				memcpy(pIssure64, token, len);
+				pIssure64 += len;
+				nIssurebase64 += len;
+			}
+
+			//finded bUser certificate
+			if (bUser)
+			{
+				memcpy(pSubject64, token, len);
+				pSubject64 += len;
+				nSubjectbase64 += len;
+			}
+
+			//finded bPrivateKey
+			if (bPrivateKey)
+			{
+				memcpy(pPrivatekey64, token, len);
+				pPrivatekey64 += len;
+				nPrivatekeybase64 += len;
+			}
+		}
+	}
+
+	/* base64 decode */
+	lenIssure = Base64Dec(issurebuf, issurebase64, nIssurebase64);
+
+	if(lenIssure == -1 || lenIssure == 0)
+	{
+		return eWAI_CERT_DECODEBASE64ERROR;
+	}
+	   //01:X509,02 is GBW
+	g_pStaCertificateParam->cerASUSTAasue.cer_identify = 0x0001;
+	g_pStaCertificateParam->cerASUSTAasue.cer_length = lenIssure;
+
+	memcpy(&(g_pStaCertificateParam->cerASUSTAasue.cer_X509),
+		(uint8 *)issurebuf, lenIssure);
+
+
+	/*-------------user cert and Privatekey */
+	/* base64 decode */
+
+	lenSubject = Base64Dec(subjectbuf, subjectbase64, nSubjectbase64);
+	lenPrivatekey = Base64Dec(privatekeybuf,privatekeybase64,
+			nPrivatekeybase64);
+
+	if(lenSubject == -1 || lenSubject == 0 || lenPrivatekey == -1
+				|| lenPrivatekey == 0)
+	{
+		return eWAI_CERT_DECODEBASE64ERROR;
+	}
+	  //01:X509,02 is GBW
+	g_pStaCertificateParam->cerSTAasue.cer_identify = 0x0001;
+	g_pStaCertificateParam->cerSTAasue.cer_length = lenSubject;
+
+	memcpy(&(g_pStaCertificateParam->cerSTAasue.cer_X509),
+		(uint8 *)subjectbuf, lenSubject);
+
+	unpack_private_key(lpPrivateKey, privatekeybuf,
+		(unsigned short)lenPrivatekey);
+
+	memset(&bdPubKey, 0, sizeof(bdPubKey));
+
+	if (get_pubkeyvalue_from_certificate(&(
+		g_pStaCertificateParam->cerSTAasue), &bdPubKey) != 0)
+	{
+		return eWAI_CERT_CERTIFICATE_FORMAT_ERROR;
+	}
+
+	if(!VerifyKey(lpPrivateKey->vPrivateKey, bdPubKey.data))
+	{
+		return eWAI_CERT_CERTIFICATE_FORMAT_ERROR;
+	}
+
+	g_pStaCertificateParam->staSecKey.length = SECKEY_LEN;
+
+	memcpy(g_pStaCertificateParam->staSecKey.data,
+		lpPrivateKey->vPrivateKey, SECKEY_LEN);
+
+	if( 0 != certificate_test(&(g_pStaCertificateParam->cerASUSTAasue)))
+	{
+		return eWAI_CERT_CERTIFICATE_FORMAT_ERROR;
+	}
+
+	if( 0 != certificate_test(&(g_pStaCertificateParam->cerSTAasue)))
+	{
+		return eWAI_CERT_CERTIFICATE_FORMAT_ERROR;
+	}
+
+	return eWAI_CERT_NO_ERROR;
+}
