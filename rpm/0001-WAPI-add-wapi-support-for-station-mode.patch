+int GenRandomNumber (MInt *theInt, MInt *maxInt)
+{
+	int j, k, aa;
+	MInt t;
+	unsigned int ss = 1;
+	ecc_srand((unsigned)ecc_time(NULL));
+
+	t.length = maxInt->length ;
+
+	for(j = 0;j < maxInt->length ;j++)
+	{
+		for(k = 0; k < 3; k++)
+	{
+
+	aa = ecc_rand()+randseed+(randseed<<1)+(randseed>>1);
+	randseed++;
+	ss = ss|(aa<<k*11);
+	}
+	t.value[j] = ss;
+	ss = 1;
+	}
+	MI_ModularReduce (&t, maxInt,theInt);
+
+	return 0;
+}
