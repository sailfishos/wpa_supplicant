+void sha256_digest_int(const void *msg, unsigned len, MInt *d)
+{
+	unsigned char tmp[64] = {0};
+	unsigned i;
+	mhash_sha256_base((unsigned char*)msg, len, tmp);
+
+	for (i = 0; i < 8; i++)
+	{
+		unsigned char* p = tmp + 4*i;
+		d->value[7-i] = (p[0]<<24) + (p[1]<<16) + (p[2]<<8) + p[3];
+	}
+	d->length = 8;
+}
