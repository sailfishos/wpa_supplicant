+int FP_Substract (MInt *minuend, MInt *subtrahend,
+		MInt *modulus, MInt *difference)
+{
+	MInt  t;
+	int status;
+	status = MI_Subtract (minuend, subtrahend, &t);
+	if (status == 0)
+		MI_Move (&t, difference);
+	else
+		MI_Subtract (modulus, &t, difference);
+    return 0;
+
+}
