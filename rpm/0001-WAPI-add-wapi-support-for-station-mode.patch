+static int FpDivByTwo(MInt *a, MInt *p)
+{
+	int len, i;
+	uint32 *av, shifth, shiftl;
+	av = a->value;
+	len = a->length;
+	shifth = 0;
+	if (av[0] == ((av[0]>>1)<<1))
+	{
+		if (av[len-1] == 1)
+			a->length=len-1;
+		for (i = len-1; i >= 0; i--)
+		{
+			shiftl = av[i] - ((av[i]>>1)<<1);
+			av[i] = (shifth<<31) + (av[i]>>1);
+			shifth = shiftl;
+		}
+	}
+	else
+	{
+		MI_Add(a, p, a);
+		len = a->length;
+		if (av[len-1] == 1)
+			a->length = len - 1;
+		for (i = len-1; i >= 0; i--)
+		{
+			shiftl = av[i] - ((av[i]>>1)<<1);
+			av[i] = (shifth<<31) + (av[i]>>1);
+			shifth = shiftl;
+		}
+	}
+	return 0;
+}
