+static int wapi_key_mgmt_to_bitfield(const u8 *s)
+{
+	if (os_memcmp(s, WAPI_AUTH_KEY_MGMT_CERT, WAPI_SELECTOR_LEN) == 0)
+		return WPA_KEY_MGMT_WAPI_CERT;
