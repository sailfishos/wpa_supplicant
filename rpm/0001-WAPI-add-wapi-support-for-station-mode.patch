+uint32 certificate_test(certificate * pcert)
+{
+
+	wapi_X509 *pCerX509 = NULL;
+
+	WAPI_X509_NAME1	   *pX509Nameissure = NULL;
+	WAPI_X509_NAME1	   *pX509Namesubject = NULL;
+	WAPI_ASN1_INTEGER  *pX509SerialNumber = NULL;
+
+	uint8 bNameissure[256] = {0};
+	uint8 bNamesubject[256] = {0};
+	uint8 bSerialNumber[256] = {0};
+	unsigned char *pNameissure = NULL;
+	unsigned char *pNamesubject = NULL;
+	unsigned char *pSerialNumber = NULL;
+
+	const unsigned char *p = NULL;
+
+
+	if (pcert->cer_identify == 0x0001)
+	{
+
+		p = pcert->cer_X509;
+
+		pCerX509 = wapi_X509_new();
+
+		if (d2i_wapi_X509(&pCerX509, &p, pcert->cer_length) == NULL)
+		{
+			wapi_X509_free(pCerX509);
+			return PACK_ERROR;
+		}
+
+		pX509Namesubject = X509_get_subject_name_wapi(pCerX509);
+		pX509Nameissure = X509_get_issuer_name_wapi(pCerX509);
+		pX509SerialNumber = X509_get_serialNumber_wapi(pCerX509);
+
+		pNameissure = bNameissure;
+		pNamesubject = bNamesubject;
+		pSerialNumber = bSerialNumber;
+
+		i2d_wapi_X509_NAME(pX509Namesubject, &pNamesubject);
+		i2d_wapi_X509_NAME(pX509Nameissure, &pNameissure);
+		i2d_wapi_ASN1_INTEGER(pX509SerialNumber, &pSerialNumber);
+
+		wapi_X509_free(pCerX509);
+	}
+	else
+	{
+		return PACK_ERROR;
+	}
+
+	return 0;
+}
