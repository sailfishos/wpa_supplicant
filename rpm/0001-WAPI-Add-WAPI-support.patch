+    }
+
+	free ( asucert_out );
+    free ( prikey_out );
+    free ( unpack_cert );
+	wapi_printf ( MSG_DEBUG , "in '%s':'%d' verify cert ok\n" , __func__ ,
+			__LINE__, __LINE__); 
+     
+	return 0;
+	
+error:
+	
+    free ( asucert_out );
+    free ( prikey_out );
+    free ( unpack_cert );
+	
+    return -1;
