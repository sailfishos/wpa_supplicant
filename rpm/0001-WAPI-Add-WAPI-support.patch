+int
+Is_Wapi_Cert ( unsigned char *asue_cert , int asue_len )
+{
+    int ret = 0;
+    X509_Cert *ctx = NULL;
+    char out [ CHAR_LENGTH ] = { 0 };
+    int outlen = 0;
+
+    if ( asue_cert == NULL || asue_len == 0 )
+    {
+        return 0;
+    }
+
+    ctx = (X509_Cert *) malloc ( sizeof(X509_Cert) );
+
+    ret = UnPack_X509 ( asue_cert , asue_len , ctx );
+    if ( !ret )
+    {
+        return 0;
+    }
+    memset ( out , 0 , CHAR_LENGTH );
+    GetX509Info_ASN1 ( ctx , ISSUER , (unsigned char *) out , &outlen );
+
+    if ( strstr ( out , "WAPI" ) == 0 )
+    {
+        return 0;
+    }
+    free ( ctx );
+    return 1;
+}
