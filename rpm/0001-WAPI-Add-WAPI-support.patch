+	};
+
+
+	switch(curve_mode)
+	{
+        case SM2_P256:
+			if(1 == s_b_init)	return 0;
+    
+			if(IWN_OpenSession((void **)&session_1,&g_SM2_Curve)!=SDR_OK)
+			{
+				return -1;
+			}
+
+            *session = session_1;
+			s_b_init = 1;
+			return s_b_init;
+			break;
+        case ECC_P192:		
+			if(1 == s_b_init_1)	return 0;
+    
+			if(IWN_OpenSession((void **)&session_1,&g_ECDSA_Curve)!=SDR_OK)
+			{
+				return -1;
+			}
+
+			*session = session_1;
+			s_b_init_1 = 1;
+			return s_b_init_1;
+            break;
+        default:
+			return -2;
+    }
+
+}
+
+void cryplib_exit(SessionHandle *session)
+{
+	IWN_CloseSession(session);
+}
+
+int create_sm2key_bin(p8 k)
+{
+
+	ECCrefPrivateKey pri_key;
+	ECCrefPublicKey pub_key;
+	SessionHandle *session = NULL;
+	int len=0;
+
+	memset(&pri_key,0,sizeof(ECCrefPrivateKey));
+	memset(&pub_key,0,sizeof(ECCrefPublicKey));
+
+	cryplib_init(&session,SM2_P256);
+    if(SDF_GenerateKeyPair_ECC(session, SGD_SM2, 256, &pub_key, &pri_key)!=SDR_OK)
+	{
+		cryplib_exit(session);
+        return -1;	
+	}
+
+	cryplib_exit(session);
+
+	memcpy(k,pub_key.x,32);
+	memcpy(k+32,pub_key.y,32);
+	memcpy(k+64,pri_key.D,32);
+
+	len = 32+32+32;
+
+	return len;
+}
+
+int create_ecc192key_bin(p8 k)
+{
+
+	ECCrefPrivateKey pri_key;
+	ECCrefPublicKey pub_key;
+	SessionHandle *session = NULL;
+	int len=0;
+
+	memset(&pri_key,0,sizeof(ECCrefPrivateKey));
+	memset(&pub_key,0,sizeof(ECCrefPublicKey));
+
+	cryplib_init(&session,ECC_P192);
+    if(SDF_GenerateKeyPair_ECC(session, SGD_ECC, 192, &pub_key, &pri_key)!=SDR_OK)
+	{
+		cryplib_exit(session);
+        return -1;	
+	}
+
+    cryplib_exit(session);
+
+	memcpy(k,pub_key.x,24);
+	memcpy(k+24,pub_key.y,24);
+	memcpy(k+48,pri_key.D,24);
+
+	len = 24+24+24;
+
+	return len;
+}
+/*------------------------------------------------------------------------------*/
+int Set_Pubkey_X509(unsigned char *in_data,int len,unsigned char **outdata)
+{
+	int len_1=0,len_2=0,len_3=0,len_4=0,len_5=0;
+	unsigned char *p_data_1=NULL;
+	unsigned char *p_data_2=NULL;
+	unsigned char *p_data_3=NULL;
+	unsigned char *p_data_4=NULL;
+	unsigned char *p_data_5=NULL;
+	unsigned char data[1]={0x04};
+	unsigned char key_data[200]={0};
+	unsigned char buf_1[20]={0};
+	unsigned char buf_2[20]={0};
+	unsigned char buf_3[40]={0};
+	unsigned char buf_4[200]={0};
+
+
+	p_data_1 = buf_1;
+	len_1 = Der_Obj(&(oid_alg_data[17]),7,&p_data_1);
+	p_data_2 = buf_2;
+	len_2 = Der_Obj(&(oid_alg_data[1]),8,&p_data_2);
+
+	len_3=Der_Obj_Len(len_1+len_2,SEQUENCE,1);
+    p_data_3 = buf_3;
+	Der_Put_Obj(&p_data_3,len_1+len_2,SEQUENCE,1,UNIVERSAL);
+	memcpy(p_data_3,buf_1,len_1);
+	memcpy(p_data_3+len_1,buf_2,len_2);
+
+	memcpy(key_data,data,1);
+	memcpy(key_data+1,in_data,len);
+    p_data_4 = buf_4;
+	len_4 = Der_Bytes(key_data,len+1,UNIVERSAL,BIT_STRING,&p_data_4);
+
+    len_5=Der_Obj_Len(len_3+len_4,SEQUENCE,1);
+    p_data_5 = *outdata;
+	Der_Put_Obj(&p_data_5,len_3+len_4,SEQUENCE,1,UNIVERSAL);
+	memcpy(p_data_5,buf_3,len_3);
+	memcpy(p_data_5+len_3,buf_4,len_4);
+	*outdata = p_data_5;
+
+    return len_5;
+}
+/*------------------------------------------------------------------------*/
+int Sign_X509(unsigned char *key,unsigned char *indata,int inlen, unsigned char *puc_id,int id_len,
+			  unsigned char **sign_data,int *sign_len,unsigned char **outdata)
+{
+	ECCrefPrivateKey pri_key;
+	ECCSignature sign;
+	SessionHandle *session = NULL;
+	int len_r=0,len_s=0,len_1=0,len_2=0,len_3=0,len_4=0,len_5=0;
+	unsigned char *outdata_r=NULL;
+	unsigned char *outdata_s=NULL;
+	unsigned char *p_data_1=NULL;
+	unsigned char *p_data_2=NULL;
+	unsigned char *p_data_3=NULL;
+	unsigned char *p_data_4=NULL;
+	unsigned char *p_data_5=NULL;
+	unsigned char *p_data_6=NULL;
+	unsigned char *p_data_7=NULL;
+	unsigned char data_r[80]={0}; 
+	unsigned char data_s[80]={0}; 
+	unsigned char buf_1[200]={0}; 
+	unsigned char buf_2[200]={0};
+	unsigned char buf_3[20]={0};
+	unsigned char buf_4[20]={0};
+	unsigned char buf_5[10]={0};
+
+
+	memset(&pri_key,0,sizeof(ECCrefPrivateKey));
+	memset(&sign,0,sizeof(ECCSignature));
+
+	memcpy(pri_key.D,key,32);
+	pri_key.bits=256;
+
+    cryplib_init(&session,SM2_P256);
+	if(IWN_ExternalSignHash_ECC(session,SGD_SM2_1,&pri_key,indata,inlen,puc_id,id_len,&sign)!=SDR_OK)
+	{
+		cryplib_exit(session);
+	    return -1;
+	}
+
+	cryplib_exit(session);
+
+	p_data_7 = *sign_data;
+	memcpy(p_data_7,sign.r,pri_key.bits/8);
+	memcpy(p_data_7+pri_key.bits/8,sign.s,pri_key.bits/8);
+	*sign_data = p_data_7;
+	*sign_len = 64;
+
+    outdata_r = data_r;
+	len_r = Der_Integer(sign.r,32,&outdata_r);
+	
+	outdata_s = data_s;
+	len_s = Der_Integer(sign.s,32,&outdata_s);
+
+	len_1=Der_Obj_Len(len_r+len_s,SEQUENCE,1);
+    p_data_1 = buf_1;
+	Der_Put_Obj(&p_data_1,len_r+len_s,SEQUENCE,1,UNIVERSAL);
+	memcpy(p_data_1,data_r,len_r);
+	memcpy(p_data_1+len_r,data_s,len_s);
+
+	p_data_2 = buf_2;
+	len_2 = Der_Bytes(buf_1,len_1,UNIVERSAL,BIT_STRING,&p_data_2);
+
+	p_data_3 = buf_3;
+	len_3 = Der_Obj(&(oid_alg_data[9]),8,&p_data_3);
+
+    //ASN1_NULL └Óą═ 0x05,0x00
+	len_5=Der_Obj_Len(0,ASN1_NULL,1);
+    p_data_6 = buf_5;
+	Der_Put_Obj(&p_data_6,0,ASN1_NULL,0,UNIVERSAL);
+
+    memcpy(buf_3+len_3,buf_5,len_5);
+	len_3 += 2;
+
+	len_4=Der_Obj_Len(len_3,SEQUENCE,1);
+    p_data_4 = buf_4;
+	Der_Put_Obj(&p_data_4,len_3,SEQUENCE,1,UNIVERSAL);
+	memcpy(p_data_4,buf_3,len_3);
+
+	p_data_5 = *outdata;
+	memcpy(p_data_5,buf_4,len_4);
+	memcpy(p_data_5+len_4,buf_2,len_2);
+	*outdata = p_data_5;
+
+    return len_2+len_4;
+}
+
+int Vrfy_X509(unsigned char *key,unsigned char *indata,int inlen, unsigned char *puc_id,int id_len,unsigned char *sign_data)
+{
+	ECCrefPublicKey pub_key;
+	ECCSignature sign;
+	SessionHandle *session = NULL;
+  
+	memset(&pub_key,0,sizeof(ECCrefPublicKey));
+	memset(&sign,0,sizeof(ECCSignature));
+
+	memcpy(pub_key.x,key,32);
+	memcpy(pub_key.y,key+32,32);
+	pub_key.bits=256;
+
+	memcpy(sign.r,sign_data,32);
+	memcpy(sign.s,sign_data+32,32);
+	cryplib_init(&session,SM2_P256);
+	if(IWN_ExternalVerifyHash_ECC(session,SGD_SM2_1,&pub_key,indata,inlen,puc_id,id_len,&sign)!=SDR_OK)
+	{
+		cryplib_exit(session);
+		return -1;
+	}
+
+	cryplib_exit(session);
+
+	return 0;
+}
+/*---------------------------------------------------------------------*/
+int Set_Pubkey_192_X509(unsigned char *in_data,int len,unsigned char **outdata)
+{
+	int len_1=0,len_2=0,len_3=0,len_4=0,len_5=0;
