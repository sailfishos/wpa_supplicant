+
+int
+Parse_P12_Cert ( unsigned char *inp12 , int len , char *password ,
+		char *out_cert , int *out_cert_len )
+{
+	char cert_begin[64] = CERT_BEGIN;
+	char cert_end[64] = CERT_END;
+	char prikey_begin[64] = PKEY_BEGIN;
+	char prikey_end[64] = PKEY_END;
+	
+    unsigned char *unpack_cert = NULL;
+    int unpack_cert_len = CERT_MAX_LEN;
+    unsigned char *unpack_prikey = NULL;
+    int unpack_prikey_len = PRIKEY_MAX_LEN;
+	
+	unsigned char *encode_cert = NULL;
+	int encode_cert_len = CERT_MAX_LEN;
+	unsigned char *encode_prikey = NULL;
+	int encode_prikey_len = PRIKEY_MAX_LEN;
+
+	/* Temp point and len*/
+	char *p = NULL;
+	int tmp_len = 0;
+	
+	int temp_cert_len = 0;
+	
+	strncat(cert_begin, "\n", 1);
+	strncat(cert_end, "\n", 1);
+	strncat(prikey_begin, "\n", 1);
+	
+	unpack_cert = (unsigned char *)malloc(unpack_cert_len);
+	unpack_prikey = (unsigned char *) malloc(unpack_prikey_len);
+	encode_cert = (unsigned char *)malloc(encode_cert_len);
+	encode_prikey = (unsigned char *) malloc(encode_prikey_len);
+	
+    if ( IWN_ParseP12ToX509_Mod ( inp12 , len , (const char *) password ,
+            unpack_cert , &unpack_cert_len , unpack_prikey , &unpack_prikey_len , NULL ,
+            NULL ) != CTP_OK )
+    {
+        wapi_printf(MSG_ERROR, "IWN_ParseP12ToX509_Mod error\n");
+		free(encode_prikey);
+		free(encode_cert);
+		free(unpack_prikey);
+		free(unpack_cert);
+        return -1;
+    }
+	
+	EncodeBase64 ( unpack_cert , unpack_cert_len , encode_cert ,
+			&encode_cert_len );
+	EncodeBase64 ( unpack_prikey , unpack_prikey_len , encode_prikey ,
+			&encode_prikey_len );
+	
+	/* wapi_hexdump(MSG_DEBUG, "encode_cert:",
+			encode_cert, encode_cert_len);
+	wapi_hexdump(MSG_DEBUG, "encode_prikey:",
+			encode_prikey, encode_prikey_len); */
+	
+	temp_cert_len = strlen(cert_begin) + encode_cert_len + 1 +
+			strlen(cert_end) + strlen(prikey_begin) + 
+			encode_prikey_len + 1 + strlen(prikey_end);
+	if (*out_cert_len < temp_cert_len)
+	{
+		wapi_printf ( MSG_ERROR , "in %s: The out_cert buffer is too small.", 
+				__func__ );
+		free(encode_prikey);
+		free(encode_cert);
+		free(unpack_prikey);
+		free(unpack_cert);
+        return -1;
+	}
+	
+	/* Generate out cert data format */
+	p = out_cert;
+	*out_cert_len = 0;
+	
+	/* Add cert begin tag */
+	tmp_len = strlen(cert_begin);
+	memcpy(p, cert_begin, tmp_len);
+	p += tmp_len;
+    *out_cert_len += tmp_len;
+	
+	/* Add cert content */
+	memcpy(p, encode_cert, encode_cert_len);
+	p[encode_cert_len] = '\n';
+	p += (encode_cert_len + 1);
+	*out_cert_len += (encode_cert_len + 1);
+	
+	/* Add cert end tag */
+	tmp_len = strlen(cert_end);
+	memcpy(p, cert_end, tmp_len);
+	p += tmp_len;
+    *out_cert_len += tmp_len;
+	
+	/* Add private key begin tag */
+	tmp_len = strlen(prikey_begin);
+	memcpy(p, prikey_begin, tmp_len);
+	p += tmp_len;
+    *out_cert_len += tmp_len;
+	
+	/* Add private key content */
+	memcpy(p, encode_prikey, encode_prikey_len);
+	p[encode_prikey_len] = '\n';
+	p += (encode_prikey_len + 1);
+	*out_cert_len += (encode_prikey_len + 1);
+	
+	/* Add private key end tag */
+	tmp_len = strlen(prikey_end);
+	memcpy(p, prikey_end, tmp_len);
+	/* p += tmp_len; */
+    *out_cert_len += tmp_len;
+	
+	free(encode_prikey);
+	free(encode_cert);
+	free(unpack_prikey);
+	free(unpack_cert);
+	
+    return 0;
+}
+
+int
+Get_Asue_Cert_Info (unsigned char *usrcert , int certlen , 
+		char *certinfo, int certinfosize)
+{
+    int ret = 0;
+    char *p;
+	char tmp[10];
+    certs_info *results = NULL;
+    unsigned char *unpack_cert = NULL;
+    int unpackcert_len = 0;
+	
+	int cert_info_len = 0;
+	
+    if ( usrcert == NULL || certlen <= 0 )
+    {
+        wapi_printf ( MSG_ERROR , "in %s:%d:buf or buflen error \n" ,
+         __func__ , __LINE__ );
+        return -1;
+    }
+
+    unpack_cert = malloc ( certlen );
+	results = (certs_info *)malloc(sizeof(certs_info));
+	memset(results, 0, sizeof(certs_info));
+    if (unpack_cert == NULL || results == NULL)
+    {
+        wapi_printf ( MSG_ERROR , "in %s:%d: malloc buf faild \n" ,
+         __func__ , __LINE__ );
+        goto error;
+    }
+
+    ret = Unpack_AsueCert ( usrcert , certlen , unpack_cert , &unpackcert_len );
+    if ( ret != 0 )
+    {
+        wapi_printf ( MSG_ERROR , "in '%s':'%d' Unpack_AsueCert failed\n" ,
+         __func__ , __LINE__ );
+        goto error;
+    }
+    
+    ret = X509_Get_Cert_Info ( unpack_cert , unpackcert_len , results );
+    if ( ret < 0 )
+    {
+        //free ( unpack_cert );
+        wapi_printf ( MSG_ERROR , "in %s:%d:X509_Get_Cert_Info error\n" ,
+         __func__ , __LINE__ );
+        goto error;
+    }
+    
+    memset ( certinfo , 0 , strlen ( certinfo ) );
+	p = certinfo;
+
+	snprintf ( tmp , 10 , "%02x%02x%02x%02x" ,SERIAL2STR ( results->serial_no->data ) );
+	
+	cert_info_len = strlen(tmp) + results->asu_name->length +
+			results->asue_name->length + results->date_after->length +
+			results->date_before->length + results->issuer->length + 6;
+	if (certinfosize < cert_info_len)
+	{
+		wapi_printf ( MSG_ERROR , "in %s: The certinfo buffer is too small." , 
+				__func__ );
+        goto error;
+	}
+	
+	memcpy ( p , tmp, strlen ( tmp ) );
+	p += strlen ( tmp );
+	memcpy ( p , "\t", 1 );
+	p += 1;
+	memcpy ( p , results->asu_name->data, results->asu_name->length );
+	p += results->asu_name->length;
+	memcpy (p , "\t", 1);
+	p += 1;
+	memcpy ( p , results->asue_name->data, results->asue_name->length );
+	p += results->asue_name->length;
+	memcpy ( p , "\t", 1 );
+	p += 1;
+	memcpy ( p , results->date_after->data, results->date_after->length );
+	p += results->date_after->length;
+	memcpy ( p , "\t", 1 );
+	p += 1;
+	memcpy ( p , results->date_before->data, results->date_before->length );
+	p += results->date_before->length;
+	memcpy ( p , "\t", 1 );
+	p += 1;
+	memcpy ( p , results->issuer->data, results->issuer->length );
+	p += results->issuer->length;
+	memcpy ( p , "\t", 1 );
+	p += 1;
+
+	/* ret = snprintf ( tmpbuf , 128 , "%02x%02x%02x%02x\t%s\t%s\t%s\t%s\t%s\t" ,
+            SERIAL2STR ( results->serial_no->data ) , results->asu_name->data ,
+            results->asue_name->data , results->date_after->data ,
+            results->date_before->data , results->issuer->data );
+    
+	memcpy( certinfo , tmpbuf , strlen ( tmpbuf )); */
+	
+	free(unpack_cert);
+    free_obj(results);
+    return 0;
+
+error:
+	free(unpack_cert);
+	free_obj(results);
+	return -1;
+}
+
