+	mint_to_fixedlen_os(&(resp_pubkey.x),EccSessionHandle->g_fixlen,ECCref_MAX_LEN,&len,ResponsePublicKey.x);
+	mint_to_fixedlen_os(&(resp_pubkey.y),EccSessionHandle->g_fixlen,ECCref_MAX_LEN,&len,ResponsePublicKey.y);
+	ResponsePublicKey.bits = EccSessionHandle->g_fixlen*PRE_BYTE_BITS;
