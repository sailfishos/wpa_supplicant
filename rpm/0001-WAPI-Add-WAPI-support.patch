+static int wpa_config_parse_wapi_psk(const struct parse_data *data,
+				     struct wpa_ssid *ssid, int line,
+				     const char *value)
+{
+	size_t len;
+	char *str = wpa_config_parse_string(value, &len);
+	if (str == NULL) {
+		return 1;
+	}
+	if (len < 8 || len > 64) {
+		wpa_printf(MSG_ERROR, "Line %d: invalid WAPI "
+			   "passphrase length %d (expected "
+			   "8..64)", line, (int)len);
+		os_free(str);
+		return 1;
+	} else {
+		ssid->wapi_psk_len = len;
+		os_free(ssid->wapi_psk);
+		ssid->wapi_psk = os_strdup(str);
+		os_free(str);
+		if (ssid->wapi_psk && os_strcmp(ssid->wapi_psk, "") != 0) {
+			/* wpa_printf(MSG_DEBUG, "Line %d: wapi_psk=%s", line, bss->ssid.wapi_psk); */
+			wpa_printf(MSG_DEBUG, "Line %d: wapi_psk=%s", line, "*");
+		}
+	}
+
+	return 0;
+}
