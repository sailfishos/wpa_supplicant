+#include <string.h>
+#include "sm4algmodes.h"
+
+/*
+ * wpi_encrypt - wpi encrypt
+ * @iv_in: iv for encrypt
+ * @buf_in: data to be encrypted
+ * @buf_len_in: data length
+ * @key_in: key for encrypt
+ * @buf_out: output encrypted data
+ *
+ * Returns: if success, return 0; else, return -1
+*/
+
+int wpi_encrypt(unsigned char *iv_in, unsigned char *buf_in, 
+		unsigned int buf_len_in, unsigned char *key_in, unsigned char *buf_out)
+{
+	unsigned char tmp_iv_in[16];
+	memcpy(tmp_iv_in, iv_in, 16);
+	return ofb_mode_endec_sm4(buf_in, buf_out, buf_len_in, tmp_iv_in, key_in);
+}
+
+/*
+ * wpi_decrypt - wpi decrypt
+ * @iv_in: iv for decrypt
+ * @buf_in: data to be decrypted
+ * @buf_len_in: data length
+ * @key_in: key for decrypt
+ * @buf_out: output decrypted data
+ *
+ * Returns: if success, return 0; else, return -1
+*/
+
+int wpi_decrypt(unsigned char *iv_in, unsigned char *buf_in, 
+		unsigned int buf_len_in, unsigned char *key_in, unsigned char *buf_out)
+{
+    return wpi_encrypt(iv_in, buf_in, buf_len_in, key_in, buf_out);
+}
