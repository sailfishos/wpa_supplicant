+int
+Unpack_AsuCert (unsigned char *asucert , int asu_len ,
+        unsigned char *asucert_out , int *asucert_outlen )
+{
+    int ret = 0;
+    unsigned char *pbuf = NULL;
+    int nCertStart = 0 , nCertEnd = 0;
+    int start = 0 , end = 0;
+    unsigned char *dec_buf = NULL;
+    int asucert_len = asu_len;
+    int outlen = 0;
+	if ( asu_len == 0 )
+    {
+        wapi_printf ( MSG_ERROR, "asu_len = 0 error.\n" );
+        return -1;
+    }
+
+    outlen = Cert_Str_filter ( asucert , asu_len );
+    pbuf = asucert;
+	
+    nCertStart = cert_search ( (const char *) pbuf , CERT_BEGIN , 0 );
+    nCertEnd = cert_search ( (const char *) pbuf , CERT_END , 0 );
+    
+	if ( nCertStart == -1 || nCertEnd == -1 )
+    {
+        wapi_printf ( MSG_ERROR , "CERT_BEGIN CERT_END not be searched.\n" );
+        return -1;
+    }
+	
+    start = (int) (nCertStart + (int) (strlen ( CERT_BEGIN )));
+	if (start >= nCertEnd)
+	{
+		wapi_printf(MSG_ERROR, "ASU cert format error.\n");
+        return -1;
+	}
+    end = (int) ((nCertEnd - nCertStart) - (int) (strlen ( CERT_BEGIN )));
+
+	dec_buf = (unsigned char *) calloc ( outlen + 1 , sizeof(unsigned char) );
+    memset ( dec_buf , 0 , outlen );
+    ret = DecodeBase64 ( (pbuf + start) , end , dec_buf , &asucert_len );
+    /* wapi_hexdump(MSG_DEBUG, "asu cert decode base64 after:", dec_buf , asucert_len); */
+    memcpy ( asucert_out , dec_buf , asucert_len );
+    *asucert_outlen = asucert_len;
+	free( dec_buf );
+    return 0;
+
+}
