diff --git a/src/libcert_parse/certcode/p12_create.c b/src/libcert_parse/certcode/p12_create.c
new file mode 100644
index 0000000..fa34a6f
--- /dev/null
+++ b/src/libcert_parse/certcode/p12_create.c
@@ -0,0 +1,178 @@
+//2015/11/17 ą▐Ė─
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include "getlen.h"
+#include "structdef.h"
+
+
+int Unpack_P12_PrivateKey(unsigned char *In,int len,P12_PRIVATEKEY *p12_prikey)
+{
+	int len0=0,len1=0,len2=0,len3=0,len4=0;
+	unsigned char Llen=0;
+	unsigned char *p=NULL,*q1=NULL,*q2=NULL,*q3=NULL,*q4=NULL;
+    int p12_prikey_length = 0;
+
+	p = In;
+	p += 1;
+	len4 = GetInfoLength(p,&Llen);
+	p += Llen;
+	p12_prikey_length += 1 + Llen;
+
+	q1 = p;
+	p += 1;
+	len0 = GetInfoLength(p,&Llen);
+	p += Llen;
+	p12_prikey->Version.data = q1;
+	p12_prikey->Version.length = len0+Llen+1;
+	p12_prikey_length += 1 + Llen + len0;
+	p += len0; 
+
+	q2 = p;
+	p += 1;
+	len1 = GetInfoLength(p,&Llen);
+	p += Llen;
+	p12_prikey->KeyInfo.data = q2;
+	p12_prikey->KeyInfo.length = len1+Llen+1;
+	p12_prikey_length += 1 + Llen + len1;
+	p += len1; 
+
+	p += 2;
+	p12_prikey_length += 2;
+	q3 = p;
+	p += 1;
+	len2 = GetInfoLength(p,&Llen);
+	p += Llen;
+	p12_prikey->AlgorithmInfo.data = q3;
+	p12_prikey->AlgorithmInfo.length = len2+Llen+1;
+	p12_prikey_length += 1 + Llen + len2;
+	p += len2; 
+
+	q4 = p;
+	p += 1;
+	len3 = GetInfoLength(p,&Llen);
+	p += Llen;
+	p12_prikey->PublicKey.data = q4;
+	p12_prikey->PublicKey.length = len3+Llen+1;
+	p12_prikey_length += 1 + Llen + len3; 
+	
+	if(p12_prikey_length == len)
+	{
+	    return CTP_OK;	
+	}
+	else
+	{
+		return CTP_FALSE;
+	}
+	return CTP_OK;
+}
+
+void End_P12_PrivateKey(P12_PRIVATEKEY *p12_prikey)
+{
+	memset(p12_prikey,0,sizeof(P12_PRIVATEKEY));
+}
+
+int Get_P12_PK_Version(P12_PRIVATEKEY *p12_prikey,unsigned char *out,int *outlen)
+{
+	int len=0;
+	unsigned char Llen=0;
+	unsigned char *p = p12_prikey->Version.data;
+
+	if(p12_prikey->Version.data == NULL)
+		return CTP_FALSE;
+
+	p += 1;
+	len = GetInfoLength(p,&Llen);
+	p += Llen;
+	*outlen = len;
+	memcpy(out,p,len);
+	return CTP_OK;
+}
+
+int Get_P12_PK_PriKey(P12_PRIVATEKEY *p12_prikey,unsigned char *out,int *outlen)
+{
+	int len=0;
+	unsigned char Llen=0;
+	unsigned char *p = p12_prikey->KeyInfo.data;
+
+	if(p12_prikey->KeyInfo.data == NULL || out == NULL || outlen == NULL)
+		return CTP_FALSE;
+
+	p += 1;
+	len = GetInfoLength(p,&Llen);
+	if(len>*outlen)
+		return CTP_FALSE;
+	p += Llen;
+	*outlen = len;
+	if(len != 0)
+	{
+		memcpy(out,p,len);
+	}
+	return CTP_OK;
+}
+
+int Get_P12_PK_AlgorithmPARAM(P12_PRIVATEKEY *p12_prikey,unsigned char *out,int *outlen)
+{
+	int len=0;
+	unsigned char Llen=0;
+	unsigned char *p = p12_prikey->AlgorithmInfo.data;
+
+	if(p12_prikey->AlgorithmInfo.data == NULL)
+		return CTP_FALSE;
+
+	p += 1;
+	len = GetInfoLength(p,&Llen);
+	p += Llen;
+	*outlen = len;
+	if(len != 0)
+	{
+		memcpy(out,p,len);
+	}
+	return CTP_OK;
+}
+
+int Get_P12_PK_PubKey(P12_PRIVATEKEY *p12_prikey,unsigned char *out,int *outlen)
+{
+	int len=0,len_1=0;
+	unsigned char Llen=0;
+	unsigned char *p = p12_prikey->PublicKey.data;
+
+	if(p12_prikey->PublicKey.data == NULL)
+		return CTP_FALSE;
+
+	p += 1;
+	len = GetInfoLength(p,&Llen);
+	p += Llen;
+
+	p += 1;
+	len_1 = GetInfoLength(p,&Llen);
+	p += Llen;
+
+	*outlen = len_1;
+	if(len_1 != 0)
+	{
+		memcpy(out,p,len);
+	}
+	return CTP_OK;
+}
+
+int Get_P12_PK_Der_PubKey(P12_PRIVATEKEY *p12_prikey,unsigned char *out,int *outlen)
+{
+	int len=0;
+	unsigned char Llen=0;
+	unsigned char *p = p12_prikey->PublicKey.data;
+
+	if(p12_prikey->PublicKey.data == NULL)
+		return CTP_FALSE;
+
+	p += 1;
+	len = GetInfoLength(p,&Llen);
+	p += Llen;
+
+	*outlen = len;
+	if(len != 0)
+	{
+		memcpy(out,p,len);
+	}
+	return CTP_OK;
+}
