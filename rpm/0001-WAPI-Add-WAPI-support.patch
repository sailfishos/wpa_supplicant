+int wapi_auth_set_key(struct wapi_authenticator *wapi_auth,
+				   int vlan_id, int alg, const u8_t *addr, int idx,
+				   u8_t *iv, size_t iv_len, u8_t *key, size_t key_len,
+				   int keyflag);
+struct wapi_authenticator * wapi_init(const u8_t *addr,
+				    struct wapi_auth_config *conf,
+				    struct wapi_auth_callbacks *cb);
+void _wapi_msk_announcement_tx(struct wapi_authenticator *wapi_auth,
+			   struct wapi_state_machine *sm);
+void _wapi_usk_negotiation_confirmation(struct wapi_authenticator *wapi_auth,
+			   struct wapi_state_machine *sm);
+int  _wapi_msk_announcement_res(struct wapi_authenticator *wapi_auth,
+		 struct wapi_state_machine *sm, u8_t *iv_pos, u8_t *payload_data, size_t payload_len);
+int _wapi_usk_negotiation_res(struct wapi_authenticator *wapi_auth,
+		 struct wapi_state_machine *sm, u8_t *payload_data, size_t payload_len);
+void _wapi_send_usk_negotiation_req(struct wapi_authenticator *wapi_auth,
+			   struct wapi_state_machine *sm);
+
+#endif /* WPA_AUTH_H */
