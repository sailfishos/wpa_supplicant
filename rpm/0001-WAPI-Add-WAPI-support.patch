+/*Ąź▓ź├▄į┐ąŁ╔╠╚Ę╚ŽĘųūķ*/
+void _wapi_usk_negotiation_confirmation(struct wapi_authenticator *wapi_auth,
+			   struct wapi_state_machine *sm)
+{
+	u8_t *hdr_data;
+	u8_t *pos;
+	u8_t wai_data_flag = 0x00;
+	u8_t dynamic_key_used;
+	u8_t MIC[WAPI_MIC_LEN];
+	const u8_t *ie;
+	size_t ie_len;
+	size_t data_len;
+	int timeout_ms;
+	
+	//ie = wapi_auth_get_ie(wapi_auth, &ie_len);
+
+	ie = wapi_auth->wapi_ie;
+	ie_len = wapi_auth->wapi_ie_len;
+	wapi_hexdump(MSG_DEBUG, "WAPI IE", ie, ie_len);
+	
+	data_len =	  1						//FLAG len
+				+ WAPI_BKID_LEN			//BKID len
+				+ 1						//USKID len
+				+ (ETH_ALEN+ETH_ALEN)	//ADDID len
+				+ WAPI_NONCE_LEN		//ASUE Nonce len
+				+ ie_len				//IE len
+				+ WAPI_MIC_LEN;			//MIC len
+
+	hdr_data = os_malloc(data_len);
+	if(hdr_data == NULL)
+	{
+		wapi_printf(MSG_ERROR, "--wapi_usk_negotiation_confirmation--: "
+			"malloc buf for data error!");
+		return;
+	}
+
+	pos = hdr_data;
+
+	/*┤“░³▒ĻųŠ*/
+	wai_data_flag  = sm->wai_flag_in_data & WAI_FLAG_USK_UPDATE;
+	os_memcpy(pos, &wai_data_flag, 1);
+	pos += 1;
+
+	/*┤“░³bkid*/
+	os_memcpy(pos, sm->BKID, WAPI_BKID_LEN);
+	pos += WAPI_BKID_LEN;
+
+	/*┤“░³ėąą¦Ą─uskid*/
+	os_memcpy(pos, &sm->USKSA.uskid, 1);
+	pos += 1;
+	
+	/*┤“░³addid*/
+	os_memcpy(pos, wapi_auth->addr, ETH_ALEN);
+	pos += ETH_ALEN;
+	os_memcpy(pos, sm->addr, ETH_ALEN);
+	pos += ETH_ALEN;
+
+	/*┤“░³ASUEĄ─╠¶šĮ*/
+	os_memcpy(pos, sm->SNonce, WAPI_NONCE_LEN);
+	pos += WAPI_NONCE_LEN;
+
+	/*┤“░³AEĄ─WIE*/
+	os_memcpy(pos, ie, ie_len);
+	pos += ie_len;
+
+	/*╝Ų╦ŃMIC*/
+	dynamic_key_used = sm->USKSA.uskid & 0x01;
+
+
+	iwn_hmac_sha256(hdr_data, (pos - hdr_data),
+			sm->USKSA.usk[dynamic_key_used].mak, 16, 
+			MIC, WAPI_MIC_LEN);
+	
+	os_memcpy(pos, MIC, WAPI_MIC_LEN);
+	pos += WAPI_MIC_LEN;
+
+	__wapi_send_wai(wapi_auth, sm, \
+					hdr_data, (pos - hdr_data),	\
+					WAI_SUBTYPE_SESSIONKEYNEGCONFIRM);
+	sm->group_sc += 1;
+	return;	
+}
