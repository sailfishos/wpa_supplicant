+
+#define STATE_MACHINE_DATA struct wapi_state_machine
+#define STATE_MACHINE_DEBUG_PREFIX "WAPI"
+#define STATE_MACHINE_ADDR sm->addr
+static const u32 WAPIConfigGroupUpdateCount = 4;
+static const u32 WAPIConfigPairwiseUpdateCount = 4;
+static const u32 usk_key_timeout_first = 100; /* ms */
+static const u32 usk_key_timeout_subseq = 1000; /* ms */
+
+static const int dot11RSNAConfigPMKLifetime = 43200;
+static const int dot11RSNAConfigPMKReauthThreshold = 70;
+static const int dot11RSNAConfigSATimeout = 60;
+
+extern int _wapi_alg_init(void);
+extern void _wapi_alg_exit(void);
+extern int _wapi_auth_get_bkid(const u8 *ap_addr, const u8 *addr,	\
+					  const u8 *bk, u8 *bkid);
+extern int _wapi_auth_get_usk(const u8 *bk, u8 *mac1, u8 *mac2, u8 *ANonce,	\
+				    u8 *SNonce, u8 *next_ANonce, u8 *master_key);
+extern int _wapi_auth_get_msk(u8 *nmk, u8 *msk, size_t len);
+
+static int hex2int(char c)
+{
+	if (c >= '0' && c <= '9')
+		return (c - '0');
+	if (c >= 'a' && c <= 'f')
+		return (c - 'a' + 10);
+	if (c >= 'A' && c <= 'F')
+		return (c - 'A' + 10);
+	return -1;
+}
+
+static int str2byte( unsigned char *str, int len,  char *byte_out)
+{
+	int i, val, val2;
+	unsigned char *pos = str;
+
+	for (i = 0; i < len; i++) {
+		val = hex2int(*pos++);
+		if (val < 0)
+			return -1;
+		val2 = hex2int(*pos++);
+		if (val2 < 0)
+			return -1;
+		byte_out[i] = (val * 16 + val2) & 0xff;
+	}
+
+	return 0;
+}
+
+
+SM_STATE(WAPI_USK, INITIALIZE)
+{
+	SM_ENTRY_MA(WAPI_USK, INITIALIZE, wapi_usk);
+	if (sm->Init) {
+		sm->changed = _FALSE;
+	}
+
+	sm->keycount = 0;
+	if (sm->GUpdateStationKeys)
+		sm->group->GKeyDoneStations--;
+	sm->GUpdateStationKeys = _FALSE;
+	sm->TimeoutCtr = 0;
+}
+
+
+SM_STATE(WAPI_USK, AUTHENTICATION)
+{
+	SM_ENTRY_MA(WAPI_USK, AUTHENTICATION, wapi_usk);
+	os_memset(&sm->BKID, 0, sizeof(sm->BKID));
+	sm->BKID_valid = _FALSE;
+	sm->AuthenticationRequest = _FALSE;
+}
+
+SM_STATE(WAPI_USK, AUTHENTICATION2)
+{
+	SM_ENTRY_MA(WAPI_USK, AUTHENTICATION2, wapi_usk);
+
+	if (random_pool_ready() != 1) {
+		wpa_printf(MSG_INFO, "WAPI: Not enough entropy in random pool "
+			   "to proceed - reject usk negotiation req");
+	}
+	if (random_get_bytes(sm->ANonce, WAPI_NONCE_LEN) < 0)
+		wpa_printf(MSG_ERROR, "wapi: gen random error ");
+	else
+	{
+		wpa_printf(MSG_DEBUG,"wapi: ANonce %02X%02X%02X%02X%02X%02X%02X%02X"
+			"%02X%02X%02X%02X%02X%02X%02X%02X"
+			"%02X%02X%02X%02X%02X%02X%02X%02X"
+			"%02X%02X%02X%02X%02X%02X%02X%02X",
+			sm->ANonce[0], sm->ANonce[1], sm->ANonce[2], sm->ANonce[3],
+			sm->ANonce[4], sm->ANonce[5], sm->ANonce[6], sm->ANonce[7],
+			sm->ANonce[8], sm->ANonce[9], sm->ANonce[10], sm->ANonce[11],
+			sm->ANonce[12], sm->ANonce[13], sm->ANonce[14], sm->ANonce[15],
+			sm->ANonce[16], sm->ANonce[17], sm->ANonce[18], sm->ANonce[19],
+			sm->ANonce[20], sm->ANonce[21], sm->ANonce[22], sm->ANonce[23],
+			sm->ANonce[24], sm->ANonce[25], sm->ANonce[26], sm->ANonce[27],
+			sm->ANonce[28], sm->ANonce[29], sm->ANonce[30], sm->ANonce[31]);
+	}
+
+	wpa_hexdump(MSG_DEBUG, "WAPI: Assign ANonce", sm->ANonce,
+		    WAPI_NONCE_LEN);
+	sm->ReAuthenticationRequest = _FALSE;
+	//sm->changed = TRUE;
+	sm->TimeoutCtr = 0;
+}
+
+
+SM_STATE(WAPI_USK, INITBKID)
+{
+	int ret;
+	SM_ENTRY_MA(WAPI_USK, INITBKID, wapi_usk);
+	ret = wapi_auth_get_bkid(sm->wapi_auth, sm->addr, sm->BKID);
+	if (ret) {
+		wpa_printf(MSG_ERROR,"wapi: WAPI BKID derivation fail");
+	}
+	else
+	{
+		wpa_printf(MSG_DEBUG,"wapi: BKID %X%X%X%X%X%X%X%X%X%X%X%X%X%X%X%X",
+				sm->BKID[0], sm->BKID[1], sm->BKID[2], sm->BKID[3],
+				sm->BKID[4], sm->BKID[5], sm->BKID[6], sm->BKID[7],
+				sm->BKID[8], sm->BKID[9], sm->BKID[10], sm->BKID[11],
+				sm->BKID[12], sm->BKID[13], sm->BKID[14], sm->BKID[15]);
+		sm->BKID_valid = _TRUE;
+	}
+}
+
+
+SM_STATE(WAPI_USK, START)
+{
+	SM_ENTRY_MA(WAPI_USK, START, wapi_usk);
+	sm->USKRequest = _FALSE;						//used in rekey
+	sm->TimeoutEvt = _FALSE;
+
+	sm->TimeoutCtr++;
+	if (sm->TimeoutCtr > (int) WAPIConfigPairwiseUpdateCount) {
+		return;
+	}
+	
+	wapi_send_usk_negotiation_req(sm->wapi_auth, sm);
+}
+
+
+SM_STATE(WAPI_USK, CALCNEGOTIATING)
+{
+	SM_ENTRY_MA(WAPI_USK, CALCNEGOTIATING, wapi_usk);
+	sm->WAPIwaiReceived = _FALSE;
+
+	//usk_negotiation_confirmation()
+	//sm->pending_1_of_4_timeout = 0;
+	//eloop_cancel_timeout(wpa_send_eapol_timeout, sm->wpa_auth, sm);
+}
+
+
+SM_STATE(WAPI_USK, CALCNEGOTIATING2)
+{
+	SM_ENTRY_MA(WAPI_USK, CALCNEGOTIATING2, wapi_usk);
+	sm->TimeoutCtr = 0;
+}
+
+
+SM_STATE(WAPI_USK, INITNEGOTIATING)
+{
+	SM_ENTRY_MA(WAPI_USK, INITNEGOTIATING, wapi_usk);
+	sm->TimeoutEvt = _FALSE;
+
+	sm->TimeoutCtr++;
+	if (sm->TimeoutCtr > (int) WAPIConfigPairwiseUpdateCount) {
+	
+		return;
+	}
+
+	_wapi_usk_negotiation_confirmation(sm->wapi_auth, sm);
+}
+
+SM_STATE(WAPI_USK, SETKEY)
+{
+	SM_ENTRY_MA(WAPI_USK, SETKEY, wapi_usk);
+	enum wpa_alg alg = WPA_CIPHER_NONE;
+	int klen = 0;
+	if (sm->pairwise == WPA_CIPHER_SMS4) {
+		alg = WPA_ALG_SMS4;
+		klen = 32;
+	}
+	if (wapi_auth_set_key(sm->wapi_auth, 0, alg, sm->addr, 0, NULL, 0,
+				 (u8 *)&sm->USKSA.usk[sm->USKSA.uskid], klen, KEY_FLAG_PAIRWISE_RX_TX)) {
+		//wapi_sta_disconnect(sm->wapi_auth, sm->addr);
+		return;
+	}
+
+}
+
+SM_STATE(WAPI_USK, DONE)
+{
+	SM_ENTRY_MA(WAPI_USK, DONE, wapi_usk);
+
+	sm->in_msk_step = _TRUE;
+	sm->has_USK = _TRUE;
+	sm->MSKGroupInit = _TRUE;
+}
+
+
+SM_STEP(WAPI_USK)
+{
+	struct wapi_authenticator *wapi_auth = sm->wapi_auth;
+	if (sm->in_msk_step)
+		return;
+	if (sm->Init)
+		SM_ENTER(WAPI_USK, INITIALIZE);
+
+	else if (sm->AuthenticationRequest)
+		SM_ENTER(WAPI_USK, AUTHENTICATION);
+
+	else switch (sm->wapi_usk_state) {
+	case WAPI_USK_INITIALIZE:
+		break;
+
+	case WAPI_USK_AUTHENTICATION:
+		SM_ENTER(WAPI_USK, AUTHENTICATION2);
+		break;
+	case WAPI_USK_AUTHENTICATION2:
+		if (sm->wapi_key_mgmt)
+			SM_ENTER(WAPI_USK, INITBKID);
+		break;
+	case WAPI_USK_INITBKID:
+		if (sm->BKID_valid)
+			SM_ENTER(WAPI_USK, START);
+		else {
+			wpa_printf(MSG_ERROR, "wapi: no BKID configured for the STA");
+			wapi_auth->WAPIUSKAuthenticationvalidFailures++;
+		}
+		break;
+	case WAPI_USK_START:
+		if (sm->WAPIwaiReceived)
+			SM_ENTER(WAPI_USK, CALCNEGOTIATING);
+		else if (sm->TimeoutCtr >
+			 (int) WAPIConfigPairwiseUpdateCount) {
+			wapi_auth->WAPIUSKAuthenticationvalidFailures++;
+
+		} else if (sm->TimeoutEvt)
+			SM_ENTER(WAPI_USK, START);
+		break;
+	case WAPI_USK_CALCNEGOTIATING:
+		if (sm->UMICVerified)
+			SM_ENTER(WAPI_USK, CALCNEGOTIATING2);
+		break;
+	case WAPI_USK_CALCNEGOTIATING2:
+		SM_ENTER(WAPI_USK, INITNEGOTIATING);
+		break;
+	case WAPI_USK_INITNEGOTIATING:
+		SM_ENTER(WAPI_USK, SETKEY);
+		break;
+	case WAPI_USK_SETKEY:
+		SM_ENTER(WAPI_USK, DONE);
+		break;
+	case WAPI_USK_DONE:
+		break;
+	default:
+		break;
+	}
+}
+
+
+SM_STATE(WAPI_MSK_GROUP, IDLE)
+{
+	SM_ENTRY_MA(WAPI_MSK_GROUP, IDLE, wapi_msk_group);
+	if (sm->Init) {
+		sm->changed = _FALSE;
+	}
+	sm->GTimeoutCtr = 0;
+}
+
+SM_STATE(WAPI_MSK_GROUP, AUTHENTICATION)
+{
+	SM_ENTRY_MA(WAPI_MSK_GROUP, AUTHENTICATION, wapi_msk_group);
+	sm->TimeoutEvt = _FALSE;
+
+	sm->GTimeoutCtr++;
+	if (sm->GTimeoutCtr > (int) WAPIConfigGroupUpdateCount) {
+		return;
+	}
+	
+	wapi_msk_announcement_tx(sm->wapi_auth, sm);
+	sm->WAPIwaiReceived = _FALSE;
+}
+
+SM_STATE(WAPI_MSK_GROUP, AUTHENTICATION2)
+{
+	SM_ENTRY_MA(WAPI_MSK_GROUP, AUTHENTICATION2, wapi_msk_group);
+	
+	sm->in_msk_step = _FALSE;
+	sm->has_MSK = _TRUE;
+	sm->WAPIwaiReceived = _FALSE;
+
+	wapi_auth_set_authorized(sm->wapi_auth, sm->addr,
+					   WAI_authorized, 1);
+}
+
+
+SM_STEP(WAPI_MSK_GROUP)
+{
+	struct wapi_authenticator *wapi_auth = sm->wapi_auth;
+	if (sm->in_msk_step != _TRUE)
+		return;
+	if (sm->MSKGroupInit) {
+		SM_ENTER(WAPI_MSK_GROUP, IDLE);
+		sm->MSKGroupInit = _FALSE;
+	} else switch (sm->wapi_msk_group_state) {
+	case WAPI_MSK_GROUP_IDLE:
+			SM_ENTER(WAPI_MSK_GROUP, AUTHENTICATION);
+		break;
+	case WAPI_MSK_GROUP_AUTHENTICATION:
+		if(sm->WAPIwaiReceived && sm->GMICVerified)
+			SM_ENTER(WAPI_MSK_GROUP, AUTHENTICATION2);
+		else if (sm->GTimeoutCtr >(int) WAPIConfigGroupUpdateCount) {
+			//wapi_auth->WAPIUSKAuthenticationvalidFailures++;
+		} else if (sm->TimeoutEvt)
+			SM_ENTER(WAPI_MSK_GROUP, AUTHENTICATION);
+		break;
+	case WAPI_MSK_GROUP_AUTHENTICATION2:
+		break;
+	default:
+		break;
+	}
+}
+
+static void wapi_free_sta_sm(struct wapi_state_machine *sm)
+{
+	os_free(sm->wapi_ie);
+	os_free(sm);
+}
+static int wapi_sm_step(struct wapi_state_machine *sm)
+{
+	wpa_printf(MSG_DEBUG, "Enter %s",__func__);
+	if (sm == NULL)
+		return 0;
+
+	if (sm->in_step_loop) {
+		wpa_printf(MSG_ERROR, "WAPI: wapi_sm_step() called recursively");
+		return 0;
+	}
+
+	sm->in_step_loop = 1;
+	do {
+		if (sm->pending_deinit)
+			break;
+
+		sm->changed = _FALSE;
+		sm->wapi_auth->group->changed = _FALSE;
+
+		SM_STEP_RUN(WAPI_USK);
+		if (sm->pending_deinit)
+			break;
+		SM_STEP_RUN(WAPI_MSK_GROUP);
+		if (sm->pending_deinit)
+			break;
+
+	} while (sm->changed || sm->wapi_auth->group->changed);
+	sm->in_step_loop = 0;
+
+	if (sm->pending_deinit) {
+		wpa_printf(MSG_DEBUG, "WAPI: Completing pending STA state "
+			   "machine deinit for " MACSTR, MAC2STR(sm->addr));
+		wapi_free_sta_sm(sm);
+		return 1;
+	}
+	wpa_printf(MSG_DEBUG, "Enter %s end",__func__);
+	return 0;
+}
+
+
+
+struct wapi_state_machine *
+wapi_auth_sta_init(struct wapi_authenticator *wapi_auth, const unsigned char *addr)
+{
+	struct wapi_state_machine *sm;
+
+	sm = os_zalloc(sizeof(struct wapi_state_machine));
+	if (sm == NULL)
+		return NULL;
+	os_memcpy(sm->addr, addr, ETH_ALEN);
+
+	sm->wapi_auth = wapi_auth;
+	sm->group = wapi_auth->group;
+	sm->group_sc = 1;
+
+	return sm;
+}
+
+
+int wapi_auth_sta_associated(struct wapi_authenticator *wapi_auth,
+			    struct wapi_state_machine *sm)
+{
+	if (wapi_auth == NULL || !wapi_auth->conf->wapi || sm == NULL)
+		return -1;
+
+	if (sm->started) {
+		os_memset(&sm->key_replay, 0, sizeof(sm->key_replay));
+		sm->ReAuthenticationRequest = _TRUE;
+		return wapi_sm_step(sm);
+	}
+
+	sm->started = 1;
+	sm->Init = _TRUE;
+	sm->in_msk_step = _FALSE;
+	if (wapi_sm_step(sm) == 1)
+		return 1; /* should not really happen */
+	sm->Init = _FALSE;
+	sm->AuthenticationRequest = _TRUE;
+	return wapi_sm_step(sm);
+}
