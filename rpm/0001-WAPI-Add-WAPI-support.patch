+		p += len6+Llen;
+
+		p += 1;
+		len7 = GetInfoLength(p,&Llen);
+		p += Llen;
+
+		p += 1;
+		len8 = GetInfoLength(p,&Llen);
+		p += Llen;
+
+		if (len8 > *pUserCertlen)
+			return CTP_FALSE;
+		memcpy(pUserCert,p,len8);
+		*pUserCertlen = len8;
+
+		p += len8+1;
+		len9 = GetInfoLength(p,&Llen);
