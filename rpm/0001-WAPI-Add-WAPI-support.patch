+		case SERIALNUMBER:
+			{
+				*outlen = ctx->Serialnumber.length;
+				if (out == NULL)
+				{
+					return CTP_FALSE;
+				}
+				memcpy(out,ctx->Serialnumber.data,ctx->Serialnumber.length);
+			}
+			break;
+		case SIGNATURE:
+			{
+				*outlen = ctx->Signature.length;
+				if (out == NULL)
+				{
+					return CTP_FALSE;
+				}
+				memcpy(out,ctx->Signature.data,ctx->Signature.length);
+			}
+			break;
+		case ISSUER:
+			{
+				*outlen = ctx->Issuer.length;
+				if (out == NULL)
+				{
+					return CTP_FALSE;
+				}
+				memcpy(out,ctx->Issuer.data,ctx->Issuer.length);
+			}
+			break;
+		case VALIDITY:
+			{
+				*outlen = ctx->validity.length;
+				if (out == NULL)
+				{
+					return CTP_FALSE;
+				}
+				memcpy(out,ctx->validity.data,ctx->validity.length);
+			}
+			break;
+		case SUBJECT:
+			{
+				*outlen = ctx->Subject.length;
+				if (out == NULL)
+				{
+					return CTP_FALSE;
+				}
+				memcpy(out,ctx->Subject.data,ctx->Subject.length);
+			}
+			break;
+		case SUBJECTPUBLICKEYINFO:
+			{
+				*outlen = ctx->subjectPublicKeyInfo.length;
+				if (out == NULL)
+				{
+					return CTP_FALSE;
+				}
+				memcpy(out,ctx->subjectPublicKeyInfo.data,ctx->subjectPublicKeyInfo.length);
+			}
+			break;
+		case EXTENSIONS:
+			{
+				*outlen = ctx->extensions.length;
+				if (out == NULL)
+				{
+					return CTP_FALSE;
+				}
+				if(ctx->extensions.data == NULL)
+				{
+					return ERROR_EXTENSIONSNOEXIST;
+				}
+
+				memcpy(out,ctx->extensions.data,ctx->extensions.length);
+			}
+			break;
+		case SIGNATUREALGORITHM:
+			{
+				*outlen = ctx->signatureAlgorithm.length;
+				if (out == NULL)
+				{
+					return CTP_FALSE;
+				}
+				memcpy(out,ctx->signatureAlgorithm.data,ctx->signatureAlgorithm.length);
+			}
+			break;
+		case SIGNATUREVALUE:
+			{
+				*outlen = ctx->signatureValue.length;
+				if (out == NULL)
+				{
+					return CTP_FALSE;
+				}
+				memcpy(out,ctx->signatureValue.data,ctx->signatureValue.length);
+			}
+			break;
+		default:
+			return CTP_FALSE;
+	}
+
+	return CTP_OK;
+}
