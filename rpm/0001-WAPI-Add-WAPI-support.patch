+
+#ifndef min
+#define min(a,b) ((a)<(b) ? (a):(b))
+#endif
+
+//ASCII┬ļū¬╗»╬¬UINCODE
+unsigned char *ascii_to_unicode(const char *asc_data, int asc_datalen, unsigned char **uni_data, int *uni_datalen)
+{
+	unsigned char *data;
+	int i,length;
+
+	if(asc_datalen == -1) 
+		asc_datalen = strlen(asc_data);
+
+	length = asc_datalen*2  + 2;
+    data = (unsigned char*)malloc(length);
+	if(data == NULL)
+	{
+		return NULL;
+	}
+
+	for(i=0; i<length-2; i+=2) 
+	{
+		data[i] = 0;
+		data[i+1] = asc_data[i>>1];
+	}
+
+	data[length-2] = 0;
+	data[length-1] = 0;
+
+	if (uni_datalen) 
+		*uni_datalen = length;
+	if (uni_data) 
+		*uni_data = data;
+
+	return data;
+}
+
+//ASCII┬ļ╗∙ė┌┐┌┴Ņ▓·╔·KEY,IV
+int pass_gen_key(const char *password, int p_len, unsigned char *salt,int s_len, 
+		         int iter, int id_tag, unsigned char *data,int data_len)
+{	
+	unsigned char *pass_data;
+	int pass_data_len;
+	int ret;
+			
+	if(!password) 
+	{
+		pass_data = NULL;
+		pass_data_len = 0;
+	}else if(!ascii_to_unicode(password, p_len, &pass_data, &pass_data_len)) 
+	{
+		if(pass_data) 
+	    {
+		    free(pass_data);
+		    pass_data = NULL;
+	    }
+		return 0;
+	}
+
+	ret = unicode_gen_key(pass_data, pass_data_len, salt, s_len, iter, id_tag, data, data_len);
+	if (ret <= 0)
+	{
+		if(pass_data) 
+	    {
+		    free(pass_data);
+		    pass_data = NULL;
+	    }
+	    return 0;
+	}
+
+	if(pass_data) 
+	{
+		free(pass_data);
+		pass_data = NULL;
+	}
+
+	return ret;
+}
+
+
+//pkcs#12v1.pdf B.2 General method
+//UNICODE┬ļ╗∙ė┌┐┌┴Ņ▓·╔·KEY,IV
+//id_tag = 1 ╝ėĮŌ├▄╦ŃĘ©├▄į┐KEY
+//id_tag = 2 ╝ėĮŌ├▄╦ŃĘ©│§╩╝Ž“┴┐IV
+//id_tag = 3 HMACųąĄ─├▄į┐
+int unicode_gen_key(unsigned char *password, int p_len, unsigned char *salt, int s_len, 
+				    int iter, int id_tag, unsigned char *data, int data_len)
+{
+	int i, j, u, v;
+	MINT ij, ij_1, b_1, b_2, tmp;
+	unsigned char *b_data, *d_data, *i_data, *ai_data, *q;				
+	unsigned char m_data[1024]={0};
+	unsigned char value[1]={0x01};
+	unsigned int b_len=0;
+	int s_len_1, p_len_1, i_len, ij_len;	
+	int ret = 0;
+	
+	if(password == NULL || salt == NULL || data == NULL || 
+			iter <= 0 || data_len <= 0)
+	{
+	    return 0;
+	}
+
+	v = 64; //SHA1Ęų┐ķ│żČ╚
+	d_data = (unsigned char*)malloc(v);
+	if(d_data == NULL)
+	{
+	    return 0;
+	}
+
+	for(i=0; i<v; i++) d_data[i] = id_tag;
+
+	s_len_1 = v * ((s_len+v-1)/v);
+
+	if(p_len) 
+		p_len_1 = v * ((p_len+v-1)/v);
+	else p_len_1 = 0;
+
+	i_len = s_len_1 + p_len_1;
+	i_data = (unsigned char*)malloc(i_len);
+	if(i_data == NULL)
+	{
+		free(d_data);
+		d_data = NULL;
+	    return 0;
+	}
+
+	q = i_data;
+	for(i=0; i<s_len_1; i++) *q++ = salt[i % s_len];
+	for(i=0; i<p_len_1; i++) *q++ = password[i % p_len];
+
+	b_data = (unsigned char*)malloc(v + 1);
+	if(b_data == NULL)
+	{
+		free(d_data);
+		d_data = NULL;
+		free(i_data);
+		i_data = NULL;
+	    return 0;
+	}
+
+	u = 20; //SHA1š¬ę¬│żČ╚
+	if(u<0)
+	{
+		free(d_data);
+		d_data = NULL;
+		free(i_data);
+		i_data = NULL;
+		free(b_data);
+		b_data = NULL;
+		return 0;
+	}
+	ai_data = (unsigned char*)malloc(u);
+	if(ai_data == NULL)
+	{
+		free(d_data);
+		d_data = NULL;
+		free(i_data);
+		i_data = NULL;
+		free(b_data);
+		b_data = NULL;
+	    return 0;
+	}
+
+	memcpy(m_data,d_data,v);
+	memcpy(m_data+v,i_data,i_len);
+	sha1_a(m_data,v+i_len,ai_data);
+
+	for(j=1; j<iter; j++) 
+	{
+		sha1_a(ai_data,u,ai_data);
+	}
+	memcpy(data, ai_data, min(data_len,u));
+
+	while(data_len>u) 
+	{
+		data_len -= u;
+		data += u;
+		
+		for(j=0; j<v; j++) b_data[j] = ai_data[j % u];
+
+		//╝Ų╦Ń b_data+1
+		octetstring_to_mint_c(b_data,v,&b_1);
+		octetstring_to_mint_c(value,1,&tmp);		
+		mint_add_c(&b_1,&tmp,&b_2);
+		mint_copy_c(&b_1,&b_2);
+
+		for (j=0; j<i_len; j+=v) 
+		{
+			octetstring_to_mint_c(i_data + j,v,&ij);
+			mint_add_c(&ij,&b_1,&ij_1);
+			mint_copy_c(&ij,&ij_1);
+			mint_to_octetstring_c(&ij,1024,b_data,&b_len);
+			ij_len = (get_mint_bit_len_c(&ij)+7)/8;
+
+			//ij_len > 2^(v*8) - 1
+			if(ij_len > v) 
+			{
+				b_len=0;
+				mint_to_octetstring_c(&ij,1024,b_data,&b_len);
+				memcpy(i_data+j, b_data+1, v);
+
+#ifndef P12_GEN_KEY_IV
+
+			//ij_len < v
+			} 
+			else if (ij_len < v) 
+			{
+				memset(i_data+j, 0, v-ij_len);
+				b_len=0;
+				mint_to_octetstring_c(&ij,1024,i_data+j+v-ij_len,&b_len); 
+#endif
+
+			} 
+			else 
+			{
+				b_len=0;
+				mint_to_octetstring_c(&ij,1024,i_data+j,&b_len);
+			}
+		}
+
+		memcpy(m_data,d_data,v);
+		memcpy(m_data+v,i_data,i_len);
+		sha1_a(m_data,v+i_len,ai_data);
+
+		for(j=1; j<iter; j++) 
+		{
+			sha1_a(ai_data,u,ai_data);
+		}
+
+		memcpy(data, ai_data, min(data_len,u));
+	}
+
+	ret = 1;
+
+_free_1:
+	if (ai_data)
+	{
+	    free(ai_data);
+        ai_data = NULL;
+	}
+	if (b_data)
+	{
+	    free(b_data);
+		b_data = NULL;
+	}
+	if (i_data)
+	{
+	    free(i_data);
+		i_data = NULL;
+	}
+	if (d_data)
+	{
+	    free(d_data);
+		d_data = NULL;
+	}
+
+	return ret;
+}
