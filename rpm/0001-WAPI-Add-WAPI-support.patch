+/*--------------------------------------------------------------------------------*/
+int UnPack_X509(unsigned char *In, int len, X509_Cert *ctx)
+{
+	int len0=0,len1=0,len2=0,len3=0,len4=0,len5=0,len6=0;
+	int	len7=0,len8=0,len9=0,len10=0,len11=0,len12=0;
+	unsigned char Llen=0;
+	unsigned char *p = NULL;
+	unsigned char *q = NULL;
+	unsigned char alg_oid_data[12]={0x06,0x08,0x2A,0x81,0x1C,0xCF,0x55,0x01,0x83,0x75,0x05,0x00};
+	unsigned char alg_oid_data_1[12]={0x06,0x08,0x2A,0x81,0x1C,0xD7,0x63,0x01,0x01,0x01,0x05,0x00};
+	int ret=0,ret_1=0;
+	int X509Certificate_Length = 0;    //X509ųż╩ķ╣╠Č©Ą─3▓┐ĘųĄ─│żČ╚(ųż╩ķą┼ŽóĪóŪ®├¹╦ŃĘ©ĪóŪ®├¹ųĄ)
+
+
+	p = In;	
+	p += 1;
+	len0 = GetInfoLength(p,&Llen);
+	p += Llen;
+
+	X509Certificate_Length += 1 + Llen;
+	
+	p += 1;
+	len1 = GetInfoLength(p,&Llen);
+	p += Llen;
+
+	X509Certificate_Length += 1 + Llen + len1;
+
+	p += 1;
+	len2 = GetInfoLength(p,&Llen);
+	p += Llen;
+
+	ctx->Version.data = p;
+	p += 1;
+	len3 = GetInfoLength(p,&Llen);
+	p += Llen;
+	ctx->Version.length = len3+Llen+1;
+	p += len3;  
+
+	ctx->Serialnumber.data = p;
+	p += 1;
+	len4 = GetInfoLength(p,&Llen);
+	p += Llen;
+	ctx->Serialnumber.length = len4+Llen+1;
+	p += len4;
+
+	ctx->Signature.data = p;
+	p += 1;
+	len5 = GetInfoLength(p,&Llen);
+	p += Llen;
+	ctx->Signature.length = len5+Llen+1;
+	p += len5;
+
+	ctx->Issuer.data = p;
+	p += 1;
+	len6 = GetInfoLength(p,&Llen);
+	p += Llen;
+	ctx->Issuer.length = len6+Llen+1;
+	p += len6;
+	
+	ctx->validity.data = p;
+	p += 1;
+	len7 = GetInfoLength(p,&Llen);
+	p += Llen;
+	ctx->validity.length = len7+Llen+1;
+	p += len7;
+
+	ctx->Subject.data = p;
+	p += 1;
+	len8 = GetInfoLength(p,&Llen);
+	p += Llen;
+	ctx->Subject.length = len8+Llen+1;
+	p += len8;
+	
+	ctx->subjectPublicKeyInfo.data = p;
+	p += 1;
+	len9 = GetInfoLength(p,&Llen);
+	p += Llen;
+	ctx->subjectPublicKeyInfo.length = len9+Llen+1;
+	p += len9;
+
+    q=p;
+	ctx->signatureAlgorithm.data = q;
+	q += 1;
+	len10 = GetInfoLength(q,&Llen);
+	q += Llen;
+	ctx->extensions.length = len10+Llen+1;
+	
+	ret = memcmp(q,alg_oid_data,len10);
+	ret_1 = memcmp(q,alg_oid_data_1,len10);
+	if((ret != 0) && (ret_1 != 0))
+	{
+	    ctx->extensions.data = p;
+	    p += 1;
+	    len10 = GetInfoLength(p,&Llen);
+	    p += Llen;
+	    ctx->extensions.length = len10+Llen+1;
+		p += len10;		
+	}	
+
+	ctx->signatureAlgorithm.data = p;
+	p += 1;
+	len11 = GetInfoLength(p,&Llen);
+	p += Llen;
+	ctx->signatureAlgorithm.length = len11+Llen+1;
+
+	p += len11;
+
+	X509Certificate_Length += 1 + Llen + len11;
+
+	ctx->signatureValue.data = p;
+	p += 1;
+	len12 = GetInfoLength(p,&Llen);
+	p += Llen;
+	ctx->signatureValue.length = len12+Llen+1;
+	p += len12;
+
+	X509Certificate_Length += 1 + Llen + len12;
+
+	if(X509Certificate_Length == len)
+	{
+	    return CTP_OK;
+	}
+	else
+	{
+		return CTP_FALSE;
+	}
+}
+
+void End_X509(X509_Cert *ctx)
+{
+	memset(ctx, 0, sizeof(X509_Cert));
+}
+
+int GetVersion_X509(X509_Cert *ctx, unsigned char *out, int *outlen, unsigned char *tag)
+{
+	int len=0;
+	unsigned char Llen=0;
+	unsigned char *p = ctx->Version.data;
+
+	if(ctx->Version.data == NULL)
+		return CTP_FALSE;
+
+	*tag = *p;
+	p += 1;
+	len = GetInfoLength(p,&Llen);
+	*outlen = len;
+	if(len != 0)
+	{
+		p += Llen;
+		memcpy(out,p,len);
+	}
+	return CTP_OK;
+}
+
+
+int GetSerialnumber_X509(X509_Cert *ctx, unsigned char *out, int *outlen, unsigned char *tag)
+{
