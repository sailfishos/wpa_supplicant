+	p += 1;
+	len = GetInfoLength(p,&Llen);
+	*outlen = len;
+	if(len != 0)
+	{
+		p += Llen;
+		memcpy(out,p,len);
+	}
+	return CTP_OK;
+}
+int GetSignature_parameters_X509(X509_Cert *ctx, unsigned char *out, int *outlen, unsigned char *tag)
+{
+	int len=0;
+	unsigned char Llen=0;
+	unsigned char *p = ctx->Signature.data;
+
+	int len2=0,len3=0;
+
+	if(ctx->Signature.data == NULL)
+		return CTP_FALSE;
+
+	p += 1;
+	len = GetInfoLength(p,&Llen);
