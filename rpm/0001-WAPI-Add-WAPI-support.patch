+/* 
+ * Copyright (C) 2015-2018 China IWNCOMM Co., Ltd. All rights reserved.
+ * 
+ * Contains the debug functions
+ * 
+ * Authors:  
+ * iwncomm
+ * 
+ * History: 
+ * yucun tian  09/10/2015 v1.0 maintain the code.
+ * yucun tian  07/20/2016 v1.1 fix for change code style.
+ * 
+ * Related documents:
+ * -GB/T 15629.11-2003/XG1-2006 
+ * -ISO/IEC 8802.11:1999,MOD
+ * 
+*/ 
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#ifdef ANDROID
+#include <cutils/log.h>
+#endif
+#include "wapi_debug.h"
+
+#ifndef WAPI_LOG_TAG
+#define WAPI_LOG_TAG "wapi"
+#endif
+
+static int wapi_debug_level = MSG_DEBUG;
+
+void wapi_printf(int level, const char *format, ...)
+{
+#ifdef CONFIG_ANDROID_LOG
+	va_list ap;
+
+	va_start(ap, format);
+	if (level >= wapi_debug_level) 
+	{
+	    vprintf(format, ap);
+	    printf("\n"); 
+
+	    if (level == MSG_DEBUG)
+		{
+			level = ANDROID_LOG_DEBUG;
+		}
+	    else if (level == MSG_INFO)
+		{
+			level = ANDROID_LOG_INFO;
+		}
+	    else if (level == MSG_WARNING)
+		{
+			level = ANDROID_LOG_WARN;
+		}
+	    else if (level == MSG_ERROR)
+		{
+			level = ANDROID_LOG_ERROR;
+		}
+	    else
+		{
+			level = ANDROID_LOG_DEBUG;
+		}
+
+	    LOG_PRI_VA(level, WAPI_LOG_TAG, format, ap);
+	}
+	va_end(ap);
+#endif
+}
+
+void wapi_hexdump(int level, const char *title, const void *buf, int len)
+{
+	int cl = 0;
+	int i = 0;
+	int j = 0;
+	char txt[260] = {0};
+	
+	if (level < wapi_debug_level)
+	{
+		return;
+	}
+	
+	cl = (len - 1) / 16 + 1;
+	snprintf(txt, sizeof(txt), "\n%s(len = %d, 0x%X)\n", 
+		title, len, len);
+
+	wapi_printf(MSG_DEBUG, txt);
+	for (i = 0; i < cl; i++)
+	{
+		int n = 16;
+		const unsigned char* p = NULL;
+		if (i == (cl - 1))
+		{	
+			/* lastest line */
+			n = len % 16;
+			if (0 == n)
+			{
+				n = 16;
+			}
+		}
+		snprintf(txt, sizeof(txt), "%.4X  ",
+			(i * 16));
+		p = (const unsigned char*)buf + (i * 16);
+		for (j = 0; j < n; j++)
+		{
+			snprintf(txt + strlen(txt), 
+				sizeof(txt)-strlen(txt),
+				"%.2X", p[j]);
+			if (j == (n - 1))
+			{	
+				/* lastest char */
+				if (16 == n)
+				{	
+					/* whole line */
+					strncat(txt, "  ", strlen("  "));
+				}
+				else
+				{	
+					/* fill none whole line */
+					int k;
+					for (k = strlen(txt); k < 43; k++)
+					{
+						txt[k] = ' ';
+					}
+					txt[k] = 0;
+				}
+			}
+			else if (3 == j%4)
+			{
+				strncat(txt, " ", strlen(" "));
+			}
+		}
+		for (j = 0; j < n; j++)
+		{
+			int c = p[j];
+			if (c < 32)
+			{
+				c = '.';
+			}
+			if (c > 127 && c < 160)
+			{
+				c = '.';
+			}
+			if (c > 127)
+			{
+				/* c = '.'; */
+			}
+
+			char tmp[2] = {c};
+			strncat(txt, tmp, strlen(tmp));
+		}
+
+		wapi_printf(MSG_DEBUG, txt);
+	}
+	
+	wapi_printf(MSG_DEBUG, "\n");
+}
+
