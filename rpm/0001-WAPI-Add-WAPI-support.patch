+	int dext_3 = 0;
+	int a = 0, b = 0, c = 0, n = 0;
+	unsigned char *q = NULL;
+
+	if (d == NULL)
+	{
+	    return -1;
+	}
+
+	if (dext <= 0)
+	{
+	    return -1;
+	}
+
+	if (dext > 0x80)
+	{
+	    return -1;
+	}
+
+	if (exp == NULL)
+	{
+	    return -1;
+	}
+
+	dext_1 = dext;
+	dext_2 = dext;	
+	q = (unsigned char *)&(exp[0]);
+
+	for (a = 0; a < dext; a++)
+	{
+		q[a] = d[a];
+	}
+
+	for (b = dext; b <= 0x7F; b++)
+	{
+		q[b] = sg_uc_cst[(q[b - 1] + q[b - dext]) & 0xFF];
+	}
