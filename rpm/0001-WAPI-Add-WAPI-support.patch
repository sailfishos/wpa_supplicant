+	{
+		q[c] = sg_uc_cst[q[c + 1] ^ q[c + dext_2]];
+	}
+  
+	for (n = 0; n < 0x80; n = n + 2)
+	{
+		exp[n / 2] = (q[n] | (q[n + 1] << 8)) & 0xFFFF;
+	}
+
+	return 1;
