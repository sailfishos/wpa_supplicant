+static int
+mypint ( const char ** s , int n , int min , int max , int * e )
+{
+    int retval = 0;
+    while ( n )
+    {
+        if ( **s < '0' || **s > '9' )
+        {
+            *e = 1;
+            return 0;
+        }
+        retval *= 10;
+        retval += **s - '0';
+        --n;
+        ++(*s);
+    }
+
+    if ( retval < min || retval > max )
+    {
+        *e = 1;
+    }
+    return retval;
+}
