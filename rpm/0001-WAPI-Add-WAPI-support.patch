+*/
+
+#ifndef _MINTEX_H
+#define _MINTEX_H
+
+#ifdef  __cplusplus
+extern "C" {
+#endif
+
+#include "random.h"
+
+int mint_exp(MINT *g,MINT *a,MINT *p,MINT *x);
