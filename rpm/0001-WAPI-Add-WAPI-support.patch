+static int
+X509_Get_CN ( X509_Cert *ctx , X509_Info type , unsigned char *cn ,
+        int *cn_len )
+{
+    int iType = 0 , ret = -1;
+    int iCount = 0 , iPos = 0;
+    unsigned char ID [ 32 ] = { 0 };
+    int IDLen = 0;
+    int iLen = 0, outlen = 0;
+    unsigned char commonName [ 8 ] = { 0x55 , 0x04 , 0x03 };
+    unsigned char taga , tagb;
+    unsigned char cnName [ CHAR_LENGTH ] = { 0 };
+    unsigned char out [ CHAR_LENGTH ] = { 0 };
+
+    if ( ctx == NULL )
+        return ret;
+
+    memset ( out , 0 , CHAR_LENGTH );
+
+    Get_Sets_Count_X509 ( ctx , type , &iCount );
+
+    for ( iPos = 0; iPos < iCount ; iPos++ )
+    {
+		IDLen = 32;
+		iLen = CHAR_LENGTH;
+        if (GetName_Sets_TypeAndValue_X509 ( ctx , type , iPos , ID , &IDLen ,
+                &taga , cnName , &iLen , &tagb ) != CTP_OK)
+		{
+			wapi_printf(MSG_ERROR,"in %s: GetName_Sets_TypeAndValue_X509 error \n",
+					__func__);
+			return -1;
+		}
+
+        if ( IDLen == 3 && taga == 0x06
+                && 0 == memcmp ( ID , commonName , IDLen ) )
+        {
+            outlen = 0;
+            if ( iLen > 0 && iLen < 256 )
+            {
+                memcpy ( out , cnName , iLen );
+                outlen = iLen;
+            }
+            break;
+        }
+        memset ( ID , 0 , 32 );
+        memset ( cnName , 0 , sizeof(cnName) / sizeof(cnName [ 0 ]) );
+    }
+
+	if (*cn_len < outlen)
+	{
+		return -1;
+	}
+	memcpy ( cn , out , outlen );
+    *cn_len = outlen;
+	
+    return 0;
+}
