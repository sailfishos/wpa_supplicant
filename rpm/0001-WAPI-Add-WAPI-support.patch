+#else
+	//form mh
+	if((ret = mint_sub(a,b,&t))==0)
+	{
+		mint_copy(c,&t);
+	}
+	else
+	{
+		mint_sub(p,&t,c);
+	}
+#endif
+	return 0;
+}
