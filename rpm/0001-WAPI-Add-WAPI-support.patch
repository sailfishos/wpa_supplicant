+void wapi_wai_receive(struct hostapd_data *hapd, const u8 *sa,
+							const u8 *buf, size_t len)
+{
+	struct sta_info *sta;
+	struct wapi_wai_hdr *hdr;
+	u16 datalen;
+	int key_mgmt;
+
+	if (!(hapd->conf->wpa & WPA_PROTO_WAPI))
+		return;
+
+	wpa_printf(MSG_DEBUG, "WAPI WAI: %lu bytes from " MACSTR,
+		   (unsigned long) len, MAC2STR(sa));
+	sta = ap_get_sta(hapd, sa);
+	if (!sta || !(sta->flags & (WLAN_STA_ASSOC | WLAN_STA_PREAUTH))) {
+		wpa_printf(MSG_DEBUG, "WAPI wai data frame from not "
+			   "associated/Pre-authenticating STA");
+		return;
+	}
+	
+	key_mgmt = wapi_auth_sta_key_mgmt(sta->wapi_sm);
+	if (key_mgmt & WPA_KEY_MGMT_WAPI_PSK) {
+		wpa_printf(MSG_DEBUG, "WAPI wai: Ignore WAI message - "
+			   "STA is using PSK");
+	} else if (key_mgmt & WPA_KEY_MGMT_WAPI_CERT) {
+		wpa_printf(MSG_DEBUG, "WAPI wai: Ignore WAI message - "
+			   "STA is using CERT");
+	} else {
+		wpa_printf(MSG_ERROR, "WAPI wai: STA is not using WAPI key mgmt");
+		return;
+	}
+
+	if (len < sizeof(*hdr)) {
+		wpa_printf(MSG_DEBUG, "   too short WAPI wai packet\n");
+		return;
+	}
+
+	hdr = (struct wapi_wai_hdr *) buf;
+	datalen = be_to_host16(hdr->data_len);
+	wpa_printf(MSG_DEBUG, "   WAPI wai: version=%d type=%d length=%d",
+		   hdr->version, hdr->type, datalen);
+
+	if (len < datalen) {
+		wpa_printf(MSG_DEBUG, "   frame too short for this WAPI wai packet\n");
+		return;
+	}
+	if (len > datalen) {
+		wpa_printf(MSG_DEBUG, "   ignoring %lu extra octets after "
+			   "WAPI wai packet",
+			   (unsigned long) len - datalen);
+	}
+
+	if (hdr->type == WAI_PROTOCOL_TYPE) {
+		wai_receive(hapd->wapi_auth, sta->wapi_sm, (u8 *) hdr, datalen);
+		return;
+	}
+}
+
+int wapi_set_hex_psk(struct hostapd_bss_config *bss)
+{
+	if (bss->ssid.wapi_psk_type == 1) {
+		bss->ssid.wapi_hex_psk = (unsigned char *)bss->ssid.wapi_psk;
+		
+		if(bss->ssid.wapi_psk_len % 2 != 0) {
+			wpa_printf(MSG_ERROR, "The length of hex psk is not even!");
+			return 1;
+		}
+
+		bss->ssid.wapi_psk = os_malloc((bss->ssid.wapi_psk_len / 2) + 1);
+		if (bss->ssid.wapi_psk == NULL) {
+			wpa_printf(MSG_ERROR, "can't malloc memory for transform hex psk");
+			return 1;
+		}
+
+		str2byte(bss->ssid.wapi_hex_psk, bss->ssid.wapi_psk_len, bss->ssid.wapi_psk);
+		bss->ssid.wapi_psk_len = bss->ssid.wapi_psk_len / 2;
+		
+		bss->ssid.wapi_psk[bss->ssid.wapi_psk_len] = '\0';
+
+		os_free(bss->ssid.wapi_hex_psk);
+		bss->ssid.wapi_hex_psk = NULL;
+	}
+	return 0;
+}
+
+
+int hostapd_setup_wapi_psk_bksa(struct hostapd_bss_config *conf)
+{
+	struct hostapd_ssid *ssid = &conf->ssid;
+	wpa_printf(MSG_DEBUG, "Enter %s",__func__);
+	if (ssid->wapi_psk != NULL) {
+		wpa_printf(MSG_DEBUG, "Deriving WAPI BK based on passphrase");
+		ssid->wapi_psk_bksa = os_zalloc(sizeof(struct hostapd_wapi_psk_bksa));
+		if (ssid->wapi_psk_bksa == NULL) {
+			wpa_printf(MSG_ERROR, "Unable to alloc space for WAPI PSK_BKSA");
+			return -1;
+		}
+		if (wapi_pskbk_derivation(ssid->wapi_psk,
+				ssid->wapi_psk_len, ssid->wapi_psk_bksa->bk) < 0)
+			return -1;
+		wpa_printf(MSG_DEBUG, "wapi BK: %X%X%X%X%X%X%X%X%X%X%X%X%X%X%X%X", 
+				ssid->wapi_psk_bksa->bk[0], ssid->wapi_psk_bksa->bk[1],
+				ssid->wapi_psk_bksa->bk[2], ssid->wapi_psk_bksa->bk[3],
+				ssid->wapi_psk_bksa->bk[4], ssid->wapi_psk_bksa->bk[5],
+				ssid->wapi_psk_bksa->bk[6], ssid->wapi_psk_bksa->bk[7],
+				ssid->wapi_psk_bksa->bk[8], ssid->wapi_psk_bksa->bk[9],
+				ssid->wapi_psk_bksa->bk[10], ssid->wapi_psk_bksa->bk[11],
+				ssid->wapi_psk_bksa->bk[12], ssid->wapi_psk_bksa->bk[13],
+				ssid->wapi_psk_bksa->bk[14], ssid->wapi_psk_bksa->bk[15]);
+	}
+	return 0;
+}
+
+void hostapd_event_wai_rx(struct hostapd_data *hapd, const u8 *src,
+				   const u8 *data, size_t data_len)
+{
+	struct hostapd_iface *iface = hapd->iface;
+	size_t j;
+	struct sta_info *sta;
+	wpa_printf(MSG_DEBUG, "Enter %s", __func__);
+	for (j = 0; j < iface->num_bss; j++) {
+		if ((sta = ap_get_sta(iface->bss[j], src))) {
+			if (sta->flags & WLAN_STA_ASSOC) {
+				hapd = iface->bss[j];
+				break;
+			}
+		}
+	}
+	wapi_wai_receive(hapd, src, data, data_len);
+}
