+    unsigned char tag_4 [ 10 ] = { 0 };
+    unsigned char rc2_iter [ 10 ] = { 0 };
+    unsigned char tag_5 [ 10 ] = { 0 };
+    int rc2_salt_len = 16 , rc2_iter_len = 10 , rc2_iter_1 = 0;
+    unsigned char rc2_key_out [ 64 ] = { 0 };
+    unsigned char rc2_iv_out [ 20 ] = { 0 };
+    unsigned char bag_data [ 3072 ] = { 0 };
+    unsigned char tag_6 [ 10 ] = { 0 };
+    unsigned char plain [ 3072 ] = { 0 };
+    int bag_data_len = 3072 , length = 0;
+    unsigned char user_data [ 2048 ] = { 0 };
+    unsigned char ca_data [ 2048 ] = { 0 };
+    int user_data_len = 2048 , ca_data_len = 2048;
+    unsigned char des3_salt [ 16 ] = { 0 };
+    unsigned char tag_7 [ 10 ] = { 0 };
+    unsigned char des3_iter [ 10 ] = { 0 };
+    unsigned char tag_8 [ 10 ] = { 0 };
+    int des3_salt_len = 16 , des3_iter_len = 10 , des3_iter_1 = 0;
+    unsigned char des3_key_out [ 64 ] = { 0 };
+    unsigned char des3_iv_out [ 20 ] = { 0 };
+    unsigned char prik_data [ 1024 ] = { 0 };
+    unsigned char tag_9 [ 10 ] = { 0 };
+    unsigned char plain_1 [ 1024 ] = { 0 };
+    int prik_data_len = 1024 , length_1 = 0;
+    unsigned char p12_prikey [ 1024 ] = { 0 };
+    P12_Cert p12_ctx;
+    AUTH_SAFE_BAG auth_safe_bag;
+    P8_PRIVATEKEY p8_prikey;
+
+    memset ( &p12_ctx , 0 , sizeof(P12_Cert) );
+    memset ( &auth_safe_bag , 0 , sizeof(AUTH_SAFE_BAG) );
+    memset ( &p8_prikey , 0 , sizeof(P8_PRIVATEKEY) );
+#if 0
+    fp = fopen( pP12FileName,"rb" );
+    if( fp == NULL )
+    {
+        return -1;
+    }
+    fopen_s( &fp, pP12FileName, "rb" );
+    len=fread( buf, 1, 4096, fp );
+    print_str_array( "p12", buf, len );
+    fclose( fp );
+    fp = NULL;
+#endif
+    version = (unsigned char*) malloc ( 10 );
+    if ( version == NULL )
+    {
+        return CTP_FALSE;
+    }
+	version_len = 10;
+	
+    p7data_id = (unsigned char*) malloc ( 32 );
+    if ( p7data_id == NULL )
+    {
+        return CTP_FALSE;
+    }
+	p7data_id_len = 32;
+	
+    safe_bag = (unsigned char*) malloc ( 3 * 1024 );
+    if ( safe_bag == NULL )
+    {
+        return CTP_FALSE;
+    }
+	safe_bag_len = 3 * 1024;
+	
+    mac_info = (unsigned char*) malloc ( 1024 );
+    if ( mac_info == NULL )
+    {
+        return CTP_FALSE;
+    }
+	mac_info_len = 1024;
+
+    ret = UnPack_P12 ( cert_buf , cert_len , version , &version_len ,
+            p7data_id , &p7data_id_len , safe_bag , &safe_bag_len , mac_info ,
+            &mac_info_len , &p12_ctx );
+    if ( ret != CTP_OK )
+        return CTP_FALSE;
+    if ( GetMacValue_P12 ( &p12_ctx , mac_value , &mac_len , tag_1 ) != CTP_OK )
+        return CTP_FALSE;
+    if ( GetMacSalt_P12 ( &p12_ctx , mac_salt , &mac_salt_len , tag_2 )
+            != CTP_OK )
+        return CTP_FALSE;
+    if ( GetMacIter_P12 ( &p12_ctx , mac_iter , &mac_iter_len , tag_3 )
+            != CTP_OK )
+        return CTP_FALSE;
+
+    mac_iter_1 = chart_to_int ( mac_iter , mac_iter_len );
+
+    if ( !password || !*password )
+    {
+        if ( Verify_Mac ( mac_value , mac_len , safe_bag , safe_bag_len ,
+                mac_salt , mac_salt_len , mac_iter_1 , NULL , 0 ) )
+            password = NULL;
+        else if ( Verify_Mac ( mac_value , mac_len , safe_bag , safe_bag_len ,
+                mac_salt , mac_salt_len , mac_iter_1 , "" , 0 ) )
+            password = "";
+
+    } else if ( !Verify_Mac ( mac_value , mac_len , safe_bag , safe_bag_len ,
+            mac_salt , mac_salt_len , mac_iter_1 , password , -1 ) )
+    {
+        return CTP_FALSE;
+    }
+
+    ret = 0;
+    ret = UnPack_AUTH_SAFE_BAG ( safe_bag , safe_bag_len , &auth_safe_bag );
+    if ( ret != CTP_OK )
+        return CTP_FALSE;
+
+    if ( GetRc2Salt_P12 ( &auth_safe_bag , rc2_salt , &rc2_salt_len , tag_4 )
+            != CTP_OK )
+        return CTP_FALSE;
+    if ( GetRc2Iter_P12 ( &auth_safe_bag , rc2_iter , &rc2_iter_len , tag_5 )
+            != CTP_OK )
+        return CTP_FALSE;
+    rc2_iter_1 = chart_to_int ( rc2_iter , rc2_iter_len );
+
+    if ( !pass_gen_key ( password , -1 , rc2_salt , rc2_salt_len , rc2_iter_1 ,
+            1 , rc2_key_out , 5 ) )
+        return 0;
+    /* print_str_array( "rc2_key_out", rc2_key_out, 5 ); */
+
+    if ( !pass_gen_key ( password , -1 , rc2_salt , rc2_salt_len , rc2_iter_1 ,
+            2 , rc2_iv_out , 8 ) )
+        return 0;
+
+    if ( GetCertData_P12 ( &auth_safe_bag , bag_data , &bag_data_len , tag_6 )
+            != CTP_OK )
+        return CTP_FALSE;
+    p12_rc2_cbc_decrypt ( bag_data , bag_data_len , rc2_iv_out , 8 ,
+            rc2_key_out , 5 , plain , &length );
+
+    if ( (pCACert != NULL) && (pCACertlen != NULL) )
+    {
+        if ( Cert_BagInfo ( plain , length , user_data , &user_data_len ,
+                ca_data , &ca_data_len ) != CTP_OK )
+            return CTP_FALSE;
+		
+		if (*pUserCertlen < user_data_len)
+		{
+			return CTP_FALSE; 
+		}
+        memcpy ( pUserCert , user_data , user_data_len );
+        *pUserCertlen = user_data_len;
+
+		if (*pCACertlen < ca_data_len)
+		{
+			return CTP_FALSE; 
+		}
+        memcpy ( pCACert , ca_data , ca_data_len );
+        *pCACertlen = ca_data_len;
+    } 
+	else
+    {
+        if ( Cert_BagInfo ( plain , length , user_data , &user_data_len , NULL ,
+                NULL ) != CTP_OK )
+            return CTP_FALSE;
+
+		if (*pUserCertlen < user_data_len)
+		{
+			return CTP_FALSE; 
+		}
+        memcpy ( pUserCert , user_data , user_data_len );
+        *pUserCertlen = user_data_len;
+    }
+
+    if ( Get3DesSalt_P12 ( &auth_safe_bag , des3_salt , &des3_salt_len , tag_7 )
+            != CTP_OK )
+        return CTP_FALSE;
+    if ( Get3DesIter_P12 ( &auth_safe_bag , des3_iter , &des3_iter_len , tag_8 )
+            != CTP_OK )
+        return CTP_FALSE;
+    des3_iter_1 = chart_to_int ( des3_iter , des3_iter_len );
+
+    if ( !pass_gen_key ( password , -1 , des3_salt , des3_salt_len ,
+            des3_iter_1 , 1 , des3_key_out , 24 ) )
+        return 0;
+    if ( !pass_gen_key ( password , -1 , des3_salt , des3_salt_len ,
+            des3_iter_1 , 2 , des3_iv_out , 8 ) )
+        return 0;
+
+    if ( GetPrikeyData_P12 ( &auth_safe_bag , prik_data , &prik_data_len ,
+            tag_9 ) != CTP_OK )
+        return CTP_FALSE;
+    p12_3des_cbc_decrypt ( prik_data , prik_data_len , des3_iv_out , 8 ,
+            des3_key_out , 24 , plain_1 , &length_1 );
+
+    ret = 0;
+    ret = Unpack_P8_PrivateKey ( plain_1 , length_1 , &p8_prikey );
+    if ( ret != CTP_OK )
+        return CTP_FALSE;
+
+    if ( P8toP12_PriKey ( plain_1 , length_1 , p12_prikey , &prikey_len )
+            != CTP_OK )
+        return CTP_FALSE;
+
+	if (*pKeylen < prikey_len)
+	{
+		return CTP_FALSE; 
+	}
+    memcpy ( pPrivateKey , p12_prikey , prikey_len );
+    *pKeylen = prikey_len;
+
+    End_P8_PrivateKey ( &p8_prikey );
+    End_AUTH_SAFE_BAG ( &auth_safe_bag );
+    End_P12 ( &p12_ctx );
+    free ( mac_info );
+    free ( safe_bag );
+    free ( p7data_id );
+    free ( version );
+
+    return CTP_OK;
+}
