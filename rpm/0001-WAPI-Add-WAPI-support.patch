+static int waigroup_cert_3_3(struct wapi_asue_st* wpa_s, 
+					u8* payload, int len)
+{
+	u8 flag = 0;
+	u8 *Nasue = NULL;
+	u8 *Nae = NULL;
+	u8 *acc_res = NULL;
+	u8 *asue_key_data = NULL;
+	u8 *ae_key_data = NULL;
+	u8 *ae_id = NULL;
+	u8 *asue_id = NULL;
+	u8 *cert_res = NULL;
+	u8 *ae_sign = NULL;
+	u8 *ae_sign_type = NULL;
+	int request_len = 0;
+	char cur_user_cert_name[128] = "\0";
+	unsigned char temp_pubkey[256];
+	int temp_pubkey_len = 256;
+	/* Certificate information*/
+	wapi_cert_data *cert_info = &(wpa_s->cert_info);
+	/* Current asue certificate */
+	wapi_x509_cert_asue_data *asue_cert_cur = cert_info->asue_cert_cur;
+	
+	wapi_printf(MSG_DEBUG, "WAI: Enter %s", __func__);
+
+	if (wpa_s->wapi_state != WAPISM_CNT_REQ)
+	{
+		wapi_printf(MSG_ERROR, "WAI: in %s:%d: wapi state error, "
+				"drop the frame.", __func__, __LINE__);
+		return -1;
+	}
+	
+	/* flag */
+	flag = payload[0];
+	wapi_printf(MSG_DEBUG, "WAI: flag = %d", flag);
+	wapi_printf(MSG_DEBUG, "WAI: wpa_s->flag = %d, (flag & BIT(0) ) = %d", 
+				flag, (flag & BIT(0) ));
+	wapi_printf(MSG_DEBUG, "WAI: wpa_s->flag = %d, (flag & BIT(1) ) = %d", 
+				flag, (flag & BIT(1) )); 
+
+	if ((flag & 0x03) != (wpa_s->flag & 0x03))
+	{
+		wapi_printf(MSG_ERROR, "WAI: not same flag bit 0, 1");
+		return -1;
+	}
+	request_len += 1;
+	Nasue = payload + 1;
+	if (Nasue == NULL) 
+	{
+		return -1;
+	}
+	if (memcmp(Nasue, wpa_s->Nasue, 32) != 0)
+	{
+		wapi_printf(MSG_ERROR, "WAI: not same Nasue!\n");
+		return -1;
+	}
+	request_len += 32;
+	Nae = Nasue + 32;
+	if (Nae == NULL) 
+	{
+		return -1;
+	}
+	memcpy(wpa_s->Nae, Nae, 32);
+	request_len += 32;
+	
+	acc_res = Nae + 32;
+	if (acc_res == NULL) 
+	{
+		wapi_printf(MSG_ERROR, "WAI: acc_res == null.\n");
+		return -1;
+	}
+	wapi_printf(MSG_DEBUG, "WAI: access result = %d.\n", acc_res[0]);
+	
+	show_access_result(wpa_s, acc_res, flag);
+	
+	if (acc_res[0] != 0) 
+	{
+		wapi_printf(MSG_ERROR, "WAI: access result is faild, acc_res[0] != 0");
+		return -2;
+	}
+	request_len += 1;
+	
+	asue_key_data = acc_res + 1;
+	if (asue_key_data == NULL) 
+	{
+		return -1;
+	}
+	if ((asue_key_data[0] != wpa_s->asue_key_data.length)
+		|| memcmp((char *)asue_key_data + 1, 
+			&(wpa_s->asue_key_data.data), 
+			wpa_s->asue_key_data.length ) != 0)
+	{
+		wapi_printf(MSG_ERROR, "WAI: not same asue key data!");
+		return -1;
+	}
+	request_len += wpa_s->asue_key_data.length + 1;
+	ae_key_data = asue_key_data + wpa_s->asue_key_data.length + 1;
+	if (ae_key_data == NULL) 
+	{
+		return -1;
+	}
+	memcpy(wpa_s->ae_key_data.data, ae_key_data + 1, ae_key_data[0]);
+	wpa_s->ae_key_data.length = ae_key_data[0];
+	request_len += ae_key_data[0] + 1;
+	ae_id = ae_key_data + ae_key_data[0] + 1;
+	if (ae_id == NULL) 
+	{
+		return -1;
+	}
+	if (cmp_var_struct(ae_id, &(wpa_s->ae_id), wpa_s->ae_id.id_len))
+	{
+		wapi_printf(MSG_ERROR, "WAI: not same ae id!\n");
+		wapi_hexdump(MSG_ERROR, "ae_id", ae_id, wpa_s->ae_id.id_len + 4);
+		wapi_hexdump(MSG_ERROR, "wpa_s->ae_id", 
+					(unsigned char *)&(wpa_s->ae_id),
+					wpa_s->ae_id.id_len + 4);
+		return -1;
+	}
+	request_len += wpa_s->ae_id.id_len + 4;
+
+	asue_id = ae_id + wpa_s->ae_id.id_len + 4;
+	if (asue_id == NULL) 
+	{
+		return -1;
+	}
+	
+	if (asue_cert_cur == NULL
+		|| asue_cert_cur->user_id == NULL)
+	{
+		wapi_printf(MSG_ERROR, "in %s:%d: current cert is null", 
+					__func__, __LINE__);		
+		return -1;		 
+	}
+
+	if (cmp_var_struct(asue_id, asue_cert_cur->user_id, 
+				asue_cert_cur->user_id->id_len))
+	{
+		wapi_printf(MSG_ERROR, "WAI: not same asue id!\n");
+		return -1;
+	}
+	request_len += asue_cert_cur->user_id->id_len + 4;
+
+	if (flag & BIT(3))
+	{
+		u8 *cert_pos = NULL;
+		u8 *asu_sign = NULL;
+		u16 fix_data_len = 0, sign_len = 0; 
+		tkey *asu_pubkey = NULL;
+		wapi_x509_cert_as_data *tmp = NULL;
+		u16 sign_flag = 0;
+		u8 *cert_verify_res_asue = NULL;
+		/* add 2012.12.13 */
+		u8 *cert_res_random1 = NULL;
+		u8 *cert_res_random2 = NULL;
+		u8 *cert_res1 = NULL;
+		u8 *cert_res2 = NULL;
+		u8 *cert_res_cert1 = NULL;
+		u8 *cert_res_cert2 = NULL;
+		u16 cert_flag_temp = 0;
+		u16 cert_len_temp = 0;
+		/* end */
+
+		cert_res = asue_id + asue_cert_cur->user_id->id_len + 4;
+	
+		if (cert_res[0] != 2)
+		{
+			wapi_printf(MSG_ERROR, "cert result flag is not 2!\n");
+			return -1;
+		}
+
+		/* add 2012.12.13 check cert_res_random1 and cert_res_random2 */
+		cert_res_random1 = cert_res + 1 + 2;
+		cert_res_random2 = cert_res_random1 + 32;
+		if (memcmp(cert_res_random1, Nae, 32) != 0)
+		{
+			wapi_printf(MSG_ERROR, "in %s:%d: Nae is not same to cert_res_random1", 
+						__func__, __LINE__);
+			return -1;
+		}
+		if (memcmp(cert_res_random2, wpa_s->Nasue , 32) != 0)
+		{
+			wapi_printf(MSG_ERROR, "in %s:%d: Nasue is not same to cert_res_random2",
+						__func__, __LINE__);
+			return -1;
+		}
+		/* end */
+
+		/* add 2012.12.13 check cert_res_cert1 */
+		cert_res1 = cert_res + 1 + 2 + 32 + 32;
+		if (cert_res1[0] != 0)
+		{
+			wapi_printf(MSG_ERROR, "in %s:%d: cert_res1 != 0(ASUE cert error)",
+						__func__, __LINE__);
+			return -1;
+		}
+		cert_res_cert1 = cert_res + 1 + 2 + 32 + 32 + 1;
+		GETSHORT((cert_res_cert1), cert_flag_temp);
+		GETSHORT((cert_res_cert1 + 2), cert_len_temp);
+		if (cert_flag_temp != asue_cert_cur->user_cert_st->cert_flag
+			|| cert_len_temp != asue_cert_cur->user_cert_st->length
+			|| memcmp(cert_res_cert1 + 2 + 2, 
+				asue_cert_cur->user_cert_st->data,
+				cert_len_temp) != 0)
+		{
+			wapi_printf(MSG_ERROR, "in %s:%d: cert_res_cert1 "
+					"is not same to asue cert", 
+						__func__, __LINE__);
+			return -1;
+		}
+		/* end */
+
+		/* add 2012.12.13 check cert_res_cert2 */
+		cert_res2 = cert_res_cert1 + 2 + 2 + cert_len_temp;
+		if (cert_res2[0] != 0)
+		{
+			wapi_printf(MSG_ERROR, "in %s:%d: cert_res2 != 0(AP cert error)", 
+						__func__, __LINE__);
+			return -2;
+		}
+
+		if (acc_res[0] != 0)
+		{
+			wapi_printf(MSG_ERROR, "WAI: access result is faild(2), "
+					"acc_res[0] != 0.\n");
+			return -1;
+		}
+		
+		cert_res_cert2 = cert_res_cert1 + 2 + 2 + cert_len_temp + 1;
+		GETSHORT((cert_res_cert2), cert_flag_temp);
+		GETSHORT((cert_res_cert2 + 2), cert_len_temp);
+		if (cert_flag_temp != wpa_s->ae_cert.cert_flag
+			|| cert_len_temp != wpa_s->ae_cert.length
+			|| memcmp(cert_res_cert2 + 2 + 2, wpa_s->ae_cert.data, cert_len_temp) != 0)
+		{
+			wapi_printf(MSG_ERROR, "in %s:%d: cert_res_cert2 "
+						"is not same to ae cert. \n", 
+						__func__, __LINE__);
+			/* 2013.6.13 add "return -1" for check cert_res_cert2 */
+			return -1;
+		}
+		/* end */
+		
+		cert_pos = cert_res + 1 + 2 + 32 + 32 + 1 + 2 ;
+		GETSHORT((cert_pos), fix_data_len);
+		cert_pos = cert_pos + fix_data_len + 2;
+		if (cert_pos[0] != 0)
+		{
+			wapi_printf(MSG_ERROR, "cert result is not ok!\n");
+			return -2;
+		}
+		GETSHORT((cert_pos + 1 + 2), fix_data_len);
+		asu_sign = cert_pos + fix_data_len + 1 + 2 + 2;
+		GETSHORT((asu_sign + 1), sign_len);
+		GETSHORT((cert_res + 1), fix_data_len);
+		
+		asu_pubkey = asue_cert_cur->asu_pubkey;
+		if (asu_pubkey == NULL)
+		{ 
+			wapi_printf(MSG_ERROR, "Get asu_pubkey failed !\n");
+			return -1;
+		}
+
+		/* ECC verify ASUE trusted server signature
+		 * The public key len is 50 bytes, 
+		 * but the function ecc_vrfy
+		 * need 48 bytes, so the pointer 
+		 * asu_pubkey->data offset 2 bytes
+		*/
+		if (ecc_vrfy(cert_res, fix_data_len + 3,
+				asu_pubkey->data + 2,
+				asu_sign + 1 + 2 + sign_len - 48) != 0)
+		{
+			wapi_printf(MSG_ERROR, "WAI: in %s:%d Verify ASUE trusted"
+					"server signature error !",
+					__func__, __LINE__);
+			wapi_hexdump(MSG_ERROR, "asu_pubkey: ", 
+					asu_pubkey->data, asu_pubkey->length);
+			wapi_hexdump(MSG_ERROR, "asu_sign: ", 
+					asu_sign + 1 + 2 + sign_len - 48, 48);
+			wapi_printf(MSG_ERROR, "sign fix_data_len: %d\n", fix_data_len);
+			return -1;
+		}
+		
+		request_len += fix_data_len + 3 + sign_len + 3;
+		wapi_printf(MSG_DEBUG, "WPA: in %s:%d, request_len = %d, len = %d", 
+					__func__, __LINE__, request_len, len);
+
+		/* need to confirm */
+		/*check if not have ae_trust server sign */
+		GETSHORT((payload + request_len + 1), fix_data_len);
+		u16 temp_len = request_len + fix_data_len + 3;
+		u8 *ae_trust_pos;
+		if (temp_len != len)
+		{
+			wapi_printf(MSG_INFO, "has ae_trust servier sign\n");
+			ae_trust_pos = asu_sign + sign_len + 1 + 2 + 1;
+			GETSHORT(ae_trust_pos , fix_data_len);
+			request_len += fix_data_len + 3;
+		}
+	}
+
+	u16 fix_data_len = 0;
+	u16 cert_flag = wpa_s->ae_cert.cert_flag;
+
+	ae_sign_type = payload + request_len;
+	/* wapi_printf(MSG_ERROR, "WAI: in %s:%d, ae_sign_type(%d) ", 
+				__func__, __LINE__, *ae_sign_type); */
+	if (*ae_sign_type != 1)
+	{
+		wapi_printf(MSG_ERROR, "WAI: in %s:%d, ae sign type error(type != 1) ", 
+					__func__, __LINE__);
+		return -1;
+	}
+	
+	ae_sign = payload + len - 48;
+
+	if (X509_Get_Pubkey(wpa_s->ae_cert.data, wpa_s->ae_cert.length, 
+				temp_pubkey, &temp_pubkey_len) != 0)
+	{
+		wapi_printf(MSG_ERROR, "WAI: in '%s':'%d', X509_Get_Pubkey failed\n", 
+					__func__, __LINE__);
+		return -1;
+	}
+	
+	/* ECC verify ae AE signature
+	 * The public key len is 50 bytes, 
+	 * but the function ecc_vrfy
+	 * need 48 bytes, so the pointer 
+	 * temp_pubkey offset 2 bytes
+	*/
+	if (ecc_vrfy(payload, request_len,
+			temp_pubkey + 2, ae_sign) != 0)
+	{
+		wapi_printf(MSG_ERROR, "WAI: in %s:%d, Verify AE signature error !", 
+					__func__, __LINE__);
+		wapi_hexdump(MSG_ERROR, "ae_pubkey: ", 
+				temp_pubkey + 1, temp_pubkey_len - 1);
+		wapi_hexdump(MSG_ERROR, "ae_sign: ", ae_sign, 48);
+		wapi_printf(MSG_ERROR, "sign request_len: %d\n", request_len);
+		return -1;
+	}
+	
+	GETSHORT((payload + request_len + 1), fix_data_len);
+	request_len += fix_data_len + 3;
+	
+	if (len != request_len)
+	{
+		wapi_printf(MSG_ERROR, "WAI: in %s:%d, invalid request_len", 
+					__func__, __LINE__);
+		return -1;
+	}
+
+	wapi_printf(MSG_DEBUG, "WAI: Leave %s", __func__);
+	asue_certauthbk_derivation(wpa_s);
+
+	/* Add 2017.11.9 */
+	wpa_s->prev_rxseq = wpa_s->curr_rxseq;
+	
+	wpa_s->wapi_state = WAPISM_CNT_RESP;
+
+	return 0;
+}
+
+static int waigroup_unicast_1_3(struct wapi_asue_st* wpa_s, 
+						u8* payload, int len)
+{
+    u8 flag = 0;
+    u8 *bkid = NULL;
+    u8 uskid = 0;
+    u8 *addid = NULL;
+    u8 *ae_challenge = NULL;
+    u8 *text = NULL;
+    u8 *pos = NULL;
+    int text_len = 0;
+    struct wapi_state_machine *wapi_sm = wpa_s->wapi_sm;
+
+    u8 usk_request_len = WAI_FLAG_LEN + 1 + BKID_LEN
+				+ ADDID_LEN + CHALLENGE_LEN;
+
+    wapi_printf(MSG_DEBUG, "WPA: in %s:%d", __func__, __LINE__);
+
+    if (len < usk_request_len)
+    {
+        wapi_printf(MSG_ERROR, "WPA: WAI frame payload "
+				"too short, len(%u)", len);
+        return -1;
+    }
+	
+    flag = payload[0];
+    bkid = payload + 1;
+    uskid = (bkid + BK_LEN)[0] ;
+    addid = (bkid + BK_LEN + 1);
+    ae_challenge = addid + ETH_ALEN * 2;
+
+    {
+        int usk_up = flag & BIT(4);
+        wapi_states require = WAPISM_FINISH;
+		/*save bk update flag */
+		wpa_s->usk_updated = usk_up;			
+        if (usk_up)
+        {
+            require = WAPISM_FINISH;
+        }
+        else
+        {
+            int psk = (AUTH_TYPE_WAPI_PSK == wpa_s->ap_type);
+            require = psk ? WAPISM_AL_ASSOC : WAPISM_CNT_RESP;
+        }
+
+        if (wpa_s->wapi_state != require)
+        {
+            /* skip the usk update */
+            if (wpa_s->usk_updated
+                && usk_up
+                && (wpa_s->wapi_state == WAPISM_FINISH
+                    || wpa_s->wapi_state == WAPISM_UNI_ACK
+                    || wpa_s->wapi_state == WAPISM_CNT_RESP))
+            {
+				/* empty */
+			}
+            else 
+			{
+				wapi_printf(MSG_ERROR, "WAI: in %s:%d: wapi state error, "
+						"drop the frame.", __func__, __LINE__);		
+                return -1;
+            }
+        }
+    }
+
+	/* Add 2018.3.13 */
+	if (AUTH_TYPE_WAPI_PSK == wpa_s->ap_type &&
+			(! wpa_s->usk_updated))
+	{
+		wapi_notify_connect_state(WAPI_AUTHENTICATING);
+	}
+	
+	if (!memcmp(bkid, 
+			"\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00", 
+			BKID_LEN)) 
+	{
+		wapi_printf(MSG_DEBUG, "WPA: in %s:%d BKID is wrong", __func__, __LINE__);
+		return -1;
+    }
+
+    u8* add_asue = addid + ETH_ALEN;
+	if (!memcmp(addid, "\x00\x00\x00\x00\x00\x00", ETH_ALEN)) 
+	{
+		wapi_printf(MSG_DEBUG, "WPA: in %s:%d AE ADD is wrong", 
+				__func__, __LINE__);
+		return -1;
+	}
+
+	if (memcmp(addid, wpa_s->bssid, ETH_ALEN)) 
+	{
+		wapi_printf(MSG_DEBUG, "WPA: in %s:%d AE ADD is wrong", 
+				__func__, __LINE__);
+		return -1;
+	}
+
+	if (!memcmp(add_asue, "\x00\x00\x00\x00\x00\x00", ETH_ALEN)) 
+	{
+	  	wapi_printf(MSG_DEBUG, "WPA: in %s:%d ASUE ADD is wrong", 
+				__func__, __LINE__);
+	    return -1;
+    }
+
+	if (memcmp(add_asue, wpa_s->own_addr, ETH_ALEN)) 
+	{
+		wapi_printf(MSG_DEBUG, "WPA: in %s:%d ASUE ADD is wrong", 
+				__func__, __LINE__);
+	    return -1;
+    }		
+
+    if (memcmp(bkid, wapi_sm->bksa.bkid, BKID_LEN) != 0) 
+	{
+        wapi_printf(MSG_DEBUG, "WPA: BKID is wrong");
+        wapi_hexdump(MSG_ERROR, "AE BKID", bkid, BKID_LEN);
+        wapi_hexdump(MSG_ERROR, "ASUE BKID", wapi_sm->bksa.bkid, BKID_LEN);
+        wapi_hexdump(MSG_ERROR, "ASUE BK", wapi_sm->bksa.bk, BKID_LEN);
+        return -2;
+    }
+
+	if (wpa_s->usk_first_auth_flag == 0)
+	{
+	    if (flag & BIT(4))
+	    {
+			wapi_printf(MSG_ERROR, "WAI:USK update flag error");
+	        return -1;
+	    }
+		else
+		{
+			if (uskid != 0)
+			{
+				wapi_printf(MSG_ERROR, "WPA: USKID  is not invalid");
+	        	return -1;
+			}
+		}
+	}
+	else
+	{	
+		if ((flag & BIT(4)) && (uskid == wapi_sm->usksa.uskid))
+	    {
+	        wapi_printf(MSG_ERROR, "WPA: USKID  is not invalid");
+	        return -1;
+	    }
+	}
+	
+    if ((flag & BIT(4)) && 
+		check_challege(wapi_sm->usksa.usk[wapi_sm->usksa.uskid].ae_challenge, 
+				ae_challenge))
+    {
+        wapi_hexdump(MSG_ERROR, "ae_challenge", ae_challenge, CHALLENGE_LEN);
+        return -1;
+    }
+
+	wapi_sm->flag = flag;
+
+    wapi_sm->usksa.uskid = uskid;
+
+    text_len = strlen(USK_TEXT) + ADDID_LEN + CHALLENGE_LEN * 2;
+    text = iwn_get_buffer(text_len);
+    if (text == NULL)
+    {
+        wapi_printf(MSG_DEBUG, "WPA: malloc failure");
+        return -1;
+    }
+    pos = text;
+    get_random(wapi_sm->usksa.usk[uskid].asue_challenge, CHALLENGE_LEN);
+
+    pos = MEMCPY(pos, addid, ADDID_LEN);
+    pos = MEMCPY(pos, ae_challenge, CHALLENGE_LEN);
+    wapi_hexdump(MSG_DEBUG, "asue_challenge", 
+				wapi_sm->usksa.usk[uskid].asue_challenge, 32);
+    wapi_hexdump(MSG_DEBUG, "ae_challenge", ae_challenge, 32);
+    pos = MEMCPY(pos, wapi_sm->usksa.usk[uskid].asue_challenge, CHALLENGE_LEN);
+    pos = MEMCPY(pos, USK_TEXT, strlen(USK_TEXT));
+
+    key_derivation(wapi_sm->bksa.bk, wapi_sm->bksa.bk_len, text, text_len, 
+				wapi_sm->usksa.usk[uskid].uek, USKSA_LEN, ISUSK);
+				
+    iwn_free_buffer(text, text_len);
+	
+    if (waigroup_unicast_2_3_send(wpa_s, payload, len)) 
+	{
+        return -1;
+    }
+
+	/* Add 2017.11.9 */
+	wpa_s->prev_rxseq = wpa_s->curr_rxseq;
+	
+    return 0;
+}
+
+static int waigroup_unicast_2_3_send(struct wapi_asue_st* wpa_s, 
+							u8* payload, int len_in)
+{
+	struct wapi_state_machine *wapi_sm = wpa_s->wapi_sm;
+	struct wapi_usk *usk = &wapi_sm->usksa.usk[wapi_sm->usksa.uskid];
+
+	/* Disable warning */
+	UNUSED(len_in);
+
+	u8 *tbuf = NULL;
+	u8 *pos = NULL;
+	int len = WAI_FLAG_LEN + BKID_LEN + 1 + ADDID_LEN;
+	int tbuflen = WAI_HDR + len + 2 * CHALLENGE_LEN + 
+				wapi_sm->assoc_wapi_ie_len + WAI_MIC_LEN;
+
+	wapi_printf(MSG_DEBUG, "WPA: in %s:%d\n", __func__, __LINE__);
+
+	tbuf = iwn_get_buffer(tbuflen);
+	if (tbuf == NULL)
+	{
+		wapi_printf(MSG_DEBUG, "WPA: in %s:%d", __func__, __LINE__);	
+		return -1;
+	}
+
+	pos = tbuf;
+	pos = wpa_build_hdr(pos, ++wpa_s->txseq, WAI_USK_NEGOTIATION_RESPONSE);
+	pos = MEMCPY(pos, payload, len);
+	pos = MEMCPY(pos, usk->asue_challenge, CHALLENGE_LEN);
+	pos = MEMCPY(pos, payload + len, CHALLENGE_LEN);
+
+	pos = MEMCPY(pos, wapi_sm->assoc_wapi_ie, wapi_sm->assoc_wapi_ie_len);
+
+	iwn_hmac_sha256(tbuf + WAI_HDR, tbuflen - WAI_MIC_LEN - WAI_HDR, 
+				usk->mak, PAIRKEY_LEN, pos, WAI_MIC_LEN);
+
+	wapi_hexdump(MSG_DEBUG, "sta's hmac: ", pos, WAI_MIC_LEN);
+	pos += WAI_MIC_LEN;
+	wai_set_length(tbuf, (short)(pos - tbuf));
+	iwn_wpa_ether_send(tbuf, tbuflen);
+	
+	timer_set(2, tbuf, tbuflen);
+	iwn_free_buffer(tbuf, tbuflen);
+
+	wpa_s->wapi_state = WAPISM_UNI_RESP;
+	return 0;
+}
+
+static int waigroup_unicast_3_3(struct wapi_asue_st* wpa_s, 
+						u8* payload, int len)
+{
+    struct wapi_state_machine *wapi_sm = wpa_s->wapi_sm;
+    int uskid = wpa_s->wapi_sm->usksa.uskid;
+    struct wapi_usk *usk = &wapi_sm->usksa.usk[uskid];
+
+	u8 *bkid = payload + 1;
+    u8 *addid = (bkid + BK_LEN + 1);
+	u8* add_asue = NULL;
+	
+    u8 *pos = payload + WAI_FLAG_LEN + BKID_LEN + 1 + ADDID_LEN;
+    u8 *wie = NULL;
+    u8 wie_len = 0;
+    u8 mic[WAI_MIC_LEN] = {0,};
+    u8 *rxmic = payload + len - WAI_MIC_LEN;
+
+	wapi_printf(MSG_DEBUG, "in %s:%d", __func__, __LINE__);
+	
+    if (wpa_s->wapi_state != WAPISM_UNI_RESP)
+    {
+		wapi_printf(MSG_ERROR, "WAI: in %s:%d: wapi state error, "
+				"drop the frame.", __func__, __LINE__);	
+        return -1;
+    }
+
+   	if (!memcmp(bkid, 
+		"\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00", 
+		BKID_LEN)) 
+	{
+		wapi_printf(MSG_DEBUG, "WPA: in %s:%d BKID is wrong", 
+					__func__, __LINE__);
+	    return -1;
+    }
+
+    add_asue = addid + ETH_ALEN;
+    if (!memcmp(addid, "\x00\x00\x00\x00\x00\x00", ETH_ALEN)) 
+	{
+		wapi_printf(MSG_DEBUG, "WPA: in %s:%d AE ADD is wrong", 
+					__func__, __LINE__);
+	    return -1;
+    }
+
+  	if (memcmp(addid, wpa_s->bssid, ETH_ALEN)) 
+	{
+		wapi_printf(MSG_DEBUG, "WPA: in %s:%d AE ADD is wrong", 
+					__func__, __LINE__);
+        return -1;
+    }
+
+	if (!memcmp(add_asue, "\x00\x00\x00\x00\x00\x00", ETH_ALEN)) 
+	{
+		wapi_printf(MSG_DEBUG, "WPA: in %s:%d ASUE ADD is wrong", 
+					__func__, __LINE__);
+	    return -1;
+    }
+
+	if (memcmp(add_asue, wpa_s->own_addr, ETH_ALEN)) 
+	{
+		wapi_printf(MSG_DEBUG, "WPA: in %s:%d ASUE ADD is wrong", 
+					__func__, __LINE__);
+	    return -1;
+    }
+
+	/* add 2012.12.17 for flag check */
+	if (wapi_sm->flag != payload[0])
+	{
+		wapi_printf(MSG_DEBUG, "WAI: in %s:%d bkid is not same to previous", 
+					__func__, __LINE__);
+		return -1;
+	}
+	
+	/* add 2012.12.17 for bkid check */
+	if (memcmp(wapi_sm->bksa.bkid, payload + 1, BKID_LEN) != 0)
+	{
+		wapi_printf(MSG_DEBUG, "WAI: in %s:%d bkid is not same to previous", 
+					__func__, __LINE__);
+		return -1;
+	}
+	
+	/* add 2012.12.17 for uskid check */
+	if (wapi_sm->usksa.uskid != payload[1 + BKID_LEN])
+	{
+		wapi_printf(MSG_DEBUG, "WAI: in %s:%d uskid is not same to previous", 
+					__func__, __LINE__);
+		return -1;
+	}
+
+    if (check_challege(wapi_sm->usksa.usk[uskid].asue_challenge, pos))
+    {
+        return -1;
+    }
+
+	iwn_hmac_sha256(payload, len - WAI_MIC_LEN, usk->mak, 
+			PAIRKEY_LEN, mic, WAI_MIC_LEN);
+
+    if (memcmp(mic, rxmic, WAI_MIC_LEN))
+    {
+        wapi_hexdump(MSG_DEBUG, "receive ap's mic", rxmic, WAI_MIC_LEN);
+        wapi_hexdump(MSG_DEBUG, "own mic", mic, WAI_MIC_LEN);
+        return -1;
+    }
+    pos += CHALLENGE_LEN;
+    wie = pos; 
+	wie_len = wie[1]+2;
+    wapi_hexdump(MSG_DEBUG, "WIE ", wie, wie_len);
+
+    /* not unicast update  */
+    if (!(payload[0] & BIT(4)))
+	{
+		/* with hidden AP, need to confirm */
+        if (wapi_sm->ap_wapi_ie_len == 0)
+        {
+            wapi_sm->ap_wapi_ie_len = wie_len;
+            memcpy(wapi_sm->ap_wapi_ie, wie, wie_len);
+        }
+        if ((wie_len != wapi_sm->ap_wapi_ie_len)
+            || memcmp(wie, wapi_sm->ap_wapi_ie, wapi_sm->ap_wapi_ie_len))
+        {
+            wapi_printf(MSG_ERROR, "WIE is different from beacon IE");
+            wapi_hexdump(MSG_ERROR, "WIE ", wie, wie_len);
+            wapi_hexdump(MSG_ERROR, "Beacon IE ", 
+					wapi_sm->ap_wapi_ie, wapi_sm->ap_wapi_ie_len);
+            return -2;
+        }
+    }
+    wapi_sm->usksa.uskid = payload[1 + BKID_LEN];
+    if (wapi_install_usk(wpa_s))
+    {
+		wapi_printf(MSG_ERROR, "in %s install usk failure", __func__);
+        return -1;
+    }
+
+	/* Add 2017.11.9 */
+	wpa_s->prev_rxseq = wpa_s->curr_rxseq;
+	
+	if (!wpa_s->usk_updated && (payload[0] & BIT(4)))
+    {
+        wpa_s->usk_updated = 1;
+    }
+	
+    wpa_s->wapi_state = WAPISM_UNI_ACK;
+    
+    return 0;
+}
+
+static int waigroup_multicast_1_2(struct wapi_asue_st* wpa_s, 
+						u8* payload, int len)
+{
+    u8 *pos = payload;
+    u8 mic[20] = {0,};
+    u8 ct_msk[16] = {0,};
+    u8 iv[16] = {0,};
+    u8 *key_an_id = pos + 3 + ADDID_LEN + WAI_IV_LEN;
+    u8 *key_data = key_an_id + WAI_KEY_AN_ID_LEN;
+    u8 tmp_msk[16];
+    struct wapi_usk *usk = NULL;
+    struct wapi_state_machine *sm = wpa_s->wapi_sm;
+
+    wapi_printf(MSG_DEBUG, "WAI: in %s:%d", __func__, __LINE__);
+    if (WAPISM_UNI_ACK == wpa_s->wapi_state 
+		|| WAPISM_FINISH == wpa_s->wapi_state)
+    {
+		/* Empty*/
+    }
+    else
+    {
+        wapi_printf(MSG_ERROR, "WAI: in %s:%d: wapi state error, "
+				"drop the frame.", __func__, __LINE__);	
+        return -1;
+    }
+	
+    if (payload[0] & BIT(5))
+    {
+        wapi_printf(MSG_DEBUG, "WPA: STAKEY_NEG  is not supptable by ASUE");
+        return -1;
+    }
+    pos += 1 + BKID_LEN;
+#ifdef REKEY
+    if (payload[1] != !sm->msksa.mskid)
+    {
+        wapi_printf(MSG_DEBUG, "WPA: MSKID  is not invalid");
+        return -1;
+    }
+#endif
+    sm->msksa.mskid = payload[1];
+    if (check_addid(wpa_s, payload + 3) != 0)
+    {
+        wapi_printf(MSG_DEBUG, "WPA: ADDID  is wrong");
+        return -1;
+    }
+
+    /* Modify 2017.11.10 */
+	if (check_iv(&sm->msksa, key_an_id) > 0)
+    {
+        wapi_printf(MSG_DEBUG, "WPA: Key annoucement identfier is wrong");
+        wapi_hexdump(MSG_DEBUG, "WPA: msk_ann_id", 
+				sm->msksa.msk_ann_id, WAI_IV_LEN);
+        wapi_hexdump(MSG_DEBUG, "rx WPA: Key_an_id", 
+				key_an_id, WAI_IV_LEN);
+        return -1;
+    }
+    memcpy(sm->msksa.msk_ann_id, key_an_id, WAI_IV_LEN );
+    usk = get_usk(sm, payload[2]);
+    if (usk == NULL)
+    {
+        wapi_printf(MSG_DEBUG, "WPA: Key annoucement uskid  is wrong");
+        return -1;
+    }
+	
+	iwn_hmac_sha256(payload, len - WAI_MIC_LEN, usk->mak, 
+			PAIRKEY_LEN, mic, WAI_MIC_LEN);
+
+    if (memcmp(mic, payload + len - WAI_MIC_LEN, WAI_MIC_LEN) != 0)
+    {
+        wapi_printf(MSG_DEBUG, "WPA: Multicast announcement "
+				"packet mic is wrong");
+        return -1;
+    }
+
+    memcpy(ct_msk, &key_data[1], PAIRKEY_LEN);
+    memcpy(iv, key_an_id, WAI_IV_LEN);
+
+    wapi_hexdump(MSG_DEBUG, "ct_msk", &key_data[1], PAIRKEY_LEN);
+    wapi_hexdump(MSG_DEBUG, "kek", usk->kek, PAIRKEY_LEN);
+    wapi_hexdump(MSG_DEBUG, "iv", iv, WAI_IV_LEN);
+
+    /* decrypt the multicast key */
+    memset(tmp_msk, 0, sizeof(tmp_msk));
+    memcpy(tmp_msk, key_data + 1, sizeof(tmp_msk));
+    wpi_encrypt(iv, tmp_msk, 16, usk->kek, ct_msk);
+    wapi_hexdump(MSG_DEBUG, "outmkey", ct_msk, PAIRKEY_LEN);
+    key_derivation(ct_msk, key_data[0], (u8 *)MSK_TEXT, strlen(MSK_TEXT), 
+			sm->msksa.msk, PAIRKEY_LEN * 2, 0);
+
+    wapi_hexdump(MSG_DEBUG, "msk", sm->msksa.msk, PAIRKEY_LEN * 2);
+    /*wpa_build_bksa(msksa);*/
+
+	/* Modify 2017.11.10 */
+	/* ret = waigroup_multicast_2_2_send(wpa_s, payload, len); */
+	if (waigroup_multicast_2_2_send(wpa_s, payload, len))
+	{
+		return -1;
+	}
+	
+	/* Add 2017.11.9 */
+	wpa_s->prev_rxseq = wpa_s->curr_rxseq;
+
+	return 0;
+}
+
+static int waigroup_multicast_2_2_send(struct wapi_asue_st* wpa_s, 
+							u8* payload, int len)
+{
+	u8 *tbuf = NULL;
+	u8 *pos = NULL;
+	int tlen = WAI_FLAG_LEN + 1 + 1 + ADDID_LEN;
+	int tbuflen = WAI_HDR + tlen + WAI_IV_LEN + WAI_MIC_LEN;
+	struct wapi_usk *usk = NULL;
+	
+	/* Disable warning */
+	UNUSED(len);
+	
+	wapi_printf(MSG_DEBUG, "WPA: in %s:%d", __func__, __LINE__);
+	usk = get_usk(wpa_s->wapi_sm, payload[2]);
+	if (usk == NULL)
+	{
+		wapi_printf(MSG_DEBUG, "WPA: Key annoucement uskid  is wrong");
+		return -1;
+	}
+
+	tbuf = (u8 *)iwn_get_buffer(tbuflen);
+	if (tbuf == NULL)
+	{
+		return -1;
+	}
+	
+	pos = tbuf;
+	pos = wpa_build_hdr(pos, ++wpa_s->txseq, WAI_MSK_ANNOUNCEMENT_RESPONSE);
+	pos = MEMCPY(pos, payload, tlen);
+	pos = MEMCPY(pos, payload + tlen + WAI_IV_LEN, WAI_IV_LEN);
+
+	wapi_hexdump(MSG_DEBUG, "WPA: mak", 
+				usk->mak, PAIRKEY_LEN);
+	wapi_hexdump(MSG_DEBUG, "WPA: tbuf", 
+				tbuf + WAI_HDR, tbuflen - WAI_MIC_LEN - WAI_HDR);
+
+	iwn_hmac_sha256(tbuf + WAI_HDR, tbuflen - WAI_MIC_LEN - WAI_HDR, 
+				usk->mak, PAIRKEY_LEN, pos, WAI_MIC_LEN);
+
+	/* set wai length field */
+	pos += WAI_MIC_LEN;
+	wai_set_length(tbuf, (short)(pos - tbuf));
+
+	iwn_wpa_ether_send(tbuf, tbuflen);
+
+	timer_set(3, tbuf, tbuflen);
+	iwn_free_buffer(tbuf, tbuflen);
+
+	wpa_s->wapi_state = WAPISM_MUL_RESP;
+	if (wapi_install_msk(wpa_s, &payload[tlen])) 
+	{
+		wapi_printf(MSG_ERROR, "in %s install msk failure", __func__);
+		return -1;
+	}
+	wpa_s->wapi_state = WAPISM_FINISH;
+
+	wpa_s->usk_first_auth_flag = 1;
+
+	/* Add 2018.3.13 */
+	wapi_notify_connect_state(WAPI_CONNECTED);
+	
+	return 0;
+}
+
+static int wapi_install_usk(struct wapi_asue_st *wpa_s)
+{
+	struct wapi_usksa *usksa = &wpa_s->wapi_sm->usksa;
+	int uskid = (int)usksa->uskid;
+	struct wapi_usk *usk = &usksa->usk[uskid];
+
+	wapi_hexdump(MSG_DEBUG, "wapi_install_usk:", (u8*)usk, 32);
+	wapi_printf(MSG_DEBUG, "uskid is %d.", uskid);
+	
+	if (0 != wapi_set_unicast_key((const char*)usk, 32, uskid))
+	{
+		wapi_printf(MSG_WARNING, "WPA: Failed to set PTK to the driver");
+		return -1;
+	}
+
+	return 0;
+}
+
+static int wapi_install_msk(struct wapi_asue_st *wpa_s, unsigned char *key_sc)
+{
+	struct wapi_msksa *msksa = &wpa_s->wapi_sm->msksa;
+	int mskid = (int)msksa->mskid;
+
+	wapi_hexdump(MSG_DEBUG, "wapi_install_msk:", msksa->msk, 32);
+	wapi_hexdump(MSG_DEBUG, "WPA: KEYSC", key_sc, 16);
+	wapi_printf(MSG_DEBUG, "mskid is %d.", mskid);
+	
+	if (0 != wapi_set_group_key(msksa->msk, 32, mskid, key_sc))
+	{
+		wapi_printf(MSG_WARNING, "WPA: Failed to set MSK to the driver.");
+		return -1;
+	}
+	
+	return 0;
+}
