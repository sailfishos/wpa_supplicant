+wapi_x509_cert_asue_data *alloc_asue_cert_data()
+{
+	wapi_x509_cert_asue_data *asue_cert_data = NULL;
+	
+	asue_cert_data = 
+		(wapi_x509_cert_asue_data *)malloc(sizeof(wapi_x509_cert_asue_data));
+	asue_cert_data->asu_cert_st = (cert_id *)malloc(sizeof(cert_id));
+	asue_cert_data->user_cert_st = (cert_id *)malloc(sizeof(cert_id));
+	asue_cert_data->asu_pubkey = (tkey *)malloc(sizeof(tkey));
+	asue_cert_data->private_key = (tkey *)malloc(sizeof(tkey));
+	asue_cert_data->user_id = (wai_fixdata_id *)malloc(sizeof(wai_fixdata_id));
+	asue_cert_data->asu_id = (wai_fixdata_id *)malloc(sizeof(wai_fixdata_id));
+	
+	if (asue_cert_data == NULL 
+		|| asue_cert_data->asu_cert_st == NULL 
+		|| asue_cert_data->user_cert_st == NULL
+		|| asue_cert_data->asu_pubkey == NULL
+		|| asue_cert_data->private_key == NULL
+		|| asue_cert_data->user_id == NULL
+		|| asue_cert_data->asu_id == NULL)
+	{
+		return NULL;
+	}
+	
+	return asue_cert_data;
+}
+
+void free_asue_cert_data(wapi_x509_cert_asue_data *asue_cert_data)
+{
+	if (asue_cert_data == NULL)
+	{
+		return;
+	}
+	
+	if (asue_cert_data->asu_cert_st != NULL)
+	{
+		free(asue_cert_data->asu_cert_st);
+		asue_cert_data->asu_cert_st = NULL;
+	}
+	if (asue_cert_data->user_cert_st != NULL)
+	{
+		free(asue_cert_data->user_cert_st);
+		asue_cert_data->user_cert_st = NULL;
+	}
+	if (asue_cert_data->asu_pubkey != NULL)
+	{
+		free(asue_cert_data->asu_pubkey);
+		asue_cert_data->asu_pubkey = NULL;
+	}
+	if (asue_cert_data->private_key != NULL)
+	{
+		free(asue_cert_data->private_key);
+		asue_cert_data->private_key = NULL;
+	}
+	if (asue_cert_data->user_id != NULL)
+	{
+		free(asue_cert_data->user_id);
+		asue_cert_data->user_id = NULL;
+	}
+	
+	if (asue_cert_data->asu_id != NULL)
+	{
+		free(asue_cert_data->asu_id);
+		asue_cert_data->asu_id = NULL;
+	}
+	
+	asue_cert_data = NULL;
+}
+
+void free_aliases(char** aliases, int count)
+{
+	int i = 0;
+	
+	if (aliases == NULL || count <= 0)
+	{
+		return;
+	}
+	
+	for (i = 0; i < count; i ++)
+	{
+		if (aliases[i] != NULL)
+		{
+			free(aliases[i]);
+		}
+	}
+	
+	free(aliases);
+}
