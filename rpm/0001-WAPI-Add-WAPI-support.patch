+int IWN_OpenSession(void **phSessionHandle,ECCrefPara *pucEccPara)
+{
+	int ret = -1;
+	SessionHandle *EccSessionHandle = NULL;
+	EccCurveHandle *EccHandle = NULL;
+
+	if(phSessionHandle==NULL || pucEccPara==NULL)
+	{
+		ret = SDR_PARAINPUTERR;
+		return ret;
+	}
+
+    EccSessionHandle = (SessionHandle *)malloc(sizeof(SessionHandle));
+    if(EccSessionHandle == NULL)
+    {
+		ret = SDR_SESSIONRESMALLOCERR;
+		return ret;
+    }
+	memset(EccSessionHandle,0,sizeof(SessionHandle));
+
+	EccHandle = (EccCurveHandle *)malloc(sizeof(EccCurveHandle));
+    if(EccHandle == NULL)
+    {
+		ret = SDR_ECCMALLOCERR;
+		return ret;
+    }
+	memset(EccHandle,0,sizeof(EccCurveHandle));
+    EccSessionHandle->CurveHandle = (EccCurveHandle *)EccHandle;
+
+	if(pucEccPara!=NULL)
+	{
+		IWN_CurveParaCfg(EccSessionHandle,(enum_bits)pucEccPara->mode,pucEccPara);
+	}
+    *phSessionHandle = EccSessionHandle;
+
+    ret = SDR_OK;
+    return ret;
+}
+/*--------------------------------------------------------------------*/
+int IWN_CloseSession(void *hSessionHandle)
+{
+	int ret = -1;
+    SessionHandle *EccSessionHandle = NULL;
+	
+    if(hSessionHandle == NULL)
+    {
+		ret = SDR_CLOSESESSIONERR;
+		return ret;
+    }
+
+    EccSessionHandle = (SessionHandle *)hSessionHandle;
+	if(EccSessionHandle->EccConfigPara!=NULL)
+	{
+		free(EccSessionHandle->EccConfigPara);
+		EccSessionHandle->EccConfigPara=NULL;
+	}
+
+	if(EccSessionHandle->CurveHandle!=NULL)
+	{
+		free(EccSessionHandle->CurveHandle);
+		EccSessionHandle->CurveHandle=NULL;
+	}
+
+    free(EccSessionHandle);
+    EccSessionHandle=NULL;
+
+    ret = SDR_OK;
+    return ret;
+}
