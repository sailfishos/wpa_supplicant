+int Unpack_X509_PrivateKey(unsigned char *In, int len, X509_PRIVATEKEY *prikey_ctx)
+{
+	int len0=0,len1=0,len2=0,len3=0,len4=0,len5=0,len6=0;
+	unsigned char Llen=0;
+	unsigned char *p = NULL;
+	int g_Private_Length = 0;
+
+	p = In;
+	p += 1;
+	len0 = GetInfoLength(p,&Llen);
+	p += Llen;
+	
+	g_Private_Length += 1 + Llen;
+
+	p += 1;
+	len1 = GetInfoLength(p,&Llen);
+	p += Llen;
+	prikey_ctx->Version.data = p;
+	prikey_ctx->Version.length = len1;
+	p += len1;
+
+	g_Private_Length += 1 + Llen + len1;
+
+	p += 1;
+	len2 = GetInfoLength(p,&Llen);
+	p += Llen;
+	prikey_ctx->PrivateKey.data = p;
+	prikey_ctx->PrivateKey.length = len2;
+	p += len2;
+
+	g_Private_Length += 1 + Llen + len2;
+
+	p += 1;
+	len3 = GetInfoLength(p,&Llen);
+	p += Llen;
+	g_Private_Length += 1 + Llen;
+	p += 1;
+	len4 = GetInfoLength(p,&Llen);
+	p += Llen;
+	prikey_ctx->AlgorithmID.data = p;
+	prikey_ctx->AlgorithmID.length = len4;
+	p += len4;
+	g_Private_Length += 1 + Llen + len4;
+
+	p += 1;
+	len5 = GetInfoLength(p,&Llen);
+	p += Llen;
+	g_Private_Length += 1 + Llen;
+	p += 1;
+	len6 = GetInfoLength(p,&Llen);
+	p += Llen;
+	prikey_ctx->PublicKey.data = p;
+	prikey_ctx->PublicKey.length = len6;
+	p += len6;
+	g_Private_Length += 1 + Llen + len6;
+
+	if(g_Private_Length < len)
+	{
+		prikey_ctx->Reserve.data = p;
+		prikey_ctx->Reserve.length = len - g_Private_Length;
+		return CTP_OK;
+	}
+	else if(g_Private_Length == len)
+	{
+	    return CTP_OK;
+	
+	}
+	else
+	{
+		return CTP_FALSE;
+	}
+}
