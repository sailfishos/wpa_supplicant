+	para_alg ecdh;
+
+	struct timer_dispose* ptm;				
+	struct wapi_state_machine vpt_wapi_sm;
+	struct timer_dispose vpt_tm;
+
+	/*0-open,1-cert,2-key*/
+	int ap_type;
+	u8 psk_bk[16];
+	
+	/* flag for first waigroup_unicast,1:yes,0:no*/
