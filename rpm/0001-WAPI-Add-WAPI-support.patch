+int Get128_NthPower(int n)
+{
+	int result = 1;  //0th power
+	int i=1;
+
+	for(i=1;i<=n;i++)
+	{
+		result *= 128;
+	}
+	return result;
+}
+//└²ūėŻ║░č0x2A,0x81,0x1C,0xCF,0x55,0x01,0x82,0x2D╝Ų╦Ń│╔╬¬1.2.156.10197.1.301
+int ChangeIdentifyToString_X509(unsigned char *in, int len, int *out,int *outlen)
+{
+	unsigned char *p = NULL;
+	int pos=0;
+	int k = 0;
+	int n[10] = {0};
+	int data[10] = {0};
+	int i=0,res=0;
+	
+	p = in;
+	data[k] = *p/40;
+	k++;
+	data[k] = *p%40;
+	k++;
+	pos++;
+
+	while(pos < len)
+	{
+		int j=0;
+		for(i=pos;i<len;i++)
+		{
+			if(*(p+i)<128)
+			{
+				n[j] = *(p+i);
+				j++;
+				break;
+			}
+			n[j] = *(p+i)-128;
+			j++;
+		}
+		for(i=0;i<j;i++)
+		{
+			res = Get128_NthPower(j-1-i);
+			data[k] += n[i]*res;
+		}
+		pos += j;
+		k++;
+	}
+	*outlen = k;	
+	memcpy(out,data,k*sizeof(int));
+	
+	return CTP_OK;
+}
