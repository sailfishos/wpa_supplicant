+int wapi_auth_sm_event(struct wapi_state_machine *sm, wapi_ap_event event)
+{
+	int remove_ptk = 1;
+
+	if (sm == NULL)
+		return -1;
+
+	switch (event) {
+	case WAPI_AUTH:
+	case WAPI_ASSOC:
+		break;
+	case WAPI_DEAUTH:
+	case WAPI_DISASSOC:
+		sm->DeauthenticationRequest = _TRUE;
+		break;
+
+	case WAPI_REAUTH:	
+
+		break;
+	}
+
+	return wapi_sm_step(sm);
+}
