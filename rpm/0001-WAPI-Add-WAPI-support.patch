+	void (*mic_failure_report)(void *ctx, const u8_t *addr);
+	void (*set_authorized)(void *ctx, const u8_t *addr, wapi_variable var, int value);
+	//int (*get_eapol)(void *ctx, const u8_t *addr, wpa_eapol_variable var);
+	int (*get_bkid)(void *ctx, const u8_t *addr, u8_t *prev_psk);
+	int (*get_msk)(u8_t *nmk, u8_t *msk, size_t key_len);
+	int (*get_usk)(void *ctx, u8_t *mac1, u8_t *mac2, u8_t *ANonce,
+				    u8_t *SNonce, u8_t *next_ANonce, u8_t *master_key);
+	int (*set_key)(void *ctx, int vlan_id, int alg, const u8_t *addr,
+					int idx, u8_t *iv, size_t iv_len,
+					u8_t *key, size_t key_len, int keyflag);
+	int (*get_seqnum)(void *ctx, const u8_t *addr, int idx, u8_t *seq);
+	int (*send_wapi)(void *ctx, const u8_t *addr, const u8_t *data,
+			  size_t data_len, int encrypt);
+	int (*for_each_sta)(void *ctx, int (*cb)(struct wapi_state_machine *sm,
+						 void *ctx), void *cb_ctx);
+	int (*for_each_auth)(void *ctx, int (*cb)(struct wapi_authenticator *a,
+						  void *ctx), void *cb_ctx);
