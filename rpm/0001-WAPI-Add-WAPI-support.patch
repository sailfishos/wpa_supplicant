+int IWN_CurveVerify(enum_bits CurveType, ECCrefPara *CurvePara)
+{
+	ECC_FpCURVE curve;
+	int fixlen=0;
+	MINT sum,sum1,sum2;
+	ECC_FpPOINT pt;
+	int ret = -1;
+		 
+	if ((CurveType <= ECC_API_OPS_BITS_NONE) || (CurveType >= ECC_API_OPS_BITS_MAX) || (CurvePara == NULL))
+	{
+		ret = SDR_PARAINPUTERR;
+	    return ret;
+	}
+
+	memset(&curve,0,sizeof(ECC_FpCURVE));
+	memset(&pt,0,sizeof(ECC_FpPOINT));
+	memset(&sum,0,sizeof(MINT));
+	memset(&sum1,0,sizeof(MINT));
+	memset(&sum2,0,sizeof(MINT));
+
+	switch(CurveType)
+	{
+		case ECC_API_OPS_BIT160:
+			fixlen = 20;
+			break;
+		case ECC_API_OPS_BIT192:
+			fixlen = 24;
+			break;
+		case ECC_API_OPS_BIT224:
+			fixlen = 28;
+			break;
+		case ECC_API_OPS_BIT256:
+			fixlen = 32;
+			break;
+		case ECC_API_OPS_SM2EXP:
+			fixlen = 32;
+			break;
+		case ECC_API_OPS_SM2REC:
+			fixlen = 32;
+			break;
+		default:
+			break;			
+	}
+
+	octetstring_to_mint(CurvePara->P,fixlen,&(curve.P));
+	octetstring_to_mint(CurvePara->A,fixlen,&(curve.A));
+	octetstring_to_mint(CurvePara->B,fixlen,&(curve.B));
+	octetstring_to_mint(CurvePara->Gx,fixlen,&(curve.G.x));
+	octetstring_to_mint(CurvePara->Gy,fixlen,&(curve.G.y));
+	octetstring_to_mint(CurvePara->N,fixlen,&(curve.N));
+	
+	//y2 = x3 + ax + b   čķųż╩ŪĘ±┬·ūŃ═ųį▓Ū·Ž▀ĘĮ│╠
+	mint_mod_mul(&curve.G.x, &curve.G.x,&curve.P, &sum2);
+	mint_mod_mul(&sum2, &curve.G.x,&curve.P, &sum1);
+	mint_mod_mul(&curve.A, &curve.G.x,&curve.P, &sum2); 
+	mint_mod_add(&sum1,&sum2,&curve.P,&sum);
+	mint_mod_add(&sum,&curve.B,&curve.P,&sum1);
+	mint_mod_mul(&curve.G.y, &curve.G.y,&curve.P, &sum);
+	if (mint_compare(&sum,&sum1) != 0 || MINT_ISZERO(&sum) || MINT_ISZERO(&sum1))
+	{
+		return ret;
+	}
+	ecc_unknown_point_mul(&curve.N,&curve.G,&curve.A,&curve.B,&curve.P,&pt);
+	if(pt.is_infinite != 1)
+	{
+		return ret;
+	}
+	ret=SDR_OK;
+	return ret;
+}
