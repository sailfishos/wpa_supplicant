+/*--------------------------------------------------------------------*/
+/* quotient = dividend / divisor ; remainder = dividend % divisor */
+int mint_div(MINT *dividend,MINT *divisor,MINT *quotient,MINT *remainder)
+{
+	int bit,i,j,k;
+	MINT m,pp,t;
+    unsigned int *tp,*wp;
+	unsigned int *wnp;
+	unsigned int p0,p1;
+	int r_len,pp_len;
+	int result;
+	unsigned int g;
+	unsigned int c0,c1,f=0;
+
+	memset(&m,0,sizeof(MINT));
+	memset(&pp,0,sizeof(MINT));
+	memset(&t,0,sizeof(MINT));
+
+	if(MINT_ISZERO(divisor)||remainder==NULL)
+		return 0;
+		
+	if(mint_compare(dividend,divisor) < 0)
+	{	
+		mint_copy(remainder,dividend);
+		MI_DWORDTOMINT(quotient,0);
+		return 1;
+	}
+	
+	bit =  MINT_BIT-((get_mint_bit_len(divisor))% MINT_BIT);
+
+	mint_copy(&pp,divisor);
+	mint_left_move(&pp,bit);
+
+	bit +=  MINT_BIT;
+
+    mint_copy(remainder,dividend);
+	mint_left_move(remainder,bit);
+
+	pp_len = pp.len;
+	r_len = remainder->len;
+	k = r_len-pp_len;
+
+	wnp = &(remainder->value[k]);
+         
+ 	p0 = pp.value[pp_len-1];
+    p1 = (pp_len == 1)?0:pp.value[pp_len-2];
+
+	wp = &(remainder->value[r_len-1]);
+
+	t.len = k;
+	tp = &(t.value[k-1]);
+
+	result = 0;
+
+	for (i=remainder->len-1,j=pp.len-1;j>=0;i--,j--)
+	{
+		if (remainder->value[i] > pp.value[j])
+		{
+			result = 1;
+			break;
+		}
+		if (remainder->value[i] < pp.value[j])
+		{
+			result = -1;
+			break;
+		}
+	}
+
+	if(result>=0)
+	{
+		sub_2(wnp, pp.value, pp_len, wnp);
+		*tp = 1;
+	}
+	else
+		t.len--;
+
+	tp--;
+
+	for(i=0; i<k-1; i++, wp--, tp--)
+	{
+		c0 = wp[0];
+		c1 = wp[-1];
+		if(c0 == p0)
+			g = MAX_DWORD_VALUE;
+		else 			
+		{
+			word64 s;
+
+#if defined(MINT_DIV)
+			g = (unsigned int)(((((word64)c0)<< MINT_BIT)|c1)/p0);
+
+
+#else
+			g=div_2(c0,c1,p0);
+
+#endif
+
+			f = (c1-g*p0)&MAX_DWORD_VALUE;
+
+			s = (word64)p1*g;
+
+			for (;;)
+			{
+				if(s <= ((((word64)f)<< MINT_BIT)|wp[-2]))
+					break;
+				g--;
+				f += p0;
+				if (f < p0) break;
+				s -= p1;
+			}
+
+		}
+
+		m.value[pp_len]=mint_mul_4(m.value,pp.value,g,pp_len);
+	
+		wnp--;
+
+		if(sub_2(wnp, m.value, pp_len+1,wnp))
+		{
+			g--;
+
+			if(add_2(wnp, pp.value, pp_len, wnp))
+	
+				(*wp)++;
+		}
+
+		*tp = g;
+	}
+
+	mint_right_move(remainder,bit);	
+	mint_adjust_len(remainder,divisor->len);
+
+	mint_copy(quotient,&t);
+	mint_adjust_len(quotient,t.len);
+
+	return 1;
+
+}
