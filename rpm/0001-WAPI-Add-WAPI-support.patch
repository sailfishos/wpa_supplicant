+int 
+X509_Get_Cert_Info(unsigned char *incert , int len , 
+ 							certs_info *certinfo )
+{
+    unsigned char out [ CHAR_LENGTH ] = { 0 };
+	/* unsigned char out [ CHAR_LENGTH ] = { 0 }; */
+    X509_Cert ctx;
+    int ret = 0 , outlen = 0 , err = -1;
+    unsigned char tag [ 100 ] = { 0 };
+    struct tm *t1 , *t2;
+    char temp [ CHAR_LENGTH ] = { 0 };
+    time_t time1 , time2;
+	char t_year[5];
+	char b_year[5], b_mon[3], b_day[3];
+	
+    if (incert == NULL || certinfo == NULL)
+    {
+        return -1;
+    }
+
+    memset ( &ctx , 0 , sizeof(X509_Cert) );
+    ret = UnPack_X509 ( incert , len , &ctx );
+    if ( !ret )
+    {
+        return -1;
+    }
+	
+	/* Get serial number */
+	certinfo->serial_no = (cert_info *)malloc(sizeof(cert_info));
+	if (certinfo->serial_no == NULL)
+	{
+		wapi_printf(MSG_ERROR,  "in '%s': Failed to alloc memory "
+				"for cert_info.", __func__);
+		return -1;
+	}
+	certinfo->serial_no->data = malloc(ctx.Serialnumber.length);
+	if (certinfo->serial_no->data == NULL)
+	{
+		wapi_printf(MSG_ERROR,  "in '%s': Failed to alloc memory "
+				"for serial number.", __func__);
+		return -1;
+	}
+	memcpy(certinfo->serial_no->data, ctx.Serialnumber.data + 2, 
+			ctx.Serialnumber.length - 2);
+	certinfo->serial_no->length = ctx.Serialnumber.length - 2;
+    /* wapi_hexdump(MSG_DEBUG, "serial no :", out, outlen); */
+	
+    /* get issuer cn */
+    memset ( out , 0 , CHAR_LENGTH );
+    outlen = CHAR_LENGTH;
+    if (X509_Get_CN ( &ctx , ISSUER , out , &outlen ) != 0)
+	{
+		wapi_printf(MSG_ERROR,  "in '%s': Failed to get issuer cn",
+				__func__);
+		return -1;
+	}
+	certinfo->asu_name = (cert_info *) malloc ( sizeof(cert_info) );
+	certinfo->asu_name->data = (unsigned char *) malloc ( outlen );
+	memset ( certinfo->asu_name->data , 0 , outlen );
+    memcpy ( certinfo->asu_name->data , out , outlen );
+    certinfo->asu_name->length = outlen;
+    /* wapi_hexdump(MSG_DEBUG, "issuer cn :", out, outlen); */
+    
+	/* get subject cn */
+    memset ( out , 0 , CHAR_LENGTH );
+    outlen = CHAR_LENGTH;
+    if (X509_Get_CN ( &ctx , SUBJECT , out , &outlen ) != 0)
+	{
+		wapi_printf(MSG_ERROR,  "in '%s': Failed to get subject cn",
+				__func__);
+		return -1;
+	}
+    certinfo->asue_name = (cert_info *) malloc ( sizeof(cert_info) );
+	certinfo->asue_name->data = (unsigned char *) malloc ( outlen );
+	memset ( certinfo->asue_name->data , 0 , outlen );
+    memcpy ( certinfo->asue_name->data , out , outlen );
+    certinfo->asue_name->length = outlen;
+    /* wapi_hexdump(MSG_DEBUG, "subject cn :", out, outlen); */
+	
+    /* get before time */
+    memset ( out , 0 , CHAR_LENGTH );
+    outlen = CHAR_LENGTH;
+    GetBeforeTime_X509 ( &ctx , out , &outlen , tag );
+	/* wapi_hexdump(MSG_DEBUG, "BeforeTime :", out, outlen); */
+    memset ( temp , 0 , CHAR_LENGTH );
+
+	time1 = time(NULL);
+    t1 = localtime ( &time1 );
+	
+	memset(t_year, 0, 5);	
+	memset(b_year, 0, 5);
+	memset(b_mon, 0, 3);
+	memset(b_day, 0, 3);
+	
+	snprintf ( t_year , 5 , "%d" , 1900 + t1->tm_year);
+	memcpy(b_year ,t_year, 2);
+	memcpy(b_year + 2 , out, 2);
+	b_year[4] = '\0';
+	memcpy(b_mon, out + 2, 2);
+	b_mon[2] = '\0';
+	memcpy(b_day, out + 4, 2);
+	b_day[2] = '\0';	
+    snprintf ( temp , sizeof(temp) , "%s/%s/%s" , 
+			b_year, b_mon, b_day );
+	/* wapi_printf(MSG_DEBUG,  "in '%s', '%d' Before Time =%s ", 
+			__func__, __LINE__, temp); */
+	
+	outlen = strnlen(temp, sizeof(temp) - 1);
+	certinfo->date_before = (cert_info *)iwn_get_buffer(sizeof(cert_info));
+	certinfo->date_before->data = (unsigned char *)iwn_get_buffer(outlen);
+	memset(certinfo->date_before->data, 0, outlen);
+    memcpy(certinfo->date_before->data, temp, outlen);
+    certinfo->date_before->length = outlen;
+	
+    /* get after time */
+    memset ( out , 0 , CHAR_LENGTH );
+    outlen = CHAR_LENGTH;
+    GetAfterTime_X509 ( &ctx , out , &outlen , tag );
+	/* wapi_hexdump(MSG_DEBUG, "AfterTime :", out, outlen); */
+	
+    memset ( temp , 0 , CHAR_LENGTH );
+	
+    time2 = time(NULL);
+    t2 = localtime ( &time2 );
+	memset(t_year, 0, 5);	
+	memset(b_year, 0, 5);
+	memset(b_mon, 0, 3);
+	memset(b_day, 0, 3);
+	snprintf ( t_year , 5 , "%d" , 1900 + t2->tm_year);
+	memcpy(b_year , t_year, 2);
+	memcpy(b_year + 2 , out, 2);
+	b_year[4] = '\0';
+	memcpy(b_mon, out + 2, 2);
+	b_mon[2] = '\0';
+	memcpy(b_day, out + 4, 2);
+	b_day[2] = '\0';	
+    snprintf ( temp , sizeof(temp) , "%s/%s/%s" , 
+			b_year, b_mon, b_day );
+	/* wapi_printf(MSG_DEBUG,  "in '%s', '%d' After Time =%s ", 
+			__func__, __LINE__, temp); */
+
+	outlen = strnlen(temp, sizeof(temp)-1);
+	certinfo->date_after = (cert_info *)iwn_get_buffer(sizeof(cert_info));
+	certinfo->date_after->data = (unsigned char *)iwn_get_buffer(outlen);
+	memset(certinfo->date_after->data, 0, outlen);
+    memcpy(certinfo->date_after->data, temp, outlen);
+    certinfo->date_after->length = outlen;
+ 
+    char *au = "WAPI";
+	certinfo->issuer = (cert_info *) malloc ( sizeof(cert_info) );
+	certinfo->issuer->data = (unsigned char *) malloc ( strlen ( au ) );
+	memset ( certinfo->issuer->data , 0 , strlen ( au ) );
+    memcpy ( certinfo->issuer->data , au , strlen ( au ) );
+    certinfo->issuer->length = strlen ( au );
+
+    return 0;
+
+}
