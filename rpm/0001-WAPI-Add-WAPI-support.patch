+    if ( c == 11 )
+    {
+        /* wapi_printf ( MSG_INFO , "in %s:%d:user cert is p12\n" ,
+         __func__ , __LINE__ ); */
+        return 0;
+    } 
+	else
+    {
+        /* wapi_printf ( MSG_INFO , "in %s:%d:user cert not p12 \n" , 
+         __func__ , __LINE__ ); */
+        return -1;
+    }
+}
+
+int
+Check_Asue_Asu_Cert(unsigned char *user_cert, int user_cert_len,
+        unsigned char *pri_key, int pri_key_len,
+        unsigned char *as_cert , int as_cert_len )
+{
+    int unpackcert_len = 0;
+    int prikey_outlen = 0;
+    int asu_outlen = 0;
+
+    unsigned char *unpack_cert = malloc ( user_cert_len );
+    unsigned char *prikey_out = malloc ( pri_key_len );
+    unsigned char *asucert_out = malloc ( as_cert_len );
+    int ret;
+
+	memset(unpack_cert , 0 , user_cert_len);
+	memset(prikey_out , 0 , pri_key_len);
+	memset(asucert_out , 0 , as_cert_len);
+	
+    ret = Unpack_AsueCert ( user_cert , user_cert_len , unpack_cert ,
+            &unpackcert_len );
+    if ( ret != 0 )
+    {
+         wapi_printf ( MSG_ERROR ,
+         "in '%s':'%d' Unpack_AsueCert_And_Prikey failed\n" ,
+         __func__ , __LINE__ ); 
+        goto error;
+    }
+
+    ret = Unpack_AsuCert ( as_cert , as_cert_len , asucert_out , &asu_outlen );
+    if ( ret != 0 )
+    {
+         wapi_printf ( MSG_ERROR , "in '%s':'%d' Unpack_AsuCert failed\n" ,
+         __func__ , __LINE__ ); 
+        goto error;
+    }
+    /* wapi_hexdump(MSG_DEBUG, "Decode ca cert:", asucert_out, asu_outlen); */
+
+    if ( IWN_Check_UserCert_by_CACert ( unpack_cert , unpackcert_len ,
+            asucert_out , asu_outlen , ECC_P192 ) != 1 )
+    {
+         wapi_printf ( MSG_ERROR ,
+         "in '%s':'%d' Check_UserCert_by_CACert failed\n" , 
+         __func__ ,  __LINE__ ); 
+        goto error;
+    }
+
+	ret = Unpack_AsuePrikey ( pri_key , pri_key_len , prikey_out ,
+            &prikey_outlen );
+    if ( ret != 0 )
+    {
+         wapi_printf ( MSG_ERROR , "in '%s':'%d' Unpack_AsuePrikey failed\n" ,
+         __func__ , __LINE__ ); 
+        goto error;
+    }
+	
+    if ( IWN_Match_Pub_Pri_key ( unpack_cert , unpackcert_len , prikey_out ,
+            prikey_outlen , ECC_P192 ) != 1 )
+    {
+     
+         wapi_printf ( MSG_ERROR , "in '%s':'%d' Match_Pub_Pri_key failed\n" ,
+         __func__ , __LINE__ ); 
