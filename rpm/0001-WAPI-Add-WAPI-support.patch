+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <openssl/des.h>
+
+/* For disable warning */
+#define UNUSED(x) (void)x
+
+int p12_3des_cbc_encrypt(unsigned char *indata, int in_len,
+						 unsigned char *iv,int iv_len,
+						 unsigned char *key,int key_len,
+						 unsigned char *outdata, int *out_len)
+{
+	unsigned char *tmpdata = NULL;	
+	unsigned char buf[8] = {0};
+	int m = 0;
+	int n = 0;
+	int i = 0;
+	int d_len = 0,r_len = 0;
+	DES_cblock tmpk1;
+	DES_cblock tmpk2;
+	DES_cblock tmpk3;
+	DES_key_schedule k1;
+	DES_key_schedule k2;
+	DES_key_schedule k3;
+	DES_cblock tmpiv;
+
+	/* Disable warning */
+	UNUSED(iv_len);
+	UNUSED(key_len);
+
+	tmpdata = (unsigned char *)malloc(in_len + 8);
+	if(tmpdata == NULL){
+		return 0;
+	}
+	//changed from the tmpk1.bytes to the &tmpk1[0], the following are the same changes.
+    memcpy(&tmpk1[0], key, 8);
+    DES_set_key(&tmpk1, &k1);
+	memcpy(&tmpk2[0], key + 8, 8);
+    DES_set_key(&tmpk2, &k2);
+	memcpy(&tmpk3[0], key + 16, 8);
+    DES_set_key(&tmpk3, &k3);
+
+	m = 8;
+	d_len = in_len / 8;
+	r_len = in_len % 8;
+
+	if(r_len == 0)
+	{
+	    memset(buf, 0, 8);
+	}
+	else
+	{
+	    memcpy(buf, indata + (d_len * 8), r_len);
+	}
+
+	n = m - r_len;
+	for(i = r_len; i < m; i++)
+		buf[i] = n;
+
+	memcpy(tmpdata, indata, d_len * 8);
+	memcpy(tmpdata + (d_len * 8), buf, m);
+
+	memcpy(&tmpiv[0], iv, 8);
+    DES_ede3_cbc_encrypt(tmpdata, outdata, in_len+n, &k1, &k2, &k3, &tmpiv[0], DES_ENCRYPT);
+
+	*out_len = (in_len + n);
+	free(tmpdata);
+	tmpdata = NULL;
+    return 1;
+}
+
+int p12_3des_cbc_decrypt(unsigned char *indata, int in_len,
+						 unsigned char *iv,int iv_len,
+						 unsigned char *key,int key_len,
+						 unsigned char *outdata, int *out_len)
+{
+	unsigned char *tmpdata = NULL;	
+	unsigned char buf[8] = {0};
+	unsigned char buf_1[8] = {0};
+	unsigned int m = 0;
+	int n = 0;
+	int i = 0;
+
+	DES_cblock tmpk1;
+	DES_cblock tmpk2;
+	DES_cblock tmpk3;
+	DES_key_schedule k1;
+	DES_key_schedule k2;
+	DES_key_schedule k3;
+	DES_cblock tmpiv;
+
+	/* Disable warning */
+	UNUSED(iv_len);
+	UNUSED(key_len);
+	
+	tmpdata = (unsigned char *)malloc(in_len);
+	if(tmpdata == NULL){
+		return 0;
+	}
+	//changed from the tmpk1.bytes to the &tmpk1[0], the following are the same changes.
+	memcpy(&tmpk1[0], key, 8);
+    DES_set_key(&tmpk1, &k1);
+	memcpy(&tmpk2[0],key+8, 8);
+    DES_set_key(&tmpk2, &k2);
+	memcpy(&tmpk3[0], key+16, 8);
+    DES_set_key(&tmpk3, &k3);
+
+	memcpy(&tmpiv[0], iv, 8);
+    DES_ede3_cbc_encrypt(indata, tmpdata, in_len, &k1, &k2, &k3, &tmpiv, DES_DECRYPT);
+
+	m = 8;
+	*out_len = (in_len - m);
+
+	memcpy(outdata, tmpdata, *out_len);
+	memcpy(buf, tmpdata + (*out_len), 8);
+	n = buf[m - 1];
+	n = m - n;
+
+	for (i = 0; i < n; i++)
+		buf_1[i] = buf[i];
+
+	memcpy(outdata + (*out_len), buf_1, n);
+
+	*out_len = (*out_len + n);
+
+	free(tmpdata);
+	tmpdata = NULL;
+
+    return 1;
+}
+
