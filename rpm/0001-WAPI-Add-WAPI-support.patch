diff --git a/src/libecc/ecc.c b/src/libecc/ecc.c
new file mode 100644
index 0000000..77a089a
--- /dev/null
+++ b/src/libecc/ecc.c
@@ -0,0 +1,1010 @@
+/* 
+* Copyright (c) 2000-2012 China IWNCOMM Co., Ltd. All rights reserved.
+*
+* Module:        Elliptic Curve Cryptography Algorithm F(p)           
+* Description:   Elliptic curve cryptography algorithm implement,
+*				 The algorithm implement mainly includes Point doubling,
+*                Point addition and Point multiplication.
+* Writer:        zhangguoqiang@DST <zhanggq@iwncomm.com>;
+*                wanhongtao@DST <wanht@iwncomm.com>
+* Version:       $Id:ecc.c,v 1.0 2011/12/15 08:24:24 zhangguoqiang Exp $;
+*                $Id:ecc.c,v 1.1 2012/11/21 09:00:00 wanhongtao Exp $ 
+*
+* History: 
+* zhangguoqiang    2011/12/15    v1.0    Created.
+* wanhongtao       2012/11/21    v1.1    Modify.
+*/
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include "typedef.h"
+#include "mintex.h"
+#include "ecc.h"
+
+/*====================================================================*/
+#define ONE 1
+#define MINUS_ONE 3
+
+#define ECC_D_VAL			32
+#define ECC_E_VAL			(ECC_D_VAL/2)
+
+
+#define IWN_USE_ECC_GPT		/* ╣╠Č©ĄŃ│╦╩╣ė├įżį╦╦Ń▒ĒĖ±,ė├ė┌Ū·Ž▀╗ß╗░╣▓┤µ */
+
+/*====================================================================*/
+static int ecc_fq_minus(MINT *operand,MINT *prime,MINT *result);
+
+#ifdef IWN_USE_ECC_GPT
+static int ecc_get_dpt_1(ECC_FpPOINT *p,MINT *a,MINT *b,MINT *prime,ECC_FpPOINT g_GdPt_1[ECC_GDPT_LEN_1]);
+#endif
+/*====================================================================*/
+int mint_mod_left_move_1(MINT *c, MINT *a, MINT *p)
+{ 
+	mint_copy(c,a);
+	mint_left_move(c,1);
+
+	if (mint_compare(c,p) >= 0)
+		mint_sub(c,p,c);
+	return 1;
+}
+/*--------------------------------------------------------------------*/
+int mint_mod_left_move_n(MINT *c, MINT *a, MINT *p, int n)
+{
+	int bits;
+	if (c != a)
+	{
+		mint_copy(c,a);
+	}
+
+	while (n > 0)
+	{
+		
+		bits = get_mint_bit_len(p) - get_mint_bit_len(c);
+		
+		if (bits < 0)
+		{
+			return 0;
+		}
+
+		if (bits > n)
+			bits = n;
+
+		if (bits)
+		{
+			mint_left_move(c, bits);
+			n -= bits;
+		}
+		else
+		{         
+			mint_left_move(c, 1);
+			--n;
+		}
+
+		if (mint_compare(c, p) >= 0) 
+		{
+			mint_sub(c, p, c);
+		}
+	}
+	
+	return 1;
+}
+/*====================================================================*/
+static int ecc_fq_minus(MINT *operand,MINT *prime,MINT *result)
+{
+	if(MINT_ISZERO(operand))
+		mint_copy(result,operand);
+	else
+		mint_sub(prime,operand,result);
+	return 0;
+}
+/*--------------------------------------------------------------------*/
+#ifdef IWN_USE_ECC_GPT
+static int ecc_get_dpt_1(ECC_FpPOINT *p,MINT *a,MINT *b,MINT *prime,ECC_FpPOINT g_GdPt_1[ECC_GDPT_LEN_1])
+{
+
+	int i,j=0;
+	int w=0;
+	int tlen=0;
+	ECC_FpPOINT pt;
+
+	memset(&pt,0,sizeof(ECC_FpPOINT));
+
+	g_GdPt_1[0].is_infinite = p->is_infinite;
+	mint_copy(&(g_GdPt_1[0].x),&(p->x));
+	mint_copy(&(g_GdPt_1[0].y),&(p->y));
+
+	tlen=1<<(prime->len);
+	w = prime->len;
+	
+	for (i=0;i<(w-1);i++)
+	{
+		ecc_point_add(&(g_GdPt_1[i]),&(g_GdPt_1[i]),a,b,prime,&pt);//2
+		for(j=0;j<ECC_D_VAL-2;j++)
+		{
+			ecc_point_add(&pt,&pt,a,b,prime,&pt);//4
+		}
+		ecc_point_add(&pt,&pt,a,b,prime,&(g_GdPt_1[i+1]));//32
+	}
+
+	for (i=(w-1);i<w*2;i++)
+	{
+		ecc_point_add(&(g_GdPt_1[i-(w-1)]),&(g_GdPt_1[i-(w-1)]),a,b,prime,&pt);//2
+		for(j=0;j<ECC_E_VAL-2;j++)
+		{
+			ecc_point_add(&pt,&pt,a,b,prime,&pt);//4
+		}
+		ecc_point_add(&pt,&pt,a,b,prime,&(g_GdPt_1[i+1]));//16
+	}
+	return 0;
+}
+#endif
+/*--------------------------------------------------------------------*/
+int ecc_affine_jacobin(ECC_JacPOINT *dest,ECC_FpPOINT *src)
+{
+	if(src->is_infinite==1)
+	{
+		MI_DWORDTOMINT(&(dest->x),1);
+		MI_DWORDTOMINT(&(dest->y),1);
+		MI_DWORDTOMINT(&(dest->z),0);
+	}
+	else
+	{
+		mint_copy(&(dest->x),&(src->x));
+		mint_copy(&(dest->y),&(src->y));
+		MI_DWORDTOMINT(&(dest->z),1);
+	}
+	return 0;
+}
+/*--------------------------------------------------------------------*/
+int ecc_jacobin_affine(ECC_FpPOINT *dest,MINT *prime,ECC_JacPOINT *src)
+{
+	MINT r,t,r1;
+	MINT t1;
+
+	memset(&r,0,sizeof(MINT));
+	memset(&t,0,sizeof(MINT));
+	memset(&r1,0,sizeof(MINT));
+
+	memset(&t1,0,sizeof(MINT));
+
+	if (MINT_ISZERO(&(src->z)))
+	{
+		dest->is_infinite=1;
+		dest->x.len = 0;
+		dest->y.len = 0;
+	}
+	else
+	{
+		dest->is_infinite = 0;
+		mint_copy(&t1,&(src->z));
+
+		mint_EEA_algo(&t1,prime,&r);
+
+		mint_mod_mul(&r,&r,prime,&t);
+		mint_mod_mul(&(src->x),&t,prime,&(dest->x));
+		mint_mod_mul(&r,&t,prime,&t);
+		mint_mod_mul(&(src->y),&t,prime,&(dest->y));
+	}
+	return 0;
+}
+/*--------------------------------------------------------------------*/
+int ecc_jac_point_add(ECC_JacPOINT *addend1,ECC_FpPOINT *addend2,MINT *a,MINT *b,MINT *prime,ECC_JacPOINT *result)
+{
+	MINT t1,t2,t3,t4;
+	MINT x1,y1,z1;
+	MINT x2,y2,z2;
+	MINT x3,y3,z3;
+	ECC_JacPOINT tmp;
+
+	memset(&tmp,0,sizeof(ECC_JacPOINT));
+
+	memset(&t1,0,sizeof(MINT));
+	memset(&t2,0,sizeof(MINT));
+	memset(&t3,0,sizeof(MINT));
+	memset(&t4,0,sizeof(MINT));
+
+	memset(&x1,0,sizeof(MINT));
+	memset(&y1,0,sizeof(MINT));
+	memset(&z1,0,sizeof(MINT));
+
+	memset(&x2,0,sizeof(MINT));
+	memset(&y2,0,sizeof(MINT));
+	memset(&z2,0,sizeof(MINT));
+
+	memset(&x3,0,sizeof(MINT));
+	memset(&y3,0,sizeof(MINT));
+	memset(&z3,0,sizeof(MINT));
+
+	mint_copy(&x1,&(addend1->x));
+	mint_copy(&y1,&(addend1->y));
+	mint_copy(&z1,&(addend1->z));
+
+	mint_copy(&x2,&(addend2->x));
+	mint_copy(&y2,&(addend2->y));
+
+	if (addend2->is_infinite==1)
+	{
+		mint_copy(&(result->x),&x1);
+		mint_copy(&(result->y),&y1);
+		mint_copy(&(result->z),&z1);
+		return 0; 
+	}
+	else if (MINT_ISZERO(&z1))
+	{
+		mint_copy(&(result->x),&x2);
+		mint_copy(&(result->y),&y2);
+		MI_DWORDTOMINT(&(result->z),1);
+	}
+	else
+	{
+		mint_mod_mul(&z1,&z1,prime,&t1);//A=Z1^2
+		mint_mod_mul(&t1,&z1,prime,&t2);//B=Z1*A
+		mint_mod_mul(&t1,&x2,prime,&t1);//C=X2*A
+		mint_mod_mul(&t2,&y2,prime,&t2);//D=Y2*B
+		mint_mod_sub(&t1,&x1,prime,&t1);//E=C-X1
+		mint_mod_sub(&t2,&y1,prime,&t2);//F=D-Y1
+		if(MINT_ISZERO(&t1))
+		{
+			if(MINT_ISZERO(&t2))
+			{
+				mint_copy(&(tmp.x),&x2);
+				mint_copy(&(tmp.y),&y2);
+				MI_DWORDTOMINT(&(tmp.z),1);
+				ecc_jac_point_double(&tmp,a,b,prime,result);
+				return 0;
+			}
+			else
+			{
+				MI_DWORDTOMINT(&(result->x),1);
+				MI_DWORDTOMINT(&(result->y),1);
+				MI_DWORDTOMINT(&(result->z),0);
+				return 0; 
+			}
+		}
+		mint_mod_mul(&z1,&t1,prime,&z3);//Z3=Z1*E
+		mint_mod_mul(&t1,&t1,prime,&t3);//G=E^2
+		mint_mod_mul(&t3,&t1,prime,&t4);//H=G*E
+		mint_mod_mul(&t3,&x1,prime,&t3);//I=X1*G
+        mint_mod_left_move_1(&t1, &t3, prime);//2I
+
+		mint_mod_mul(&t2,&t2,prime,&x3);//F^2
+		mint_mod_sub(&x3,&t1,prime,&x3);//F^2-2I
+		mint_mod_sub(&x3,&t4,prime,&x3);//X3=F^2-(H+2I)=F^2-2I-H
+		mint_mod_sub(&t3,&x3,prime,&t3);//I-X3
+		mint_mod_mul(&t3,&t2,prime,&t3);//F*(I-X3)
+		mint_mod_mul(&t4,&y1,prime,&t4);//Y1*H
+		mint_mod_sub(&t3,&t4,prime,&y3);//Y3=F*(I-X3)-Y1*H
+
+		mint_copy(&(result->x),&x3);
+		mint_copy(&(result->y),&y3);
+		mint_copy(&(result->z),&z3);
+	}
+	return 0;
+}
+/*====================================================================*/
+#ifdef IWN_USE_ECC_GPT
+int ecc_precomputation_point(ECC_FpPOINT *p,MINT *a,MINT *b,MINT *prime,ECC_FpPOINT g_GPt_1[ECC_GPT_LEN_1])
+{
+	ECC_FpPOINT g_GdPt_1[ECC_GDPT_LEN_1];
+	int i,j=0,k;
+	int w=0;
+	int tlen = 0;
+	ECC_FpPOINT pt;
+
+	memset(g_GdPt_1,0,sizeof(ECC_FpPOINT));
+	memset(&pt,0,sizeof(ECC_FpPOINT));
+	ecc_get_dpt_1(p,a,b,prime,g_GdPt_1);
+
+	tlen=1<<(prime->len);
+	w = prime->len;
+
+	g_GPt_1[0].is_infinite = g_GdPt_1[0].is_infinite;
+	mint_copy(&(g_GPt_1[0].x),&(g_GdPt_1[0].x));
+	mint_copy(&(g_GPt_1[0].y),&(g_GdPt_1[0].y));
+	
+	for(i=1;i<=(tlen-1);i++)
+	{
+		memset(&g_GPt_1[i],0,sizeof(ECC_FpPOINT));
+		g_GPt_1[i].is_infinite = 1;
+		for(j=0;j<w;j++)
+		{
+			if(((i>>j)&1)==1)
+			{
+				ecc_point_add(&g_GPt_1[i],&g_GdPt_1[j],a,b,prime,&g_GPt_1[i]);
+			}
+		}
+	}
+	memset(&g_GPt_1[i],0,sizeof(ECC_FpPOINT));
+	k=tlen;
+	//n = w;
+	for(i=1;i<=tlen;i++)
+	{
+		memset(&g_GPt_1[i+k],0,sizeof(ECC_FpPOINT));
+		g_GPt_1[i+k].is_infinite = 1;
+		for(j=0;j<w;j++)
+		{
+			if(((i>>j)&1)==1)
+			{
+				ecc_point_add(&g_GPt_1[i+k],&g_GdPt_1[w+j],a,b,prime,&g_GPt_1[i+k]);
+			}
+		}
+	}
+	memset(&g_GPt_1[tlen],0,sizeof(ECC_FpPOINT));
+	return 0;
+}
+#else
+int ecc_precomputation_point(ECC_FpPOINT *p,MINT *a,MINT *b,MINT *prime,ECC_FpPOINT g_GPt_1[ECC_GPT_LEN_1])
+{
+	return 0;
+}
+#endif
+/*--------------------------------------------------------------------*/
+int ecc_point_add(ECC_FpPOINT *addend1,ECC_FpPOINT *addend2,MINT *a,MINT *b,MINT *prime,ECC_FpPOINT *sum)
+{
+	MINT r,s,t;
+	MINT x,y;
+
+	/* Disable warning */
+	UNUSED(b);
+	
+	memset(&r,0,sizeof(MINT));
+	memset(&s,0,sizeof(MINT));
+	memset(&t,0,sizeof(MINT));
+	memset(&x,0,sizeof(MINT));
+	memset(&y,0,sizeof(MINT));
+
+	if (addend1->is_infinite==1 && addend2->is_infinite==1)
+	{
+		sum->is_infinite=1;
+		sum->x.len = 0;
+		sum->y.len = 0;
+		return 0;
+	}
+	else if (addend1->is_infinite == 1)
+	{
+		sum->is_infinite = addend2->is_infinite;
+		mint_copy(&(sum->x),&(addend2->x));
+		mint_copy(&(sum->y),&(addend2->y));
+		return 0;
+	}
+	else if (addend2->is_infinite == 1)
+	{
+		sum->is_infinite = addend1->is_infinite;
+		mint_copy(&(sum->x),&(addend1->x));
+		mint_copy(&(sum->y),&(addend1->y));
+		return 0;
+	}
+	else if (mint_compare(&(addend1->x),&(addend2->x))==0 && mint_compare(&(addend1->y),&(addend2->y))==0)
+	{
+		//form doc
+		mint_mod_sub(prime,&(addend2->y),prime,&r);
+		if(mint_compare(&(addend1->y),&r)==0)
+		{
+			sum->is_infinite=1; 
+			sum->x.len = 0;
+			sum->y.len = 0;
+			return 0;
+		}
+		mint_mod_mul(&(addend1->x),&(addend1->x),prime, &r);	//r=(x1^2)
+		mint_mod_left_move_1(&t, &r, prime);                    //t=(2*x1^2)
+
+		mint_mod_add(&r, &t, prime, &s);	                    //s=(3*x1^2)
+		mint_mod_add(&s, a, prime, &r);		                    //r=(3*x1^2+a)
+		mint_mod_left_move_1(&t, &(addend1->y), prime);         //t=(2*y1)	
+
+		mint_EEA_algo(&t, prime, &s);		                    //s=(1/2*y1)
+
+		mint_mod_mul(&s, &r, prime, &t);	                    //t=((3*x1^2+a)/2*y1)
+		mint_mod_mul(&t,&t,prime, &r);		                    //r=((3*x1^2+a)/2*y1)^2
+		mint_mod_sub(&r, &(addend1->x), prime, &s);		        //((3*x1^2+a)/2*y1)^2-x1
+		mint_mod_sub(&s, &(addend1->x), prime, &x);	            //x3=((3*x1^2+a)/2*y1)^2-2x1
+		mint_mod_sub(&(addend1->x), &x, prime, &s);	            //s=x1-x3
+		mint_copy(&(sum->x),&r);		
+		mint_mod_mul(&t, &s, prime, &r);	                    //((3*x1^2+a)/2*y1)*(x1-x3)
+		mint_mod_sub(&r, &(addend1->y), prime, &y);	            //y3=((3*x1^2+a)/2*y1)*(x1-x3)-y1
+		
+		if(MINT_ISZERO(&x) && MINT_ISZERO(&y))
+		{
+			sum->is_infinite=1; 
+			sum->x.len = 0;
+			sum->y.len = 0;
+		}
+		else
+		{
+			sum->is_infinite=0; 
+			mint_copy(&(sum->x),&x);
+			mint_copy(&(sum->y),&y);
+		}
+		return 0;
+	}
+	else
+	{
+		mint_mod_sub(&(addend2->y), &(addend1->y), prime, &s);	//s=(y2-y1)
+		mint_mod_sub(&(addend2->x), &(addend1->x), prime, &t);	//t=(x2-x1)
+
+		mint_EEA_algo(&t, prime, &r);                         //r=(1/(x2-x1))
+
+		mint_mod_mul(&s, &r, prime, &t);						//t=((y2-y1)/(x2-x1))
+		mint_mod_mul(&t, &t,prime, &r);							//r=((y2-y1)/(x2-x1))^2
+		mint_mod_sub(&r, &(addend1->x), prime, &s);				//s=((y2-y1)/(x2-x1))^2-x1
+		mint_mod_sub(&s, &(addend2->x), prime, &x);				//x3=((y2-y1)/(x2-x1))^2-x1-x2
+		mint_mod_sub(&(addend1->x), &x, prime, &s);				//s=(x1-x3)
+		mint_mod_mul(&t, &s, prime, &r);						//r=((y2-y1)/(x2-x1))*(x1-x3)
+		mint_mod_sub(&r, &(addend1->y), prime, &y);				//y3=((y2-y1)/(x2-x1))*(x1-x3)-y1
+
+		if(MINT_ISZERO(&x) && MINT_ISZERO(&y))
+		{
+			sum->is_infinite=1; 
+			sum->x.len = 0;
+			sum->y.len = 0;
+		}
+		else
+		{
+			sum->is_infinite=0; 
+			mint_copy(&(sum->x),&x);
+			mint_copy(&(sum->y),&y);
+		}
+	}
+	return 0;
+}
+/*--------------------------------------------------------------------*/
+int ecc_point_double(ECC_FpPOINT *operand,MINT *a,MINT *b,MINT *prime,ECC_FpPOINT *result)
+{	
+	return ecc_point_add(operand,operand,a,b,prime,result);
+}
+/*--------------------------------------------------------------------*/
+//fix point mul
+#ifdef IWN_USE_ECC_GPT
+int ecc_fix_point_mul(MINT *k,ECC_FpPOINT *x,MINT *a,MINT *b,MINT *prime,ECC_FpPOINT *y,ECC_FpPOINT g_GPt_1[ECC_GPT_LEN_1])
+{
+	int i,j,m;
+	int e;
+	int length;
+	dword t,t2,ki,ki2;
+	ECC_FpPOINT pta,ptb;
+
+	ECC_JacPOINT pt1,pt2,qt;
+
+	/* Disable warning */
+	UNUSED(x);
+	
+	memset(&pt1,0,sizeof(ECC_JacPOINT));
+	memset(&pt2,0,sizeof(ECC_JacPOINT));
+	memset(&qt,0,sizeof(ECC_JacPOINT));
+	memset(&pta,0,sizeof(ECC_FpPOINT));
+	memset(&ptb,0,sizeof(ECC_FpPOINT));
+
+	pta.is_infinite = 1;
+	pta.x.len = 0;
+	pta.y.len = 0;
+
+	ptb.is_infinite = 1;
+	ptb.x.len = 0;
+	ptb.y.len = 0;
+
+	length=1<<(prime->len);
+	
+	if (MINT_ISZERO(k))
+	{
+		y->is_infinite = 1;
+		y->x.len = 0;
+		y->y.len = 0;
+	}
+	else
+	{
+		//from guidetoecc.pdf
+		MI_DWORDTOMINT(&(qt.x),1);
+		MI_DWORDTOMINT(&(qt.y),1);
+		MI_DWORDTOMINT(&(qt.z),0);
+
+		e=16;
+		for(i=e;i>0;i--)
+		{
+			ecc_jac_point_double(&qt,a,b,prime,&qt);
+			t=0;t2=0;
+			for(j=0;j<k->len;j++)
+			{
+				ki=k->value[j]<<(32-i);
+				ki=ki>>31;
+				ki2=k->value[j]<<(32-(e+i));
+				ki2=ki2>>31;
+				for(m=0;m<j;m++){ ki=ki*2;	ki2=ki2*2;}
+				t+=ki;
+				t2+=ki2;
+			}
+			if(t!=0)
+				ecc_jac_point_add(&qt, g_GPt_1+t,a,b,prime, &qt);
+			if(t2!=0)
+				ecc_jac_point_add(&qt, g_GPt_1+length+t2,a,b, prime, &qt);
+		}
+		ecc_jacobin_affine(y,prime,&qt);
+	}
+	return 0;
+}
+#else
+int ecc_fix_point_mul(MINT *k,ECC_FpPOINT *x,MINT *a,MINT *b,MINT *prime,ECC_FpPOINT *y,ECC_FpPOINT g_GPt_1[ECC_GPT_LEN_1])
+{
+	return ecc_unknown_point_mul(k,x,a,b,prime,y);
+}
+#endif
+/*====================================================================*/
+static signed char *ecc_mint_w_naf(MINT *k, int width, int *length)
+{
+	int value,i;
+	signed char *ki = NULL;
+	int a, b, c;
+	int bit_len = 0;
+	int bit;
+	
+	if (width <= 0 || width > 7) 
+	    return NULL;
+		
+	a = 1 << width; 
+	b = a << 1; 
+	c = b - 1;
+
+	if (MINT_ISZERO(k))
+	{
+		ki = malloc(1);
+		if(ki == NULL)
+        {
+		    return NULL;
+	    }
+			
+		ki[0] = 0;
+		*length = 1;
+		return ki;
+	}
+		
+	bit_len = get_mint_bit_len(k);
+	ki = malloc(bit_len + 1); 	                          
+	if(ki == NULL)
+    {
+	    return NULL;
+    }
+	memset(ki,0,bit_len+1);
+	/* if (k->value == NULL || k->len == 0) */
+	if (k->len == 0)
+	{
+		free(ki);
+		ki = NULL;
+		return NULL;
+	}
+	value = k->value[0] & c;
+	i = 0;
+	while ((value != 0) || (i + width + 1 < bit_len)) 
+	{
+        bit = 0;
+		if (value & 1)
+		{
+		
+			if (value & a)
+			{
+				bit = value - b; 
+
+				if (i + width + 1 >= bit_len)
+				{		
+					bit = value & (c >> 1); 
+				}
+
+			}
+			else
+			{
+				bit = value;
+			}
+			
+			if (bit <= -a || bit >= a || !(bit & 1))
+			{
+				free(ki);
+				ki = NULL;
+				return NULL;
+	        }
+				
+			value -= bit;	
+			if (value != 0 && value != b && value != a)
+			{
+				free(ki);
+				ki = NULL;
+				return NULL;
+	        }			
+		}
+
+		ki[i++] = bit;
+
+		value >>= 1;
+		value += a * mint_bit_set(k, i + width);
+
+		if (value > b)  
+		{
+			free(ki);
+			ki = NULL;
+			return NULL;
+		}		
+	}
+
+	if (i > bit_len + 1)  
+	{
+		free(ki);
+		ki = NULL;
+		return NULL;
+	}
+
+	bit_len = i;
+	*length = bit_len;
+	return ki;
+}
+/*--------------------------------------------------------------------*/
+int ecc_infinite_point(ECC_JacPOINT *x)
+{
+	MI_DWORDTOMINT(&(x->z),0);
+	return 1;
+}
+/*--------------------------------------------------------------------*/
+int  ecc_invert_point(MINT *prime, ECC_JacPOINT *x)
+{
+    if (MINT_ISZERO(&(x->z))|| MINT_ISZERO(&(x->y)))		
+		return 1;
+	return mint_sub(prime, &(x->y), &(x->y));
+}
+/*--------------------------------------------------------------------*/
+int ecc_copy_point(ECC_JacPOINT *y, ECC_JacPOINT *x)
+{
+	mint_copy(&(y->x), &(x->x));
+	mint_copy(&(y->y), &(x->y));
+	mint_copy(&(y->z), &(x->z));
+	return 1;
+}
+/*--------------------------------------------------------------------*/
+int ecc_jac_point_double(ECC_JacPOINT *operand,MINT *a,MINT *b,MINT *prime,ECC_JacPOINT *result)
+{
+	MINT r1, r2, r3, r4;
+
+	/* Disable warning */
+	UNUSED(b);
+	
+	memset(&r1,0,sizeof(MINT));
+	memset(&r2,0,sizeof(MINT));
+	memset(&r3,0,sizeof(MINT));
+	memset(&r4,0,sizeof(MINT));
+
+	if (MINT_ISZERO(&(operand->z)))
+	{
+		MI_DWORDTOMINT(&result->z,0);
+	}
+	
+	if(operand->z.len==1 && operand->z.value[0]==1)
+	{
+		mint_mod_mul(&operand->x,&operand->x,prime,&r1);
+        mint_mod_left_move_1(&r2, &r1, prime);
+		mint_mod_add(&r1,&r2,prime,&r1);
+		mint_mod_add(&r1,a,prime,&r2);
+	}
+	else
+	{
+        mint_mod_mul(&operand->x,&operand->x,prime,&r1);
+        mint_mod_left_move_1(&r2, &r1, prime);
+		mint_mod_add(&r1,&r2,prime,&r1);
+		
+        mint_mod_mul(&operand->z,&operand->z,prime,&r2);
+
+		mint_mod_mul(&r2,&r2,prime,&r2);
+
+		mint_mod_mul(&r2,a,prime,&r2);
+		mint_mod_add(&r2,&r1,prime,&r2);	
+
+	}
+		
+	if(operand->z.len==1 && operand->z.value[0]==1)
+	{
+		mint_copy(&r1,&operand->y);
+	}
+	else
+	{
+		mint_mod_mul(&operand->y,&operand->z,prime,&r1);
+	}
+
+	mint_mod_left_move_1(&result->z, &r1, prime);
+
+	mint_mod_mul(&operand->y,&operand->y,prime,&r4);
+	mint_mod_mul(&operand->x,&r4,prime,&r3);
+    mint_mod_left_move_n(&r3, &r3, prime, 2);
+
+    mint_mod_left_move_1(&r1, &r3, prime);
+	mint_mod_mul(&r2,&r2,prime,&result->x);
+	mint_mod_sub(&result->x,&r1,prime,&result->x);
+
+	mint_mod_mul(&r4,&r4,prime,&r1);
+	mint_mod_left_move_n(&r4, &r1, prime, 3);
+
+	mint_mod_sub(&r3,&result->x,prime,&r1);
+	mint_mod_mul(&r2,&r1,prime,&r1);
+	mint_mod_sub(&r1,&r4,prime,&result->y);
+
+	return 1;
+}
+/*--------------------------------------------------------------------*/
+int ecc_jac_point_add_1(ECC_JacPOINT *addend1,ECC_JacPOINT *addend2,MINT *a,MINT *b,MINT *prime,ECC_JacPOINT *result)
+{   
+	int result2 = 0;
+	MINT r1, r2, r3, r4, r5, r6, r7;
+	
+	if (addend1 == addend2)
+        return ecc_jac_point_double(addend1, a, b, prime, result);
+
+    if (MINT_ISZERO(&(addend1->z)))
+		return ecc_copy_point(result, addend2);       
+
+	if (MINT_ISZERO(&(addend2->z)))
+		return ecc_copy_point(result, addend1);
+		
+	memset(&r1,0,sizeof(MINT));
+	memset(&r2,0,sizeof(MINT));
+	memset(&r3,0,sizeof(MINT));
+	memset(&r4,0,sizeof(MINT));
+	memset(&r5,0,sizeof(MINT));
+	memset(&r6,0,sizeof(MINT));
+	memset(&r7,0,sizeof(MINT));
+
+	if(addend1->z.len==1 && addend1->z.value[0]==1)
+	{
+		mint_copy(&r4, &addend2->x);
+		mint_copy(&r5, &addend2->y);
+	}
+	else
+	{
+        mint_mod_mul(&addend1->z,&addend1->z,prime,&r1);
+		mint_mod_mul(&addend2->x,&r1,prime,&r4);
+		      
+		mint_mod_mul(&r1,&addend1->z,prime,&r1);
+		mint_mod_mul(&addend2->y,&r1,prime,&r5);		
+	}
+
+
+	if(addend2->z.len==1 && addend2->z.value[0]==1)
+	{
+		mint_copy(&r2, &addend1->x);
+		mint_copy(&r3, &addend1->y);
+	}
+	else
+	{
+		mint_mod_mul(&addend2->z,&addend2->z,prime,&r1);
+		mint_mod_mul(&addend1->x,&r1,prime,&r2);
+		
+		mint_mod_mul(&r1,&addend2->z,prime,&r1);
+		mint_mod_mul(&addend1->y,&r1,prime,&r3);
+		
+	}
+	
+	mint_mod_sub(&r2,&r4,prime,&r6);
+	mint_mod_sub(&r3,&r5,prime,&r7);
+
+
+	if (MINT_ISZERO(&r6))
+	{
+		if (MINT_ISZERO(&r7))
+		{
+			result2 = ecc_jac_point_double(addend1,a,b,prime,result);
+		}
+		else
+		{		
+            MI_DWORDTOMINT(&result->z,0);
+			result2 = 1;
+		}
+	}
+    mint_mod_add(&r2,&r4,prime,&r2);
+	mint_mod_add(&r3,&r5,prime,&r3);   
+	
+	if((addend1->z.len==1 && addend1->z.value[0]==1) && (addend2->z.len==1 && addend2->z.value[0]==1))
+	{
+		mint_copy(&result->z, &r6); 
+	}
+	else
+	{
+
+		if(addend1->z.len==1 && addend1->z.value[0]==1)
+		{ 
+			mint_copy(&r1, &addend2->z);
+		}
+
+		else if(addend2->z.len==1 && addend2->z.value[0]==1)
+		{ 
+			mint_copy(&r1, &addend1->z);
+		}
+		else
+		{ 
+			mint_mod_mul(&addend1->z, &addend2->z,prime,&r1);
+		}	
+
+		mint_mod_mul(&r1, &r6,prime,&result->z);
+	}
+
+    mint_mod_mul(&r7, &r7,prime,&r1);
+	mint_mod_mul(&r6, &r6,prime,&r5);
+	mint_mod_mul(&r2, &r5,prime,&r4);
+	mint_mod_sub(&r1, &r4,prime,&result->x);
+	
+	mint_mod_left_move_1(&r1, &result->x, prime);
+	mint_mod_sub(&r4, &r1, prime,&r1);
+	
+	mint_mod_mul(&r1, &r7,prime,&r1);
+	mint_mod_mul(&r5, &r6,prime,&r6);
+    mint_mod_mul(&r3, &r6,prime,&r2);
+	mint_mod_sub(&r1, &r2,prime,&r1);
+
+	if (mint_is_odd(&r1))
+		mint_add(&r1,prime,&r1);
+	
+	mint_copy(&result->y,&r1);
+	mint_right_move(&result->y,1);
+	
+	result2 = 1;
+	return result2;
+}
+/*--------------------------------------------------------------------*/
+//unknown point mul
+int ecc_unknown_point_mul(MINT *k,ECC_FpPOINT *x,MINT *a,MINT *b,MINT *prime,ECC_FpPOINT *y)
+{
+
+
+	int i,n,width;		
+	int w_naf_length=0;
+	int infinite_point = 1;
+	int invert_point = 0;      
+    int length = 0;
+	int bit,ki,neg;
+	signed char *w_naf = NULL;
+
+	ECC_JacPOINT pi;   	
+	ECC_JacPOINT x1;
+
+	ECC_JacPOINT x2;
+	ECC_JacPOINT val[4];
+
+	memset(&pi,0,sizeof(ECC_JacPOINT));
+	memset(&x1,0,sizeof(ECC_JacPOINT));
+	memset(&x2,0,sizeof(ECC_JacPOINT));
+
+	memset(val,0,sizeof(ECC_JacPOINT));
+		
+	if (MINT_ISZERO(k)||x->is_infinite==1)
+	{
+		y->is_infinite = 1;
+		y->x.len = 0;
+		y->y.len = 0;
+	}
+
+    bit = get_mint_bit_len(k);
+	width = window_size(bit);
+	
+	w_naf = ecc_mint_w_naf(k, width, &w_naf_length);
+	if (w_naf == NULL) 
+		return -1;
+	length = w_naf_length;
+ 
+	ecc_affine_jacobin(&x1,x);
+	ecc_copy_point(&(val[0]),&x1);
+
+	ecc_jac_point_double(&(val[0]), a, b, prime, &pi);
+
+    for (i = 1; i < ((1<<(width-1))); i++)
+	{
+    	ecc_jac_point_add_1(&(val[i-1]), &pi, a, b, prime, &(val[i]));
+	}
+	
+	infinite_point = 1;
+
+	for (n = length - 1; n >= 0; n--)
+	{
+		if (!infinite_point)
+		{
+			ecc_jac_point_double(&x1, a, b, prime,&x1);
+		}
+		
+		if (w_naf_length > n)
+		{
+
+			ki = w_naf[n];
+
+			if (ki) 
+			{
+				neg = ki < 0;
+
+				if (neg)
+					ki = -ki;
+
+				if (neg != invert_point)
+				{
+					if (!infinite_point)
+					{
+						 ecc_invert_point(prime,&x1);
+					}
+					invert_point = !invert_point;
+				}
+
+				// ki > 0 
+
+				if (infinite_point)
+				{
+					ecc_copy_point(&x1, &val[ki >> 1]);
+					infinite_point = 0;
+				}
+				else
+				{
+					ecc_jac_point_add_1(&val[ki >> 1], &x1, a, b, prime, &x1);	
+				}
+			}
+		}
+
+	}
+	
+	if (infinite_point)
+	{
+		 ecc_infinite_point(&x1);
+	}
+	else
+	{
+		if (invert_point)
+		ecc_invert_point(prime,&x1);
+	}
+
+    ecc_jacobin_affine(y,prime,&x1);
+
+	if (w_naf != NULL)
+	{
+		free(w_naf);
+		w_naf = NULL;
+	}
+
+	return 1;
+}
+/*--------------------------------------------------------------------*/
+//▓Ō╩įĄŃ╩ŪĘ±į┌═ųį▓Ū·Ž▀╔Ž
+int ecc_test_point(ECC_FpPOINT *x,MINT *a,MINT *b,MINT *prime)
+{
+	MINT u,v,t;
+	memset(&u,0,sizeof(MINT));
+	memset(&v,0,sizeof(MINT));
+	memset(&t,0,sizeof(MINT));
+
+	mint_mod_mul(&(x->y),&(x->y),prime,&u);
+	mint_mod_mul(&(x->x),&(x->x),prime,&t);
+	mint_mod_mul(&t,&(x->x),prime,&v);
+	mint_mod_mul(a,&(x->x),prime,&t);
+	mint_mod_add(&v,&t,prime,&v);
+	mint_mod_add(&v,b,prime,&v);
+	if(mint_compare(&u,&v)==0)
+		return 0;
+	return 1;
+}
+/*====================================================================*/
+int ecc_point_unpress(MINT *y,MINT *x,MINT *a,MINT *b,MINT *prime,unsigned int yp)
+{
+	MINT u,v,t;
+	unsigned int yq;
+	memset(&u,0,sizeof(MINT));
+	memset(&v,0,sizeof(MINT));
+	memset(&t,0,sizeof(MINT));
+
+	mint_mod_mul(x,x,prime,&t);
+	mint_mod_mul(&t,x,prime,&v);
+	mint_mod_mul(a,x,prime,&t);
+	mint_mod_add(&v,&t,prime,&v);
+	mint_mod_add(&v,b,prime,&v);
+	mint_mod(&v,prime,&v);
+	if(mint_sqrt(&v,prime,&u)!=1)
+	{
+		return -1;
+	}
+	yq = u.value[0];
+	if((yq&ONE_DWORD_VALUE)==yp)
+	{
+		mint_copy(y,&u);
+	}
+	else
+	{
+		mint_sub(prime,&u,y);
+	}
+	return 0;
+}
