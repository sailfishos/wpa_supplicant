+	{
+			mint_mod(&u3,&v3,&t2);
+			mint_copy(&u3,&t2);	
+	}
+	ulsign = -1;
+	
+	if (mint_is_odd(p) && (get_mint_bit_len(p) <= (MINT_BIT2 <= 32 ? 450 : 2048)))
+	{	
+		while (!MINT_ISZERO(&u3))
+		{		
+			m = 0;
+			while (!mint_bit_set(&u3, m)) 
+			{
+				m++;
+				
+				if (mint_is_odd(&u1))
+				{
+					mint_add(&u1,p,&u1);	
+				}
+				mint_right_move(&u1,1);	
+			}
+
+			if (m > 0)
+			{
+				mint_right_move(&u3,m);	
+			}
+			
+			m = 0;
+			while (!mint_bit_set(&v3, m))
+			{
+				m++;
+				
+				if (mint_is_odd(&v1))
+				{
+					mint_add(&v1,p,&v1);
+				}			
+                mint_right_move(&v1,1);
+			}
+			
+			if (m > 0)
+			{
+				mint_right_move(&v3,m);
+			}
+
+			if(mint_compare(&u3,&v3) >=0)
+			{
+			
+				mint_add(&u1,&v1,&u1);
+				mint_sub(&u3,&v3,&u3);
+			}
+			else
+			{			
+				mint_add(&v1,&u1,&v1);
+				mint_sub(&v3,&u3,&v3);
+			}
+		}
+
+	}
+	else
+	{
+		
+		while (u3.len != 0 && !MINT_ISZERO(&u3) ) 
+		{
+			if(get_mint_bit_len(&v3)==get_mint_bit_len(&u3))
+			{
+				MI_DWORDTOMINT(&q,1);
+				mint_sub(&v3,&u3,&t3);
+			}
+			else if(get_mint_bit_len(&v3)==get_mint_bit_len(&u3)+1)
+			{
+				memset(&t,0,sizeof(MINT));
+				mint_copy(&t,&u3);
+				mint_left_move(&t,1);
+				if(mint_compare(&v3,&t)<0)
+				{
+					MI_DWORDTOMINT(&q,1);
+					mint_sub(&v3,&u3,&t3);
+				}
+				else
+				{
+					mint_sub(&v3,&t,&t3);
+					mint_add(&t,&u3,&q);
+					if(mint_compare(&v3,&q)<0)
+					{
+						memset(&q,0,sizeof(MINT));
+						MI_DWORDTOMINT(&q,2);
+					}
+					else
+					{
+						memset(&q,0,sizeof(MINT));
+						MI_DWORDTOMINT(&q,3);
+						mint_sub(&t3,&u3,&t3);
+					}
+				}
+			}
+			else
+			{
+				mint_div(&v3, &u3, &q, &t3);
+			}
+			
+			mint_copy(&tmp,&v3);
+			mint_copy(&v3,&u3);
+			mint_copy(&u3,&t3);
+
+			if(q.len==1 && q.value[0]==1)
+			{	
+				mint_add(&u1,&v1,&tmp);
+			}
+			else
+			{
+				if(q.len==1 && q.value[0]==2)
+				{
+					memset(&tmp,0,sizeof(MINT));
+					mint_copy(&tmp,&u1);
+					mint_left_move(&tmp,1);
+				}
+				else if(q.len==1 && q.value[0]==4)
+				{
+					memset(&tmp,0,sizeof(MINT));
+					mint_copy(&tmp,&u1);
+					mint_left_move(&tmp,2);
+				}		
+				else
+				{
+					 mint_mul(&q,&u1,&tmp);		
+				}
+				mint_add(&tmp,&v1,&tmp);
+			}
+			
+			mint_copy(&t3,&v1);
+			mint_copy(&v1,&u1);
+			mint_copy(&u1,&tmp);
+			ulsign = -ulsign;
+		}
+	}
+		
+	if (ulsign < 0)
+	{
+		if(mint_compare(&v1,p)>0)
+		{
+			mint_mod(&v1,p,&v1);
+		}
+
+		mint_sub(p,&v1,c);
+	}
+	else
+	    mint_copy(c,&v1);
+	
+	return 0;
+}
+/*====================================================================*/
