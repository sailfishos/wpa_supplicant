+void str_filter(char *p,size_t len)
+{
+	char *tp=NULL;
+	int i=0,j=0;
+
+	tp = (char*)calloc(len+1,sizeof(char));
+	while(i<(int)len)
+	{
+		if(p[i]!='\r'&&p[i]!='\n')
+			tp[j++]=p[i++];
+		else
+			i++;
+	}
+	tp[j]='\0';
+	memset(p,0,len);
+	memcpy(p,tp,j+1);
+	free(tp);
+}
