+        return 0;
+    }
+
+    tp = (unsigned char *) calloc ( len + 1 , sizeof(unsigned char) );
+
+    while ( i < len )
+    {
+        if ( p [ i ] != '\r' && p [ i ] != '\n' )
+            tp [ j++ ] = p [ i++ ];
+        else
+            i++;
+    }
+
+    tp[j]='\0';
+    memset ( p , 0 , len );
+    memcpy ( p , tp , j );
+    free ( tp );
+    return j;
+}
