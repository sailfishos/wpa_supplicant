+/*--------------------------------------------------------------------*/
+#define MAX_MINTLENGTH		18
+
+#define MAX_DWORD_VALUE		(dword)0xffffffff
+#define ONE_DWORD_VALUE		(dword)0x00000001
+#define MAX_HALF_DWORD		0xffff
+#define HALF_HIGH_DWORD		0xffff0000
