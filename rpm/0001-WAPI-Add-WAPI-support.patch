+void wai_receive(struct wapi_authenticator *wapi_auth,
+		 struct wapi_state_machine *sm,
+		 u8 *data, size_t data_len)
+{
+	int ret;
+	struct wapi_wai_hdr *hdr;
+	u8 *wai_payload;
+	size_t	wai_payload_len;
+	wpa_printf(MSG_DEBUG, "%s Enter ", __func__);
+	if (wapi_auth == NULL || !(wapi_auth->conf->wapi & WPA_PROTO_WAPI) || sm == NULL)
+		return;
+
+	if (data_len < sizeof(*hdr))
+		return;
+
+	hdr = (struct wapi_wai_hdr *) data;
+
+	if (hdr->stype < WAI_SUBTYPE_PREAUTHSTART 
+		|| hdr->stype > WAI_SUBTYPE_GROUPKEYNOTICERESPONSE)
+		return;
+
+	if (!hdr->frame_flag && hdr->frame_sc == 0)
+	{
+		wpa_printf(MSG_INFO, "wapi: There's nothing to defragment");
+	}
+
+	wai_payload = (u8 *) (hdr + 1);
+	wai_payload_len = data_len - sizeof(struct wapi_wai_hdr);
+
+	switch(hdr->stype)
+	{
+		/*├▄į┐ąŁ╔╠Žņė”Ęųūķ*/
+		case WAI_SUBTYPE_SESSIONKEYNEGRESPONSE:
+			wpa_printf(MSG_DEBUG, "receive SESSION KEY NEG RESPONSE from sta:"
+				MACSTR, MAC2STR(sm->addr));
+			
+			ret = _wapi_usk_negotiation_res(wapi_auth, sm, wai_payload, wai_payload_len);
+			if (ret != 0)
+			{
+				wpa_printf(MSG_ERROR, "USK process_dynamic_sessionkey Error\n ");
+				return;
+			}
+			break;
+		/*ūķ▓ź═©ĖµŽņė”Ęųūķ*/
+		case WAI_SUBTYPE_GROUPKEYNOTICERESPONSE:
+			ret = wapi_msk_announcement_res(wapi_auth, sm, wai_payload, wai_payload_len);
+			if (ret != 0)
+			{
+				wpa_printf(MSG_ERROR, "MSK process_dynamic_sessionkey Error\n ");
+				return;
+			}
+			break;
+	}
+
+	eloop_cancel_timeout(wapi_send_wai_timeout, sm->wapi_auth, sm);
+
+	sm->group_sc += 1;
+	sm->WAPIwaiReceived = _TRUE;
+	wapi_sm_step(sm);
+
+}
