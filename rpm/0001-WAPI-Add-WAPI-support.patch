+/*====================================================================*/
+int SDF_GenerateKeyPair_ECC(void *hSessionHandle, unsigned int uiAlgID, unsigned int uiKeyBits, ECCrefPublicKey *pucPublicKey, ECCrefPrivateKey *pucPrivateKey)
+{
+	MINT prikey;
+	ECC_FpPOINT pubkey;
+	unsigned int len=0;
+	int ret = -1;
+	
+	SessionHandle *EccSessionHandle = NULL;
+
+    if (hSessionHandle == NULL) 
+    {
+       ret = SDR_NOSESSIONHANDLE;
+	   return ret;
+    }
+	memset(&prikey,0,sizeof(MINT));
+	memset(&pubkey,0,sizeof(ECC_FpPOINT));
+
+    EccSessionHandle = (SessionHandle *)hSessionHandle;
+
+	if(uiKeyBits!=EccSessionHandle->g_fixlen*BITS_PER_BYTE)
+	{
+		ret = SDR_PARAINPUTERR;
+		return ret;
+	}
+
+	switch(uiAlgID)
+	{
+	case SGD_SM2:
+	case SGD_ECC:
+		gen_random_number(&prikey,&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.N),EccSessionHandle->g_hash_type);
+		mint_to_fixedlen_os(&prikey,EccSessionHandle->g_fixlen,ECCref_MAX_LEN,&len,pucPrivateKey->D);
+		pucPrivateKey->bits = len*BITS_PER_BYTE;	
+		ecc_fix_point_mul(&prikey,&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.G),&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.A),&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.B),&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.P),&pubkey,((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_GPt_1);
+		mint_to_fixedlen_os(&(pubkey.x),EccSessionHandle->g_fixlen,ECCref_MAX_LEN,&len,pucPublicKey->x);
+		mint_to_fixedlen_os(&(pubkey.y),EccSessionHandle->g_fixlen,ECCref_MAX_LEN,&len,pucPublicKey->y);
+		pucPublicKey->bits = len*BITS_PER_BYTE;
+		ret = SDR_OK;
+		break;
+	default:
+		break;
+	}	
+	return ret;
+}
+/*--------------------------------------------------------------------*/
+int SDF_ExternalSign_ECC(void *hSessionHandle, unsigned int uiAlgID, ECCrefPrivateKey *pucPrivateKey, unsigned char *pucData, unsigned int uiDataLength, ECCSignature *pucSignature)
+{	
+	MINT prikey;
+	MINT r,s;
+	unsigned int len=0;
+	int ret=-1;
+	SessionHandle *EccSessionHandle = NULL;
+
+    if (hSessionHandle == NULL) 
+    {
+       ret = SDR_NOSESSIONHANDLE;
+	   return ret;
+    }
+
+	memset(&prikey,0,sizeof(MINT));
+	memset(&r,0,sizeof(MINT));
+	memset(&s,0,sizeof(MINT));
+
+	EccSessionHandle = (SessionHandle *)hSessionHandle;
+	
+	octetstring_to_mint(pucPrivateKey->D,pucPrivateKey->bits/PRE_BYTE_BITS,&prikey);
+	if(MINT_ISZERO(&prikey) || mint_compare(&prikey,&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.N))>=0){
+		return SDR_SIGNERR;
+	}
+
+	switch(uiAlgID)
+	{
+#ifdef IWN_ECC_SM2
+	case SGD_SM2_1:
+		ret = SM2_ExternalSign_ECC(((EccCurveHandle*)(EccSessionHandle->CurveHandle)), &prikey, pucData, uiDataLength, &r, &s, EccSessionHandle->g_hash_type);
+		break;
+#endif
+#ifdef IWN_ECC_ECDSA
+	case SGD_ECDSA:
+        ret = ECDSA_ExternalSign_ECC(((EccCurveHandle*)(EccSessionHandle->CurveHandle)), &prikey, pucData, uiDataLength, &r, &s, EccSessionHandle->g_hash_type);
+		break;
+#endif
+	default:
+		break;
+	}
+
+	if(ret ==SDR_OK)
+	{
+		mint_to_fixedlen_os(&r,EccSessionHandle->g_fixlen,ECCref_MAX_LEN,&len,pucSignature->r);
+		mint_to_fixedlen_os(&s,EccSessionHandle->g_fixlen,ECCref_MAX_LEN,&len,pucSignature->s);
+	}
+
+	return ret;
+}
+/*--------------------------------------------------------------------*/
+int SDF_ExternalVerify_ECC( void *hSessionHandle, unsigned int uiAlgID, ECCrefPublicKey *pucPublicKey, unsigned char *pucDataInput, unsigned int uiInputLength, ECCSignature *pucSignature)
+{
+	ECC_FpPOINT pubkey;
+	MINT r,s;
+	MINT one,m;
+	SessionHandle *EccSessionHandle = NULL;	
+	int ret=-1;
+
+    if (hSessionHandle == NULL) 
+    {
+       ret = SDR_NOSESSIONHANDLE;
+	   return ret;
+    }
+
+	memset(&pubkey,0,sizeof(ECC_FpPOINT));
+	memset(&r,0,sizeof(MINT));
+	memset(&s,0,sizeof(MINT));
+	memset(&one,0,sizeof(MINT));
+	memset(&m,0,sizeof(MINT));
+
+	EccSessionHandle = (SessionHandle *)hSessionHandle;
+
+	octetstring_to_mint(pucPublicKey->x,pucPublicKey->bits/PRE_BYTE_BITS,&(pubkey.x));
+	octetstring_to_mint(pucPublicKey->y,pucPublicKey->bits/PRE_BYTE_BITS,&(pubkey.y));
+	octetstring_to_mint(pucSignature->r,EccSessionHandle->g_fixlen,&r);
+	octetstring_to_mint(pucSignature->s,EccSessionHandle->g_fixlen,&s);
+
+	MI_DWORDTOMINT(&one, 1);
+	mint_sub(&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.N), &one, &m);
+	if(mint_compare(&r,&one)<0)
+	{
+		return SDR_VERIFYERR;
+	}
+
+	if(mint_compare(&r,&m)>0)
+	{
+		return SDR_VERIFYERR;
+	}
+
+	if(mint_compare(&s,&one)<0)
+	{
+		return SDR_VERIFYERR;
+	}
+
+	if(mint_compare(&s,&m)>0)
+	{
+		return SDR_VERIFYERR;
+	}
+
+	switch(uiAlgID)
+	{
+#ifdef IWN_ECC_SM2
+	case SGD_SM2_1:
+        ret = SM2_ExternalVerify_ECC(((EccCurveHandle*)(EccSessionHandle->CurveHandle)), &pubkey, pucDataInput, uiInputLength, &r, &s);
+		break;
+#endif
+#ifdef IWN_ECC_ECDSA
+	case SGD_ECDSA:
+        ret = ECDSA_ExternalVerify_ECC(((EccCurveHandle*)(EccSessionHandle->CurveHandle)), &pubkey, pucDataInput, uiInputLength, &r, &s);
+		break;
+#endif
+	default:
+		break;
+	}
+
+	return ret;
+}
+/*--------------------------------------------------------------------*/
+//═Ō▓┐├▄į┐ECC╝ė├▄
+int SDF_ExternalEncrytp_ECC( void *hSessionHandle, unsigned int uiAlgID, ECCrefPublicKey *pucPublicKey, unsigned char *pucData, unsigned int uiDataLength, ECCCipher *pucEncData)
+{
+	ECC_FpPOINT pubkey;
