+int IWN_ExternalSignHash_ECC(void *hSessionHandle, unsigned int uiAlgID, ECCrefPrivateKey *pucExpPrivateKey, unsigned char *pucData, unsigned int uiDataLength,  unsigned char *pucID, unsigned int uiIDLength,ECCSignature *pucSignature)
+{
