+static int wapi_driver_nl80211_hapd_send_wapi(
+	void *priv, const u8 *addr, const u8 *data,
+	size_t data_len, int encrypt, const u8 *own_addr, u32 flags)
+{
+	struct i802_bss *bss = priv;
+	struct wpa_driver_nl80211_data *drv = bss->drv;
+	struct ieee80211_hdr *hdr;
+	
+	size_t len;
+	u8 *pos;
+	int res = -1;
+	wpa_printf(MSG_INFO, "nl80211: Enter %s",__func__);
+	if (drv->device_ap_sme || !drv->use_monitor){
+		return nl80211_send_wapi_data(bss, addr, data, data_len);
+	}
+
+	len = sizeof(*hdr) + sizeof(rfc1042_header) + 2 + data_len;
+	
+	hdr = os_zalloc(len);
+	if (hdr == NULL) {
+		wpa_printf(MSG_ERROR,"malloc() failed for %s (len=%lu)\n",
+		       __func__, (unsigned long) len);
+		return -1;
+	}
+
+	hdr->frame_control = IEEE80211_FC(WLAN_FC_TYPE_DATA, WLAN_FC_STYPE_DATA);
+	hdr->frame_control |= host_to_le16(WLAN_FC_FROMDS);
+	memcpy(hdr->IEEE80211_DA_FROMDS, addr, ETH_ALEN);
+	memcpy(hdr->IEEE80211_BSSID_FROMDS, own_addr, ETH_ALEN);
+	memcpy(hdr->IEEE80211_SA_FROMDS, own_addr, ETH_ALEN);
+	pos = (u8 *) (hdr + 1);
+
+	memcpy(pos, rfc1042_header, sizeof(rfc1042_header));
+	pos += sizeof(rfc1042_header);
+	WPA_PUT_BE16(pos, ETH_P_WAPI);
+	pos += 2;
+	memcpy(pos, data, data_len);
+
+#if 0 //changed for the wpa-supplicant-2.10
+	res = wpa_driver_nl80211_send_frame(bss, (u8 *) hdr, len, encrypt, 0,
+					    0, 0, 0, 0, NULL, 0);
+#else
+	res = nl80211_send_monitor(drv, hdr, len, encrypt, 0);
+#endif
+	if (res < 0) {
+		wpa_printf(MSG_ERROR, "%s - packet len: %lu - failed: %d (%s)",
+			   __func__, (unsigned long) len, errno, strerror(errno));
+	}
+	os_free(hdr);
+
+	return res;
+}
+#endif /* CONFIG_WAPI_AP*/
 
