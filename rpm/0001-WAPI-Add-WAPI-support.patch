+static int hex2int(char c)
+{
+	if (c >= '0' && c <= '9')
+	{
+		return (c - '0');
+	}
+	if (c >= 'a' && c <= 'f')
+	{
+		return (c - 'a' + 10);
+	}
+	if (c >= 'A' && c <= 'F')
+	{
+		return (c - 'A' + 10);
+	}
+	
+	return -1;
+}
+
+static int str2byte(const unsigned char *str, int len,  char *byte_out)
+{
+	int i, val, val2;
+	const char* pos = (const char*)str;
+	
+	for (i = 0; i < (len / 2); i++) 
+	{
+		val = hex2int(*pos++);
+		if (val < 0)
+		{
+			return -1;
+		}
+		val2 = hex2int(*pos++);
+		if (val2 < 0)
+		{
+			return -1;
+		}
+		byte_out[i] = (val * 16 + val2) & 0xff;
+	}
+
+	return 0;
+}
+
+static int iwn_password_bk_derivation(u8 *password, unsigned password_len, 
+									u8 *out_bk)
+{
+	u8 input_text[] = 
+			"preshared key expansion for authentication and key negotiation";
+	
+	if (password == NULL || password_len == 0 || out_bk == NULL)
+	{
+		return -1;
+	}
+	
+	iwn_kdhmac_sha256(input_text, strlen((char*)input_text), 
+			password, password_len, out_bk, 16);
+	
+	return 0;
+}
+
+static void wapi_init_iv(struct wapi_msksa *msksa)
+{
+	/* Modify 2017.11.10 */
+	/*
+	u8 init_iv[] = {0x5c, 0x36, 0x5c, 0x36, 0x5c, 0x36, 0x5c, 0x36,
+				0x5c, 0x36, 0x5c, 0x36, 0x5c, 0x36, 0x5c, 0x35};
+	*/
+	u8 init_iv[] = {0x5c, 0x36, 0x5c, 0x36, 0x5c, 0x36, 0x5c, 0x36,
+				0x5c, 0x36, 0x5c, 0x36, 0x5c, 0x36, 0x5c, 0x36};
+	memcpy(msksa->msk_ann_id, init_iv, WAI_IV_LEN);
+}
+
+int wapi_sta_init()
+{
+	struct wapi_asue_st* wpa_s = NULL;
+	int ret = 1;
+	
+	/* check initialized */
+	if (!s_init)
+	{
+		/* check the cpu mode(little and big) */
+		short v_test = 1;
+		char* p = (char*)&v_test;
+		if (p[0])
+		{
+			s_l_endian = 1;
+		}
+
+		/* get memory for library main body */
+		s_asue = iwn_get_buffer(sizeof(struct wapi_asue_st));
+		if (s_asue == NULL)
+		{
+			return ret;
+		}
+		wpa_s = s_asue;
+
+		if (ecc_init() != 0)
+		{
+			wapi_printf(MSG_ERROR, "ecc_init faild \n");
+		}
+		
+		wpa_s->ptm = &wpa_s->vpt_tm;
+		wpa_s->wapi_sm = &wpa_s->vpt_wapi_sm;
+
+		wpa_s->wapi_sm->usksa.uskid = 1;
+		wpa_s->wapi_sm->msksa.mskid = 1;
+		wpa_s->wapi_sm->bksa.bk_len = BKID_LEN;
+
+		wpa_s->cert_info.cert_state_list = NULL;
+		wpa_s->cert_info.cert_asue_data = NULL;
+		wpa_s->cert_info.asue_cert_cur = NULL;
+		
+		wapi_config_file_read(WAPI_CONFIG_FILE, wpa_s);
+		
+		/* initialized */
+		s_init = 1;
+
+		ret = 0;
+	}
+
+	return ret;
+}
+
+int wapi_sta_deinit()
+{
+	/* cleanup resource */
+	timer_destory1();
+	
+	ecc_exit();
+
+	deinit_wapi_cert(&(s_asue->cert_info));
+	
+	s_asue = iwn_free_buffer(s_asue, sizeof(struct wapi_asue_st));
+
+	/* not initialized */
+	s_init = 0;	
+	
+	return 0;
+}
+
+int wapi_set_connect_param(const connect_param* pPar)
+{
+	struct wapi_asue_st* wpa_s = s_asue;
+	wapi_cert_data *cert_info = &(wpa_s->cert_info);
+	
+	unsigned char buff[128];
+	unsigned char psk_len = 0;
+	
+	/* check initialized and param */
+	if (0 == s_init || NULL == pPar)
+	{
+		return -1;
+	}
+
+	/* save and parse client auth type */
+	wpa_s->ap_type = pPar->authType;
+	if (AUTH_TYPE_NONE_WAPI != pPar->authType)
+	{
+		/* guoxd 20081210 modify start */
+		unsigned char buf_ie[64] =
+                     {0x44,22,1,0, 1,0,0,0x14,0x72,1, 1,0,0,0x14,0x72,1, 0,0x14,0x72,1, 0, 0, 0, 0};/* little endian*/
+		/* guoxd 20081210 modify end */
+
+		if (AUTH_TYPE_WAPI_PSK == pPar->authType)
+		{
+			buf_ie[9] = 2;
+		}
+
+		/* set wapi IE field with the output interface */
+		wapi_set_assoc_ie(buf_ie, 2 + buf_ie[1]);
+
+		memcpy(wpa_s->wapi_sm->assoc_wapi_ie, buf_ie, 2 + buf_ie[1]);
+		wpa_s->wapi_sm->assoc_wapi_ie_len = (u8)(2 + buf_ie[1]);
+	}
+
+	/* cert security mode*/
+	if (AUTH_TYPE_WAPI_CERT == pPar->authType)
+	{
+		wapi_printf(MSG_DEBUG, "wapi cert mode \n");
+		
+		wapi_printf(MSG_DEBUG, "wapi cert select mode = %d \n", 
+				pPar->wapi_cert_sel_mode);
+		cert_info->wapi_cert_sel_mode = pPar->wapi_cert_sel_mode;
+		
+		if (pPar->wapi_cert_sel_mode == 1)
+		{
+			wapi_printf(MSG_DEBUG, "wapi cert select: %s\n", 
+						pPar->wapi_cert_sel);
+			strncpy(cert_info->wapi_cert_sel, pPar->wapi_cert_sel,
+				strlen(pPar->wapi_cert_sel)+1);
+		}
+
+		cert_info->cert_flag = 1;
+		
+		if (init_wapi_cert(cert_info) != 0)
+		{
+			wapi_printf(MSG_ERROR, "init_roam_cert faild.\n");
+			return -1;
+		}
+	}
+	/* PSK security mode*/
+	else if (AUTH_TYPE_WAPI_PSK == pPar->authType)
+	{
+		wapi_printf(MSG_DEBUG, "wapi psk mode \n");
+		
+		if (strlen((char *)pPar->kv) <= 0)
+		{
+			wapi_printf(MSG_ERROR, "key is empty \n");
+			return -1;
+		}
+		wapi_printf(MSG_DEBUG, "key is %s \n", "*");
+		
+		/* ASCII mode */
+		if (pPar->kt == KEY_TYPE_ASCII)
+		{
+			wapi_printf(MSG_DEBUG, "key type is ASCII. \n");
+			/* get BK value */
+			if (iwn_password_bk_derivation((u8*)pPar->kv, pPar->kl, 
+				wpa_s->psk_bk) != 0)
+			{
+				return -1;
+			}
+		}
+		/* HEX mode */
+		else
+		{
+			wapi_printf(MSG_DEBUG, "key type is HEX \n");
+			/* get BK value */
+			memset(buff, 0, sizeof(buff));
+			if (pPar->kl % 2) 
+			{
+				return -1;
+			}
+			str2byte(pPar->kv, pPar->kl, (char*)buff);
+			if (iwn_password_bk_derivation(buff, (pPar->kl) / 2, 
+				wpa_s->psk_bk) != 0)
+			{
+				return -1;
+			}
+		}
+		
+		/*wapi_hexdump(MSG_DEBUG, "WAI_CNTAPPARA_SET: wpa_s->psk_bk", 
+				wpa_s->psk_bk, 16);*/
+	}
+	/* other mode */
+	else
+	{
+		// empty
+	}
+
+	return 0;
+}
+
+void wapi_event_process(wapi_event event, 
+		const unsigned char *bssid, 
+		const unsigned char *local_mac, 
+		unsigned char *assoc_ie, 
+		unsigned char assoc_ie_len)
+{
+	struct wapi_asue_st* wpa_s = s_asue;
+	int i;
+	
+	if (0 == s_init || NULL == bssid || NULL == local_mac
+		|| (NULL != assoc_ie && 0 == assoc_ie_len)
+		|| (NULL == assoc_ie && 0 != assoc_ie_len))
+	{
+		wapi_printf(MSG_ERROR, "%s: invalid param \n", 
+				__func__);
+		return;
+	}
+
+	if (CONN_ASSOC == event)
+	{	
+		wapi_printf(MSG_DEBUG, "%s: recv event CONN_ASSOC \n",
+				__func__);
+		memcpy(wpa_s->own_addr, local_mac, ETH_ALEN);
+
+		/* save wapi state */
+		wpa_s->wapi_state = WAPISM_AL_ASSOC;
+		wpa_s->usk_updated = 0;
+
+		/* new ap */
+		if (memcmp(wpa_s->bssid, bssid, ETH_ALEN) != 0)
+		{
+			memcpy(wpa_s->bssid, bssid, ETH_ALEN);
+			wapi_init_iv(&wpa_s->wapi_sm->msksa);
+
+			if (AUTH_TYPE_WAPI_PSK == wpa_s->ap_type)
+			{
+				u8 addid[12] = {0};
+				u8 bkid[16] = {0};
+
+				wapi_printf(MSG_DEBUG, "WAI_Msg_Input(): "
+						"auth type is AUTH_TYPE_WAPI_PSK \n");
+				memcpy(addid, wpa_s->bssid, 6);
+				memcpy(addid + 6, wpa_s->own_addr, 6);
+				
+				iwn_kdhmac_sha256(addid, 12, wpa_s->psk_bk, 16, bkid, BKID_LEN);
+				
+				memcpy(wpa_s->wapi_sm->bksa.bk, wpa_s->psk_bk, 16);
+				wapi_hexdump(MSG_DEBUG, "bk: ", wpa_s->wapi_sm->bksa.bk, 16);
+				memcpy(wpa_s->wapi_sm->bksa.bkid, bkid, 16);
+				wapi_hexdump(MSG_DEBUG, "bkid", wpa_s->wapi_sm->bksa.bkid, 16);
+			}
+
+			if (AUTH_TYPE_NONE_WAPI != wpa_s->ap_type)
+			{
+				/* WAPI IE */
+				memset(wpa_s->wapi_sm->ap_wapi_ie, 0, sizeof(wpa_s->wapi_sm->ap_wapi_ie));
+				if (assoc_ie_len >= sizeof(wpa_s->wapi_sm->ap_wapi_ie)-1)
+				{
+					assoc_ie_len = sizeof(wpa_s->wapi_sm->ap_wapi_ie)-1;
+				}
+				memcpy(wpa_s->wapi_sm->ap_wapi_ie, assoc_ie, assoc_ie_len);
+				wpa_s->wapi_sm->ap_wapi_ie_len = assoc_ie_len;
+			}
+		}
+		
+		/* Modify 2017.9.15*/
+		/* wpa_s->rxseq = 0; */
+		wpa_s->prev_rxseq = 0;
+		wpa_s->curr_rxseq = 0;
+		wpa_s->txseq = 0;
+	 	wpa_s->rxfrag = NULL;
+
+		/* add 2014.9.25 */
+		wpa_s->auth_active_retry = 0;
+		wpa_s->bk_update_flag = 0;
+		
+		/* Add 2018.3.13 */
+		wapi_notify_connect_state(WAPI_ASSOCIATED);
+		
+		timer_create1();
+	}
+	else if (CONN_DISASSOC == event)
+	{
+		wapi_printf(MSG_DEBUG, "%s: recv event CONN_DISASSOC \n",
+				__func__);
+		wpa_s->wapi_state = WAPISM_N0_ASSOC;
+		wpa_s->usk_updated = 0;
+
+		timer_destory1();
+
+		memset(wpa_s->own_addr, 0, sizeof(wpa_s->own_addr));
+		memset(wpa_s->bssid, 0, sizeof(wpa_s->bssid));
+		memset(wpa_s->last_wai_src, 0, sizeof(wpa_s->last_wai_src));
+		
+		memset(wpa_s->ae_auth_flag, 0, sizeof(wpa_s->ae_auth_flag));
+		memset(wpa_s->Nasue, 0, sizeof(wpa_s->Nasue));
+		memset(wpa_s->Nae, 0, sizeof(wpa_s->Nae));
+		
+		memset(&wpa_s->ae_cert, 0, sizeof(wpa_s->ae_cert));
+		memset(&wpa_s->sign_alg, 0, sizeof(wpa_s->sign_alg));
+		memset(&wpa_s->asue_eck, 0, sizeof(wpa_s->asue_eck));
+		memset(&wpa_s->ae_key_data, 0, sizeof(wpa_s->ae_key_data));
+		memset(&wpa_s->ecdh, 0, sizeof(wpa_s->ecdh));
+		memset(&wpa_s->ae_asu_id, 0, sizeof(wpa_s->ae_asu_id));
+		memset(&wpa_s->ae_id, 0, sizeof(wpa_s->ae_id));
+
+		memset(&wpa_s->wapi_sm->usksa, 0, sizeof(wpa_s->wapi_sm->usksa));
+		memset(&wpa_s->wapi_sm->msksa, 0, sizeof(wpa_s->wapi_sm->msksa));
+		memset(&wpa_s->wapi_sm->bksa, 0, sizeof(wpa_s->wapi_sm->bksa));
+
+		wpa_s->wapi_sm->usksa.uskid = 1;
+		wpa_s->wapi_sm->msksa.mskid = 1;
+		wpa_s->wapi_sm->bksa.bk_len = BKID_LEN;
+		wapi_init_iv(&wpa_s->wapi_sm->msksa);
+		wpa_s->usk_first_auth_flag=0;/*iwncomm add */
+		/* WAPI IE */
+		memset(wpa_s->wapi_sm->ap_wapi_ie, 0, sizeof(wpa_s->wapi_sm->ap_wapi_ie));
+		wpa_s->wapi_sm->ap_wapi_ie_len = 0;
+
+		/* add 2014.9.25 */
+		wpa_s->auth_active_retry = 0;
+		wpa_s->bk_update_flag = 0;
+		
+		/* Add 2018.3.13 */
+		wapi_notify_connect_state(WAPI_DISCONNECTED);
+	}
+}
+
+void wai_recv_packet(const u8* src_addr, const u8* buf, size_t len)
+{
+	struct wapi_asue_st* wpa_s = s_asue;
+	int t = wpa_s->ap_type;
+    struct wapi_rxfrag rxbuf;
+	struct wapi_rxfrag *temp_rxbuf = NULL;
+	
+    if (AUTH_TYPE_WAPI_CERT != t && AUTH_TYPE_WAPI_PSK != t) 
+	{
+        return;
+    }
+
+    rxbuf.data = buf;
+    rxbuf.data_len = len;
+    temp_rxbuf = iwn_wpa_defrag(wpa_s, &rxbuf);
+    if (temp_rxbuf) 
+	{
+        iwn_wapi_sm_rx_wai(wpa_s, src_addr, temp_rxbuf->data,
+						temp_rxbuf->data_len);
+    }		
+}
+
+int wapi_rx_wai_packet(const unsigned char* pbuf, int length)
+{
+	struct wapi_asue_st* wpa_s = s_asue;
+	wai_recv_packet((const u8*)wpa_s->bssid, (const u8*)pbuf, (size_t)length);
+	return 0;
+}
+
+static void wlan_deauth(void)
+{
+	struct wapi_asue_st* wpa_s = s_asue;
+	wpa_s->wapi_state = WAPISM_N0_ASSOC;
+	wpa_s->wapi_sm->usksa.uskid = 1;
+	if (memcmp(wpa_s->bssid, "\0\0\0\0\0\0", ETH_ALEN) != 0)
+	{
+		wapi_deauthenticate();
+		memcpy(wpa_s->bssid, "\0\0\0\0\0\0", ETH_ALEN);
+	}
+}
+
+void wlan_deauth_for_otherc(void)
+{
+	struct wapi_asue_st* wpa_s = s_asue;
+	struct timer_dispose* ptm = wpa_s->ptm;
+
+	wlan_deauth();
+	timer_destory1();
+	ptm->t = 0;
+}
+
+/* timer */
+void timer_set(int t, const unsigned char* dat, int l)
+{
+	struct wapi_asue_st* wpa_s = s_asue;
+	struct timer_dispose* ptm = wpa_s->ptm;
+
+	ptm->t = t;
+	ptm->l = l;
+	ptm->ctm = 0;
+	ptm->ctx = 0;
+	memcpy(ptm->dat, dat, l);
+	
+	/* Add 2017.9.15*/
+	if (t == 3)
+	{
+		/* Multicast key annoucement response packet already sent, */
+		/* WAI authentication has been completed, so destory the timer */
+		wapi_printf(MSG_DEBUG, "WAI authentication has been completed, "
+			"destory the timer.");
+		timer_destory1();
+	}
+}
+
+void timer_reset(void)
+{
+	struct wapi_asue_st* wpa_s = s_asue;
+	struct timer_dispose* ptm = wpa_s->ptm;
+
+	ptm->t = 0;
+}
+
+void timer_resend(void)
+{
+	struct wapi_asue_st* wpa_s = s_asue;
+	struct timer_dispose* ptm = wpa_s->ptm;
+	int t = ptm->t;
+	if (1 == t || 2 == t)
+	{
+		ptm->ctx++;
+		if (ptm->ctx >= 3)
+		{
+			wlan_deauth();
+			timer_destory1();
+			ptm->t = 0;
+			return;
+		}
+		iwn_wpa_ether_send(ptm->dat, ptm->l);
+		ptm->ctm = 0;
+	}
+}
+
+static void timer_run(const int arg)
+{
+	struct wapi_asue_st* wpa_s = s_asue;
+	struct timer_dispose* ptm = wpa_s->ptm;
+	int t = ptm->t;
+	int timeout[4] = {0, 31, 1, 1};
+	int n = 2;
+
+	/* Disable warning */
+	UNUSED(arg);
+	
+	/* Modify 2017.9.15*/
+	if (t > 2 || t < 1)
+	{
+		return;
+	}
+
+	/* Add 2017.9.15*/
+	if ((t == 1 && wpa_s->wapi_state != WAPISM_CNT_REQ) ||
+		(t == 2 && wpa_s->wapi_state != WAPISM_UNI_RESP))
+	{
+		wapi_printf(MSG_DEBUG, "timer_run: type = %d"
+			"wapi status has been switched, so no longer resend.", t);
+		return;
+	}
+	
+	ptm->ctm++;
+	if (ptm->ctm >= timeout[t]*n)
+	{
+		ptm->ctx++;
+		if (ptm->ctx >= 3)
+		{
+			if (1 == t || 2 == t)
+			{
+				wlan_deauth();
+			}
+			timer_destory1();
+			ptm->t = 0;
+			return;
+		}
+		iwn_wpa_ether_send(ptm->dat, ptm->l);
+		ptm->ctm = 0;
+	}
+}
+
+static void timer_create1 (void)
+{
+	struct wapi_asue_st* wpa_s = s_asue;
+	wpa_s->ptm->pt = OS_timer_setup( 500, 500, timer_run, NULL);
+	timer_reset() ;
+}
+
+static void timer_destory1 (void)
+{
+	struct wapi_asue_st* wpa_s = s_asue;
+	if ((NULL != wpa_s) && (NULL != wpa_s->ptm->pt))
+	{
+		OS_timer_clean(wpa_s->ptm->pt);
+		wpa_s->ptm->pt = NULL;
+		timer_reset() ;
+	}
+}
+
+/* random */
+static void smash_random(unsigned char *buffer, int len)
+{
+	unsigned char smash_key[32] = { 0x09, 0x1A, 0x09, 0x1A, 0xFF, 0x90, 0x67, 0x90,
+									0x7F, 0x48, 0x1B, 0xAF, 0x89, 0x72, 0x52, 0x8B,
+									0x35, 0x43, 0x10, 0x13, 0x75, 0x67, 0x95, 0x4E,
+									0x77, 0x40, 0xC5, 0x28, 0x63, 0x62, 0x8F, 0x75};
+	iwn_hmac_sha256(buffer, len, smash_key, 32, buffer, len);
+}
+
+#ifndef NORAND
+void get_random(unsigned char *buffer, int len)
+{
+	int i = 0;
+	
+	for (i = 0; i < len; i++)
+	{
+		buffer[i] = get_rand_byte();
+	}
+	smash_random(buffer, len);
+}
+#else
+void get_random(unsigned char *buffer, int len)
+{
+	int i = 0;
+	
+	for (i = 0; i < len; i++)
+	{
+		buffer[i] = 18;
+	}
+}
+#endif
