+	unsigned char *p0 = NULL;
+	unsigned char *p1 = NULL;
+	unsigned char *p2 = NULL;
+	unsigned char *p3 = NULL;
+	unsigned char buf_0[2] = {0};
+	unsigned char buf_1[2] = {0};
+	unsigned char buf_2[2] = {0};
+	unsigned char buf_3[2] = {0};
+	int n1 = 0;
+	int n2 = 0;
+	int n3 = 0;
+
+	ucp_to_uintp(data, &b0, &b1, &b2, &b3);
+
+    for (n1 = 0; n1 < 5; n1++)
+	{
+		cal_a(b0, b1, b2, b3, n1, exp, &b0, &b1, &b2, &b3);
+	}
+
+	cal_b(b0, b3, exp, &b0);
+	cal_b(b1, b0, exp, &b1);
+	cal_b(b2, b1, exp, &b2);
+	cal_b(b3, b2, exp, &b3);
+
+	for (n2 = 5; n2 < 11; n2++)
+	{
+		cal_a(b0, b1, b2, b3, n2, exp, &b0, &b1, &b2, &b3);	    
+	}
+
+	cal_b(b0, b3, exp, &b0);
+	cal_b(b1, b0, exp, &b1);
+	cal_b(b2, b1, exp, &b2);
+	cal_b(b3, b2, exp, &b3);
+
+	for (n3 = 11; n3 < 16; n3++)
+	{
+		cal_a(b0, b1, b2, b3, n3, exp, &b0, &b1, &b2, &b3);	    
+	}
+
+	p0 = buf_0;
+	uintp_to_ucp(b0, p0);
+	p1 = buf_1;
+	uintp_to_ucp(b1, p1);
+	p2 = buf_2;
+	uintp_to_ucp(b2, p2);
+	p3 = buf_3;
+	uintp_to_ucp(b3, p3);
+	memcpy(cdata, buf_0, 2);
+	memcpy(cdata + 2, buf_1, 2);
+	memcpy(cdata + 2 + 2, buf_2, 2);
+	memcpy(cdata + 2 + 2 + 2, buf_3, 2);
+}  
+
+void cr_nf(unsigned int m, unsigned int n, unsigned int *outm)
+{
+	m &= 0xFFFF;
+	switch(n)
+	{
+		case 1:
+			*outm = (m << 15) | (m >> 1);
+			break;
+		case 2:
+			*outm = (m << 14) | (m >> 2);
+			break;
+		case 3:
+			*outm = (m << 13) | (m >> 3);
+			break;
+		case 4:
+			*outm = (m << 12) | (m >> 4);
+			break;
+		case 5:
+			*outm = (m << 11) | (m >> 5);
+			break;
+		default:
+			break;
+	}
+}
+
+void cal_c(unsigned int a0, unsigned int a1, unsigned int a2, unsigned int a3, int inx, unsigned short exp[64],
+		   unsigned int* out_a0, unsigned int* out_a1, unsigned int *out_a2, unsigned int *out_a3)
+{
+	int tmp = 0;
+
+	tmp = 4 * inx + 3;
+	cr_nf(a3, 5, &a3);
+	a3 = a3 - exp[tmp] - (a2 & a1) - (~(a2) & a0);
+	tmp = tmp - 1;	
+	*out_a3 = a3;  
+
+	cr_nf(a2, 3, &a2);
+	a2 = a2 - exp[tmp] - (a1 & a0) - (~(a1) & a3);
+	tmp = tmp - 1;
+	*out_a2 = a2;
+
+	cr_nf(a1, 2, &a1);
+	a1 = a1 - exp[tmp] - (a0 & a3) - (~(a0) & a2);
+	tmp = tmp - 1;
+	*out_a1 = a1;
+
+	cr_nf(a0, 1, &a0);
+	a0 = a0 - exp[tmp] - (a3 & a2) - (~(a3) & a1);
+	*out_a0 = a0;
+}
+
+void cal_d(unsigned int a0, unsigned int a1, unsigned short exp[64], unsigned int *a2)
+{
+	*a2 = a0 - exp[a1 & 0x3F]; 
+}
+
+void iwn_rc2_dec(unsigned char *data, unsigned char *pdata, unsigned short exp[64])  
+{
+	unsigned int b0 = 0;
+	unsigned int b1 = 0;
+	unsigned int b2 = 0;
+	unsigned int b3 = 0;
+	unsigned char *p0 = NULL;
+	unsigned char *p1 = NULL;
+	unsigned char *p2 = NULL;
+	unsigned char *p3 = NULL;
+	unsigned char buf_0[2] = {0};
+	unsigned char buf_1[2] = {0};
+	unsigned char buf_2[2] = {0};
+	unsigned char buf_3[2] = {0};
+	int n1 = 0;
+	int n2 = 0;
+	int n3 = 0;
+
+	ucp_to_uintp(data, &b0, &b1, &b2, &b3);
+
+    for (n1 = 15; n1 > 10; n1--)
+	{
+		cal_c(b0, b1, b2, b3, n1, exp, &b0, &b1, &b2, &b3);
+	}
+
+	cal_d(b3, b2, exp, &b3);
+	cal_d(b2, b1, exp, &b2);
+	cal_d(b1, b0, exp, &b1);
+	cal_d(b0, b3, exp, &b0);
+
+	for (n2 = 10; n2 > 4; n2--)
+	{
+		cal_c(b0, b1, b2, b3, n2, exp, &b0, &b1, &b2, &b3);	    
+	}
+
+	cal_d(b3, b2, exp, &b3);
+	cal_d(b2, b1, exp, &b2);
+	cal_d(b1, b0, exp, &b1);
+	cal_d(b0, b3, exp, &b0);
+
+	for (n3 = 4; n3 >= 0; n3--)
+	{
+		cal_c(b0, b1, b2, b3, n3, exp, &b0, &b1, &b2, &b3);	    
+	}
+
+	p0 = buf_0;
+	uintp_to_ucp(b0, p0);
+	p1 = buf_1;
+	uintp_to_ucp(b1, p1);
+	p2 = buf_2;
+	uintp_to_ucp(b2, p2);
+	p3 = buf_3;
+	uintp_to_ucp(b3, p3);
+	memcpy(pdata, buf_0, 2);
+	memcpy(pdata + 2, buf_1, 2);
+	memcpy(pdata + 2 + 2, buf_2, 2);
+	memcpy(pdata + 2 + 2 + 2, buf_3, 2);	 
+}  
+
+void iwn_rc2_enc_cbc(unsigned char *pdata,int pdl,unsigned char *iv, unsigned char *cdata, unsigned short exp[64]) 
+{
+	int n = 0;
+
+	while(pdl)
+	{
+		for(n = 0; n < 8 && n < pdl; ++n)
+			cdata[n] = pdata[n]^ iv[n];
+		for(; n < 8; ++n)
+			cdata[n] = iv[n];
+		iwn_rc2_enc(cdata, cdata, exp);
+		iv = cdata;
+		if(pdl <= 8) break;
+		pdl -= 8;
+		pdata  += 8;
+		cdata += 8;
+	
+	}
+}
+
+void iwn_rc2_dec_cbc(unsigned char *cdata, int cdl, unsigned char *iv, unsigned char *pdata, unsigned short exp[64]) 
+{
+	int n = 0;
+
+	while(cdl)
+	{
+		unsigned char tmp[8];
+		unsigned char c;
+
+		iwn_rc2_dec(cdata, tmp, exp);
+		for(n = 0; n < 8 && n < cdl; ++n)
+		{
+			c = cdata[n];
+			pdata[n] = tmp[n]^ iv[n];
+			iv[n] = c;
+		}
+
+		if(cdl <= 8)
+		{
+		    for(; n < 8; ++n)
+				iv[n] = cdata[n];
+			break;		
+		}
+
+		cdl -= 8;
+		cdata  += 8;
+		pdata += 8;
+	}
+
+}
+
+int p12_rc2_cbc_encrypt(unsigned char *indata, int in_len,
+						unsigned char *iv, int iv_len,
+						unsigned char *key, int key_len,
+						unsigned char *outdata, int *out_len)
+
+{
+	unsigned char *tmpdata = NULL;
+	unsigned char buf[8] = {0};
+	unsigned short exp[64] = {0};
+	int m = 0;
+	int n = 0;
+	int i = 0;
+	int d_len = 0;
+	int r_len = 0;
+
+	/* Disable warning */
+	UNUSED(iv_len);
+	
+	tmpdata = (unsigned char *)malloc(in_len + 8);
+	if(tmpdata == NULL){
+		return 0;
+	}
+
+	expank(key,key_len, exp);
+	m = 8;
+	d_len = in_len / 8;
+	r_len = in_len % 8;
+
+	if(r_len == 0)
+	{
+	    memset(buf, 0, 8);
+	}
+	else
+	{
+	    memcpy(buf, indata + (d_len*8), r_len);
+	}
+
+	n = m - r_len;
+	for(i = r_len; i < m; i++)
+		buf[i] = n;
+
+	memcpy(tmpdata, indata, d_len * 8);
+	memcpy(tmpdata + (d_len * 8), buf, m);
+	iwn_rc2_enc_cbc(tmpdata, in_len + n, iv, outdata, exp);
+
+	*out_len = (in_len + n);
+	free(tmpdata);
+	tmpdata = NULL;
+    return 1;
+}
+
+int p12_rc2_cbc_decrypt(unsigned char *indata, int in_len,
+						unsigned char *iv,int iv_len,
+						unsigned char *key,int key_len,
+						unsigned char *outdata, int *out_len)
+
+{
+	unsigned char *tmpdata = NULL;
+	unsigned char buf[8] = {0};
+	unsigned char buf_1[8] = {0};
+	unsigned short exp[64] = {0};
+	unsigned int m = 0;
+	int n = 0;
+	int i = 0;
+
+	/* Disable warning */
+	UNUSED(iv_len);
+	
+	tmpdata = (unsigned char *)malloc(in_len);
+	if(tmpdata == NULL){
+		return 0;
+	}
+
+	expank(key,key_len, exp);
+	iwn_rc2_dec_cbc(indata, in_len, iv, tmpdata, exp);
+
+	m = 8;
+	*out_len = (in_len - m);
+
+	memcpy(outdata, tmpdata, *out_len);
+	memcpy(buf, tmpdata + (*out_len), 8);
+	n = buf[m-1];
+
+	n = m - n;
+
+	for (i = 0; i < n; i++)
+		buf_1[i] = buf[i];
+
+	memcpy(outdata + (*out_len), buf_1, n);
+	*out_len = (*out_len + n);
+	free(tmpdata);
+	tmpdata = NULL;
+
+    return 1;
+}
+
+
