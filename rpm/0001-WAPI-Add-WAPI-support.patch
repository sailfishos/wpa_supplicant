+static void wapi_send_wai_timeout(void *eloop_ctx, void *timeout_ctx)
+{
+	struct wapi_authenticator *wapi_auth = eloop_ctx;
+	struct wapi_state_machine *sm = timeout_ctx;
+
+	sm->pending_1_of_4_timeout = 0;
+	wpa_printf(MSG_DEBUG, "WAPI_auth: Enter %s",__func__);
+	sm->TimeoutEvt = _TRUE;
+	wapi_sm_step(sm);
+}
