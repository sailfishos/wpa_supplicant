diff --git a/src/libcert_parse/check/check.c b/src/libcert_parse/check/check.c
new file mode 100644
index 0000000..3c44ee1
--- /dev/null
+++ b/src/libcert_parse/check/check.c
@@ -0,0 +1,158 @@
+//2015/11/17 ą▐Ė─
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include "structdef.h"
+#include "cryp_alg.h"
+
+
+// čķųżė├╗¦ųż╩ķ╩ŪĘ±╬¬Ė├CA░õĘó ╩ŪĘĄ╗žTRUE ▓╗╩ŪĘĄ╗žFALSE;
+int IWN_Check_UserCert_by_CACert(const unsigned char *pUserCert,	// ė├╗¦ųż╩ķ╩²Š▌;
+	int usercertlen,												// ė├╗¦ųż╩ķ╩²Š▌│żČ╚;
+	const unsigned char *pCACert,									// CAųż╩ķ╩²Š▌;
+	int cacertlen,                                                 // CAųż╩ķ╩²Š▌│żČ╚;
+	int curve_mode)									                // Ū·Ž▀─Ż╩Į
+{
+	int ret=0,len=4096,sig_len=0,sn_len=30,key_len=150;
+	unsigned char data[4096]={0};
+	unsigned char sig[150]={0};
+	unsigned char sn[30]={0};
+	unsigned char tag[10]={0};
+	unsigned char key[150]={0};
+	//unsigned char key[1024]={0};
+	CHECK_X509_Cert check_ctx;
+	X509_Cert ctx;
+	X509_Cert ctx_1;
+
+    memset(&check_ctx, 0, sizeof(CHECK_X509_Cert));
+	memset(&ctx, 0, sizeof(X509_Cert));
+	memset(&ctx_1, 0, sizeof(X509_Cert));
+
+	ret = UnPack_CHECK_X509((unsigned char *)pUserCert,usercertlen,&check_ctx);
+	if(ret != CTP_OK)
+	{
+		return -1;
+	}
+
+	if (Get_X509_Check_Info(&check_ctx,data,&len) != CTP_OK)
+	{
+		return -1;
+	}
+
+	ret = 0;
+	ret = UnPack_X509((unsigned char *)pUserCert,usercertlen,&ctx);
+	if(ret != CTP_OK)
+	{
+        return -1;
+	}
+
+    GetsignatureValue_X509(&ctx,sig,&sig_len,tag);
+
+	ret = 0;
+	ret = UnPack_X509((unsigned char *)pCACert,cacertlen,&ctx_1);
+	if(ret != CTP_OK)
+	{
+        return -1;
+	}
+
+    if (GetSerialnumber_X509(&ctx_1,sn,&sn_len,tag) != CTP_OK)
+	{
+		return -1;
+	}
+	if (GetPubkey_Info_X509(&ctx_1,key,&key_len,tag) != CTP_OK)
+	{
+		return -1;
+	}
+
+	switch(curve_mode)
+	{
+        case SM2_P256:
+            if(Vrfy_X509(key+2,data,len,sn,sn_len,sig) != 0)
+			    return -2;
+			break;
+        case ECC_P192:
+			if(Vrfy_192_X509(key+2,data,len,sig) != 0)
+				return -2;
+			break;
+        default:
+	        return -1; 
+    }
+
+	End_CHECK_X509(&check_ctx);
+	End_X509(&ctx_1);
+	End_X509(&ctx);
+
+    return 1;
+
+}
+                                                                    
+// čķųżė├╗¦ųż╩ķ╩ŪĘ±ėļĖ├╦Įį┐┼õČį ╩ŪĘĄ╗žTRUE ▓╗╩ŪĘĄ╗žFALSE;
+int IWN_Match_Pub_Pri_key(unsigned char *pUserCert,  		// ė├╗¦ųż╩ķ╩²Š▌;
+	long usercertlen,				                        // ė├╗¦ųż╩ķ╩²Š▌│żČ╚;
+	unsigned char *pPriKey,				                    // ė├╗¦ųż╩ķ╦Įį┐╩²Š▌;
+	long prikeylen,int                                      // ė├╗¦ųż╩ķ╦Įį┐╩²Š▌│żČ╚;
+	curve_mode)				                                // Ū·Ž▀─Ż╩Į
+{
+	int ret=0,sn_len=30,key_len=150,pri_key_len=70,sign_len=0;
+	unsigned char *sig=NULL,*s_value=NULL;
+	unsigned char sig_data[150]={0};
+	unsigned char sn[30]={0};
+	unsigned char tag[10]={0};
+	unsigned char key[150]={0};
+	unsigned char pri_key[70]={0};
+	unsigned char outdata[200]={0};
+	X509_Cert ctx;
+	P12_PRIVATEKEY p12_prikey;
+
+	memset(&ctx, 0, sizeof(X509_Cert));
+	memset(&p12_prikey,0,sizeof(P12_PRIVATEKEY));
+	ret = 0;
+	ret = UnPack_X509((unsigned char *)pUserCert,usercertlen,&ctx);
+	if(ret != CTP_OK)
+	{
+        return -1;
+	}
+
+    if (GetSerialnumber_X509(&ctx,sn,&sn_len,tag) != CTP_OK)
+	{
+		return -1;
+	}
+	if (GetPubkey_Info_X509(&ctx,key,&key_len,tag) != CTP_OK)
+	{
+		return -1;
+	}
+
+	ret = 0;
+	ret = Unpack_P12_PrivateKey((unsigned char *)pPriKey,prikeylen,&p12_prikey);
+	if(ret != CTP_OK)
+	{
+        return -1;
+	}
+
+	Get_P12_PK_PriKey(&p12_prikey,pri_key,&pri_key_len);
+
+    sig=sig_data;
+    s_value=outdata;
+	switch(curve_mode)
+	{
+        case SM2_P256:
+			if(Sign_X509(pri_key,pUserCert,usercertlen,sn,sn_len,&sig,&sign_len,&s_value) == 0)
+				return -3;
+            if(Vrfy_X509(key+2,pUserCert,usercertlen,sn,sn_len,sig_data) != 0)
+				return -2;
+			break;
+        case ECC_P192:	
+            if(Sign_192_X509(pri_key,pUserCert,usercertlen,&sig,&sign_len,&s_value) == 0)
+				return -3;
+            if(Vrfy_192_X509(key+2,pUserCert,usercertlen,sig_data) != 0)
+                return -2;
+			break;
+        default:
+	        return -1; 
+    }
+
+	End_X509(&ctx);
+	End_P12_PrivateKey(&p12_prikey);
+
+    return 1;
+}
