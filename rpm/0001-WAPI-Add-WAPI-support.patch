+/*
+ * Copyright (C) 2016-2018 China IWNCOMM Co., Ltd. All rights reserved.
+ *
+ * This module is wapi cert parse jni interface function.
+ * this function parse cert.
+ *
+ * Authors:
+ * <iwncomm@iwncomm.com>
+ *
+ * History:
+ * pi yongping 06/06/2016 v1.0 add by piyp
+ *
+ * Related documents:
+ * wapi_cert_jni.c
+ *
+ * Description:
+ *
+ */
+
+#include <assert.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+
+#include <jni.h>
+#include <JNIHelp.h>
+
+#include "wapi_cert.h"
+#include "wai_common.h"
+#include "wapi_debug.h"
+
+/* Test jni interface */
+jint
+Java_com_wapi_wapicertstore_WapiCertStore_testJniNative ( JNIEnv* env ,
+        jobject clazz , jstring str )
+{
+	/* Disable warning */
+	UNUSED(clazz);
+	
+    /* convert Java string to UTF-8 */
+    const char *utf8_str = (*env)->GetStringUTFChars ( env , str , NULL );
+    assert ( NULL != utf8_str );
+
+    wapi_printf ( MSG_DEBUG , "testJni: %s" , utf8_str );
+
+    return 0;
+}
+
+jint
+Java_com_wapi_wapicertstore_WapiCertStore_isP12CertNative ( JNIEnv* env ,
+        jobject clazz , jbyteArray userCert )
+{
+	/* Disable warning */
+	UNUSED(clazz);
+	
+    unsigned char *byteUserCert = (unsigned char *)(*env)->GetByteArrayElements(env ,
+            userCert, 0);
+    int userCertLen = (*env)->GetArrayLength(env, userCert);
+    int ret = Is_P12_Cert(byteUserCert, userCertLen);
+    return ret;
+}
+
+jbyteArray
+Java_com_wapi_wapicertstore_WapiCertStore_parseP12CertNative ( JNIEnv* env ,
+        jobject clazz , jbyteArray userCert , jstring password )
+{
+	jbyteArray outCertArray;
+	char strPassword[256] = "";
+	/* Disable warning */
+	UNUSED(clazz);
+	
+    unsigned char *byteUserCert = (unsigned char *)(*env)->GetByteArrayElements(env,
+            userCert, 0);
+    int userCertLen = (*env)->GetArrayLength(env, userCert);
+    const char *utf8_password = (*env)->GetStringUTFChars ( env , password , NULL );
+	strncpy(strPassword, utf8_password, 
+			strnlen(utf8_password, 255));
+	
+	int outCertLen = 4096;
+	char *outCert = (char *)malloc(outCertLen);
+
+    if (0 != Parse_P12_Cert((unsigned char *)byteUserCert, userCertLen, strPassword,
+            outCert , &outCertLen))
+    {
+        wapi_printf ( MSG_ERROR,
+				"parseP12CertNative: password is invalid!" );
+		free(outCert);
+		outCertArray = (*env)->NewByteArray(env, 0);
+		return outCertArray;
+    }
+	
+	/*
+	wapi_hexdump(MSG_DEBUG, "parseP12CertNative out cert:",
+			outCert , outCertLen);
+	*/
+	
+    /* return cert content and private key */
+    outCertArray = (*env)->NewByteArray(env, outCertLen);
+    jbyte *jbyOutCert = (*env)->GetByteArrayElements(env, outCertArray, 0);
+    memcpy(jbyOutCert, outCert, outCertLen);
+    (*env)->SetByteArrayRegion(env, outCertArray, 0, outCertLen, jbyOutCert);
+
+	free(outCert);
+
+    return outCertArray;
+}
+
+jint
+Java_com_wapi_wapicertstore_WapiCertStore_checkUserCaCertNative ( JNIEnv* env ,
+        jobject clazz , jbyteArray userCert , jbyteArray priKey ,
+        jbyteArray caCert )
+{
+	/* Disable warning */
+	UNUSED(clazz);
+	
+    unsigned char *byteUserCert = (unsigned char *) (*env)->GetByteArrayElements ( env ,
+            userCert , 0 );
+    int userCertLen = (*env)->GetArrayLength ( env , userCert );
+	
+    unsigned char *bytePriKey = (unsigned char *) (*env)->GetByteArrayElements ( env , priKey ,
+            0 );
+    int priKeyLen = (*env)->GetArrayLength ( env , priKey );
+	
+    unsigned char *byteCaCert = (unsigned char *) (*env)->GetByteArrayElements ( env , caCert ,
+            0 );
+    int caCertLen = (*env)->GetArrayLength ( env , caCert );
+
+	if ( byteUserCert == NULL ||
+		userCertLen == 0 ||
+		bytePriKey == NULL ||
+		priKeyLen == 0 ||
+		byteCaCert == NULL ||
+		caCertLen == 0 )
+	{
+		wapi_printf ( MSG_DEBUG ,
+                "in '%s':'%d' recv UsrCert Or Prikey or CaCert is NULL\n" , __func__ ,
+                __LINE__ );
+        return -1;
+	}
+    int ret = Check_Asue_Asu_Cert ( byteUserCert , userCertLen , bytePriKey ,
+            priKeyLen , byteCaCert , caCertLen );
+    if ( ret != 0 )
+    {
+        wapi_printf ( MSG_DEBUG ,
+                "in '%s':'%d' Get UsrCert Or Prikey error\n" , __func__ ,
+                __LINE__ );
+        return -1;
+    }
+    return 0;
+}
+
+jstring
+Java_com_wapi_wapicertstore_WapiCertStore_getCertInfoNative ( JNIEnv* env ,
+        jobject clazz , jbyteArray userCert )
+{
+	/* Disable warning */
+	UNUSED(clazz);
+	
+    unsigned char *byteUserCert = (unsigned char *) (*env)->GetByteArrayElements ( env ,
+            userCert , 0 );
+    int userCertLen = (*env)->GetArrayLength ( env , userCert );
+
+    char chInfo [ 128 ];
+    memset ( chInfo , 0 , 128 );
+	int ret = Get_Asue_Cert_Info ( byteUserCert , userCertLen , chInfo, 128);
+	if ( ret != 0 ) 
+	{
+		memset ( chInfo , 0 , 128 );
+	}
+    
+    wapi_hexdump(MSG_DEBUG, "Get_Asue_Cert_Info:", chInfo , strlen(chInfo));
+   
+    return (char *) (*env)->NewStringUTF ( env , chInfo );
+}
