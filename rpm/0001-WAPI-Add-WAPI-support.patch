+//2015/11/17 ą▐Ė─
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include "structdef.h"
+#include "genkey.h"
+#include "rc2_e.h"
+#include "des_e.h"
+#include "getlen.h"
+#include "der.h"
+
+/*-----------------------------------------------------------------------------*/
+int UnPack_P12(unsigned char *In, int len,
+	           unsigned char *version, int *version_len,
+			   unsigned char *p7data_id, int *p7data_id_len,
+			   unsigned char *safe_bag, int *safe_bag_len,
+			   unsigned char *mac_info, int *mac_info_len,
+			   P12_Cert *p12_ctx)
+{
+	int len0=0,len1=0,len2=0,len3=0,len4=0;
+	unsigned char Llen=0;
+	unsigned char *p = NULL;
+	int P12Certificate_Length = 0;
+
+	if(NULL == In || NULL == version || NULL == version_len || NULL == p7data_id 
+		|| NULL == p7data_id_len || safe_bag == NULL || NULL == safe_bag_len 
+		|| NULL == mac_info || mac_info_len == NULL || NULL == p12_ctx)
+	{
+		return CTP_FALSE;
+	}
+
+	p = In;
+	p += 1;
+	len0 = GetInfoLength(p,&Llen);
+	p += Llen;
+
+	P12Certificate_Length += 1 + Llen +len0;
+	
+	p12_ctx->version.data = p;
+	p += 1;
+	len1 = GetInfoLength(p,&Llen);
+	p += Llen;
+	p12_ctx->version.length = len1+Llen+1;
+	p += len1;  
+	
+	if(p12_ctx->version.length>*version_len)
+		return CTP_FALSE;
+
+	memcpy(version,p12_ctx->version.data,p12_ctx->version.length);
+	*version_len = p12_ctx->version.length;
+
+	p += 1;
+	len4 = GetInfoLength(p,&Llen);
+	p += Llen;
+
+	p12_ctx->p7data_id.data = p;
+	p += 1;
+	len4 = GetInfoLength(p,&Llen);
+	p += Llen;
+
+	p12_ctx->p7data_id.length = len4+Llen+1;
+
+	if(p12_ctx->p7data_id.length>*p7data_id_len)
+		return CTP_FALSE;
+
+	memcpy(p7data_id,p12_ctx->p7data_id.data,p12_ctx->p7data_id.length);
+	*p7data_id_len = p12_ctx->p7data_id.length;
+
+    p += len4;
+	p += 1;
+	len2 = GetInfoLength(p,&Llen);
+	p += Llen;
+
