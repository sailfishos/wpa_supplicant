+unsigned int div_2(unsigned int x1,unsigned int x2, unsigned int y)
+{
+	int a,n=2;
+	unsigned int y1,y2,g,q1,q2,k,t=0;
+	
+	if(y == 0) return(MAX_DWORD_VALUE);
+
+	a= mint_bit(y);
+	a=MINT_BIT-a;
+	if(x1 >= y) x1-=y;
+
+	if(a)
+	{
+		y<<=a;
+		x1=(x1<<a)|(x2>>(MINT_BIT-a));
+		x2<<=a;
+	}
+	y1=(y&HALF_HIGH_DWORD)>>HALF_DWORD_BITS;
+	y2=(y&MAX_HALF_DWORD);
+	for (;;)
+	{
+		if ((x1>>HALF_DWORD_BITS) == y1)
+			g=MAX_HALF_DWORD;
+		else
+			g=x1/y1;
+
+		q1=g*y1;
+		q2=y2*g;
+		for (;;)
+		{
+			k=x1-q1;
+			if((k&HALF_HIGH_DWORD) ||
+				((q2) <= (
+					(k<<HALF_DWORD_BITS)|
+					((x2&HALF_HIGH_DWORD)>>HALF_DWORD_BITS))))
+				break;
+			g--;
+			q1-=y1;
+			q2-=y2;
+		}
+		k=(q2>>HALF_DWORD_BITS);
+		q2=(q2<<HALF_DWORD_BITS)&HALF_HIGH_DWORD;
+		q1+=k;
+
+		if(x2 < q2) q1++;
+		x2-=q2;
+		if (x1 < q1)
+		{
+			x1+=y;
+			g--;
+		}
+		x1-=q1;
+
+		if(--n == 0) break;
+
+		t=g<<HALF_DWORD_BITS;
+		x1=((x1<<HALF_DWORD_BITS)|(x2>>HALF_DWORD_BITS))&MAX_DWORD_VALUE;
+		x2=(x2&MAX_HALF_DWORD)<<HALF_DWORD_BITS;
+	}
+	t|=g;
+	return t;
+}
