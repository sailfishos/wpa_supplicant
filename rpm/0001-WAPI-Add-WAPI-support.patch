+++ b/src/libecc/mintex.c
@@ -0,0 +1,339 @@
+/* 
+* Copyright (c) 2000-2012 China IWNCOMM Co., Ltd. All rights reserved.
+*
+* Module:        Bigint arithmetic expansion methods.           
+* Description:   Bigint arithmetic expansion methods implement,includes 
+*                exponent and sqrt.According to SM2 document.
+* Writer:        zhangguoqiang@TEVG <zhanggq@iwncomm.com>
+* Version:  $Id:mintex.c,v 1.0 2012/03/26 09:00:00 zhangguoqiang Exp $     
+*
+* History: 
+* zhangguoqiang    2012/03/26    v1.0    Created.
+*/
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include "mintex.h"
+
+#define IWN_MINTEX_SQRT
+#ifdef IWN_MINTEX_SQRT
+#define SQRT_EXP_LEN 200
+static MINT g_bq[SQRT_EXP_LEN];
+#endif
+/*====================================================================*/
+static int mint_sqr(MINT *a,MINT *b,MINT *p,MINT *y);
+static int mint_random(MINT *p,MINT *y,MINT *x);
+/*--------------------------------------------------------------------*/
+//x=g^a
+int mint_exp(MINT *g,MINT *a,MINT *p,MINT *x)
+{
+	MINT e,t;
+	MINT one;
+	MINT qd;
+	int i,j;
+	int dwbits;
+	dword v;
+	memset(&e,0,sizeof(MINT));
+	memset(&t,0,sizeof(MINT));
+	memset(&one,0,sizeof(MINT));
+	memset(&qd,0,sizeof(MINT));
+	MI_DWORDTOMINT(&one,1);
+
+	mint_sub(p,&one,&qd);
+	mint_mod(a,&qd,&e);
+
+	if(MINT_ISZERO(&e))
+	{
+		MI_DWORDTOMINT(x,1);
+		return 0;
+	}
+	memset(&t,0,sizeof(MINT));
+	mint_copy(&t,g);
+	for(i=e.len-1;i>=0;i--)
+	{
+		v = e.value[i];
+		dwbits = BITS_DWORD_SIZE;
+		if(i==e.len-1)
+		{
+			while(!(v>>(BITS_DWORD_SIZE-1)))
+			{
+				v<<=1;
+				dwbits-=1;
+			}
+			v<<=1;
+			dwbits-=1;
+		}
+
+		for(j=dwbits;j>0;j-=1,v<<=1)
+		{
+			mint_mod_mul(&t,&t,p,&t);
+			if(v>>(BITS_DWORD_SIZE-1)){
+				mint_mod_mul(&t,g,p,&t);
+			}
+		}
+	}
+	mint_copy(x,&t);
+	return 0;
+}
+/*--------------------------------------------------------------------*/
+int mint_sqrt(MINT *g,MINT *p,MINT *x)
+{
+	MINT t1,t2,t3,t4;
+	MINT q,r,u;
+	MINT m,y;
+	MINT k;
+
+	memset(&t1,0,sizeof(MINT));
+	memset(&t2,0,sizeof(MINT));
+	memset(&t3,0,sizeof(MINT));
+	memset(&t4,0,sizeof(MINT));
+	memset(&q,0,sizeof(MINT));
+	memset(&r,0,sizeof(MINT));
+	memset(&u,0,sizeof(MINT));
+	memset(&m,0,sizeof(MINT));
+	memset(&y,0,sizeof(MINT));
+	memset(&k,0,sizeof(MINT));
+
+	//╦ŃĘ©1 p=3(mod 4)
+	MI_DWORDTOMINT(&t1,3);
+	mint_sub(p,&t1,&t2);
+	memset(&t1,0,sizeof(MINT));
+	MI_DWORDTOMINT(&t1,4);
+	mint_div(&t2,&t1,&q,&r);
+	if(MINT_ISZERO(&r))
+	{
+		memset(&t1,0,sizeof(MINT));
+		memset(&t2,0,sizeof(MINT));
+		MI_DWORDTOMINT(&t1,1);
+		mint_add(&q,&t1,&t2);
+		mint_exp(g,&t2,p,&y);
+		memset(&t1,0,sizeof(MINT));
+		mint_mod_mul(&y,&y,p,&t1);
+		if(mint_compare(&t1,g)==0)
+		{
+			mint_copy(x,&y);
+			return 1;
+		}
+	}
+	else
+	{
+		//╦ŃĘ©2 p=5(mod 8)
+		memset(&t1,0,sizeof(MINT));
+		memset(&t2,0,sizeof(MINT));
+		memset(&q,0,sizeof(MINT));
+		memset(&r,0,sizeof(MINT));
+		memset(&u,0,sizeof(MINT));
+		MI_DWORDTOMINT(&t1,5);
+		mint_sub(p,&t1,&t2);
+		memset(&t1,0,sizeof(MINT));
+		MI_DWORDTOMINT(&t1,8);
+		mint_div(&t2,&t1,&q,&r);
+		if(MINT_ISZERO(&r))
+		{
+			memset(&t1,0,sizeof(MINT));
+			memset(&t2,0,sizeof(MINT));
+			memset(&y,0,sizeof(MINT));
+			MI_DWORDTOMINT(&t1,1);
+			mint_copy(&u,&q);
+			mint_add(&q,&q,&t2);
+			mint_add(&t2,&t1,&t2);
+			mint_exp(g,&t2,p,&y);
+
+			//z=1(modp)
+			memset(&t1,0,sizeof(MINT));
+			memset(&t2,0,sizeof(MINT));
+			memset(&q,0,sizeof(MINT));
+			memset(&r,0,sizeof(MINT));
+			MI_DWORDTOMINT(&t1,1);
+			mint_sub(&y,&t1,&t2);			
+			mint_div(&t2,p,&q,&r);
+			if(MINT_ISZERO(&r))
+			{
+				memset(&t1,0,sizeof(MINT));
+				memset(&t2,0,sizeof(MINT));
+				memset(&y,0,sizeof(MINT));
+				MI_DWORDTOMINT(&t1,1);
+				mint_add(&u,&t1,&t2);
+				mint_exp(g,&t2,p,&y);
+				mint_copy(x,&y);
+				return 1;
+			}
+
+			//z=-1(modp)
+			memset(&t1,0,sizeof(MINT));
+			memset(&t2,0,sizeof(MINT));
+			memset(&q,0,sizeof(MINT));
+			memset(&r,0,sizeof(MINT));
+			MI_DWORDTOMINT(&t1,1);
+			mint_add(&y,&t1,&t2);			
+			mint_div(&t2,p,&q,&r);
+			if(MINT_ISZERO(&r))
+			{
+				memset(&t1,0,sizeof(MINT));
+				memset(&t2,0,sizeof(MINT));
+				memset(&t3,0,sizeof(MINT));
+				memset(&y,0,sizeof(MINT));
+				mint_mod_add(g,g,p,&t1);
+				mint_mod_add(&t1,&t1,p,&t2);
+				mint_exp(&t2,&u,p,&t3);
+				mint_mod_mul(&t1,&t3,p,&y);
+				mint_copy(x,&y);
+				return 1;
+			}
+		}
+		else
+		{
+			//╦ŃĘ©3 p = 1(mod 8)
+			memset(&t1,0,sizeof(MINT));
+			memset(&t2,0,sizeof(MINT));
+			memset(&q,0,sizeof(MINT));
+			memset(&r,0,sizeof(MINT));
+			MI_DWORDTOMINT(&t1,1);
+			mint_sub(p,&t1,&t2);
+			memset(&t1,0,sizeof(MINT));
+			MI_DWORDTOMINT(&t1,8);
+			mint_div(&t2,&t1,&q,&r);
+			if(MINT_ISZERO(&r))
+			{
+				memset(&t1,0,sizeof(MINT));
+				memset(&t2,0,sizeof(MINT));
+				memset(&y,0,sizeof(MINT));
+				memset(&m,0,sizeof(MINT));
+				MI_DWORDTOMINT(&t1,1);
+				mint_add(p,&t1,&k);
+				mint_right_move(&k,1);
+				mint_copy(&y,g);
+				if(mint_random(p,&y,&m)!=0)
+				{
+					return -1;
+				}
+				if(mint_sqr(&y,&m,p,&t2)!=0)
+				{
+					return -1;
+				}
+				mint_copy(x,&t2);
+				return 1;
+			}
+		}
+	}
+	return 0;
+}
+/*====================================================================*/
+static int mint_random(MINT *p,MINT *y,MINT *x)
+{
+	int i=2;
+	int r=-1;
+	MINT t;
+	MINT t1,t2,t3;
+	
+	/* Disable warning */
+	UNUSED(y);
+	
+	memset(&t,0,sizeof(MINT));
+	memset(&t1,0,sizeof(MINT));
+	memset(&t2,0,sizeof(MINT));
+	memset(&t3,0,sizeof(MINT));
+
+	MI_DWORDTOMINT(&t1,1);
+	mint_sub(p,&t1,&t2);
+	memset(&t1,0,sizeof(MINT));
+	mint_copy(&t1,&t2);
+	mint_right_move(&t1,1);
+	do
+	{
+		if (i < 22)
+		{
+			MI_DWORDTOMINT(&t,i);
+		}
+		else
+		{
+			gen_random_number(&t,p,1);
+			if(MINT_ISZERO(&t))
+			{
+				return -1;
+			}
+		}
+		mint_exp(&t,&t1,p,&t3);
+		if(mint_compare(&t2,&t3)!=0)
+		{
+			r=1;
+		}
+		else
+		{
+			mint_copy(x,&t);
+			r=0;
+		}
+	}while((r==1) && ((++i)<82));
+
+	return r;
+}
+/*--------------------------------------------------------------------*/
+static int mint_sqr(MINT *a,MINT *b,MINT *p,MINT *y)
+{
+#ifdef SQRT_EXP_LEN
+	MINT t1,t2,t3,t4;
+	MINT aq;
+	MINT at,bt;
+	MINT qq;
+	int flag=0;
+	int i;
+
+	memset(&t1,0,sizeof(MINT));
+	memset(&t2,0,sizeof(MINT));
+	memset(&t3,0,sizeof(MINT));
+	memset(&t4,0,sizeof(MINT));
+	memset(&qq,0,sizeof(MINT));
+	memset(&aq,0,sizeof(MINT));
+	memset(g_bq,0,sizeof(MINT)*SQRT_EXP_LEN);
+	memset(&at,0,sizeof(MINT));
+	memset(&bt,0,sizeof(MINT));
+
+	MI_DWORDTOMINT(&t1,1);
+	mint_sub(p,&t1,&t2);
+	mint_copy(&qq,&t2);
+	mint_right_move(&qq,1);
+	mint_copy(&aq,&qq);
+	mint_copy(&at,a);
+	mint_copy(&bt,b);
+
+	while(1)
+	{
+		mint_right_move(&aq,1);
+		mint_exp(&at,&aq,p,&t3);
+		i=0;
+		while(i<flag)
+		{
+			mint_right_move(&g_bq[i],1);
+			mint_exp(&bt,&g_bq[i],p,&t4);
+			mint_mod_mul(&t3,&t4,p,&t3);
+			i++;
+		}
+		if(mint_compare(&t2,&t3)==0)
+		{
+			mint_copy(&g_bq[flag],&qq);
+			flag++;
+		}
+		if((aq.len>0) && (aq.value[0]&ONE_DWORD_VALUE))
+		{
+			mint_add(&aq,&t1,&aq);
+			mint_right_move(&aq,1);
+			mint_exp(&at,&aq,p,&t3);
+			i=0;
+			while(i<flag)
+			{
+				mint_right_move(&g_bq[i],1);
+				mint_exp(&bt,&g_bq[i],p,&t4);
+				mint_mod_mul(&t3,&t4,p,&t3);
+				i++;
+			}
+			break;
+		}
+	}
+	mint_copy(y,&t3);
+	return 0;
+#else
+	return -1;
+#endif
+}
+/*====================================================================*/
