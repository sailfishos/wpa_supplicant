+int 
+X509_Get_Prikey(unsigned char *inprikey, int inprikey_len,
+		unsigned char *prikey, int *prikey_len)
+{
+	X509_PRIVATEKEY prikey_ctx;
+	unsigned char out[CHAR_LENGTH] = { 0 };
+	int outlen = CHAR_LENGTH;
+	
+	memset(&prikey_ctx, 0, sizeof(X509_PRIVATEKEY));		
+	/* unpack user prikey */		
+	if (Unpack_X509_PrivateKey(inprikey, inprikey_len, &prikey_ctx) != CTP_OK)		
+	{			
+		wapi_printf(MSG_ERROR, "unpack user prikey error\n");			
+		return -1;		
+	}
+	
+	memset(out, 0, CHAR_LENGTH);		
+	/* get user prikey */		
+	if (Get_X509_PK_PrivateKey(&prikey_ctx, out, &outlen) != CTP_OK)		
+	{			
+		wapi_printf(MSG_ERROR, "get user prikey error\n");			
+		return -1;		
+	}		
+
+	if (*prikey_len < outlen)
+	{
+		wapi_printf(MSG_ERROR, "prikey buffer is too small.\n");
+		return -1;
+	}
+	memcpy(prikey, out, outlen);		
+	*prikey_len = outlen;
+
+	return 0;
+
+}
