+static int asue_x_x_p_derivation(struct wapi_asue_st *wpa_s)
+{
+    if (wpa_s == NULL)
+	{	
+		return -1;
+	}
+	
+    /* Reset buffer */
+	wpa_s->asue_eck.length = 0;
+	memset(wpa_s->asue_eck.data, 0, sizeof(wpa_s->asue_eck.data));
+	wpa_s->asue_key_data.length = 0;
+	memset(wpa_s->asue_key_data.data, 0, sizeof(wpa_s->asue_key_data.data));
+
+    /* 
+	 * Get the public key and the private key for ECC alg 
+	 * The ecc_new_key func return 48 bytes pubkey, 
+	 * but the asue_key_data.data
+	 * need 49 bytes, so the pointer 
+	 * asue_key_data.data offset 1 byte
+	 * and then set asue_key_data.data[0] to 0x04
+	*/
+	if (ecc_new_key(wpa_s->asue_eck.data, wpa_s->asue_key_data.data + 1) != 0)
+	{
+	     return -1;
+	}
+	wpa_s->asue_eck.length = SECKEY_LEN;
+	wpa_s->asue_key_data.data[0] = 0x04;
+	wpa_s->asue_key_data.length  = PUBKEY2_LEN;
+
+	return 0;
+}
+
+static int asue_certauthbk_derivation(struct wapi_asue_st *wpa_s)
+{
+	char input_text[] = "base key expansion for key and additional nonce";
+	u8 text[256] = {0,};
+	u8 temp_out[48] = {0,};
+	u8 ecdhkey[24] = {0,};
+	int ecdhkeyl = sizeof(ecdhkey);
+	int ret = -1;
+
+	wapi_hexdump(MSG_DEBUG, "asue_eck", 
+				wpa_s->asue_eck.data, wpa_s->asue_eck.length);
+	wapi_hexdump(MSG_DEBUG, "ae_key_data", 
+				wpa_s->ae_key_data.data, wpa_s->ae_key_data.length);
+
+	/* 
+	 * The ecc_ecdh_compute func need 48 bytes pubkey, 
+	 * but the ae_key_data.data
+	 * has 49 bytes, so the pointer 
+	 * ae_key_data.data offset 1 byte
+	*/
+	ret = ecc_ecdh_compute(wpa_s->asue_eck.data, 
+				wpa_s->ae_key_data.data + 1, ecdhkey);
+	if (ret != 0)
+	{
+		wapi_printf(MSG_DEBUG, "ecdh compute faild: in %s:%d", 
+					__func__, __LINE__);
+		ret = -1;
+		return ret;
+	}
+
+	/* wapi_hexdump(MSG_DEBUG, "ecdhkey", ecdhkey,ecdhkeyl); */
+	
+	memset(text, 0, sizeof(text));
+	memcpy(text, wpa_s->Nae, 32);
+	memcpy(text + 32, wpa_s->Nasue, 32);
+	memcpy(text + 32 + 32, input_text, strlen(input_text));
+	iwn_kdhmac_sha256(text, 32 + 32 + strlen(input_text), 
+					ecdhkey, 24,
+					temp_out, 16 + 32);
+	wapi_hexdump(MSG_DEBUG, "text", text, 32 + 32 + strlen(input_text));
+	wapi_hexdump(MSG_DEBUG, "temp_out", temp_out, 48);
+	
+	memcpy(wpa_s->wapi_sm->bksa.bk, temp_out, 16);
+	
+	memset(text, 0, sizeof(text));
+	memcpy(text, wpa_s->bssid, ETH_ALEN);
+	memcpy(text + ETH_ALEN, wpa_s->own_addr, ETH_ALEN);
+	wapi_hexdump(MSG_DEBUG, "text1", text, 32 + 32 + strlen(input_text));
+	
+	iwn_kdhmac_sha256(text, 12,
+					wpa_s->wapi_sm->bksa.bk, 16, 
+					wpa_s->wapi_sm->bksa.bkid, 16);
+	
+	iwn_mhash_sha256(temp_out + 16, 32, wpa_s->ae_auth_flag);
+	
+	wapi_hexdump(MSG_ERROR, "bk", wpa_s->wapi_sm->bksa.bk, 16);
+	wapi_hexdump(MSG_ERROR, "bkid", wpa_s->wapi_sm->bksa.bkid, 16);
+	
+	ret = 0;
+
+	return ret;
+}
