+/*--------------------------------------------------------------------*/
+#define IWN_ECC_ECDSA_WAPI
+
+#define ECDSA_OK								0x0                    
+#define ECDSA_BASE                              0x01000000               
+#define ECDSA_VERIFYERR                         ECDSA_BASE + 0x0000000E 
+
+#define ECDSA_MAX_BITS                          256
+#define ECDSA_MAX_LEN                           ((ECDSA_MAX_BITS+7) / 8)
+
+int ECDSA_ExternalSign_ECC(EccCurveHandle *Curve, MINT *PrivateKey, unsigned char *Data, unsigned int DataLength, MINT *r, MINT *s, int HashType)
+{	
+	MINT hv;
+	MINT k,t,one;
+	ECC_FpPOINT pt;
+	int ret=-1;
+
+	memset(&hv,0,sizeof(MINT));
+	memset(&k,0,sizeof(MINT));
+	memset(&t,0,sizeof(MINT));
+	memset(&one,0,sizeof(MINT));
+	memset(&pt,0,sizeof(ECC_FpPOINT));
+	
+	octetstring_to_mint(Data,DataLength,&hv);
+
+#ifdef IWN_ECC_ECDSA_WAPI
+	mint_mod(&hv,&(Curve->g_fp_curve.N), &hv);//WAPI▒žąļ
+#endif
+
+	do{
+		do {
+			gen_random_number(&k,&(Curve->g_fp_curve.N),HashType);
+			ecc_fix_point_mul(&k,&(Curve->g_fp_curve.G),&(Curve->g_fp_curve.A),&(Curve->g_fp_curve.B),&(Curve->g_fp_curve.P),&pt,Curve->g_GPt_1);
+			mint_mod(&(pt.x),&(Curve->g_fp_curve.N),r);
+		}while (MINT_ISZERO(r));
+
+		mint_mod_mul(PrivateKey,r,&(Curve->g_fp_curve.N),&t);
+		mint_mod_add(&t,&hv,&(Curve->g_fp_curve.N),s);
+		mint_EEA_algo(&k,&(Curve->g_fp_curve.N),&t);
+		mint_mod_mul(&t,s,&(Curve->g_fp_curve.N),s);
+	}while(MINT_ISZERO(s));
+	ret = ECDSA_OK;
+
+	return ret;
+}
+/*-------------------------------------------------------------------------------*/
+int ECDSA_ExternalVerify_ECC(EccCurveHandle *Curve, ECC_FpPOINT *PublicKey, unsigned char *Data, unsigned int DataLength, MINT *r, MINT *s)
+{
+	MINT hv;
+	MINT c,k,t;
+	ECC_FpPOINT pt0,pt1,pt2;	
+	int ret=-1;
+
+	memset(&hv,0,sizeof(MINT));
+	memset(&c,0,sizeof(MINT));
+	memset(&k,0,sizeof(MINT));
+	memset(&t,0,sizeof(MINT));
+	memset(&pt0,0,sizeof(ECC_FpPOINT));
+	memset(&pt1,0,sizeof(ECC_FpPOINT));
+	memset(&pt2,0,sizeof(ECC_FpPOINT));
+	
+	octetstring_to_mint(Data,DataLength,&hv);
+
+#ifdef IWN_ECC_ECDSA_WAPI
+	mint_mod(&hv,&(Curve->g_fp_curve.N), &hv);//WAPI▒žąļ
+#endif
+
+	mint_EEA_algo(s,&(Curve->g_fp_curve.N),&c);
+	mint_mod_mul(&hv,&c,&(Curve->g_fp_curve.N),&k);
+	mint_mod_mul(r,&c,&(Curve->g_fp_curve.N),&t);
+
+	ecc_fix_point_mul(&k,&(Curve->g_fp_curve.G),&(Curve->g_fp_curve.A),&(Curve->g_fp_curve.B),&(Curve->g_fp_curve.P),&pt0,Curve->g_GPt_1);
+	ecc_unknown_point_mul(&t,PublicKey,&(Curve->g_fp_curve.A),&(Curve->g_fp_curve.B),&(Curve->g_fp_curve.P),&pt1);
+	ecc_point_add(&pt0,&pt1,&(Curve->g_fp_curve.A),&(Curve->g_fp_curve.B),&(Curve->g_fp_curve.P),&pt2);
+	mint_mod(&(pt2.x),&(Curve->g_fp_curve.N),&k);
+
+	if(mint_compare(&k,r)!=0)
+	{
+		ret = ECDSA_VERIFYERR;
+	}
+	else
+	{
+		ret = ECDSA_OK;
+	}
+	
+	return ret;
+}
+/*--------------------------------------------------------------------*/
+int ECES_ExternalEncrytp_ECC(EccCurveHandle *Curve, ECC_FpPOINT *PublicKey, unsigned char *Data, unsigned int DataLength, unsigned int FixLen, 
+							 int HashType, unsigned char *XData, unsigned char *YData, unsigned char *CipherData,unsigned char *MData)
+{
+	ECC_FpPOINT pt1,pt2;
+	MINT m,k,t;
+	unsigned int len=0;
+	int ret=-1;
+
+	/* Disable warning */
+	UNUSED(DataLength);
+	
+	memset(&pt1,0,sizeof(ECC_FpPOINT));
+	memset(&pt2,0,sizeof(ECC_FpPOINT));
+	memset(&m,0,sizeof(MINT));
+	memset(&k,0,sizeof(MINT));
+	memset(&t,0,sizeof(MINT));
+
+
+	octetstring_to_mint(Data,FixLen,&m);
+
+	do{
+		gen_random_number(&k,&(Curve->g_fp_curve.N),HashType);
+		ecc_fix_point_mul(&k,&(Curve->g_fp_curve.G),&(Curve->g_fp_curve.A),&(Curve->g_fp_curve.B),&(Curve->g_fp_curve.P),&pt1,Curve->g_GPt_1);
+		ecc_unknown_point_mul(&k,PublicKey,&(Curve->g_fp_curve.A),&(Curve->g_fp_curve.B),&(Curve->g_fp_curve.P),&pt2);
+	}while(MINT_ISZERO(&(pt2.x)));
+	mint_mod_mul(&m,&(pt2.x),&(Curve->g_fp_curve.P),&t);
+
+	mint_to_fixedlen_os(&(pt1.x),FixLen,ECDSA_MAX_LEN,&len,XData);
+	mint_to_fixedlen_os(&(pt1.y),FixLen,ECDSA_MAX_LEN,&len,YData);
+	mint_to_fixedlen_os(&t,FixLen,ECDSA_MAX_LEN,&len,CipherData);
+	memset(MData,0,ECDSA_MAX_LEN);
+	ret = ECDSA_OK;
+	
+	return ret;
+}
+
+/*--------------------------------------------------------------------*/
+int ECES_ExternalDecrypt_ECC(EccCurveHandle *Curve, MINT *PrivateKey, unsigned int FixLen, unsigned char *XData, 
+							 unsigned char *YData, unsigned char *CipherData, unsigned char *Data, unsigned int *DataLength)
+{
+	ECC_FpPOINT pt1,pt2;
+	MINT m,k,t;
+	unsigned int len=0;
+	int ret=-1;
+    unsigned char pt22[ECDSA_MAX_LEN]={0};
+	unsigned char pp[ECDSA_MAX_LEN]={0};
+
+	memset(&pt1,0,sizeof(ECC_FpPOINT));
+	memset(&pt2,0,sizeof(ECC_FpPOINT));
+	memset(&m,0,sizeof(MINT));
+	memset(&k,0,sizeof(MINT));
+	memset(&t,0,sizeof(MINT));
+
+	octetstring_to_mint(XData,FixLen,&(pt1.x));
+	octetstring_to_mint(YData,FixLen,&(pt1.y));
+	pt1.is_infinite = 0;
+	octetstring_to_mint(CipherData,FixLen,&t);
+
+	ecc_unknown_point_mul(PrivateKey,&pt1,&(Curve->g_fp_curve.A),&(Curve->g_fp_curve.B),&(Curve->g_fp_curve.P),&pt2);
+
+    mint_to_fixedlen_os(&(pt2.x),FixLen,ECDSA_MAX_LEN,&len,pt22);
+	mint_to_fixedlen_os(&(Curve->g_fp_curve.P),FixLen,ECDSA_MAX_LEN,&len,pp);
+
+	mint_EEA_algo(&(pt2.x),&(Curve->g_fp_curve.P),&k);
+	mint_mod_mul(&k,&t,&(Curve->g_fp_curve.P),&m);
+
+	mint_to_octetstring(&m,ECDSA_MAX_LEN,Data,&len);
+	*DataLength = len;
+	ret = ECDSA_OK;
+		
+	return ret;
+}
+/*----------------------------------------------------------------------------*/
+int EcdhKeyAgreement(EccCurveHandle *Curve, MINT *PrivateKey, ECC_FpPOINT *PublicKey, unsigned int FixLen, unsigned char *KeyData)
+{
+	ECC_FpPOINT dhkey;
+	unsigned int len=0;
+	int ret=-1;
+
+	memset(&dhkey,0,sizeof(ECC_FpPOINT));
+
+	ecc_unknown_point_mul(PrivateKey,PublicKey,&(Curve->g_fp_curve.A),&(Curve->g_fp_curve.B),&(Curve->g_fp_curve.P),&dhkey);
+	mint_to_fixedlen_os(&(dhkey.x),FixLen,ECDSA_MAX_LEN,&len,KeyData);
+
+	ret = ECDSA_OK;
+	return ret;
+}
