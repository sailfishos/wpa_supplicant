+’╗┐/* 
+* Copyright ┬® 2000-2012 China IWNCOMM Co., Ltd. All rights reserved.
+*
+* Module:        Bigint arithmetic methods.           
+* Description:   Bigint arithmetic methods implement,includes 
+*                add,aubtract,multiply,divide,modular,inverse.
+* Writer:        zhangguoqiang@DST <zhanggq@iwncomm.com>
+* Version:  $Id:mint.c,v 1.0 2011/12/09 09:00:00 zhangguoqiang Exp $     
+*
+* History: 
+* zhangguoqiang    2011/12/09    v1.0    Created.
+*/
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include "mint_1.h"
+
+#ifndef max
+#define max(a,b) a>b?a:b
+#endif
+
+#ifndef min
+#define min(a,b) a<b?a:b
+#endif
+/*====================================================================*/
+int octetstring_to_mint_c(const unsigned char *octstr_val, unsigned int octstr_len,MINT *mint_val)
+{
+	dword word;
+	int i, j, k, t, wlen;
+	memset(mint_val,0,sizeof(MINT));
+	wlen = (octstr_len+MI_BYTES_PER_DWORD-1)/MI_BYTES_PER_DWORD;
+	for (i = octstr_len, j = 0; i > 0; i -= 4, ++ j) 
+	{
+		word = 0;
+		t = (int)min (i, (int)MI_BYTES_PER_DWORD);
+		for (k = 0; k < t; ++ k) 
+		{
+			word = (word << MI_BITS_PER_BYTE) | octstr_val[i - t + k];
+		}
+		mint_val->value[j] = word;
+	}
+	mint_adjust_len_c(mint_val, wlen);
+	return 0;
+}
+/*--------------------------------------------------------------------*/
+int mint_to_octetstring_c(const MINT *mint_val,int buflen,unsigned char *octstr_val,unsigned int *octstr_len)
+{
+	dword word;
+	int i, j, k, t;
+	int ret = 0;
+
+	for (i = mint_val->len - 1, j = 0; i >= 0; -- i) 
+	{
+		t = MI_BYTES_PER_DWORD;
+		word = mint_val->value[i];
+		if (i == mint_val->len - 1) 
+		{
+			while ((word>>((t-1)*MI_BITS_PER_BYTE)==0)&&(t>1))
+				-- t;
+			if((int)(t+i*MI_BYTES_PER_DWORD) > buflen)
+			{
+				ret = 1;
+				break;
+			}
+		}
+		for (k = t - 1; k >= 0; -- k)
+		{
+			octstr_val[j++] = (unsigned char)(mint_val->value[i]>>(k*MI_BITS_PER_BYTE));
+		}
+	}
+	if (ret == 0)
+		*octstr_len = j;
+
+	return ret;
+}
+/*====================================================================*/
+/* dest = src */
+int mint_copy_c(MINT *dest,MINT *src)
+{
+	int i;
+	for (i=0;i<src->len;i++)
+	{
+		dest->value[i] = src->value[i];
+	}
+	dest->len = src->len;
+	return 0;
+}
+/*--------------------------------------------------------------------*/
+int mint_adjust_len_c(MINT *mint_val,int len)
+{
+	int i;
+	for (i = len - 1; i >= 0; -- i)
+	{
+		if (mint_val->value[i] != 0)
+			break;
+	}
+	mint_val->len = i + 1;
+	return 0;
+}
+/*====================================================================*/
+/* sum=addend1+addend2 */
+int mint_add_c(MINT *addend1,MINT *addend2,MINT *sum)
+{
+	int i,n;
+	dword s[2]={0};
+	MINT *lv,*sv;
+
+	n = max(addend1->len,addend2->len);
+
+	if (addend1->len > addend2->len)
+	{
+		lv = addend1;
+		sv = addend2;
+	}
+	else
+	{
+		lv = addend2;
+		sv = addend1;
+	}
+
+	for (i=0;i<lv->len;i++)
+	{
+		if(i<sv->len)
+			s[0] = lv->value[i]+sv->value[i]+s[1];
+		else
+			s[0] = lv->value[i]+s[1];
+		if(s[0]<lv->value[i])
+			s[1]=1;
+		else
+			s[1]=0;
+		sum->value[i]=s[0];
+	}
+	
+	if (s[1] == 1) 
+	{
+		sum->value[n]=s[1];
+		sum->len = n + 1;
+	}
+	else
+	{
+		sum->len = n;
+	}
+	return 0;
+}
+/*--------------------------------------------------------------------*/
+int get_mint_bit_len_c(MINT *x)
+{
+	int len,i;
+	dword k;
+	len = (x->len>1)?((x->len-1)*BITS_DWORD_SIZE):0;
+	k = x->value[x->len-1];
+	for(i=0;(i<(int)BITS_DWORD_SIZE)&&(k!=0);++i,k>>=1);
+	len+=i;
+	return len;
+}
+/*====================================================================*/
