+void iwn_wapi_sm_rx_wai(struct wapi_asue_st *wpa_s, 
+				const unsigned char *src_addr, 
+				const unsigned char *buf, size_t len)
+{
+	size_t plen;
+	struct wai_hdr *hdr;
+	u8 *wai_payload;
+	int res = 0;
+	int frmlen = 0;
+
+	/* Disable warning */
+	UNUSED(src_addr);
+
+	if (wpa_s->wapi_state < WAPISM_AL_ASSOC)
+	{
+		wapi_printf(MSG_DEBUG, "wpa_s->wapi_state < WAPISM_AL_ASSOC");	
+		return ;
+	}
+	
+	/*
+	else if ((wpa_s->ap_type == AUTH_TYPE_WAPI_CERT) && (iwn_eloop.has_cert == 0))
+	{
+		wapi_printf(MSG_DEBUG, "No cert");	
+		return ;
+	}
+	*/
+
+	hdr = (struct wai_hdr *) buf;
+	if (check_wai_frame(wpa_s, buf, len) != 0)
+	{
+		wpa_s->rxfrag = free_rxfrag(wpa_s->rxfrag);
+		return;
+	}
+	wai_payload = (u8 *) (hdr + 1);
+
+	GETSHORT((buf + 6), frmlen);
+
+	plen = frmlen - sizeof(*hdr);
+
+	switch (hdr->stype) 
+	{
+		case WAI_AUTHACTIVE:
+			res = waigroup_cert_1_3(wpa_s, wai_payload, plen);
+			if (res == -1)
+			{
+				wapi_printf(MSG_ERROR, "WPA: WAI_AUTHACTIVE frame is wrong\n");
+			}
+			else if (res == -2) 
+			{
+				wapi_printf(MSG_ERROR, "WPA: WAI_AUTHACTIVE can "
+						"not auto find the match cert. \n");
+				/* Delete 2018.3.8 */
+				/* setWapiIncorrect(); */
+				wlan_deauth_for_otherc();
+			}
+			break;
+			
+		case WAI_ACCESS_AUTH_RESPONSE:
+			res = waigroup_cert_3_3(wpa_s, wai_payload, plen);
+			if (0 == res) 
+			{
+				wapi_printf(MSG_INFO, "WPA: WAI_ACCESS_AUTH_RESPONSE frame is right\n");
+				timer_reset();
+			} 
+			else if (-1 == res) 
+			{
+				wapi_printf(MSG_INFO, "WPA: WAI_ACCESS_AUTH_RESPONSE frame is wrong\n");
+				/* timer_resend(); */
+			} 
+			else if (-2 == res) 
+			{
+				wapi_printf(MSG_INFO, "WPA: WAI_AUTHACTIVE  cert  check error\n");
+				/* Delete 2018.3.8 */
+				/* setWapiIncorrect(); */
+				wlan_deauth_for_otherc();
+			}
+			break;
+			
+		case WAI_USK_NEGOTIATION_REQUEST:
+				res = waigroup_unicast_1_3(wpa_s, wai_payload, plen);
+				if (res == -1)
+				{
+				}
+				else if (-2 == res) 
+				{
+					wapi_printf(MSG_INFO, "WAI: pre shared key error \n");
+					/* Delete 2018.3.8 */
+					/* setWapiIncorrect(); */
+					wlan_deauth_for_otherc();
+				}
+				break;
+				
+		case WAI_USK_NEGOTIATION_CONFIRMATION:
+				res = waigroup_unicast_3_3(wpa_s, wai_payload, plen);
+				if (0 == res) 
+				{
+					timer_reset();
+				}  
+				else if (-1 == res) 
+				{
+					/* timer_resend(); */
+				}  
+				else if (-2 == res) 
+				{
+					wapi_printf(MSG_ERROR, "WAI: waigroup_unicast_3_3 wlan deauth \n");
+					/* Delete 2018.3.8 */
+					/* setWapiIncorrect(); */
+					wlan_deauth_for_otherc();
+				}
+				break;
+		case WAI_MSK_ANNOUNCEMENT:
+				res = waigroup_multicast_1_2(wpa_s, wai_payload, plen);
+				if (-2 == res)
+				{
+					wapi_printf(MSG_ERROR, "WAI: waigroup_multicast_1_2 wlan deauth \n");
+					/* Delete 2018.3.8 */
+					/* setWapiIncorrect(); */
+					wlan_deauth_for_otherc();
+				}
+			break;
+
+		case WAI_STAKEY_REQUEST:
+			wapi_printf(MSG_DEBUG, "WPA: receive ignore frame stype %u", hdr->stype);
+			break;
+
+		case WAI_PREAUTH_START:
+		case WAI_ACCESS_AUTH_REQUEST:
+		case WAI_CERT_AUTH_REQUEST:
+		case WAI_CERT_AUTH_RESPONSE:
+		case WAI_USK_NEGOTIATION_RESPONSE:
+		case WAI_MSK_ANNOUNCEMENT_RESPONSE:
+			wapi_printf(MSG_DEBUG, "WPA: receive error frame stype %u", hdr->stype);
+			break;
+
+		default:
+			wapi_printf(MSG_DEBUG, "WPA: receive unknown frame stype %u", hdr->stype);
+			return;
+	}
+	
+	wpa_s->rxfrag = free_rxfrag(wpa_s->rxfrag);
+}
+
+static int waigroup_cert_1_3(struct wapi_asue_st* wpa_s, u8* payload, int len)
+{
+	u8 flag = 0;
+	u8 *ae_auth_flag = NULL;
+	u8 *asu_id = NULL;
+	u8 *ae_cer = NULL;
+	u8 *ecdh = NULL;
+	int ret = -1;
+	
+	u8 auth_act_len = WAI_FLAG_LEN  
+		+32
+		+2/*ASU ID Identifier*/
+		+2/*ASU ID Length*/
+		+2/*AE Cert type*/
+		+2/*AE Cert length*/
+		+1/*ECDH Parameter Identifier*/
+		+2/*ECDH Parameter Length */;
+
+	wapi_printf(MSG_DEBUG, "WAI: in %s:%d:\n", __func__, __LINE__);
+	
+	if (len < auth_act_len)
+	{
+		wapi_printf(MSG_ERROR, "WPA: WAI frame payload too short");
+		return -1;
+	}
+
+	flag = payload[0];
+	
+	wpa_s->flag = flag;	
+	ae_auth_flag = payload + 1;
+	asu_id = payload + 1 + 32;
+	
+	len -= auth_act_len;
+	
+	if (AUTH_TYPE_WAPI_CERT != wpa_s->ap_type)
+	{
+		return -1;
+	}
+	else
+	{
+		int bk_up = flag & BIT(0);
+		wapi_states require = bk_up ? WAPISM_FINISH : WAPISM_AL_ASSOC;
+		
+		if (wpa_s->wapi_state != require)
+		{
+		    /* skip the usk update check */
+		    if (wpa_s->usk_updated && bk_up && wpa_s->wapi_state == WAPISM_UNI_ACK)
+			{
+			}
+			else
+			{
+				wapi_printf(MSG_ERROR, "WAI: in %s:%d: wapi state error, "
+						"drop the frame.", __func__, __LINE__);
+				return -1;
+			}
+		}
+		
+		/*bk update flag*/
+		if (bk_up)
+		{
+			wapi_printf(MSG_INFO, "BK update\n");
+			wpa_s->bk_update_flag = 1;
+		}
+		else
+		{
+			wpa_s->bk_update_flag = 0;
+			/* Add 2018.3.13 */
+			wapi_notify_connect_state(WAPI_AUTHENTICATING);
+		}
+	}
+	
+	if (flag & BIT(0))
+	{
+		/* save auth_active_retry flag */
+		wpa_s->auth_active_retry = 1;	
+		if (memcmp(ae_auth_flag, wpa_s->ae_auth_flag, 32) != 0)
+		{
+			wapi_printf(MSG_ERROR, "WPA: ae_auth_flag not same!\n");
+			return -1;
+		}
+	}
+	else
+	{
+		/* clear auth_active_retry flag */
+		wpa_s->auth_active_retry = 0;	
+		memcpy(wpa_s->ae_auth_flag, ae_auth_flag, 32);
+	}
+	
+	/* get ASU ID */	
+	GETSHORT(asu_id, wpa_s->ae_asu_id.id_flag); 
+	GETSHORT((asu_id + 2), wpa_s->ae_asu_id.id_len);
+
+	if (wpa_s->ae_asu_id.id_flag != 1)
+	{
+		wapi_printf(MSG_ERROR, "WPA: local asu id flag error(flag != 1)");
+		return -1;
+	}
+
+	if (len < wpa_s->ae_asu_id.id_len)
+	{
+		wapi_printf(MSG_ERROR, "WPA: WAI frame payload too short");
+		return -1;
+	}
+	
+	if ((u16)sizeof(wpa_s->ae_asu_id.id_data) < wpa_s->ae_asu_id.id_len)
+	{
+		wapi_printf(MSG_ERROR, 
+				"ASU id received from AP is too large");
+		return -1;
+	}
+	
+	memcpy(wpa_s->ae_asu_id.id_data, asu_id + 4, wpa_s->ae_asu_id.id_len);
+	
+	len -= wpa_s->ae_asu_id.id_len; 
+
+	/*get AE Certificate*/
+	ae_cer = asu_id + 2 + 2 + wpa_s->ae_asu_id.id_len;
+	
+	GETSHORT(ae_cer, wpa_s->ae_cert.cert_flag); 
+	GETSHORT((ae_cer + 2), wpa_s->ae_cert.length); 
+	
+	if (len < wpa_s->ae_cert.length)
+	{
+		wapi_printf(MSG_ERROR, "WPA: WAI frame payload too short");
+		return -1;
+	}
+
+	if ((u16)sizeof(wpa_s->ae_cert.data) < wpa_s->ae_cert.length)
+	{
+		wapi_printf(MSG_ERROR, 
+				"AE cert received from AP is too large");
+		return -1;
+	}
+
+	memcpy(wpa_s->ae_cert.data, ae_cer + 4, wpa_s->ae_cert.length);
+
+	len -= wpa_s->ae_cert.length;
+	
+	/*get AE ID*/
+	get_cert_identity(&(wpa_s->ae_cert), &(wpa_s->ae_id), 
+			wpa_s->ae_cert.cert_flag);
+	
+	/*get ECDH Parameter*/
+	ecdh = ae_cer + 2 + 2 + wpa_s->ae_cert.length;
+
+	if (ecdh[0] != 1)
+	{
+		wapi_printf(MSG_ERROR, "WPA: WAI error ecdh flag   ");
+		return -1;
+	}
+	wpa_s->ecdh.para_flag = ecdh[0];
+	GETSHORT((ecdh + 1), wpa_s->ecdh.para_len);
+
+	if (len < wpa_s->ecdh.para_len)
+	{	
+		wapi_printf(MSG_ERROR, "WPA: WAI frame payload too short");
+		return -1;
+	}
+
+	if ((u16)sizeof(wpa_s->ecdh.para_data) < wpa_s->ecdh.para_len)
+	{
+		wapi_printf(MSG_ERROR, 
+				"ECDH received from AP is too large");
+		return -1;
+	}
+
+	memcpy(wpa_s->ecdh.para_data, ecdh + 3, wpa_s->ecdh.para_len);
+
+	len -= wpa_s->ecdh.para_len;
+
+	if (len != 0) 
+	{
+		wapi_printf(MSG_ERROR, "in %s:%d: ecdh.para_len error = %d\n",
+					__func__, __LINE__, wpa_s->ecdh.para_len);
+		return -1;
+	}
+	
+	asue_initialize_alg(wpa_s);
+	ret = asue_x_x_p_derivation(wpa_s);
+	if (ret == -1)
+	{
+		return -1;
+	}
+	get_random(wpa_s->Nasue, 32);
+	
+	/* bk update */
+	if (wpa_s->bk_update_flag == 1)
+	{
+		wapi_printf(MSG_DEBUG, "bk update mode \n");
+	}
+	
+	/* auth active frame retry */
+	if (wpa_s->auth_active_retry == 1)
+	{	
+		wpa_s->auth_active_retry = 0;
+		wapi_printf(MSG_DEBUG, "recv again auth active frame \n");
+	}
+	
+	if (get_match_wapi_cert(&(wpa_s->cert_info), &(wpa_s->ae_asu_id)) < 0)
+	{
+        /* wlan_deauth_for_otherc(); */
+		wapi_printf(MSG_ERROR, "wai: in %s:%d get_match_wapi_cert no match cert", 
+					__func__, __LINE__);
+		return -2;
+	}
+	
+	if (waigroup_cert_2_3_send(wpa_s, payload, len))
+	{
+		wapi_printf(MSG_ERROR, "WAI: in %s:%d", __func__, __LINE__);
+		return -1;
+	}
+	
+	/* Add 2017.11.9 */
+	wpa_s->prev_rxseq = wpa_s->curr_rxseq;
+	
+	return 0;
+}
+
+static int waigroup_cert_2_3_send(struct wapi_asue_st* wpa_s, 
+						u8* payload, int len)
+{
+	static comm_data data_buff;
+	static tsign sign;
+	u8 *sign_len_pos = NULL;
+	/* static u8 tbuf[2048]; */
+	static u8 tbuf[8192];
+	u8 *pos = NULL;
+	/* Certificate information*/
+	wapi_cert_data *cert_info = &(wpa_s->cert_info);
+	/* Current asue certificate */
+	wapi_x509_cert_asue_data *asue_cert_cur = cert_info->asue_cert_cur;
+
+	/* Disable warning */
+	UNUSED(payload);
+	UNUSED(len);
+	
+	wapi_printf(MSG_DEBUG, "WAI: Enter %s\n", __func__);
+	
+	pos = tbuf;
+	memset(pos, 0, sizeof(tbuf));
+	memset(&data_buff, 0, sizeof(data_buff));
+	memset(&sign, 0, sizeof(sign));
+	
+	pos = wpa_build_hdr(pos, ++wpa_s->txseq, WAI_ACCESS_AUTH_REQUEST);
+	wpa_s->flag = BIT(2) | wpa_s->flag;
+	
+	if (asue_cert_cur == NULL 
+		|| asue_cert_cur->user_cert_st == NULL
+		|| asue_cert_cur->private_key == NULL
+		|| asue_cert_cur->user_id == NULL)
+	{
+		wapi_printf(MSG_ERROR, "WAI: in %s:%d, current cert is NULL", 
+					__func__, __LINE__);
+		return -1;
+	}
+	
+	/*
+	if (asue_cert_cur->as != NULL)
+	{
+		wapi_printf(MSG_DEBUG, "WAI: Has trust as cert ");
+		wpa_s->flag = BIT(3) | wpa_s->flag;
+	}
+	*/
+	
+	wapi_printf(MSG_DEBUG, "WAI: in %s:%d, wpa_s->flag = %d", 
+				__func__, __LINE__, wpa_s->flag);
+				
+	*pos = wpa_s->flag;
+	pos = pos + 1;
+	pos = MEMCPY(pos, &(wpa_s->ae_auth_flag), 32);
+	pos = MEMCPY(pos, &(wpa_s->Nasue), 32);
+	pos = MEMCPY(pos, &(wpa_s->asue_key_data.length), 1);
+	pos = MEMCPY(pos, &(wpa_s->asue_key_data.data), wpa_s->asue_key_data.length);
+	
+	SETSHORT(pos, wpa_s->ae_id.id_flag); 
+	pos += 2;
+	SETSHORT(pos, wpa_s->ae_id.id_len); 
+	pos += 2;
+	pos = MEMCPY(pos, wpa_s->ae_id.id_data, wpa_s->ae_id.id_len);
+
+	SETSHORT(pos, cert_info->cert_flag); 
+	pos += 2;
+ 
+	SETSHORT(pos, asue_cert_cur->user_cert_st->length); 
+	pos += 2;
+
+	pos = MEMCPY(pos, asue_cert_cur->user_cert_st->data, 
+			asue_cert_cur->user_cert_st->length);
+	
+	/*
+	wapi_hexdump(MSG_DEBUG, "user_cert_st:", 
+		asue_cert_cur->user_cert_st->data, 
+		asue_cert_cur->user_cert_st->length);
+	*/
+	
+	/* Add ecdh */
+	*pos = wpa_s->ecdh.para_flag;
+	pos++;
+	SETSHORT(pos, wpa_s->ecdh.para_len); 
+	pos += 2;
+	pos = MEMCPY(pos, &(wpa_s->ecdh.para_data), wpa_s->ecdh.para_len);
+	
+	data_buff.length = pos - tbuf - sizeof(struct wai_hdr);
+	memcpy(data_buff.data, tbuf + sizeof(struct wai_hdr), data_buff.length);
+	
+	/* Get ecc sign data */
+	if (ecc_sign(
+		data_buff.data, data_buff.length,
+		asue_cert_cur->private_key->data, 
+		sign.data) != 0)
+	{
+		wapi_printf(MSG_ERROR, "Failed to get sign data !!\n");
+		return -1;
+	}
+	
+	*pos ++ = 1;
+	sign_len_pos = pos;
+	pos += 2;
+	
+	/* Add asue cert id*/
+	SETSHORT(pos, asue_cert_cur->user_id->id_flag); 
+	pos += 2;
+	SETSHORT(pos, asue_cert_cur->user_id->id_len); 
+	pos += 2;		
+	pos = MEMCPY(pos, asue_cert_cur->user_id->id_data, 
+		asue_cert_cur->user_id->id_len);
+	
+	/* wapi_hexdump(MSG_DEBUG, "user_id:", 
+		asue_cert_cur->user_id->id_data, 
+		asue_cert_cur->user_id->id_len); */
+		
+	
+	SETSHORT(pos, wpa_s->sign_alg.alg_length); 
+	pos += 2;
+	*pos = wpa_s->sign_alg.sha256_flag; 
+	pos++;
+	*pos = wpa_s->sign_alg.sign_alg; 
+	pos++;
+	*pos = wpa_s->sign_alg.sign_para.para_flag; 
+	pos++;
+	SETSHORT(pos, wpa_s->sign_alg.sign_para.para_len); 
+	pos += 2;
+	pos = MEMCPY(pos, &(wpa_s->sign_alg.sign_para.para_data), 
+			wpa_s->sign_alg.sign_para.para_len);
+	SETSHORT(pos, SIGN_LEN); 
+	pos += 2;
+	pos = MEMCPY(pos, &(sign.data), SIGN_LEN);
+	SETSHORT(sign_len_pos, (pos - sign_len_pos - 2));
+	
+	wai_set_length(tbuf, (short)(pos - tbuf));
+	iwn_wpa_ether_send(tbuf, pos - tbuf);
+	timer_set(1, tbuf, pos - tbuf);
+
+	wpa_s->wapi_state = WAPISM_CNT_REQ;
+
+	return 0;
+}
+
+const char* wapi_cert_state[] = 
+{ 
+	"Being used", 
+	"Unknown Issuer", 
+	"The certificate is based on the untrusted root certificate", 
+	"The certificate is not valid or has already expired", 
+	"Signature error", 
+	"Certificate has been revoked", 
+	"Certificate has not been used regularly", 
+	"Unknown certificate revocation status", 
+	"Unknown certificate error" 
+};
+	
+void show_access_result(struct wapi_asue_st* wpa_s, 
+				u8* acc_res, u8 flag)
+{
+	u8 *asue_key_data = NULL; 
+	u8 *ae_key_data = NULL;
+	u8 *ae_id = NULL; 
+	u8 *asue_id = NULL;
+	u8 *cert_res = NULL;
+	u8 *cert_verify_res_asue = NULL;
+
+	u8 *cert_res1 = NULL;
+	u8 *cert_res2 = NULL;
+	u8 *cert_res_cert1 = NULL;
+	/* u8 *cert_res_cert2 = NULL; */
+	/* u16 cert_flag_temp = 0; */
+	u16 cert_len_temp = 0;
+	
+	char cert_state[32] = "\0";
+	/* Certificate information*/
+	wapi_cert_data *cert_info = &(wpa_s->cert_info);
+	/* Current asue certificate */
+	wapi_x509_cert_asue_data *asue_cert_cur = cert_info->asue_cert_cur;
+	
+	time_t timep;
+	struct tm *p = NULL;
+	char curr_time[64] = "\0";
+	/* get current date and time for print log */
+	time(&timep);
+	p = localtime(&timep);
+	snprintf(curr_time, sizeof(curr_time),
+		"%d/%d/%d %d:%d:%d", 
+		1900 + p->tm_year, 1 + p->tm_mon, p->tm_mday,
+		p->tm_hour, p->tm_min, p->tm_sec);
+	
+	asue_key_data = acc_res + 1;
+	if (asue_key_data == NULL)
+	{
+		return;
+	}
+	
+	ae_key_data = asue_key_data + asue_key_data[0] + 1;
+	if (ae_key_data == NULL)
+	{
+		return;
+	}
+	
+	ae_id = ae_key_data + ae_key_data[0] + 1;
+	if (ae_id == NULL)
+	{
+		return;
+	}
+
+	if (cmp_var_struct(ae_id, &(wpa_s->ae_id), wpa_s->ae_id.id_len))
+	{
+		return;
+	}
+
+	asue_id = ae_id + wpa_s->ae_id.id_len + 4;
+
+	if (flag & BIT(3))
+	{	
+		if (asue_cert_cur == NULL)
+		{
+		 	return;		 
+		}
+		
+	 	if (asue_cert_cur->user_id == NULL)
+		{
+		 	return;
+	 	}
+		
+		if (cmp_var_struct(asue_id, asue_cert_cur->user_id, 
+					asue_cert_cur->user_id->id_len))
+		{
+			return;
+		}
+	
+		/* get cert result */
+		cert_res = asue_id + asue_cert_cur->user_id->id_len + 4;
+		
+		/* get asue cert result */
+		cert_res1 = cert_res + 1 + 2 + 32 + 32;
+		cert_res_cert1 = cert_res1 + 1;
+		
+		/* set asue cert result to cert config file */
+		wapi_printf(MSG_DEBUG, "asue cert verify result is %d, "
+				"cur user cert name %s. \n", 
+				*cert_res1, wpa_s->cert_info.asue_cert_cur->cert_rename);
+
+		/* If the certificate was expired or revoked, then save its state */
+		if (cert_info->wapi_cert_sel_mode == 0
+			&& cert_info->cert_count > 1)
+		{
+			if (*cert_res1 == 3 || *cert_res1 == 5)
+			{
+				snprintf(cert_state, sizeof(cert_state),
+					"%d", *cert_res1);
+				add_cert_state(&(cert_info->cert_state_list), 
+						asue_cert_cur->cert_rename, cert_state);
+				if (save_cert_state_list(cert_info->cert_state_list) != 0)
+				{
+					wapi_printf(MSG_ERROR, "Save certificate [%s] state [%s] faild: %s", 
+							asue_cert_cur->cert_rename, cert_state);
+				}
+			}
+		}
+		
+		/* print log for asue cert result */
+		if (cert_res1[0] != 0)
+		{
+			if (wpa_s->print_log_flag == 1)
+			{
+				/* wapi_printf(MSG_DEBUG, "ASUE cert state print begin:"); */
+				wapi_hexdump(MSG_DEBUG, "ASUE cert id:", 
+							asue_id, asue_cert_cur->user_id->id_len);
+				wapi_printf(MSG_DEBUG, "ASUE cert state: %s", 
+						wapi_cert_state[*cert_res1]);
+				wapi_printf(MSG_DEBUG, "Local time: %s", curr_time);
+				/* wapi_printf(MSG_DEBUG, "ASUE cert state print end"); */
+			}
+			else if (wpa_s->print_log_flag == 2)
+			{
+				wpa_s->cycle_num ++;
+				if (wpa_s->cycle_num == wpa_s->print_log_cycle)
+				{
+					/* wapi_printf(MSG_DEBUG, "ASUE cert state print begin:"); */
+					wapi_hexdump(MSG_DEBUG, "ASUE cert id:", 
+								asue_id, asue_cert_cur->user_id->id_len);
+					wapi_printf(MSG_DEBUG, "ASUE cert state: %s", 
+								wapi_cert_state[*cert_res1]);
+					wapi_printf(MSG_DEBUG, "Local time: %s", curr_time);
+					/* wapi_printf(MSG_DEBUG, "ASUE cert state print end"); */
+					wpa_s->cycle_num = 0;
+				}
+			}
+		}
+		
+		/* get ae cert result */
+		GETSHORT((cert_res_cert1 + 2), cert_len_temp);
+		cert_res2 = cert_res_cert1 + 2 + 2 + cert_len_temp;
+		/* cert_res_cert2 = cert_res2 + 1; */
+
+		/* print log for ae cert result */
+		/* wapi_printf(MSG_DEBUG, "AE cert state print begin:"); */
+		wapi_hexdump(MSG_DEBUG, "AE cert id:", ae_id, wpa_s->ae_id.id_len);
+		if (*cert_res2 >= 0 && *cert_res2 <= 8)
+		{
+			wapi_printf(MSG_DEBUG, "AE cert state: %s", 
+						wapi_cert_state[*cert_res2]);
+		}
+		wapi_printf(MSG_DEBUG, "Local time: %s", curr_time);
+		/* wapi_printf(MSG_DEBUG, "AE cert state print end"); */
+	}
+}
