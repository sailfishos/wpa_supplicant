+	memcpy(p_data_7+pri_key.bits/8,sign.s,pri_key.bits/8);
+	*sign_data = p_data_7;
+	*sign_len = 48;
+
+    outdata_r = data_r;
+	len_r = Der_Integer(sign.r,24,&outdata_r);
+	
+	outdata_s = data_s;
+	len_s = Der_Integer(sign.s,24,&outdata_s);
+
+	len_1=Der_Obj_Len(len_r+len_s,SEQUENCE,1);
+    p_data_1 = buf_1;
+	Der_Put_Obj(&p_data_1,len_r+len_s,SEQUENCE,1,UNIVERSAL);
