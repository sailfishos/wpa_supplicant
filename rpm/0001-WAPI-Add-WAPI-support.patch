+/* 
+* Copyright (c) 2000-2017 China IWNCOMM Co., Ltd. All rights reserved.
+*
+* Module:        Symmetric Cryptography Algorithm Modes          
+* Description:   SM4 cryptography algorithm OFB/MAC Modes.
+* Writer:        wanht@TEVG <wanht@iwncomm.com>
+* Version:  $Id:newmodes.c,v 1.0 2017/11/07 09:00:00 wanht Exp $     
+*
+* History: 
+* wanht    2017/11/07    v1.0    Created.
+*/
+
+#include <stdlib.h>
+#include <string.h>
+#include "sm4alg.h"
+#include "sm4algmodes.h"
+
+/* OFB─Ż╩Į╝ėĮŌ├▄║»╩² */
+/* idata  ╩õ╚ļ╩²Š▌▓╬╩² */
+/* odata  ╩õ│÷╩²Š▌▓╬╩² */
+/* idl    ╩õ╚ļ╩²Š▌│żČ╚▓╬╩² */
+/* iovec  ╩õ╚ļ/╩õ│÷Ž“┴┐▓╬╩² */
+/* kd     ╩õ╚ļ├▄į┐▓╬╩² */
+int ofb_mode_endec_sm4(const unsigned char *idata, unsigned char *odata,
+                       int idl, unsigned char *iovec, unsigned char *kd)
+{
+	int g = 0;
+	int h = 0;
+	ctx_rkey_sm4 cy;
+
+	if (idata == NULL)
+	{
+	    return -1;
+	}
+
+	if (iovec == NULL)
+	{
+	    return -1;
+	}
+
+	if (kd == NULL)
+	{
+	    return -1;
+	}
+
+	if (idl < 1)
+	{
+	    return -1;
+	}
+
+	ext_rkey_sm4alg(&cy, kd, 16);
+	while (g < idl)
+    {
+	    enc_sm4alg(&cy, iovec, iovec);
+
+        while ((g < idl) && (h < 16))
+        {
+            *odata++ = iovec[h++] ^ *idata++;
+            g++;
+        }
+
+		if (h == 16)
+		{
+			h = 0;
+		}
+		/*
+		else
+		{
+		    h = h;
+		}
+		*/
+    }
+
+    return 0;
+}
+
+/* MAC─Ż╩Į╝Ų╦Ń║»╩² */
+/* idata  ╩õ╚ļ╩²Š▌▓╬╩² */
+/* odata  ╩õ│÷╩²Š▌▓╬╩² */
+/* idl    ╩õ╚ļ╩²Š▌│żČ╚▓╬╩²,╬¬16Ą─▒Č╩² */
+/* iovec  ╩õ╚ļ/╩õ│÷Ž“┴┐▓╬╩² */
+/* kd     ╩õ╚ļ├▄į┐▓╬╩² */
+int mac_mode_sm4(const unsigned char *idata, unsigned char *odata,
+                 int idl, unsigned char *iovec, unsigned char *kd)
+{
+	int g = 0;
+	int h = 0;
+	unsigned char tpa[16] = {0};
+	unsigned char tpb[16] = {0};
+	ctx_rkey_sm4 cy;
+
+	if (idata == NULL)
+	{
+	    return -1;
+	}
+
+	if (iovec == NULL)
+	{
+	    return -1;
+	}
+
+	if (kd == NULL)
+	{
+	    return -1;
+	}
+
+	if (idl < 1)
+	{
+	    return -1;
+	}
+
+	if ((idl % 16) != 0)
+	{
+	    return -1;
+	}
+
+	ext_rkey_sm4alg(&cy, kd, 16);
+	enc_sm4alg(&cy, iovec, tpb);
+
+	while (idl) 
+	{
+		for (g = 0; g < 16 && g < idl; g++)
+		{
+			tpa[g] = idata[g] ^ tpb[g];
+		}
+
+		if (idl == 16)
+		{
+			/* iovec╩õ│÷ */
+			for (h = 0; h < 16; h++)
+			{
+				iovec[h] = tpa[h];	
+			}
+		}		
+	
+	    enc_sm4alg(&cy, tpa, tpa);
+		for (h = 0; h < 16; h++)
+		{
+			tpb[h] = tpa[h];
+		}
+
+		if (idl == 16) break;
+		idl -= 16;
+		idata += 16;
+	}
+
+	memcpy(odata, tpa, 16);
+    return 0;
+}
+
+
+
