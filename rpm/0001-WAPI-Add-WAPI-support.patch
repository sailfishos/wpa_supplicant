diff --git a/src/libcert_parse/certcode/Base64.c b/src/libcert_parse/certcode/Base64.c
new file mode 100644
index 0000000..8f450ac
--- /dev/null
+++ b/src/libcert_parse/certcode/Base64.c
@@ -0,0 +1,97 @@
+#include <stdio.h>
+#include <stdlib.h>
+#include "structdef.h"
+
+typedef unsigned char word8;
+
+int EncodeBase64(unsigned char *btSrc, int iSrcLen, unsigned char *btRet, int *piRetLen) //Base64▒Ó┬ļ  
+{  
+	int i = 0, j = 0, k = 0 ;  
+	word8 EncodeBase64Map[] = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";  
+
+	i = (iSrcLen+2) / 3 * 4 ; //╗±╚ĪbtSrcĄ─Base64▒Ó┬ļ╦∙ąĶ╗║│ÕŪ°Ą─┤¾ąĪ  
+	if(btRet != NULL)  
+	{  
+		if(*piRetLen < i) //Base64▒Ó┬ļ╦∙ąĶ╗║│ÕŪ°Ų½ąĪ  
+			return -1 ;  
+		*piRetLen = i ; //*piRetLenĘĄ╗žbtSrcĄ─Base64▒Ó┬ļĄ─╗║│ÕŪ°┤¾ąĪ  
+	}  
+	else  
+	{  
+		*piRetLen = i ;  
+		return 0 ;  
+	}  
+
+	k = iSrcLen - iSrcLen % 3 ;  
+	for(i=j=0; i<k; i+=3) //▒Ó┬ļ  
+	{  
+		btRet[j++] = EncodeBase64Map[(btSrc[i]>>2)&0x3F] ;  
+		btRet[j++] = EncodeBase64Map[((btSrc[i]<<4) + (btSrc[i+1]>>4))&0x3F] ;  
+		btRet[j++] = EncodeBase64Map[((btSrc[i+1]<<2) + (btSrc[i+2]>>6))&0x3F] ;  
+		btRet[j++] = EncodeBase64Map[btSrc[i+2]&0x3F] ;  
+	}  
+	k = iSrcLen - k ;  
+	if(1 == k)  
+	{  
+		btRet[j++] = EncodeBase64Map[(btSrc[i]>>2)&0x3F] ;  
+		btRet[j++] = EncodeBase64Map[(btSrc[i]<<4)&0x3F] ;  
+
+		//btRet[j++] = btRet[j] = '=' ; 
+		btRet[j++] = '='; 
+		btRet[j] = '='; 
+	}  
+	else if(2 == k)  
+	{  
+		btRet[j++] = EncodeBase64Map[(btSrc[i]>>2)&0x3F] ;  
+		btRet[j++] = EncodeBase64Map[((btSrc[i]<<4) + (btSrc[i+1]>>4))&0x3F] ;  
+		btRet[j++] = EncodeBase64Map[(btSrc[i+1]<<2)&0x3F] ;  
+		btRet[j] = '=' ;  
+	}  
+	
+	return ++j ;  
+}  
+
+/*====================================================================  
+ Base64ĮŌ┬ļ║»╩²  
+ btSrcųĖŽ“▒╗ĮŌ┬ļĄ─╩²Š▌╗║│ÕŪ°  
+ iSrcLen▒╗ĮŌ┬ļĄ─╩²Š▌Ą─┤¾ąĪŻ©ūųĮ┌Ż®  
+ btRetųĖŽ“┤µĘ┼Base64ĮŌ┬ļĄ─╩²Š▌╗║│ÕŪ°  
+ piRetLenųĖŽ“┤µĘ┼Base64ĮŌ┬ļĄ─╩²Š▌╗║│ÕŪ°Ą─│żČ╚  
+ ╚¶btRet╬¬NULL║»╩²ĘĄ╗ž0Ż¼piRetLen┤½╗žbtSrcĄ─Base64ĮŌ┬ļ╦∙ąĶ╗║│ÕŪ°Ą─┤¾ąĪ  
+ ╚¶btRetųĖŽ“Ą─╗║│ÕŪ°╠½ąĪŻ¼║»╩²ĘĄ╗ž-1  
+ Ę±į“║»╩²ĘĄ╗žbtSrcĄ─Base64ĮŌ┬ļ╦∙ąĶ╗║│ÕŪ°Ą─┤¾ąĪ  
+=====================================================================*/  
+int DecodeBase64(unsigned char *btSrc, int iSrcLen, unsigned char *btRet, int *piRetLen) //Base64ĮŌ┬ļ  
+{  
+	int i = 0, j = 0 ;  
+	word8 EncodeBase64Map[] = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";  
+	word8 DecodeBase64Map[256] = {0} ;  
+
+	for(j = iSrcLen; j>0 && '='==btSrc[j-1]; --j);
+	
+	i = (j/4)*3+(j%4+1)/2; //╝Ų╦ŃĮŌ┬ļ║¾ ūųĘ¹┤«Ą─│żČ╚  
+	
+	if(btRet != NULL)  
+	{  
+		if(*piRetLen < i) //Base64ĮŌ┬ļ╦∙ąĶ╗║│ÕŪ°Ų½ąĪ  
+			return -1 ;  
+		*piRetLen = i ; //*piRetLenĘĄ╗žbtSrcĄ─Base64ĮŌ┬ļĄ─╗║│ÕŪ°┤¾ąĪ  
+	}  
+	else  
+	{  
+		*piRetLen = i ;  
+		return 0 ;  
+	}  
+
+	j = sizeof(EncodeBase64Map) ;  
+	for(i=0; i<j; ++i)  
+		DecodeBase64Map[ EncodeBase64Map[i] ] = i ;  
+	for(i=j=0; i<iSrcLen; i+=4)  
+	{  
+		btRet[j++] = DecodeBase64Map[btSrc[i  ]] << 2 | DecodeBase64Map[btSrc[i+1]] >> 4 ;  
+		btRet[j++] = DecodeBase64Map[btSrc[i+1]] << 4 | DecodeBase64Map[btSrc[i+2]] >> 2 ;  
+		btRet[j++] = DecodeBase64Map[btSrc[i+2]] << 6 | DecodeBase64Map[btSrc[i+3]] ;  
+	}  
+
+	return *piRetLen ;  
+} 
