+int _wapi_usk_negotiation_res(struct wapi_authenticator *wapi_auth,
+		 struct wapi_state_machine *sm,
+		 u8_t *payload_data, size_t payload_len)
+{
+	u8_t* pos = 0;
+	u8_t uskid;
+	u8_t MIC[WAPI_MIC_LEN];
+	size_t wie_len;
+	u8_t master_key[96];
+	wapi_printf(MSG_DEBUG, "%s Enter ", __func__);
+	struct session_key_neg_response *key_res_buff;
+	
+	if( payload_len <=	1	/*flag*/
+						+WAPI_BKID_LEN	/* BKID*/
+						+1	/*USKID*/
+						+12	/*ADDID*/
+						+WAPI_NONCE_LEN/*ASUE challenge*/
+						+WAPI_NONCE_LEN	/*ASUE challenge*/
+						+2	/*WIE ID+WIE LENGTH*/)
+		return -1;
+
+	key_res_buff = os_malloc(sizeof(struct session_key_neg_response));
+	if (key_res_buff == NULL) {
+		wapi_printf(MSG_ERROR, " wapi_usk_negotiation_res "
+					"malloc session_key_neg_response buf error");
+		return -1;
+	}
+
+	pos = payload_data;
+	os_memcpy((u8_t *)&key_res_buff->flag, pos ,1);
+	pos += 1;
+	os_memcpy(key_res_buff->bkid, pos, WAPI_BKID_LEN);
+	pos += WAPI_BKID_LEN;
+	os_memcpy(&key_res_buff->uskid, pos, 1);
+	pos += 1;
+	os_memcpy(key_res_buff->addid.mac1, pos, ETH_ALEN);
+	pos += ETH_ALEN;
+	os_memcpy(key_res_buff->addid.mac2, pos, ETH_ALEN);
+	pos += ETH_ALEN;
+	os_memcpy(key_res_buff->asue_challenge, pos, WAPI_NONCE_LEN);
+	pos += WAPI_NONCE_LEN;
+	os_memcpy(key_res_buff->ae_challenge, pos, WAPI_NONCE_LEN);
+	pos += WAPI_NONCE_LEN;
+	
+	wie_len = *(pos + 1);
+	key_res_buff->wie_asue = os_malloc(wie_len + 2);
+	
+	if((pos - payload_data) + wie_len + 2 > payload_len)
+	{
+		wapi_printf(MSG_ERROR, "wapi_usk_negotiation_res "
+			"pos = %d, wie_len= %d, payload_len = %d", (pos - payload_data), wie_len, payload_len);
+		return -1;
+	}
+	os_memcpy(&key_res_buff->wie_asue, pos, wie_len + 2);
+	pos += (wie_len + 2); 	
+
+	if((size_t)((pos - payload_data) + WAPI_MIC_LEN) > payload_len)
+	 	return -1;
+	 
+	os_memcpy(key_res_buff->mic, pos, WAPI_MIC_LEN);
+	pos += WAPI_MIC_LEN;
+
+
+	uskid = key_res_buff->uskid & 0x01;
+	if (uskid != (sm->USKSA.uskid & 0x01))
+	{
+		wapi_printf(MSG_ERROR, "wapi: key_res_buff.uskid not same\n");
+		goto err;
+	}
+
+	if((key_res_buff->flag & WAI_FLAG_USK_UPDATE) != (sm->wai_flag_in_data & WAI_FLAG_USK_UPDATE))
+	{
+		wapi_printf(MSG_ERROR, "wapi: AP and STA WAI_FLAG_USK_UPDATE not same ");
+		goto err;
+	}
+	if(key_res_buff->flag & WAI_FLAG_USK_UPDATE) {
+	
+		if(sm->USKSA.usk[uskid].usk_valid) {
+			wapi_printf(MSG_ERROR, "wapi: Current USKSA is valid.  ");
+			goto err;
+		}
+	}
+
+	if(os_memcmp(key_res_buff->bkid , sm->BKID, WAPI_BKID_LEN) !=0)
+	{
+		wapi_printf(MSG_ERROR, "wapi: BKID not same");
+		wapi_printf(MSG_DEBUG, "---BKID from STA:--- %X%X%X%X%X%X%X%X%X%X%X%X%X%X%X%X",
+				key_res_buff->bkid[0], key_res_buff->bkid[1],
+				key_res_buff->bkid[2], key_res_buff->bkid[3],
+				key_res_buff->bkid[4], key_res_buff->bkid[5],
+				key_res_buff->bkid[6], key_res_buff->bkid[7],
+				key_res_buff->bkid[8], key_res_buff->bkid[9],
+				key_res_buff->bkid[10], key_res_buff->bkid[11],
+				key_res_buff->bkid[12], key_res_buff->bkid[13],
+				key_res_buff->bkid[14], key_res_buff->bkid[15]);
+		wapi_printf(MSG_DEBUG, "---BKID from STA:--- %X%X%X%X%X%X%X%X%X%X%X%X%X%X%X%X",
+				sm->BKID[0], sm->BKID[1], sm->BKID[2], sm->BKID[3],
+				sm->BKID[4], sm->BKID[5], sm->BKID[6], sm->BKID[7],
+				sm->BKID[8], sm->BKID[9], sm->BKID[10], sm->BKID[11],
+				sm->BKID[12], sm->BKID[13], sm->BKID[14], sm->BKID[15]);
+		goto err;
+	}
+	
+	if(	os_memcmp(key_res_buff->addid.mac1, wapi_auth->addr, ETH_ALEN) !=0 ||
+		os_memcmp(key_res_buff->addid.mac2, sm->addr, ETH_ALEN) !=0 )
+	{
+		wapi_printf(MSG_ERROR, "ADDID not same");
+		wapi_printf(MSG_DEBUG, MACSTR, MACNUM(key_res_buff->addid.mac1));
+		wapi_printf(MSG_DEBUG, MACSTR, MACNUM(key_res_buff->addid.mac2));
+		goto err;
+	}
+	
+	/*▒╚ĮŽAEĄ─╠¶šĮ*/
+	if(os_memcmp(key_res_buff->ae_challenge, sm->ANonce, WAPI_NONCE_LEN) !=0){
+		wapi_printf(MSG_ERROR, "ae_challenge not same\n");
+		goto err;
+	}
+	os_memcpy(sm->SNonce, key_res_buff->asue_challenge, WAPI_NONCE_LEN);
+
+	/*╝Ų╦ŃKD_HMAC_SHA256,Ą╝│÷usk*/
+	if (wapi_auth->cb->get_usk == NULL)
+		return -1;
+	if (wapi_auth->cb->get_usk(wapi_auth->cb->ctx, key_res_buff->addid.mac1,
+			key_res_buff->addid.mac2, sm->ANonce, sm->SNonce,
+			sm->next_ANonce, master_key))
+			return -1;
+
+	os_memcpy(sm->USKSA.usk[uskid].uek, master_key, 16);
+	os_memcpy(sm->USKSA.usk[uskid].uck, master_key + 16, 16);
+	os_memcpy(sm->USKSA.usk[uskid].mak, master_key + 16 +16, 16);
+	os_memcpy(sm->USKSA.usk[uskid].kek, master_key + 16 +16 +16, 16);
+
+	wapi_printf(MSG_ERROR, "&&&&&&&&&&&&&&&& KEK: &&&&&&&&&&&&&&&&&&::"
+				"%02X%02X%02X%02X%02X%02X%02X%02X"
+						  "%02X%02X%02X%02X%02X%02X%02X%02X",
+			sm->USKSA.usk[uskid].kek[0], sm->USKSA.usk[uskid].kek[1],
+			sm->USKSA.usk[uskid].kek[2], sm->USKSA.usk[uskid].kek[3],
+			sm->USKSA.usk[uskid].kek[4], sm->USKSA.usk[uskid].kek[5],
+			sm->USKSA.usk[uskid].kek[6], sm->USKSA.usk[uskid].kek[7],
+			sm->USKSA.usk[uskid].kek[8], sm->USKSA.usk[uskid].kek[9],
+			sm->USKSA.usk[uskid].kek[10], sm->USKSA.usk[uskid].kek[11],
+			sm->USKSA.usk[uskid].kek[12], sm->USKSA.usk[uskid].kek[13],
+			sm->USKSA.usk[uskid].kek[14], sm->USKSA.usk[uskid].kek[15]);
+			
+
+	/*╝Ų╦ŃMIC,▒╚ĮŽMIC*/
+	iwn_hmac_sha256(payload_data, payload_len - WAPI_MIC_LEN, 
+			sm->USKSA.usk[uskid].mak, 16, 
+			MIC, WAPI_MIC_LEN);
+
+	if(os_memcmp(MIC, key_res_buff->mic, WAPI_MIC_LEN) != 0) {
+		wapi_printf(MSG_ERROR, "Different hmac with sta's. Receive sta's MIC: "
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X"
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X",
+			key_res_buff->mic[0], key_res_buff->mic[1], key_res_buff->mic[2],key_res_buff->mic[3],
+			key_res_buff->mic[4], key_res_buff->mic[5], key_res_buff->mic[6],key_res_buff->mic[7],
+			key_res_buff->mic[8], key_res_buff->mic[9], key_res_buff->mic[10],key_res_buff->mic[11],
+			key_res_buff->mic[12], key_res_buff->mic[13], key_res_buff->mic[14],key_res_buff->mic[15],
+			key_res_buff->mic[16], key_res_buff->mic[17], key_res_buff->mic[18],key_res_buff->mic[19]);
+
+		wapi_printf(MSG_ERROR, "Different hmac with sta's The AP's MIC: "
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X"
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X",
+			MIC[0], MIC[1], MIC[2], MIC[3], MIC[4],
+			MIC[5], MIC[6], MIC[7], MIC[8], MIC[9],
+			MIC[10], MIC[11], MIC[12], MIC[13], MIC[14],
+			MIC[15], MIC[16], MIC[17], MIC[18], MIC[19]);
+		goto err;
+	}
+	else
+	{
+		sm->UMICVerified = _TRUE;
+		wapi_printf(MSG_INFO, "Receive sta's MIC: "
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X"
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X",
+			key_res_buff->mic[0], key_res_buff->mic[1], key_res_buff->mic[2],key_res_buff->mic[3],
+			key_res_buff->mic[4], key_res_buff->mic[5], key_res_buff->mic[6],key_res_buff->mic[7],
+			key_res_buff->mic[8], key_res_buff->mic[9], key_res_buff->mic[10],key_res_buff->mic[11],
+			key_res_buff->mic[12], key_res_buff->mic[13], key_res_buff->mic[14],key_res_buff->mic[15],
+			key_res_buff->mic[16], key_res_buff->mic[17], key_res_buff->mic[18],key_res_buff->mic[19]);
+
+		wapi_printf(MSG_INFO, "The AP's MIC: "
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X"
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X",
+			MIC[0], MIC[1], MIC[2], MIC[3], MIC[4],
+			MIC[5], MIC[6], MIC[7], MIC[8], MIC[9],
+			MIC[10], MIC[11], MIC[12], MIC[13], MIC[14],
+			MIC[15], MIC[16], MIC[17], MIC[18], MIC[19]);
+	}
+
+	return 0;
+
+err:	
+	wapi_printf(MSG_ERROR, "wapi: Received a undesirable negoration response and discard it ");
+	return -1;
+}
+
+
+
+void _wapi_send_usk_negotiation_req(struct wapi_authenticator *wapi_auth,
+			   struct wapi_state_machine *sm)
+{
+	u8_t buf[128];
+	u8_t *pos = buf;
+	sm->wai_flag_in_data &= ~WAI_FLAG_USK_UPDATE;
+	//WPA_PUT_LE16(pos, capab);
+	//int timeout_ms;
+	//int pairwise = key_info & WPA_KEY_INFO_KEY_TYPE;
+	int ctr;
+
+	if (sm == NULL)
+		return;
+	
+	buf[0] = sm->wai_flag_in_data;
+	pos += 1;
+
+	os_memcpy(pos, sm->BKID, WAPI_BKID_LEN);
+	pos += WAPI_BKID_LEN;
+
+	os_memcpy(pos, &sm->USKSA.uskid, 1);
+	pos += 1;
+
+	os_memcpy(pos, wapi_auth->addr, ETH_ALEN);
+	pos += ETH_ALEN;
+
+	os_memcpy(pos, sm->addr, ETH_ALEN);
+	pos += ETH_ALEN;
+
+	os_memcpy(pos, sm->ANonce, WAPI_NONCE_LEN);
+	pos += WAPI_NONCE_LEN;
+	
+	__wapi_send_wai(wapi_auth, sm,	\
+					buf, (pos - buf), \
+					WAI_SUBTYPE_SESSIONKEYNEGREQUEST);
+
+//	timeout_ms = usk_key_timeout_first;
+//	eloop_register_timeout(timeout_ms / 1000, (timeout_ms % 1000) * 1000,
+//			       wapi_send_wai_timeout, wapi_auth, sm);
+
+
+}
+
