+    /* wapi_hexdump(MSG_DEBUG, "user cert decode base64 after:", dec_buf , usrcert_len); */
+
+    memcpy ( usrcert_out , dec_buf , usrcert_len );
+    *usrcert_outlen = usrcert_len;
+	free ( dec_buf );
+    return 0;
+}
