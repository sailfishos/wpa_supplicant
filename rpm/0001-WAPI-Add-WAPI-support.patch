+int get_asue_cert_list(wapi_x509_cert_asue_data **p_asue_cert_list)
+{
+#ifdef ANDROID
+	int i = 0;
+	int ret = 0;
+	char cert_state[8] = "0";
+
+	/* wapi cert alias array */
+	char** aliases = NULL;
+	int count = 0;
+	/* key name for keystore*/
+	char key[128] = "";
+	
+	unsigned char *user_cert = NULL; 
+	int user_cert_len = 0;
+	unsigned char *ca_cert = NULL;
+	int ca_cert_len = 0;
+	unsigned char *pri_key = NULL;
+	int pri_key_len = 0;
+	/* asue certificate struct: contains user, ca and private key */
+	wapi_x509_cert_asue_data *asue_cert_list = NULL;
+	wapi_x509_cert_asue_data *asue_cert_prev = NULL;
+	wapi_x509_cert_asue_data *asue_cert_cur = NULL;
+	
+	if (p_asue_cert_list == NULL)
+	{
+		return -1;
+	}
+	
+	*p_asue_cert_list = NULL;
+	
+	/* Enum cert alias list */
+	aliases = keystore_list(WAPI_USER_CERTIFICATE, 
+					strlen(WAPI_USER_CERTIFICATE), 
+					&count);
+	if (count < 0)
+	{
+		wapi_printf(MSG_ERROR, "in %s:%d: keystore_list faild\n", 
+				__func__, __LINE__);
+		return -1;
+	}
+	wapi_printf(MSG_DEBUG, "aliases array count = %d\n", count);
+	if (count == 0 || aliases == NULL)
+	{
+		return 0;
+	}
+	
+	for (i = 0; i < count; i ++)
+	{
+		wapi_printf(MSG_DEBUG, "aliases[%d]: %s\n", i, aliases[i]);
+		
+		snprintf(key, sizeof(key), "%s%s", 
+			WAPI_USER_CERTIFICATE, aliases[i]);
+		user_cert_len = keystore_get(key, strlen(key), &user_cert);
+		/* wapi_hexdump(MSG_DEBUG, "keystore_get user cert:", user_cert, user_cert_len); */
+
+		snprintf(key, sizeof(key), "%s%s", 
+			WAPI_CA_CERTIFICATE, aliases[i]);
+		ca_cert_len = keystore_get(key, strlen(key), &ca_cert);
+		/* wapi_hexdump(MSG_DEBUG, "keystore_get ca cert:", ca_cert, ca_cert_len); */
+
+		snprintf(key, sizeof(key), "%s%s", 
+			WAPI_USER_PRIVATE_KEY, aliases[i]);
+		pri_key_len = keystore_get(key, strlen(key), &pri_key);
+		/* wapi_hexdump(MSG_DEBUG, "keystore_get private key:", pri_key, pri_key_len); */
+		
+		if (user_cert_len <= 0 || ca_cert_len <= 0 || pri_key_len <= 0)
+		{
+			wapi_printf(MSG_ERROR, "in %s:%d: keystore_get error \n", 
+					__func__, __LINE__);
+			free_asue_cert_list(asue_cert_list);
+			free_aliases(aliases, count);
+			return -1;
+		}
+		
+		asue_cert_cur = alloc_asue_cert_data();
+	
+		ret = add_cert_items(asue_cert_cur,
+							user_cert, user_cert_len,
+							ca_cert, ca_cert_len,
+							pri_key, pri_key_len,
+							aliases[i], cert_state);
+		if (ret < 0)
+		{
+			wapi_printf(MSG_ERROR, "in %s:%d: add_cert_items error \n", 
+					__func__, __LINE__);
+			free_asue_cert_list(asue_cert_list);
+			free_asue_cert_data(asue_cert_cur);
+			free(pri_key);
+			free(ca_cert);
+			free(user_cert);
+			free_aliases(aliases, count);
+			return -1;
+		}
+		
+		
+		/* Add current asue_data to list */
+		asue_cert_cur->next = NULL;
+		asue_cert_cur->as = NULL;
+		if (asue_cert_list == NULL)
+		{
+			asue_cert_list = asue_cert_cur;
+			asue_cert_prev = asue_cert_list;
+		}
+		else
+		{
+			asue_cert_prev->next = asue_cert_cur;
+			asue_cert_prev = asue_cert_cur;
+		}
+		
+		free(pri_key);
+		free(ca_cert);
+		free(user_cert);
+	}
+	
+	free_aliases(aliases, count);
+
+	*p_asue_cert_list = asue_cert_list;
+	
+	return count;
+#else
+	wapi_printf(MSG_DEBUG, "return 0 for the none Android platfornm!");
+
+	return 0;
+#endif
+}
+
+void free_asue_cert_list(wapi_x509_cert_asue_data* asue_cert_list)
+{
+	wapi_x509_cert_asue_data *prev = NULL;
+	wapi_x509_cert_asue_data *next = NULL;
+	
+	prev = asue_cert_list;
+	
+	while (prev)
+	{
+		next = prev->next;
+		free_asue_cert_data(prev);
+		prev = next;
+	}
+}
+
+wapi_x509_cert_asue_data* get_asue_cert_use_alias(char *alias)
+{
+#ifdef ANDROID
+	int ret = 0;
+	char cert_state[8] = "0";
+
+	/* key name for keystore*/
+	char key[128] = "";
+	
+	unsigned char *user_cert = NULL; 
+	int user_cert_len = 0;
+	unsigned char *ca_cert = NULL;
+	int ca_cert_len = 0;
+	unsigned char *pri_key = NULL;
+	int pri_key_len = 0;
+	
+	/* asue certificate struct: contains user, ca and private key */
+	wapi_x509_cert_asue_data *asue_cert = NULL;
+	
+	wapi_printf(MSG_DEBUG, "Enter: %s\n",  __func__);
+	
+	wapi_printf(MSG_DEBUG, "alias: %s\n", alias);
+	
+	snprintf(key, sizeof(key), "%s%s", 
+		WAPI_USER_CERTIFICATE, alias);
+	user_cert_len = keystore_get(key, strlen(key), &user_cert);
+	/* wapi_hexdump(MSG_DEBUG, "keystore_get user cert:", user_cert, user_cert_len); */
+
+	snprintf(key, sizeof(key), "%s%s", 
+		WAPI_CA_CERTIFICATE, alias);
+	ca_cert_len = keystore_get(key, strlen(key), &ca_cert);
+	/* wapi_hexdump(MSG_DEBUG, "keystore_get ca cert:", ca_cert, ca_cert_len); */
+
+	snprintf(key, sizeof(key), "%s%s", 
+		WAPI_USER_PRIVATE_KEY, alias);
+	pri_key_len = keystore_get(key, strlen(key), &pri_key);
+	/* wapi_hexdump(MSG_DEBUG, "keystore_get private key:", pri_key, pri_key_len); */
+	
+	if (user_cert_len <= 0 || ca_cert_len <= 0 || pri_key_len <= 0)
+	{
+		wapi_printf(MSG_ERROR, "in %s:%d: keystore_get error \n", 
+				__func__, __LINE__);
+		return NULL;
+	}
+	
+	asue_cert = alloc_asue_cert_data();
+
+	ret = add_cert_items(asue_cert,
+						user_cert, user_cert_len,
+						ca_cert, ca_cert_len,
+						pri_key, pri_key_len,
+						alias, cert_state);
+	if (ret < 0)
+	{
+		wapi_printf(MSG_ERROR, "in %s:%d: add_cert_items error \n", 
+				__func__, __LINE__);
+		free(pri_key);
+		free(ca_cert);
+		free(user_cert);
+		return NULL;
+	}
+	
+	free(pri_key);
+	free(ca_cert);
+	free(user_cert);
+	
+	wapi_printf(MSG_DEBUG, "Leave: %s\n",  __func__);
+	
+	return asue_cert;
+#else
+	wapi_printf(MSG_DEBUG, "return NULL for the none Android platfornm!");
+
+	return NULL;
+#endif
+}
+
+int add_cert_items(wapi_x509_cert_asue_data* asue_cert_data,
+					unsigned char *user_cert, int user_cert_len, 
+					unsigned char *ca_cert, int ca_cert_len, 
+					unsigned char *pri_key, int pri_key_len,
+					char *alias, char *cert_state)
+{
+	unsigned char *decode_buf = NULL;
+	int decode_len = 0;
+	
+	unsigned char pubkey[256];
+	int pubkey_len = 256;
+	
+	decode_buf = malloc(2048);
+	if (decode_buf == NULL)
+	{
+		wapi_printf(MSG_ERROR, "in %s:%d: alloc decode_buf faild\n",
+				__func__, __LINE__);
+		return -1;
+	}
+
+	if (user_cert_len == 0 ||
+		ca_cert_len == 0 ||
+		pri_key_len == 0 )
+	{
+		wapi_printf(MSG_ERROR, "in %s:%d: user_cert_len=0 or ca_cert_len=0 or pri_key_len=0\n",
+				__func__, __LINE__);
+		return -1;
+	}
+	
+	strncpy(asue_cert_data->cert_rename, alias,
+		strlen(alias)+1);
+	strncpy(asue_cert_data->cert_state, cert_state,
+		strlen(cert_state)+1);
+	
+	/* Unpack and base64 decode for user certificate */
+	if (Unpack_AsueCert(user_cert, user_cert_len, 
+						decode_buf, &decode_len) != 0)
+	{
+		wapi_printf(MSG_ERROR, "in '%s':'%d' Unpack_AsueCert failed\n", 
+				__func__, __LINE__);
+		free(decode_buf);
+		return -1;
+	}
+	memcpy((char *)asue_cert_data->user_cert_st->data, decode_buf, decode_len);
+	asue_cert_data->user_cert_st->length = decode_len;
+	asue_cert_data->user_cert_st->cert_flag = 1;
+	/* wapi_hexdump(MSG_DEBUG, "decode user cert:",
+		asue_cert_data->user_cert_st->data, asue_cert_data->user_cert_st->length); 
+	*/
+		
+	/* Unpack and base64 decode for ca certificate */
+	if (Unpack_AsuCert(ca_cert, ca_cert_len, 
+						decode_buf, &decode_len) != 0)
+	{
+		wapi_printf(MSG_ERROR, "in '%s':'%d' Unpack_AsuCert failed\n", 
+				__func__, __LINE__);
+		free(decode_buf);
+		return -1;
+	}
+	memcpy((char *)asue_cert_data->asu_cert_st->data, decode_buf, decode_len);
+	asue_cert_data->asu_cert_st->length = decode_len;
+	asue_cert_data->asu_cert_st->cert_flag = 1;
+	/* wapi_hexdump(MSG_DEBUG, "decode asu cert:",
+		asue_cert_data->asu_cert_st->data, asue_cert_data->asu_cert_st->length); 
+	*/
+
+	/* Unpack and base64 decode for private key */
+	if (Unpack_AsuePrikey(pri_key, pri_key_len, 
+						decode_buf, &decode_len) != 0)
+	{
+		wapi_printf(MSG_ERROR, "in '%s':'%d' Unpack_AsuePrikey failed\n", 
+				__func__, __LINE__);
+		free(decode_buf);
+		return -1;
+	}
+
+	/* Get private key*/
+	/* int p_key_len = (int)asue_cert_data->private_key->length; */
+	int p_key_len = sizeof(asue_cert_data->private_key->data);
+	if (X509_Get_Prikey( decode_buf, decode_len,
+					asue_cert_data->private_key->data,
+					&p_key_len ) != 0 )
+	{
+		wapi_printf(MSG_ERROR, "in '%s':'%d' X509_Get_Prikey failed\n", 
+				__func__, __LINE__);
+		free(decode_buf);
+		return -1;
+	}
+	/*
+	wapi_hexdump(MSG_DEBUG, "User private key:",
+		asue_cert_data->private_key->data, asue_cert_data->private_key->length);
+	*/
+		
+	/* Get asu pubkey */
+	memset(pubkey, 0, 256);
+	if (X509_Get_Pubkey(asue_cert_data->asu_cert_st->data, 
+					asue_cert_data->asu_cert_st->length, 
+					pubkey, &pubkey_len) != 0)
+	{
+		wapi_printf(MSG_ERROR, "in '%s':'%d' X509_Get_Pubkey failed\n", 
+				__func__, __LINE__);
+		free(decode_buf);
+		return -1;
+	}
+	memcpy(asue_cert_data->asu_pubkey->data, pubkey, pubkey_len);
+	asue_cert_data->asu_pubkey->length = ( u16 )pubkey_len;
+	/*
+	wapi_hexdump(MSG_DEBUG, "asu public key:",
+		asue_cert_data->asu_pubkey->data, asue_cert_data->asu_pubkey->length);
+	*/
+	
+	/* Get user cert id */
+	if (get_cert_identity(asue_cert_data->user_cert_st, 
+				asue_cert_data->user_id, 1) != 0)
+	{	
+		wapi_printf(MSG_ERROR, "in '%s', '%d' get user cert id faild\n ", 
+				__func__, __LINE__);
+		free(decode_buf);
+		return -1;
+	}
+	
+	/* wapi_hexdump(MSG_DEBUG, "user cert id:",
+		asue_cert_data->user_id->id_data, asue_cert_data->user_id->id_len); 
+	*/
+	
+	/* Get asu id */
+	if (get_cert_identity(asue_cert_data->asu_cert_st, 
+				asue_cert_data->asu_id, 1) != 0)
+	{	
+		wapi_printf(MSG_ERROR,  "in '%s', '%d' get asu cert id faild\n ", 
+				__func__, __LINE__);
+		free(decode_buf);
+		return -1;
+	}
+	
+	/* wapi_hexdump(MSG_DEBUG, "asu cert id:",
+		asue_cert_data->asu_id->id_data, asue_cert_data->asu_id->id_len);
+	*/
+
+	free(decode_buf);
+	
+	return 0;
+}
+
+int get_cert_identity(cert_id *cert_st, 
+					wai_fixdata_id *fixdata_id, 
+					unsigned short index)
+{
+	X509_Cert ctx;
+	
+	unsigned char *serialno = NULL;
+	unsigned char *subject = NULL;
+	unsigned char *issuer = NULL;
+	int serialno_len = 0;
+	int subject_len = 0;
+	int issuer_len = 0;
+	
+	unsigned char *tmp = NULL;
+	
+	if (cert_st == NULL || fixdata_id == NULL)
+	{
+		wapi_printf(MSG_ERROR, "WAI: in %s:%d input praram is null \n", 
+				__func__, __LINE__);	
+		return -1;
+	}
+	
+	memset(&ctx, 0, sizeof(X509_Cert));
+	if (! UnPack_X509(cert_st->data, cert_st->length, &ctx))
+	{
+		wapi_printf(MSG_DEBUG,  "in '%s', '%d' UnPack_X509 error \n", 
+				__func__, __LINE__);
+		return -1;
+	}
+	
+	/*
+	serialno = malloc(256);
+	subject = malloc(256);
+	issuer = malloc(256);
+	
+	GetX509Info_ASN1(&ctx, SERIALNUMBER, serialno, &serialno_len);
+	GetX509Info_ASN1(&ctx, SUBJECT, subject, &subject_len);
+	GetX509Info_ASN1(&ctx, ISSUER, issuer, &issuer_len);
+	*/
+	
+	/* Get serial number */
+	serialno_len = ctx.Serialnumber.length;
+	serialno = malloc(serialno_len);
+	if (serialno == NULL)
+	{
+		wapi_printf(MSG_DEBUG,  "in '%s': Failed to alloc memory "
+				"for serial number.", __func__);
+		return -1;
+	}
+	memcpy(serialno, ctx.Serialnumber.data, serialno_len);
+	
+	/* Get subject name */
+	subject_len = ctx.Subject.length;
+	subject = malloc(subject_len);
+	if (subject == NULL)
+	{
+		wapi_printf(MSG_DEBUG,  "in '%s': Failed to alloc memory "
+				"for subject.", __func__);
+		free(serialno);
+		return -1;
+	}
+	memcpy(subject, ctx.Subject.data, subject_len);
+	
+	/* Get issuer name */
+	issuer_len = ctx.Issuer.length;
+	issuer = malloc(issuer_len);
+	if (issuer == NULL)
+	{
+		wapi_printf(MSG_DEBUG,  "in '%s': Failed to alloc memory "
+				"for issuer.", __func__);
+		free(subject);
+		free(serialno);
+		return -1;
+	}
+	memcpy(issuer, ctx.Issuer.data, issuer_len);
+	
+	/* wapi_hexdump(MSG_DEBUG, "AE ID: Serial number", 
+			serialno, serialno_len); */
+	/* wapi_hexdump(MSG_DEBUG, "AE ID: Subject", 
+			subject, subject_len); */
+	/* wapi_hexdump(MSG_DEBUG, "AE ID: Issure", 
+			issuer, issuer_len); */
+	
+	fixdata_id->id_flag = index;
+	tmp = fixdata_id->id_data;
+	memcpy(tmp, subject, subject_len);
+	tmp += subject_len;
+	memcpy(tmp, issuer, issuer_len);
+	tmp += issuer_len;
+	memcpy(tmp, serialno, serialno_len);
+	tmp += serialno_len;
+	fixdata_id->id_len = tmp - fixdata_id->id_data;
+	
+	free(issuer);
+	free(subject);
+	free(serialno);
+	
+	return 0;
+}
+
+wapi_x509_cert_asue_data* get_asue_cert_use_index(int index, 
+					wapi_x509_cert_asue_data *asue_cert_list)
+{
+	wapi_x509_cert_asue_data *tmp_user = NULL;
+	tmp_user = asue_cert_list;
+	int i = 0;
+	
+	while (tmp_user)
+	{
+		if (i == index)
+		{
+			return tmp_user;
+		}
+		tmp_user = tmp_user->next;
+		i ++;
+	}
+
+	return NULL;
+}
+
+int get_cert_state_list(CERT_STATE **p_cert_state_list)
+{
+	FILE *file = NULL;
+	char buf[512];
+	char *pos = NULL;
+	char *start = NULL;
+	int line = 0;
+	
+	int num_state = 0;
+	CERT_STATE *cert_state = NULL;
+	CERT_STATE *prev = NULL;
+	
+	if (p_cert_state_list == NULL)
+	{
+		wapi_printf(MSG_ERROR, "Invalid param p_cert_state_list is NULL");
+		return -1;
+	}
+	*p_cert_state_list = NULL;
+	
+	file = fopen(CERT_STATE_CONFIG_FILE_NAME, "r");
+	if (file == NULL) 
+	{
+		wapi_printf(MSG_DEBUG, "WAPI cert state config file '%s' not found.", 
+				CERT_STATE_CONFIG_FILE_NAME);
+		return 0;
+	}
+
+	/* Lines format: "alias" "state" */
+	while (fgets(buf, sizeof(buf), file)) 
+	{
+		line++;
+
+		if (buf[0] == '#')
+		{
+			continue;
+		}
+		
+		pos = buf;
+		while (*pos != '\0') 
+		{
+			if (*pos == '\n') 
+			{
+				*pos = '\0';
+				break;
+			}
+			pos++;
+		}
+		if (buf[0] == '\0')
+		{
+			continue;
+		}
+
+		cert_state = NULL;
+
+		if (buf[0] != '"') 
+		{
+			wapi_printf(MSG_ERROR, "Invalid cert name (no \" in "
+				   "start) on line %d in '%s'", line, 
+				   CERT_STATE_CONFIG_FILE_NAME);
+			goto failed;
+		}
+
+		cert_state = malloc(sizeof(*cert_state));
+		if (cert_state == NULL) 
+		{
+			wapi_printf(MSG_ERROR, "cert_state allocation failed");
+			goto failed;
+		}
+		memset(cert_state, 0, sizeof(*cert_state));
+
+		pos = buf + 1;
+		start = pos;
+		while (*pos != '"' && *pos != '\0')
+		{
+			pos++;
+		}
+		if (*pos == '\0') 
+		{
+			wapi_printf(MSG_ERROR, "Invalid cert name "
+				   "(no \" in end) on line %d in '%s'",
+				   line, CERT_STATE_CONFIG_FILE_NAME);
+			goto failed;
+		}
+
+		cert_state->alias = malloc(pos - start + 1);
+		if (cert_state->alias == NULL) 
+		{
+			wapi_printf(MSG_ERROR, "Failed to allocate "
+				   "memory for cert alias");
+			goto failed;
+		}
+		memcpy(cert_state->alias, start, pos - start);
+		cert_state->alias[pos - start] = '\0';
+		cert_state->alias_len = pos - start;
+
+		pos++;
+		while (*pos == ' ' || *pos == '\t')
+		{
+			pos++;
+		}
+		
+		if (*pos == '\0') 
+		{
+			wapi_printf(MSG_ERROR, "No cert state on line %d in "
+				   "'%s'", line, CERT_STATE_CONFIG_FILE_NAME);
+			goto failed;
+		}
+
+		if (*pos == '"') 
+		{
+			pos++;
+			start = pos;
+			while (*pos != '"' && *pos != '\0')
+			{
+				pos++;
+			}
+			if (*pos == '\0') 
+			{
+				wapi_printf(MSG_ERROR, "Invalid cert state "
+					   "(no \" in end) on line %d in '%s'",
+					   line, CERT_STATE_CONFIG_FILE_NAME);
+				goto failed;
+			}
+
+			cert_state->state = malloc(pos - start + 1);
+			if (cert_state->state == NULL) 
+			{
+				wapi_printf(MSG_ERROR, "Failed to allocate "
+					   "memory for cert state");
+				goto failed;
+			}
+			memcpy(cert_state->state, start, pos - start);
+			cert_state->state[pos - start] = '\0';
+			cert_state->state_len = pos - start;
+
+			pos = NULL;
+		}
+
+	done:
+		cert_state->next = NULL;
+		if (prev == NULL) 
+		{
+			*p_cert_state_list = cert_state;
+			prev = cert_state;
+			num_state = 1;
+		}
+		else 
+		{
+			prev->next = cert_state;
+			prev = cert_state;
+			num_state ++;
+		}
+		continue;
+
+	failed:
+		if (cert_state != NULL) 
+		{
+			free(cert_state->alias);
+			free(cert_state->state);
+			free(cert_state);
+		}
+		if (*p_cert_state_list != NULL)
+		{
+			free_cert_state_list(*p_cert_state_list);
+			*p_cert_state_list = NULL;
+		}
+		fclose(file);
+		return -1;
+	}
+
+	fclose(file);
+	
+	wapi_printf(MSG_DEBUG, "wapi cert state, num = %d", num_state);
+	wapi_printf(MSG_DEBUG, "alias<->state list:");
+	cert_state = *p_cert_state_list;
+	while (cert_state != NULL) 
+	{
+		wapi_printf(MSG_DEBUG, "alias: %s, state: %s", 
+				cert_state->alias, cert_state->state);
+		cert_state = cert_state->next;
+	}
+	
+	return num_state;
+}
+
+int save_cert_state_list(CERT_STATE *cert_state_list)
+{
+	FILE *file = NULL;
+	CERT_STATE *curr = cert_state_list;
+	
+	file = fopen(CERT_STATE_CONFIG_FILE_NAME, "w+");
+	if (file == NULL) 
+	{
+		wapi_printf(MSG_ERROR, "Open cert state config file '%s' faild.", 
+				CERT_STATE_CONFIG_FILE_NAME);
+		return -1;
+	}
+				
+	while (curr != NULL) 
+	{
+		wapi_printf(MSG_DEBUG, "curr->alias '%s' curr->state '%s'", 
+				curr->alias, curr->state);
+		fprintf(file, "\"%s\" \"%s\"\n", curr->alias, curr->state);
+		curr = curr->next;
+	}
+	
+	fclose(file);
+	
+	return 0;
+}
+
+void free_cert_state_list(CERT_STATE *cert_state_list)
+{
+	CERT_STATE *curr = NULL;
+	CERT_STATE *prev = NULL;
+	
+	curr = cert_state_list;
+	while (curr != NULL) 
+	{
+		prev = curr;
+		curr = curr->next;
+		free(prev->alias);
+		free(prev->state);
+		free(prev);
+	}
+}
+
+int add_cert_state(CERT_STATE **p_cert_state_list, char *alias, char *state)
+{
+	CERT_STATE *cert_state = NULL;
+	CERT_STATE *temp = NULL;
+	int alias_len = 0;
+	int state_len = 0;
+	
+	if (p_cert_state_list == NULL || 
+		alias == NULL || 
+		state == NULL)
+	{
+		return -1;
+	}
+	
+	wapi_printf(MSG_DEBUG, "Enter func add_cert_state.");
+	
+	alias_len = strlen(alias)+1;
+	state_len = strlen(state)+1;
+	
+	cert_state = malloc(sizeof(*cert_state));
+	memset(cert_state, 0, sizeof(*cert_state));
+	
+	cert_state->alias = malloc(alias_len);
+	strncpy(cert_state->alias, alias, alias_len);
+	cert_state->alias_len = alias_len;
+	
+	cert_state->state = malloc(state_len);
+	strncpy(cert_state->state, state, state_len);
+	cert_state->state_len = state_len;
+	
+	cert_state->next = NULL;
+	if (*p_cert_state_list == NULL)
+	{
+		*p_cert_state_list = cert_state;
+	}
+	else
+	{
+		temp = *p_cert_state_list;
+		while (temp->next != NULL)
+		{
+			temp = temp->next;
+		}
+		temp->next = cert_state;
+	}
+	
+	wapi_printf(MSG_DEBUG, "Leave func add_cert_state.");
+
+	return 0;
+}
+
+int match_cert_state(wapi_x509_cert_asue_data *asue_cert_list,
+				CERT_STATE **p_cert_state_list)
+{
+	wapi_x509_cert_asue_data *asue_cert = NULL;
+	CERT_STATE *cert_state = NULL;
+	CERT_STATE *cert_state_prev = NULL;
+	CERT_STATE *cert_state_remove = NULL;
+	
+	int found = 0;
+	int removed = 0;
+	
+	wapi_printf(MSG_DEBUG, "Enter func match_cert_state");
+	
+	if (p_cert_state_list == NULL)
+	{
+		return -1;
+	}
+	
+	if (asue_cert_list == NULL || *p_cert_state_list == NULL)
+	{
+		return 0;
+	}
+	
+	cert_state_prev = NULL;
+	
+	cert_state = *p_cert_state_list;
+	while (cert_state != NULL)
+	{
+		found = 0;
+		asue_cert = asue_cert_list;
+		while (asue_cert != NULL)
+		{
+			if (strcmp(cert_state->alias, asue_cert->cert_rename) == 0)
+			{
+				wapi_printf(MSG_DEBUG, "Set state <%s> to cert <%s>", 
+							cert_state->state, cert_state->alias);
+				strncpy(asue_cert->cert_state, cert_state->state,
+					strlen(cert_state->state)+1);
+				found = 1;
+				break;
+			}
+			asue_cert = asue_cert->next;
+		}
+		
+		/* If not found the cert from the cert list,
+		then remove the cert state item from the cert state list */
+		if (! found)
+		{
+			/* Remove current cert_state: cert_state_remove */
+			cert_state_remove = cert_state;
+			/* If remove first item */
+			if (cert_state == *p_cert_state_list)
+			{
+				wapi_printf(MSG_DEBUG, 
+						"Remove first cert_state item alias <%s>, state <%s>", 
+						cert_state->alias, cert_state->state);
+				*p_cert_state_list = cert_state->next;
+				cert_state = cert_state->next;
+			}
+			else
+			{
+				wapi_printf(MSG_DEBUG, 
+						"Remove cert_state item alias <%s>, state <%s>", 
+						cert_state->alias, cert_state->state);
+				cert_state = cert_state->next;
+				cert_state_prev->next = cert_state;
+			}
+			
+			free(cert_state_remove->alias);
+			free(cert_state_remove->state);
+			free(cert_state_remove);
+			cert_state_remove = NULL;
+			
+			removed = 1;
+		}
+		else
+		{
+			cert_state_prev = cert_state;
+			cert_state = cert_state->next;
+		}
+	}
+	
+	/* If there is cert_state item has removed, 
+	then need save the config file */
+	if (removed)
+	{
+		if (save_cert_state_list(*p_cert_state_list) != 0)
+		{
+			wapi_printf(MSG_ERROR, "Save cert_state list faild: %s");
+			return -1;
+		}
+	}
+	
+	wapi_printf(MSG_DEBUG, "Leave func match_cert_state");
+	
+	return 0;
+}
+
+int init_wapi_cert(wapi_cert_data *cert_info)
+{		
+	int cert_count = 0;
+	int state_count = 0;
+	
+	wapi_printf(MSG_DEBUG, "WAI: Enter %s\n", __func__);
+	
+	/* deinit_wapi_cert(cert_info); */
+	if (cert_info->cert_asue_data != NULL)
+	{
+		wapi_printf(MSG_DEBUG, "WAI: free_asue_cert_list \n");
+		free_asue_cert_list(cert_info->cert_asue_data);
+		cert_info->cert_asue_data = NULL;
+	}
+	
+	if (cert_info->cert_state_list != NULL)
+	{
+		wapi_printf(MSG_DEBUG, "WAI: free_cert_state_list \n");
+		free_cert_state_list(cert_info->cert_state_list);
+		cert_info->cert_state_list = NULL;
+	}
+	
+	if (cert_info->wapi_cert_sel_mode == 0)
+	{
+		cert_count = get_asue_cert_list(&(cert_info->cert_asue_data));
+		if (cert_count < 0)
+		{
+			wapi_printf(MSG_ERROR, "WAI: in %s:%d, get_asue_cert_list faild\n", 
+						__func__, __LINE__);
+			return -1;
+		}
+		cert_info->cert_count = cert_count;
+
+		state_count = get_cert_state_list(&(cert_info->cert_state_list));
+		if (state_count < 0)
+		{
+			wapi_printf(MSG_ERROR, "WAI: in %s:%d, get_cert_state_list faild\n", 
+						__func__, __LINE__);
+			return -1;
+		}
+		
+		wapi_printf(MSG_DEBUG, "WAI: cert state count = %d\n", state_count);
+		
+		if (state_count > 0)
+		{
+			if (match_cert_state(cert_info->cert_asue_data, 
+						&(cert_info->cert_state_list)) != 0)
+			{
+				wapi_printf(MSG_ERROR, "WAI: in %s:%d, match_cert_state faild\n", 
+						__func__, __LINE__);
+				return -1;
+			}
+		}
+	}
+	else
+	{
+		cert_info->cert_asue_data = get_asue_cert_use_alias(cert_info->wapi_cert_sel);
+
+		if (cert_info->cert_asue_data == NULL)
+		{
+			wapi_printf(MSG_ERROR, "WAI: in %s:%d, get_asue_cert_use_alias faild\n", 
+						__func__, __LINE__);
+			return -1;
+		}
+		
+		cert_info->cert_asue_data->next = NULL;
+		cert_info->cert_count = 1;
+	}
+
+	wapi_printf(MSG_DEBUG, "WAI: cert count = %d\n", cert_info->cert_count);
+	
+	wapi_printf(MSG_DEBUG, "WAI: Leave %s\n", __func__);
+	
+	return 0;
+}
+
+void deinit_wapi_cert(wapi_cert_data *cert_info)
+{	
+	wapi_printf(MSG_DEBUG, "WAI: Enter %s\n", __func__);
+	
+	if (cert_info->cert_asue_data != NULL)
+	{
+		wapi_printf(MSG_DEBUG, "WAI: free_asue_cert_list \n");
+		free_asue_cert_list(cert_info->cert_asue_data);
+		cert_info->cert_asue_data = NULL;
+	}
+	
+	if (cert_info->cert_state_list != NULL)
+	{
+		wapi_printf(MSG_DEBUG, "WAI: free_cert_state_list \n");
+		free_cert_state_list(cert_info->cert_state_list);
+		cert_info->cert_state_list = NULL;
+	}
+	
+	wapi_printf(MSG_DEBUG, "WAI: Leave %s\n", __func__);
+}
+
+int get_match_wapi_cert(wapi_cert_data *cert_info, wai_fixdata_id *ae_asu_id)
+{
+	wapi_x509_cert_asue_data *tmp_user = NULL;
+	int bFindMatchCert = 0;
+
+	wapi_printf(MSG_DEBUG, "Enter %s \n", __func__);
+	wapi_printf(MSG_DEBUG, "cert_count = %d \n", cert_info->cert_count);		
+	
+	if (cert_info->cert_count <= 0) 
+	{
+		wapi_printf(MSG_ERROR, "in %s:%d: No valid cert \n", __func__, __LINE__);		
+		return -1;
+	}
+	
+	/* wapi_cert_sel_mode : auto select mode 0, else 1 */
+	/* If not auto select mode, return */
+	if (cert_info->wapi_cert_sel_mode != 0)
+	{
+		wapi_printf(MSG_DEBUG, "Manual select mode \n");
+		cert_info->asue_cert_cur = cert_info->cert_asue_data;
+		return 0;
+	}
+
+	wapi_printf(MSG_DEBUG, "Auto select mode \n");
+	
+	/* if only one user cert, try to connect, */
+	/* regardless of whether there is matched cert. */
+	if (cert_info->cert_count == 1)
+	{
+		wapi_printf(MSG_DEBUG, "Only one certificate, so try to connect. \n");
+		cert_info->asue_cert_cur = cert_info->cert_asue_data;		
+		return 0;
+	}
+	
+	/* find the match user cert */
+	tmp_user = cert_info->cert_asue_data;
+	while (tmp_user)
+	{
+		wapi_printf(MSG_DEBUG, "Try cert: <%s> \n", tmp_user->cert_rename);
+	
+		if (tmp_user->asu_id->id_flag == ae_asu_id->id_flag &&
+			tmp_user->asu_id->id_len == ae_asu_id->id_len && 
+			memcmp(tmp_user->asu_id->id_data, ae_asu_id->id_data, 
+				tmp_user->asu_id->id_len) == 0) 
+		{
+			if (strcmp(tmp_user->cert_state, "3") != 0 
+				&& strcmp(tmp_user->cert_state, "5") != 0)
+			{
+				wapi_printf(MSG_DEBUG, "Found the matched cert <%s>, state <%s>. \n", 
+						tmp_user->cert_rename, tmp_user->cert_state);
+				cert_info->asue_cert_cur = tmp_user;
+				bFindMatchCert = 1;
+				break;
+			}
+			else
+			{
+				wapi_printf(MSG_WARNING, 
+						"Found the matched cert <%s>, but state is error, state <%s>. \n", 
+						tmp_user->cert_rename, tmp_user->cert_state);
+			}
+		}
+		tmp_user = tmp_user->next;
+	}
+
+	if (bFindMatchCert != 1)
+	{
+		wapi_printf(MSG_DEBUG, "Could not find the matched cert \n");
+		/* Delete 2018.3.12 */
+		/* setAutoSelCertFailMsg(); */
+		return -1;
+	}
+	
+	return 0;
+}
