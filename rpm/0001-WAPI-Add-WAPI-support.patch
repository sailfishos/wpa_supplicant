+#ifdef IWN_ECC_SM2
+static void mask_val(void *hSessionHandle,unsigned char *p, int w, unsigned char *q)
+{
+     int m = 0;
+     int n = 0;
+     unsigned char val = 0;
+	 int i=0;
+	 unsigned char tmp[MAX_BUFLEN]={0};
+	 unsigned char tmp1[MAX_BUFLEN]={0};	
+	 SessionHandle *EccSessionHandle = NULL;
+
+
+	 EccSessionHandle = (SessionHandle *)hSessionHandle;
+
+	 for (i=0; i<(int)EccSessionHandle->g_fixlen; i++)
+	 {
+		tmp[i] = p[(EccSessionHandle->g_fixlen-1)-i];
+	 }
+
+     m = w/8;
+     n = w%8;
+     val = tmp[m];
+     val = val & (0xFF >> (8-n));
+     val = val + (0x1 << n);
+	 
+     memcpy(tmp1, tmp, m);
+     memcpy(tmp1 + m, &val, 1); 
+
+	 for(i=0;i<m+1;i++)
+	 {
+		q[(EccSessionHandle->g_fixlen-1)-m+i] = tmp1[m-i];
+	 }
+}
+#endif
