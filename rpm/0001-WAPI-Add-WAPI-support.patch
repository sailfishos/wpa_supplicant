diff --git a/src/libcert_parse/certcode/der.c b/src/libcert_parse/certcode/der.c
new file mode 100644
index 0000000..8177449
--- /dev/null
+++ b/src/libcert_parse/certcode/der.c
@@ -0,0 +1,373 @@
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include "der.h"
+#include "sha1_e.h"
+#include "genkey.h"
+#include "debug.h"
+
+#define BIT_WAPI
+/*------------------------------------------------------*/
+int Der_Obj_Len(int len,int tag,int truct)
+{
+    int length=0;
+
+	length = len;
+	length++;
+	if(tag >= 31)
+	{
+	    while(tag > 0)
+		{
+		    tag >>= 7;
+			length++;
+		}
+	
+	}
+
+	if((len == 0) && (truct == 2))
+        length+=2;
+	length++;
+	if(len > 127)
+	{
+	    while(len > 0)
+		{
+		    len >>= 8;
+			length++;
+		}	
+	}
+
+	return length;
+}
+
+void Der_Put_Len(unsigned char **data, int len)
+{
+	int i=0;
+	int len2=0;
+	unsigned char *q= *data;
+	
+	if (len <= 127)
+		*(q++)=(unsigned char)len;
+	else
+	{
+		len2=len;
+		for(i=0; len2>0; i++)
+			len2>>=8;
+
+		*(q++)=i|0x80;
+		len2=i;
+
+		while(i-- > 0)
+		{
+			q[i]=len&0xff;
+			len>>=8;
+		}
+		q+=len2;
+	}
+
+	*data=q;
+}
+
+void Der_Put_Obj(unsigned char **data, int len, int tag, int truct, int type)
+{
+	int i=0;
+	unsigned char *p_data= *data;
+	
+	i=(truct)? 0x20:0;
+	i|=(type & 0xc0);
+	if (tag < 31)
+	{
+		*(p_data++)=i|(tag & 0x1f);
+	}
+	else if((tag == CTX_SPEC) || (tag == CTX_SPEC_PUB) || (tag == CTX_EXT))
+	{
+	    *(p_data++)=i|(tag&CTX_TAG);
+	}
+	else if(tag == CTX_CET)
+	{
+	    *(p_data++)=(i^tag)|0x80;
+	}
+	else
+	{
+		*(p_data++)=i|0x1f;
+
+		while(tag > 0x7f)
+		{
+			*(p_data++) = (tag & 0x7f)|0x80;
+			tag >>= 7;
+		}
+		*(p_data++) = (tag & 0x7f);
+	}
+
+	if ((truct == 2) && (len == 0))
+		*(p_data++)=0x80;
+	else
+		Der_Put_Len(&p_data,len);
+	*data=p_data;
+}
+
+int Der_Obj(unsigned char *indata,int inlen,unsigned char **outdata)
+{
+	int len=0;
+	unsigned char *p_data;
+
+
+	if (indata == NULL) 
+		return 0;
+
+	len = Der_Obj_Len(inlen,OBJ,0);
+	if (outdata == NULL)
+	{
+		return len;
+	}
+
+	
+	p_data= *outdata;
+	Der_Put_Obj(&p_data,inlen,OBJ,0,UNIVERSAL);
+	memcpy(p_data,indata,inlen);
+	p_data+=inlen;
+
+	*outdata=p_data;
+	return len;
+}
+
+int Der_Alg(unsigned char *indata,int inlen,unsigned char **outdata)
+{
+	unsigned char *p_data;
+    int len=0,len1=0;
+
+	if(indata == NULL)
+		return 0;
+
+	len1 += Der_Obj(indata,inlen,NULL);
+	len = Der_Obj_Len(len1,SEQUENCE,1);
+
+	if(outdata == NULL)
+	{
+		return len;
+	}
+
+	
+	p_data = *outdata;
+	Der_Put_Obj(&p_data,len1,CTX_SPEC,1,UNIVERSAL);
+
+	Der_Obj(indata,inlen,&p_data);
+
+	*outdata = p_data;
+
+	return len;
+
+}
+/*------------------------------------------------------------------*/
+int Der_Bit_String(unsigned char *indata,int inlen,unsigned char **outdata)
+{
+    unsigned char *p_data,*q_data;
+	int i=0,bit=0;
+	int len_1=0,len_2=0,length=0;
+
+    if(indata == NULL) return 0;
+
+    length=inlen;
+
+#ifdef BIT_WAPI
+    bit=0;
+#else
+    if(length > 0)
+    {
+		i=indata[length-1];
+		if(i == 0x00)
+		{
+		    bit=8;
+		}
+		else
+		{
+			if      (i & 0x01) bit=0;
+			else if (i & 0x02) bit=1;
+			else if (i & 0x04) bit=2;
+			else if (i & 0x08) bit=3;
+			else if (i & 0x10) bit=4;
+			else if (i & 0x20) bit=5;
+			else if (i & 0x40) bit=6;
+			else if (i & 0x80) bit=7;  
+		}
+   }
+   else
+       bit=0;
+#endif
+
+   len_1=1+length;
+   len_2=Der_Obj_Len(len_1,BIT_STRING,0);
+   if(outdata == NULL) return len_2;
+
+   p_data= *outdata;
+   Der_Put_Obj(&p_data,len_1,BIT_STRING,0,UNIVERSAL);
+
+   *(p_data++)=(unsigned char)bit;
+   q_data=indata;
+   memcpy(p_data,q_data,length);
+
+   p_data+=length;
+   if(length > 0) p_data[-1]&=(0xff<<bit);
+   *outdata=p_data;
+
+   return len_2;
+}
+
+int Der_Bytes(unsigned char *indata,int inlen,int type,int tag,unsigned char **outdata)
+{	
+	unsigned char *p_data;
+	int truct=0,len=0,ret=0;
+
+	if(indata == NULL)  return 0;
+
+	if(tag == BIT_STRING)	   
+	   return(Der_Bit_String(indata,inlen,outdata));
+	   
+	len=inlen;
+	ret=Der_Obj_Len(len,tag,0);
+
+	if(outdata == NULL) return ret;
+	p_data= *outdata;
+
+	if((tag == SEQUENCE)||(tag == SET))
+	   truct=1;
+	else
+	   truct=0;
+	Der_Put_Obj(&p_data,len,tag,truct,type);
+	memcpy(p_data,indata,inlen);
+	p_data+=inlen;
+	*outdata= p_data;
+
+	return ret;
+}
+
+//š²╩²DER▒Ó┬ļ
+int Der_Integer(unsigned char *indata,int inlen, unsigned char **outdata)
+{
+	int m=0,i=0,tag=0;
+	int len_1=0,len_2=0;
+	unsigned char *p_data,q_data=0;
+
+	//INTEGER =2Ż¼tag=2▒Ē╩Š╬¬š²╩²
+	tag=2;
+
+	if(indata == NULL) return 0;
+	if(inlen == 0)
+	   len_2=1;
+	else
+	{
+	   len_2=inlen;
+	   i=indata[0];
+	   if((tag == INTEGER) && (i > 127)) 
+	   {
+		   m=1;
+		   q_data=0;
+	   } 
+	   len_2+=m;
+	}
+	len_1=Der_Obj_Len(len_2,INTEGER,0);
+	if(outdata == NULL) return len_1;
+	p_data= *outdata;
+
+	Der_Put_Obj(&p_data,len_2,INTEGER,0,UNIVERSAL);
+
+	if(m) *(p_data++)=q_data;
+	if(inlen == 0) *(p_data++)=0;
+	else if(tag == INTEGER) 
+	   memcpy(p_data,indata,(unsigned int)inlen);
+
+	*outdata+=len_1;
+
+	return len_1;
+}
+
+int chart_to_int(unsigned char *data,int len)
+{
+	int i=0,ret=0;
+
+	if (data == NULL)
+		return 0;
+	for (i=0; i<len; i++)
+	{
+		ret<<=8;
+		ret|=data[i];
+	}
+
+	return ret;
+}
+
+
+int int_to_char(unsigned int int_data,unsigned char **data,int *len)
+{
+	unsigned char *p_data=NULL;
+	unsigned char *p_data_1=NULL;
+	unsigned char tmp_data[4]={0};
+
+	if(int_data == 0)
+		return 0;
+
+	tmp_data[0]=(unsigned char)(((int_data)>>24)&0xff);
+	tmp_data[1]=(unsigned char)(((int_data)>>16)&0xff);
+	tmp_data[2]=(unsigned char)(((int_data)>> 8)&0xff);
+	tmp_data[3]=(unsigned char)(((int_data))&0xff);
+
+	p_data = tmp_data;
+	p_data_1= *data;
+	if((tmp_data[0]==0x00)&&(tmp_data[1]!=0x00))
+	{
+	    *len = 3;
+		memcpy(p_data_1,p_data+1,3);
+	}
+	else if((tmp_data[0]==0x00)&&(tmp_data[1]==0x00)&&(tmp_data[2]!=0x00))
+	{
+	    *len = 2;
+		memcpy(p_data_1,p_data+2,2);
+	}
+	else if((tmp_data[0]==0x00)&&(tmp_data[1]==0x00)&&(tmp_data[2]==0x00)&&(tmp_data[3]!=0x00))
+	{
+	    *len = 1;
+		memcpy(p_data_1,p_data+3,1);
+	}
+	else
+	{
+	    *len = 4;
+		memcpy(p_data_1,p_data,4);
+	}
+
+    *data = p_data_1;
+
+	return 1;
+}
+
+int Gen_Mac_key(unsigned char *data, int data_len,unsigned char *salt, int salt_len, 
+				const char *pass, int passlen,int iter, unsigned char *mac_data, int *len)
+{
+	unsigned char mac_key[64]={0};
+	unsigned char hmac[64]={0};
+	int iter_value=0;
+
+	if(!iter) iter_value = 1;
+	else iter_value = iter;
+	
+	if(!pass_gen_key(pass,passlen,salt,salt_len,iter_value,3,mac_key,20)) return 0;
+
+	SHA1_HMAC(data,data_len,mac_key,20,hmac,20);
+	memcpy(mac_data,hmac,20);
+	*len = 20;
+
+    return 1;
+}
+
+int Verify_Mac(unsigned char *mac_value, int mac_len,unsigned char *data, int data_len,
+			   unsigned char *mac_salt, int mac_salt_len,int mac_iter,
+			   const char *pass, int passlen)
+{
+	unsigned char out[1024]={0};
+	int outlen=0;
+
+	if((mac_value==NULL) && (mac_len==0)) return 0;
+	if(!Gen_Mac_key(data,data_len,mac_salt, mac_salt_len,pass,passlen,mac_iter,out,&outlen)) return 0;
+
+	if ((mac_len != outlen)|| memcmp (mac_value, out, mac_len)) return 0;
+
+	return 1;
+}
