+
+	unsigned char buf[ECCref_MAX_LEN]={0};
+#ifdef IWN_ECC_SM2
+	unsigned char Za[ECCref_MAX_LEN]={0};
+	unsigned int zalen;
+	unsigned int len;
+#endif
+	unsigned char *tmp=NULL;
+	unsigned int dlen;
+	int ret=-1;
+	SessionHandle  *EccSessionHandle = NULL;
+	
+#ifndef IWN_ECC_SM2
+	/* Disable warning */
+	UNUSED(pucID);
+	UNUSED(uiIDLength);
+#endif
+
+    if (hSessionHandle == NULL) 
+    {
+		ret = SDR_NOSESSIONHANDLE;
+		return ret;
+    }
+
+	memset(&pubkey,0,sizeof(ECC_FpPOINT));
+	memset(&ucPublicKey,0,sizeof(ECCrefPublicKey));
