+int P8toP12_PriKey(unsigned char *p8_data,int p8_len,unsigned char *p12_prikey,int *prikey_len)
+{	
+	int len=0,len_1=0,len_2=0;
+	int len3=0,len4=0,len5=0,len6=0;
+	int v_len=0,prik_len=0,pubk_len=0;
+	int t_len=0,t_len_1=0;
+	unsigned char *p=NULL,*q=NULL,*q1=NULL,*q2=NULL,*q3=NULL,*q4=NULL;
+	unsigned char Llen=0;
+	unsigned char key[1024]={0};
+	unsigned char alg_param[32]={0};
+	unsigned char v_data[10]={0};
+	/*unsigned char prik_data[100]={0};*/
+	unsigned char prik_data[512]={0};
+	/*unsigned char pubk_data[200]={0};*/
+	unsigned char pubk_data[512]={0};
+	/*unsigned char data[300]={0};*/
+	unsigned char data[1024]={0};
+	unsigned char data_1[48]={0};
+	P8_PRIVATEKEY p8_prikey;
+
+	if(p8_data == NULL || p12_prikey == NULL || prikey_len == NULL)
+		return CTP_FALSE;
+	
+	memset(&p8_prikey,0,sizeof(P8_PRIVATEKEY));
+	if(Unpack_P8_PrivateKey(p8_data,p8_len,&p8_prikey) != CTP_OK)
+	{
+		return CTP_FALSE;	
+	}
+
+	Get_P8_PK_AlgorithmPARAM(&p8_prikey,alg_param,&len_2);
+	Get_P8_PK_Key(&p8_prikey,key,&len_1);
+	p=key;
+	p += 1;
+	len = GetInfoLength(p,&Llen);
+	p += Llen;
+
+	q1 = p;
+	p += 1;
+	len3 = GetInfoLength(p,&Llen);
+	p += Llen;
+	v_len = len3+Llen+1;
+	if(v_len>10)
+		return CTP_FALSE;
+	memcpy(v_data,q1,v_len);
+	p += len3; 
+
+	q2 = p;
+	p += 1;
+	len4 = GetInfoLength(p,&Llen);
+	p += Llen;
+	prik_len = len4+Llen+1;
+	if(prik_len>512)
+		return CTP_FALSE;
+	memcpy(prik_data,q2,prik_len);
+	p += len4;
+
+	q3 = p;
+	p += 1;
+	len5 = GetInfoLength(p,&Llen);
+	p += Llen;
+	pubk_len = len5+Llen+1;
+	if(pubk_len>512)
+		return CTP_FALSE;
+	memcpy(pubk_data,q3,pubk_len);
+
+	t_len += v_len;
+	t_len += prik_len;
+	t_len += Der_Alg(alg_param,len_2,NULL);
+	t_len += pubk_len;
+
+	t_len_1 = Der_Obj_Len(t_len,SEQUENCE,1);
+	if(t_len_1>*prikey_len)
+		return CTP_FALSE;
+	*prikey_len = t_len_1;
+
+	q=data;
+	Der_Put_Obj(&q,t_len,SEQUENCE,1,UNIVERSAL);
+
+	memcpy(q,v_data,v_len);
+	memcpy(q+v_len,prik_data,prik_len);
+	q4=data_1;
+	len6 = Der_Alg(alg_param,len_2,&q4);
+	if(v_len+prik_len+len6+pubk_len>1024)
+		return CTP_FALSE;
+	memcpy(q+v_len+prik_len,data_1,len6);
+	memcpy(q+v_len+prik_len+len6,pubk_data,pubk_len);
+	memcpy(p12_prikey,data,t_len_1);
+
+	End_P8_PrivateKey(&p8_prikey);
+    return CTP_OK;
+}
