diff --git a/src/libwapi_ap/wapi_auth_ie.c b/src/libwapi_ap/wapi_auth_ie.c
new file mode 100644
index 0000000..d5d7f31
--- /dev/null
+++ b/src/libwapi_ap/wapi_auth_ie.c
@@ -0,0 +1,362 @@
+#include "wapi_auth_i.h"
+#include "wapi_auth.h"
+#include "wapi_auth_ie.h"
+#include "wapi_debug.h"
+
+/**
+ * wapi_auth_write_ie - write WAPI IE
+ * @conf: Pointer and structure with configuration data
+ * @buf: Pointer to structure that will be filled in with authenticator data
+ * Returns: 0 on success, <0 on failure
+ */
+static int wapi_auth_write_ie(struct wapi_auth_config *conf, u8_t *buf)
+{
+	struct wapi_ap_ie_hdr *hdr;
+	int num_suites;
+	u8_t *pos, *pos1;
+	u16_t capab;
+	u32_t val;
+
+	// wapi head
+	hdr = (struct wapi_ap_ie_hdr *) buf;
+	hdr->elem_id = _WLAN_EID_WAPI;
+	hdr->version[0] = WAPI_VERSION & 0xff;
+	hdr->version[1] = WAPI_VERSION >> 8;
+	//wapi data key_mgmt
+	pos = (u8_t *) (hdr + 1);
+	num_suites = 0;
+	pos1 = pos;
+	pos += 2;
+	if (conf->wapi_key_mgmt & _WPA_KEY_MGMT_WAPI_PSK) {
+		val = RSN_AUTH_AP_KEY_MGMT_WAPI_PSK;
+		pos[0] = (val >> 24) & 0xff;
+		pos[1] = (val >> 16) & 0xff;
+		pos[2] = (val >> 8) & 0xff;
+		pos[3] = val & 0xff;
+		pos += 4;
+		num_suites++;
+	}
+
+	if (num_suites == 0) {
+		wapi_printf(MSG_DEBUG, "Invalid key management type (%d).",
+			   conf->wapi_key_mgmt);
+		return -1;
+	}
+
+	//wapi data pairwise cipher
+	pos1[0] = num_suites & 0xff;
+	pos1[1] = num_suites >> 8;
+	num_suites = 0;
+	pos1 = pos;
+	pos += 2;
+	if (conf->wapi_pairwise & _WPA_CIPHER_SMS4) {
+		val = WAPI_CIPHER_SUITE_SMS4;
+		pos[0] = (val >> 24) & 0xff;
+		pos[1] = (val >> 16) & 0xff;
+		pos[2] = (val >> 8) & 0xff;
+		pos[3] = val & 0xff;
+		pos += 4;
+		num_suites++;
+	}
+
+	if (num_suites == 0) {
+		wapi_printf(MSG_DEBUG, "Invalid pairwise cipher (%d).",
+			   conf->wapi_pairwise);
+		return -1;
+	}
+	
+	//wapi data group cipher
+	pos1[0] = num_suites & 0xff;
+	pos1[1] = num_suites >> 8;
+	if (conf->wapi_group == _WPA_CIPHER_SMS4) {
+		val = WAPI_CIPHER_SUITE_SMS4;
+		pos[0] = (val >> 24) & 0xff;
+		pos[1] = (val >> 16) & 0xff;
+		pos[2] = (val >> 8) & 0xff;
+		pos[3] = val & 0xff;
+	} else {
+		wapi_printf(MSG_DEBUG, "Invalid group cipher (%d).",
+			   conf->wapi_group);
+		return -1;
+	}
+	pos += 4;
+
+	// wapi data capabilities
+	capab = 0;
+	if (conf->wapi_preauth)
+		capab |= _WPA_CAPABILITY_PREAUTH;
+
+	pos[0] = capab & 0xff;
+	pos[1] = capab >> 8;
+	pos += 2;
+	hdr->len = (pos - buf) - 2;
+	
+	return pos - buf;
+}
+
+/**
+ * wapi_auth_gen_ie - generate WAPI IE
+ * @wapi_auth: Pointer to structure that will be filled in with authenticator data
+ * Returns: 0 on success, <0 on failure
+ */
+int wapi_auth_gen_ie(struct wapi_authenticator *wapi_auth)
+{
+	u8_t *pos, buf[128];
+	int res;
+	wapi_printf(MSG_DEBUG, " enter  %s",__func__);
+	pos = buf;
+
+	if (wapi_auth->conf->wapi & _WPA_PROTO_WAPI) {
+		//res = wapi_auth_write_ie(wapi_auth->conf,
+		//		       pos, buf + sizeof(buf) - pos);
+		res = wapi_auth_write_ie(wapi_auth->conf, pos);
+		if (res < 0)
+			return res;
+		pos += res;
+	}
+
+	wapi_auth->wapi_ie = NULL;
+	wapi_auth->wapi_ie = os_malloc(pos - buf);
+	if (wapi_auth->wapi_ie == NULL)
+		return -1;
+	os_memcpy(wapi_auth->wapi_ie, buf, pos - buf);
+	wapi_auth->wapi_ie_len = pos - buf;
+
+	return 0;
+}
+
+
+/**
+ * wapi_auth_parse_ie - Parse WAPI IE
+ * @wapi_ie: Buffer containing WAPI IE
+ * @wapi_ie_len: WAPI IE buffer length (including IE number and length octets)
+ * @data: Pointer to structure that will be filled in with parsed data
+ * Returns: 0 on success, <0 on failure
+ */
+static int wapi_auth_parse_ie(const u8_t *wapi_ie, size_t wapi_ie_len,
+			 struct wapi_ap_ie_data *data)
+{
+	const struct wapi_ap_ie_hdr *hdr;
+	const u8_t *pos;
+	int offset;
+	int i, count;
+	wapi_printf(MSG_DEBUG, " enter  %s ",__func__);
+	
+	os_memset(data, 0, sizeof(*data));
+	data->proto = _WPA_PROTO_WAPI;
+	data->mgmt_group_cipher = 0;
+
+
+	if ((wapi_ie_len == 0) || (wapi_ie_len < sizeof(struct wapi_ap_ie_hdr))) {
+		wapi_printf(MSG_DEBUG, "%s: ie len too short %lu",
+			   __func__, (unsigned long) wapi_ie_len);
+		return -1;
+	}
+
+	hdr = (const struct wapi_ap_ie_hdr *) wapi_ie;
+
+	if (hdr->elem_id != _WLAN_EID_WAPI ||
+	    hdr->len != wapi_ie_len - 2 ||
+	    ((hdr->version[1] << 8) | hdr->version[0]) != WAPI_VERSION) {
+		wapi_printf(MSG_DEBUG, "%s: malformed ie or unknown version",
+			   __func__);
+		return -2;
+	}
+
+	pos = (const u8_t *) (hdr + 1);
+	offset = wapi_ie_len - sizeof(*hdr);
+
+	count = ((pos[1] << 8) | pos[0]);
+	offset -= 2;
+	if (count == 0 || offset < count * WAPI_SELECTOR_LEN) {
+		wapi_printf(MSG_DEBUG, "%s: ie count botch (key mgmt), "
+				   "count %u offset %u", __func__, count, offset);
+		return -6;
+	}
+	
+	wapi_printf(MSG_ERROR, "%s: count= %d offset = %d", __func__,count, offset);
+	if(count == 1){
+		//key_mgmt
+		pos += 2;
+		if ((pos[0] << 24 | 
+			 pos[1] << 16 | 
+			 pos[2] << 8 | 
+			 pos[3] ) == RSN_AUTH_AP_KEY_MGMT_WAPI_PSK ){
+			data->key_mgmt = _WPA_KEY_MGMT_WAPI_PSK;
+		}
+		pos += WAPI_SELECTOR_LEN;
+		offset -= WAPI_SELECTOR_LEN;
+
+		wapi_printf(MSG_ERROR, "%s: offset = %d", __func__, offset);
+		//pairwise_cipher
+		pos += 2;
+		offset -= 2;
+		if ((pos[0] << 24 | 
+			 pos[1] << 16 | 
+			 pos[2] << 8 | 
+			 pos[3] ) == WAPI_CIPHER_SUITE_SMS4 ){
+			data->pairwise_cipher = _WPA_CIPHER_SMS4;
+		}
+		pos += WAPI_SELECTOR_LEN;
+		offset -= WAPI_SELECTOR_LEN;
+
+		wapi_printf(MSG_ERROR, "%s: offset = %d", __func__, offset);
+		//group_cipher
+		if ((pos[0] << 24 | 
+			 pos[1] << 16 | 
+			 pos[2] << 8 | 
+			 pos[3] ) == WAPI_CIPHER_SUITE_SMS4 ){
+			data->group_cipher = _WPA_CIPHER_SMS4;
+		}
+		pos += WAPI_SELECTOR_LEN;
+		offset -= WAPI_SELECTOR_LEN;
+
+		wapi_printf(MSG_ERROR, "%s: offset = %d", __func__, offset);
+		if (offset >= 2) {
+			data->capabilities = ((pos[1] << 8) | pos[0]);
+			pos += 2;
+			offset -= 2;
+		}
+	}
+	wapi_printf(MSG_ERROR, "%s: offset = %d", __func__, offset);
+	if (offset > 0) {
+		wapi_printf(MSG_DEBUG, "%s: ie has %u trailing bytes - ignored",
+			   __func__, offset);
+	}
+	
+	return 0;
+}
+
+/**
+ * _wapi_validate_ie - validate WAPI IE
+ * @sm: Pointer and structure with state machine
+ * @wapi_ie: Pointer and structure with ie data
+ * @wapi_ie_len: ie length
+ * @mdie: Temporarily useless
+ * @mdie_len: Temporarily useless
+ * @wapi_auth: Pointer to structure that will be filled in with authenticator data
+ * Returns: 0 on success, <0 on failure
+ */
+int _wapi_validate_ie(struct wapi_authenticator *wapi_auth,
+			struct wapi_state_machine *sm,
+			const u8_t *wapi_ie, size_t wapi_ie_len,
+			const u8_t *mdie, size_t mdie_len)
+{
+	struct wapi_ap_ie_data data;
+	int ciphers, key_mgmt, res, version;
+	u32_t selector;
+	size_t i;
+	
+	/* Disable warning */
+	UNUSED(mdie);
+	UNUSED(mdie_len);
+	
+	wapi_printf(MSG_DEBUG, " enter  %s ",__func__);
+	
+	if (wapi_auth == NULL || sm == NULL)
+		return WAPI_NOT_ENABLED;
+
+	if (wapi_ie == NULL || wapi_ie_len < 1)
+		return WAPI_INVALID_IE;
+
+	if (wapi_ie[0] == _WLAN_EID_WAPI) {
+		version = _WPA_PROTO_WAPI;
+	}
+	else {
+		return WAPI_INVALID_IE;
+	}
+
+	if (!(wapi_auth->conf->wapi & version)) {
+		wapi_printf(MSG_ERROR, "Invalid WAPI proto (%d) from " MACSTR,
+			   version, MACNUM(sm->addr));
+		return WAPI_INVALID_PROTO;
+	}
+
+	res = wapi_auth_parse_ie(wapi_ie, wapi_ie_len, &data);
+	if (res) {
+		wapi_printf(MSG_DEBUG, "Failed to parse WAPI IE from "
+			   MACSTR " (res=%d)", MACNUM(sm->addr), res);
+		wapi_hexdump(MSG_DEBUG, "WAPI IE", wapi_ie, wapi_ie_len);
+		return WAPI_INVALID_IE;
+	}
+	
+	if (data.key_mgmt & _WPA_KEY_MGMT_WAPI_PSK) {
+		selector = RSN_AUTH_AP_KEY_MGMT_WAPI_PSK;
+	}
+	else if (data.key_mgmt & _WPA_KEY_MGMT_WAPI_CERT) {
+		selector = RSN_AUTH_AP_KEY_MGMT_WAPI_CERT;
+	}
+	else {
+		wapi_printf(MSG_DEBUG, "Invalid WAPI key mgmt (0x%x) from "
+			   MACSTR, data.key_mgmt, MACNUM(sm->addr));
+		return WAPI_INVALID_AKMP;
+	}
+	wapi_auth->WAPIAuthenticationSuiteSelected = selector;
+
+	if (data.pairwise_cipher & _WPA_CIPHER_SMS4) {
+		wapi_auth->WAPIPairwiseCipherSelected = WAPI_CIPHER_SUITE_SMS4;
+	}
+	else {
+		wapi_printf(MSG_DEBUG, "Invalid %s pairwise cipher (0x%x) "
+			   "from " MACSTR, "WAPI",
+			   data.pairwise_cipher, MACNUM(sm->addr));
+		return WAPI_INVALID_PAIRWISE;
+	}
+
+	if (data.group_cipher & _WPA_CIPHER_SMS4) {
+		wapi_auth->WAPIGroupCipherSelected = WAPI_CIPHER_SUITE_SMS4;
+	}
+	else {
+		wapi_printf(MSG_DEBUG, "Invalid %s group cipher (0x%x) "
+			   "from " MACSTR, "WAPI",
+			   data.group_cipher, MACNUM(sm->addr));
+		return WAPI_INVALID_GROUP;
+	}
+
+	if (data.group_cipher != wapi_auth->conf->wapi_group) {
+		wapi_printf(MSG_DEBUG, "Invalid WAPI group cipher (0x%x) from "
+			   MACSTR, data.group_cipher, MACNUM(sm->addr));
+		return WAPI_INVALID_GROUP;
+	}
+
+	key_mgmt = data.key_mgmt & wapi_auth->conf->wapi_key_mgmt;
+	if (!key_mgmt) {
+		wapi_printf(MSG_DEBUG, "Invalid WAPI key mgmt (0x%x) from "
+			   MACSTR, data.key_mgmt, MACNUM(sm->addr));
+		return WAPI_INVALID_AKMP;
+	}
+	
+	if (key_mgmt & _WPA_KEY_MGMT_WAPI_PSK)
+		sm->wapi_key_mgmt = _WPA_KEY_MGMT_WAPI_PSK;
+	else if (key_mgmt & _WPA_KEY_MGMT_WAPI_CERT)
+		sm->wapi_key_mgmt = _WPA_KEY_MGMT_WAPI_CERT;
+
+
+	ciphers = data.pairwise_cipher & wapi_auth->conf->wapi_pairwise;
+
+	if (!ciphers) {
+		wapi_printf(MSG_DEBUG, "Invalid %s pairwise cipher (0x%x) "
+			   "from " MACSTR, "WAPI",
+			   data.pairwise_cipher, MACNUM(sm->addr));
+		return WAPI_INVALID_PAIRWISE;
+	}
+
+	if (ciphers & _WPA_CIPHER_SMS4)
+		sm->pairwise = _WPA_CIPHER_SMS4;
+
+	if (wapi_ie[0] == _WLAN_EID_RSN)
+		sm->wapi = WAPI_VERSION;
+
+	if (sm->wapi_ie == NULL || sm->wapi_ie_len < wapi_ie_len) {
+		os_free(sm->wapi_ie);
+		sm->wapi_ie = os_malloc(wapi_ie_len);
+		if (sm->wapi_ie == NULL)
+			return WAPI_ALLOC_FAIL;
+	}
+	os_memcpy(sm->wapi_ie, wapi_ie, wapi_ie_len);
+	sm->wapi_ie_len = wapi_ie_len;
+
+	return WAPI_IE_OK;
+}
+
+
diff --git a/src/libwapi_ap/wapi_auth_ie.h b/src/libwapi_ap/wapi_auth_ie.h
new file mode 100644
index 0000000..b1b9eaf
--- /dev/null
+++ b/src/libwapi_ap/wapi_auth_ie.h
@@ -0,0 +1,29 @@
+#ifndef WAPI_AUTH_IE_H
+#define WAPI_AUTH_IE_H
+
+#include "wapi_os.h"
+
+#define WAPI_VERSION	1
+
+//changed from wapi_ie_hdr to wapi_ap_ie_hdr to aviod the conflict with WAPI STA
+struct wapi_ap_ie_hdr {
+	u8_t elem_id; /* WLAN_EID_WAPI */
+	u8_t len;
+	u8_t version[2]; /* little endian */
+} STRUCT_PACKED;
+
+struct wapi_ap_ie_data {
+	int proto;
+	int pairwise_cipher;
+	int group_cipher;
+	int key_mgmt;
+	int capabilities;
+	int mgmt_group_cipher;
+};
+
+int wapi_auth_gen_ie(struct wapi_authenticator *wapi_auth);
+int _wapi_validate_ie(struct wapi_authenticator *wapi_auth,	\
+			struct wapi_state_machine *sm,
+			const u8_t *wapi_ie, size_t wapi_ie_len,
+			const u8_t *mdie, size_t mdie_len);
+#endif /* WAPI_AUTH_IE_H */
diff --git a/src/libwapi_ap/wapi_os.c b/src/libwapi_ap/wapi_os.c
new file mode 100644
index 0000000..1351542
--- /dev/null
+++ b/src/libwapi_ap/wapi_os.c
@@ -0,0 +1,48 @@
+/*
+ * Copyright (C) 2003-2016 China IWNCOMM Co., Ltd. All rights reserved.
+ *
+ * This module is OS compat layer.
+ * 
+ * Authors:
+ * WeiGang Chen <chenwg@iwncomm.com sudochen@163.com>
+ * 
+ * History:
+ * WeiGang Chen     02/01/2016 v1.0.1   Code create.
+ *
+ * Related documents:
+ * -GB 15629.11-2003/XG1-2006
+ *
+ */
+
+#include "wapi_os.h"
+
+/* desc : get some random data form random device of linux
+ * @buf: for saving the random data
+ * @len: the length of random data length we want
+ * 
+ * return 0 means ok and -1 means failed
+ *
+ *
+ */
+int os_get_random (unsigned char *buf, size_t len)
+{
+    FILE *f;
+    size_t rc;
+    unsigned int count = 0;
+    
+retry:
+    f = fopen ("/dev/urandom", "rb");
+    if (f == NULL)
+    {
+        return -1;
+    }
+    rc = fread (buf, 1, len, f);
+    if (rc != len && count < 10)
+    {
+        count++;
+        goto retry;
+    }
+    fclose (f);
+    
+    return rc != len ? -1 : 0;
+}
