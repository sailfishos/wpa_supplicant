+		return CTP_FALSE;
+	
+	p = data;
+	p += 1;
+	len1 = GetInfoLength(p,&Llen);
+	p += Llen;
+
+    bag_length += 1 + Llen +len1;
+
+	if ((pCACert != NULL) && (pCACertlen != NULL))
+	{
