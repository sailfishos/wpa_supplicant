+/*ūķ▓ź═©ĖµĘųūķ*/
+void _wapi_msk_announcement_tx(struct wapi_authenticator *wapi_auth,
+			   struct wapi_state_machine *sm)
+{
+	u8_t *hdr_data;
+	u8_t *pos;
+	u8_t wai_data_flag = 0x00;
+	u8_t iv[WAI_IV_LEN];
+	u8_t MIC[WAPI_MIC_LEN];
+	size_t data_len;
+	u32_t tmp_GNonce;
+	//int timeout_ms;
+
+	data_len = 1
+			+ 1
+			+ 1
+			+ (ETH_ALEN+ETH_ALEN)
+			+ 16
+			+ 16
+			+ 1							//save NMK_LEN  need a byte
+			+ wapi_auth->group->NMK_len
+			+ WAPI_MIC_LEN;
+
+	hdr_data = os_malloc(data_len);
+	if (hdr_data == NULL)
+	{
+		wapi_printf(MSG_ERROR,"%s malloc buf for data fail",__func__);
+		return;
+	}
+
+	pos = hdr_data;
+
+	wai_data_flag &= 0x9F;	/*10011111*/ /*bit5-0,bit6-0*/
+	sm->wai_flag_in_data &= 0x9F;
+	sm->wai_flag_in_data |= (wai_data_flag &
+				WAI_FLAG_STAKEY_SESSION &
+				WAI_FLAG_STAKEY_DEL);
+
+	os_memcpy(pos, &wai_data_flag, 1);
+	pos += 1;
+
+	os_memcpy(pos, &wapi_auth->group->msksa.mskid, 1);
+	pos += 1;
+
+	os_memcpy(pos, &sm->USKSA.uskid, 1);
+	pos += 1;
+
+	/*┤“░³addid*/
+	os_memcpy(pos, wapi_auth->addr, ETH_ALEN);
+	pos += ETH_ALEN;
+	os_memcpy(pos, sm->addr, ETH_ALEN);
+	pos += ETH_ALEN;
+
+	os_memcpy(pos, wapi_auth->group->GSN, WPI_PN_LEN);
+	pos += WPI_PN_LEN;
+	wapi_printf(MSG_DEBUG, "----------------GSN :--------------- %X%X%X%X%X%X%X%X%X%X%X%X%X%X%X%X",
+				wapi_auth->group->GSN[0], wapi_auth->group->GSN[1],
+				wapi_auth->group->GSN[2], wapi_auth->group->GSN[3],
+				wapi_auth->group->GSN[4], wapi_auth->group->GSN[5],
+				wapi_auth->group->GSN[6], wapi_auth->group->GSN[7],
+				wapi_auth->group->GSN[8], wapi_auth->group->GSN[9],
+				wapi_auth->group->GSN[10], wapi_auth->group->GSN[11],
+				wapi_auth->group->GSN[12], wapi_auth->group->GSN[13],
+				wapi_auth->group->GSN[14], wapi_auth->group->GSN[15]);
+
+	tmp_GNonce = htonl(wapi_auth->group->GNonce[0]);
+	os_memcpy(pos, (u8_t *)&tmp_GNonce, 4);
+	pos += 4;
+	
+	tmp_GNonce = htonl(wapi_auth->group->GNonce[1]);
+	os_memcpy(pos, (u8_t *)&tmp_GNonce, 4);
+	pos += 4;
+	
+	tmp_GNonce = htonl(wapi_auth->group->GNonce[2]);
+	os_memcpy(pos, (u8_t *)&tmp_GNonce, 4);
+	pos += 4;
+	
+	tmp_GNonce = htonl(wapi_auth->group->GNonce[3]);
+	os_memcpy(pos, (u8_t *)&tmp_GNonce, 4);
+	pos += 4;
+	
+	wapi_printf(MSG_DEBUG, "----------------GNonce :--------------- %08X%08X%08X%08X",
+				wapi_auth->group->GNonce[0], wapi_auth->group->GNonce[1],
+				wapi_auth->group->GNonce[2], wapi_auth->group->GNonce[3]);
+
+
+	os_memcpy(pos, &wapi_auth->group->NMK_len, 1);
+	pos += 1;
+
+	os_memcpy(iv, (u8_t *)wapi_auth->group->GNonce, WAI_IV_LEN);
+	htonl_buffer(iv, WAI_IV_LEN);
+
+	wpi_encrypt(iv, wapi_auth->group->msksa.nmk, WAPI_NMK_LEN,
+		sm->USKSA.usk[sm->USKSA.uskid].kek, pos);
+	pos += WAPI_NMK_LEN;
+
+	iwn_hmac_sha256(hdr_data, (pos - hdr_data), 
+		sm->USKSA.usk[sm->USKSA.uskid].mak,
+		16, MIC, WAPI_MIC_LEN);
+
+	os_memcpy(pos, MIC, WAPI_MIC_LEN);
+	pos += WAPI_MIC_LEN;
+	wapi_printf(MSG_INFO, "The AP's MIC: "
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X"
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X",
+			MIC[0], MIC[1], MIC[2], MIC[3], MIC[4],
+			MIC[5], MIC[6], MIC[7], MIC[8], MIC[9],
+			MIC[10], MIC[11], MIC[12], MIC[13], MIC[14],
+			MIC[15], MIC[16], MIC[17], MIC[18], MIC[19]);
+
+	__wapi_send_wai(wapi_auth, sm, \
+					hdr_data, (pos - hdr_data),	\
+					WAI_SUBTYPE_GROUPKEYNOTICE);
+	//sm->group_sc += 1;
+
+	/*timeout_ms = usk_key_timeout_subseq;
+	  eloop_register_timeout(timeout_ms / 1000, (timeout_ms % 1000) * 1000,
+			       wapi_send_wai_timeout, wapi_auth, sm);
+	*/
+}
