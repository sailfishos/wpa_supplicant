diff --git a/src/libcert_parse/third/sha1_e.c b/src/libcert_parse/third/sha1_e.c
new file mode 100644
index 0000000..5c2ae1b
--- /dev/null
+++ b/src/libcert_parse/third/sha1_e.c
@@ -0,0 +1,80 @@
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <openssl/sha.h>
+
+//SHA1Ą─Įß╣¹╩²Š▌│żČ╚
+static const unsigned int ZEN_SHA1_HASH_SIZE  = 20;
+
+//SHA1╦ŃĘ©├┐┤╬┤”└ĒĄ─BLOCK┤¾ąĪ
+static const unsigned int ZEN_SHA1_BLOCK_SIZE = 64;
+/*-------------------------------------------------------------------------------------*/
+//╝Ų╦Ń╩²Š▌Ą─SHA1ųĄ
+unsigned char *sha1_a(const unsigned char *msg,unsigned int size,unsigned char *result)
+{
+	SHA1(msg, size, result);
+	return result;
+}
+
+int SHA1_HMAC(unsigned char* pucData,unsigned int uiDataLength, unsigned char* pucKey, unsigned int uiKeyLength, unsigned char* pucDigest, unsigned int uiDigestLength)
+{
+	unsigned char real_key[64]={0};
+	unsigned char ipad[64]={0};
+	unsigned char opad[64]={0};
+	unsigned char temp_digest1[32]={0};
+	unsigned char temp_digest2[32]={0};
+	unsigned char *temp_buf=NULL;
+	unsigned int temp_buf_len=0;
+	unsigned i;
+	int ret=-1;
+
+	if (uiDigestLength>ZEN_SHA1_HASH_SIZE)
+		return -1;
+
+	temp_buf_len = uiDataLength+ZEN_SHA1_BLOCK_SIZE*2+1;
+	temp_buf = (unsigned char*)malloc(sizeof(unsigned char)*temp_buf_len);
+	if(temp_buf==NULL){
+		return ret;
+	}
+	memset(temp_buf,0,temp_buf_len);
+	
+	for(i=0;i<ZEN_SHA1_BLOCK_SIZE;i++){
+		real_key[i]=0;
+		ipad[i]=0x36;
+		opad[i]=0x5c;
+	}
+	
+	/* if key_len is larger than hash block size, key is hashed first to make its length is equal hash block size */
+	if(uiKeyLength>ZEN_SHA1_BLOCK_SIZE)
+	{
+
+		sha1_a(pucKey,uiKeyLength,real_key);
+	}
+	else
+		memcpy(real_key,pucKey,uiKeyLength);
+	
+	
+	for(i=0;i<ZEN_SHA1_BLOCK_SIZE;i++){
+		ipad[i]^=real_key[i];
+		opad[i]^=real_key[i];
+	}
+
+	memcpy(temp_buf,ipad,ZEN_SHA1_BLOCK_SIZE);
+	memcpy(temp_buf+ZEN_SHA1_BLOCK_SIZE,pucData,uiDataLength);
+	sha1_a(temp_buf,ZEN_SHA1_BLOCK_SIZE+uiDataLength,temp_digest1);
+
+	memset(temp_buf,0,ZEN_SHA1_BLOCK_SIZE*2+1);
+	memcpy(temp_buf,opad,ZEN_SHA1_BLOCK_SIZE);
+	memcpy(temp_buf+ZEN_SHA1_BLOCK_SIZE,temp_digest1,ZEN_SHA1_HASH_SIZE);
+	sha1_a(temp_buf,ZEN_SHA1_BLOCK_SIZE+ZEN_SHA1_HASH_SIZE,temp_digest2);
+
+	memcpy(pucDigest,temp_digest2,uiDigestLength);
+
+	free(temp_buf);
+	temp_buf=NULL;
+
+	return 0;
+}
+
+
+
