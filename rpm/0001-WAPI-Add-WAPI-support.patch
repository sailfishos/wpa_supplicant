+	struct wapi_auth_config *conf;
+	struct wapi_auth_callbacks *cb;
+	
+	u8_t *wapi_ie;
+	size_t wapi_ie_len;
+
+	u8_t addr[ETH_ALEN];		//ap addr
+
+	//struct rsn_pmksa_cache *pmksa;
+};
