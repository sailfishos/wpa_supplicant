diff --git a/src/wapi/wai_interface.h b/src/wapi/wai_interface.h
new file mode 100644
index 0000000..dd8ed4e
--- /dev/null
+++ b/src/wapi/wai_interface.h
@@ -0,0 +1,124 @@
+/* 
+ * Copyright (C) 2015-2020 China IWNCOMM Co., Ltd. All rights reserved.
+ * 
+ * Contains data structures and function declarations 
+ * of wai interface
+ * 
+ * Authors:  
+ * iwncomm
+ * 
+ * History: 
+ * yucun tian  09/10/2015 v1.0 maintain the code.
+ * yucun tian  07/20/2016 v1.1 fix for change code style.
+ * 
+ * Related documents:
+ * -GB/T 15629.11-2003/XG1-2006 
+ * -ISO/IEC 8802.11:1999,MOD
+ * 
+*/ 
+
+#ifndef _WAI_INTERFACE_H_
+#define _WAI_INTERFACE_H_
+
+#ifdef  __cplusplus
+extern "C" {
+#endif
+
+/* struct */
+typedef enum
+{
+	/* No WAPI */
+	AUTH_TYPE_NONE_WAPI = 0,
+	/* WAPI-Cert */
+	AUTH_TYPE_WAPI_CERT,
+	/* WAPI-PSK */
+	AUTH_TYPE_WAPI_PSK,
+} auth_type;
+
+typedef enum
+{
+	/* ASCII */
+	KEY_TYPE_ASCII = 0,
+	/* HEX */
+	KEY_TYPE_HEX,
+} key_type;
+
+typedef struct
+{
+	/* Authentication type */
+	auth_type authType;
+	/* WAPI_CERT */
+	/* WAPI cert select mode */
+	/* 0: automatic select; 1: user select one from the certificate list */
+    unsigned int wapi_cert_sel_mode;
+	/* User select cert alias */
+	char wapi_cert_sel[256];
+	/* WAPI-PSK Key type */
+	key_type kt;
+	/* Key length */
+	unsigned int kl;
+	/* Key value */
+	unsigned char kv[128];
+} connect_param;
+
+typedef enum
+{
+	CONN_ASSOC = 0,
+	CONN_DISASSOC,
+} wapi_event;
+
+typedef enum
+{
+	WAPI_DISCONNECTED,
+	WAPI_ASSOCIATED,
+	WAPI_AUTHENTICATING,
+	WAPI_CONNECTED
+} wapi_connect_states;
+
+/* wapi interfaces */
+int wapi_sta_init();
+int wapi_sta_deinit();
+int wapi_set_connect_param(const connect_param* pPar);
+void wapi_event_process(wapi_event event, 
+		const unsigned char *bssid, 
+		const unsigned char *local_mac, 
+		unsigned char *assoc_ie, 
+		unsigned char assoc_ie_len);
+int wapi_rx_wai_packet(const unsigned char* pbuf, int length);
+
+/* wapi callbak interfaces */
+extern int wapi_set_assoc_ie(const unsigned char* pbuf, \
+		int length) __attribute__((weak));
+extern unsigned long wapi_tx_wai_packet(const char* pbuf, \
+		int length) __attribute__((weak));
+extern int wapi_set_unicast_key(const char* pKeyValue, \
+		int keylength, int key_idx) __attribute__((weak));
+extern int wapi_set_group_key(const unsigned char* pKeyValue, \
+		int keylength, int key_idx, \
+		const unsigned char* key_iv) __attribute__((weak));
+extern int wapi_notify_connect_state(wapi_connect_states state) \
+		__attribute__((weak));
+extern void wapi_deauthenticate() __attribute__((weak));
+extern void get_l2_mtu(int *mtu_len) __attribute__((weak));
+
+typedef void (*OS_timer_expired)(const int pdata);
+extern void* OS_timer_setup(int deltaTimer, int repeated, 
+		OS_timer_expired pfunction, const void* pdata)
+		__attribute__((weak));
+extern void OS_timer_clean(void* pTimer) __attribute__((weak));
+
+extern unsigned char get_rand_byte() __attribute__((weak));
+
+/* timer */
+void timer_set(int t, const unsigned char* dat, int l);
+void timer_reset(void);
+void timer_resend(void);
+/* random alg */
+void get_random(unsigned char *buffer, int len);
+
+#ifdef  __cplusplus
+}
+#endif
+
+#endif /* _WAI_INTERFACE_H_  */
+
diff --git a/src/wapi/wapi_asue.c b/src/wapi/wapi_asue.c
new file mode 100644
index 0000000..e710408
--- /dev/null
+++ b/src/wapi/wapi_asue.c
@@ -0,0 +1,391 @@
+/* @file wapi_asue.c
+ * @brief This file contains functions for wapi_asue
+ *
+ *  Copyright (C) 2001-2008, Iwncomm Ltd.
+ */
+
+#include <stdlib.h>
+#include <stdio.h>
+#include <stdarg.h>
+#include <unistd.h>
+#include <string.h>
+#include <assert.h>
+/*for declaration of function `inet_addr'*/
+#include <sys/types.h>
+#include <sys/socket.h>
+#include <netinet/in.h>
+#include <arpa/inet.h>
+#include <signal.h>
+#include <sys/time.h>
+
+//#include "wireless_copy.h"
+#include "common.h"
+#include "version.h"
+#include "wapi_asue.h"
+#include "wapi_config.h"
+#include "wapi_asue_i.h"
+#include "utils/eloop.h"
+#include "drivers/driver_wext.h"
+#include "wai_interface.h"
+//#include "wpa_supplicant.h"
+#include "wpa.h"
+#include "wpa_i.h"
+#include "bss.h"
+#include "driver.h"
+#include "wpa_supplicant_i.h"
+#include "wpa_ctrl.h"
+
+extern void eloop_handle_alarm(int sig);
+struct wapi_config * wapi_config_init(struct wpa_ssid *ssid);
+int wpa_sm_set_ap_wapi_ie(struct wpa_sm *sm, const u8 *ie, size_t len);
+
+struct wpa_supplicant *get_supplicant_iface()
+{
+    struct wpa_global *global;
+    struct wpa_supplicant *wpa_s = NULL, *ifs;
+
+    global = (struct wpa_global *)eloop_get_user_data();
+
+	if (global == NULL) {
+	    wpa_printf(MSG_ERROR, " global = NULL\n");
+	    return NULL;
+	}
+	
+    // get the first iface, wlan0
+	for (ifs = global->ifaces; ifs; ifs = ifs->next) 
+			wpa_s = ifs;
+
+    return wpa_s;
+}
+
+int wapi_set_assoc_ie(const u8* pbuf, int length)
+{
+	struct wpa_supplicant *wpa_s;
+
+    wpa_s = get_supplicant_iface();
+
+	if (wpa_s == NULL) {
+	    wpa_printf(MSG_ERROR, " wpa_s = NULL\n");
+	    return -1;
+	}
+
+	wpa_printf(MSG_ERROR, " Set wpa_s to global->ifaces %s", wpa_s->ifname);
+	wapi_drv_set_wpa_ie(wpa_s, pbuf, length);
+	wpa_s->assoc_wapi_ie_len = length;
+    wpa_printf(MSG_DEBUG, "wpa_s->assoc_wapi_ie_len : %d",wpa_s->assoc_wapi_ie_len);
+	memcpy(wpa_s->assoc_wapi_ie, pbuf, length);
+    wpa_printf(MSG_DEBUG, "wpa_s->assoc_wapi_ie: [%02x][%02x][%02x][%02x]\n",
+            wpa_s->assoc_wapi_ie[0], wpa_s->assoc_wapi_ie[1], 
+			wpa_s->assoc_wapi_ie[2], wpa_s->assoc_wapi_ie[3]);
+    wpa_printf(MSG_DEBUG, "@@@@@@@@@@@@@ wpa_s ===> %p\n", wpa_s);
+
+	return 0;
+}
+
+unsigned long wapi_tx_wai_packet(const char* pbuf, int length)
+{
+	struct wpa_supplicant *wpa_s;
+	int ret;
+
+    wpa_s = get_supplicant_iface();
+
+	wpa_printf(MSG_DEBUG, "%s: sending l2 %d bytes data: %s\n",
+		   __FUNCTION__, length, pbuf);
+	ret = l2_packet_send(wpa_s->l2_wapi, wpa_s->bssid, 0x88b4, (const u8*)pbuf, (unsigned  int)length);
+
+	if (ret < 0)
+	{
+		return 0;
+	}
+	else
+	{
+		return (unsigned long)ret;
+	}
+}
+
+int wapi_set_unicast_key(const char* pKeyValue, int keylength, int key_idx)
+{
+	struct wpa_supplicant *wpa_s;
+
+	int alg, keylen, rsclen;
+	u8 *key_rsc;
+	u8 null_rsc[16] = { 0, 0, 0, 0, 0, 0, 0, 0 };
+
+	wpa_printf(MSG_DEBUG, "wapi_set_unicast_key: Installing USK to the driver.");
+
+    wpa_s = get_supplicant_iface();
+
+	alg = WPA_ALG_SMS4;
+	keylen = 32;
+	rsclen = 16;
+
+	key_rsc = null_rsc;
+	if (wapi_drv_set_key(wpa_s, alg, wpa_s->bssid, key_idx, 1, key_rsc, rsclen,
+			    (u8 *) pKeyValue, keylen, KEY_FLAG_PAIRWISE_RX_TX) < 0) {
+	    wpa_printf(MSG_WARNING, "wapi_set_unicast_key: Failed to set PTK to the driver");
+	    return -1;
+	}
+
+	return 0;
+}
+
+int wapi_set_group_key(const unsigned char* pKeyValue, int keylength, int key_idx, const unsigned char* key_iv)
+{
+	struct wpa_supplicant *wpa_s;
+	int alg;
+	u8 msk_len;
+
+	wpa_printf(MSG_DEBUG, "wapi_set_group_key: Installing group key to the driver.");
+	wpa_hexdump(MSG_DEBUG, "wapi_set_group_key: KEYSC", key_iv, 16);
+
+    wpa_s = get_supplicant_iface();
+
+	alg = WPA_ALG_SMS4;
+	msk_len = 32;
+	if (wapi_drv_set_key(wpa_s, alg, (u8 *) "\xff\xff\xff\xff\xff\xff",  key_idx, 1, key_iv, 16,   pKeyValue, keylength, KEY_FLAG_GROUP_RX_TX) < 0)
+
+	{
+		wpa_printf(MSG_WARNING, "WPA: Failed to set MSK to "
+			   "the driver.");
+		return -1;
+	}
+	else
+	    wpa_printf(MSG_DEBUG, "WAPI: succeeded to set MSK to the driver.");
+
+	return 0;
+}
+
+const char * wapi_connect_state_txt(wapi_connect_states state)
+{
+	switch (state) {
+	case WAPI_DISCONNECTED:
+		return "WAPI_DISCONNECTED";
+	case WAPI_ASSOCIATED:
+		return "WAPI_ASSOCIATED";
+	case WAPI_AUTHENTICATING:
+		return "WAPI_AUTHENTICATING";
+	case WAPI_CONNECTED:
+		return "WAPI_CONNECTED";
+	default:
+		return "UNKNOWN";
+	}
+}
+
+int wapi_notify_connect_state(wapi_connect_states state)
+{
+	struct wpa_supplicant *wpa_s = NULL;
+    wpa_s = get_supplicant_iface();
+	wpa_printf(MSG_DEBUG, "Notify wapi connect state %s",
+			wapi_connect_state_txt(state));
+
+	switch (state)
+	{
+	case WAPI_DISCONNECTED:
+	case WAPI_ASSOCIATED:
+		break;
+	case WAPI_AUTHENTICATING:
+		wpa_supplicant_set_state(wpa_s, WPA_4WAY_HANDSHAKE);
+		break;
+	case WAPI_CONNECTED:
+		wpa_supplicant_set_state(wpa_s, WPA_COMPLETED);
+		break;
+	default:
+		break;
+	}
+
+	return 0;
+}
+
+void wapi_deauthenticate()
+{
+    struct wpa_supplicant *wpa_s;
+
+    wpa_s = get_supplicant_iface();
+
+    wpa_msg(wpa_s, MSG_INFO, "WAPI: authentication failed");
+    wpa_supplicant_deauthenticate(wpa_s, 
+			WLAN_REASON_DEAUTH_LEAVING);
+}
+
+void get_l2_mtu(int *mtu_len)
+{
+    struct wpa_global *global;
+	struct wpa_supplicant *wpa_s;
+	
+	global = (struct wpa_global *)eloop_get_user_data(); 
+
+	if (global == NULL) {
+	    wpa_printf(MSG_ERROR, " global = NULL\n");
+	    return;
+	}
+	else
+	{
+	  wpa_s = global->ifaces;
+	}
+	if (wpa_s == NULL) {
+	    wpa_printf(MSG_ERROR, " wpa_s = NULL\n");
+	    return;
+	}
+	
+    *mtu_len = wpa_s->mtu;
+}
+
+static void init_sigaction(int signum, OS_timer_expired handle)
+{
+	signal(signum, handle);
+}
+
+void* OS_timer_setup(int deltaTimer, int repeated, OS_timer_expired pfunction, const void* pdata)
+{
+	struct itimerval value;
+	int sec = 0, usec = 0;
+	int repsec = 0, repusec = 0;
+
+	if (deltaTimer < 0 || repeated < 0 || pfunction == NULL)
+		return NULL;
+
+	init_sigaction(SIGALRM, pfunction);
+
+	sec  = deltaTimer/(1000);
+	usec = (deltaTimer%(1000)) * 1000;
+
+	repsec  = repeated/(1000);
+	repusec = (repeated%(1000)) * 1000;
+
+	memset(&value, 0, sizeof(value));
+
+	value.it_interval.tv_sec   = repsec;
+	value.it_interval.tv_usec = repusec;
+
+	value.it_value.tv_sec   = sec;
+	value.it_value.tv_usec = usec;
+
+	setitimer(ITIMER_REAL, &value, NULL);
+
+	return (void *)pfunction;
+}
+
+void OS_timer_clean(void* pTimer)
+{
+	struct itimerval value;
+
+	memset(&value, 0, sizeof(value));
+	setitimer(ITIMER_REAL, &value, NULL);
+
+	signal(SIGALRM, eloop_handle_alarm);
+}
+
+unsigned char get_rand_byte()
+{
+	return (unsigned char)(rand() & 0xFF);
+}
+
+struct wapi_config * wapi_config_init(struct wpa_ssid *ssid)
+{
+	struct wapi_config *config = NULL;
+	connect_param lib_param;
+	char *ptr = NULL;
+	char *from, *to;
+	int i;
+	//struct wpa_global *eloop = (struct wpa_global *)eloop_get_user_data();
+
+	wpa_printf(MSG_DEBUG, "Entering %s...", __FUNCTION__);
+
+	config = os_malloc(sizeof(*config));
+	if (config == NULL)
+		return NULL;
+	os_memset(config, 0, sizeof(*config));
+
+	config->ssid_len = ssid->ssid_len;
+	/* config->ssid = (u8 *)strdup(ssid->ssid); */
+	config->ssid = (u8 *)os_malloc(ssid->ssid_len+1);
+	if (config->ssid == NULL)
+	{
+		wapi_config_free(config);
+		return NULL;
+	}
+	os_memcpy(config->ssid, ssid->ssid, ssid->ssid_len);
+	config->ssid[ssid->ssid_len] = '\0';
+	wpa_printf(MSG_DEBUG, "ssid '%s'", config->ssid);
+	
+	config->wapi_policy = ssid->wapi;
+	if (config->wapi_policy != 0)
+	{
+		config->group_cipher = WAPI_CIPHER_SMS4;
+		config->pairwise_cipher = WAPI_CIPHER_SMS4;
+	}
+	
+	if (config->wapi_policy & 0x08) {
+		wpa_printf(MSG_DEBUG, " AUTH_TYPE_WAPI_CERT");
+		lib_param.authType = AUTH_TYPE_WAPI_CERT;
+
+		wpa_printf(MSG_DEBUG, "%s: wapi_cert_sel_mode = %d \n", __FUNCTION__, 
+			ssid->wapi_cert_sel_mode);
+		lib_param.wapi_cert_sel_mode = ssid->wapi_cert_sel_mode;
+		
+		if(ssid->wapi_cert_sel_mode == 1) {
+			wpa_printf(MSG_DEBUG, "%s: wapi_cert_sel = %s \n", __FUNCTION__, 
+				ssid->wapi_cert_sel);
+			strcpy(lib_param.wapi_cert_sel, ssid->wapi_cert_sel);
+		}
+	} else if (config->wapi_policy & 0x04) {
+		wpa_printf(MSG_DEBUG, " AUTH_TYPE_WAPI_PSK");
+		lib_param.authType = AUTH_TYPE_WAPI_PSK;
+
+		wpa_printf(MSG_DEBUG, "%s: wapi_psk_type = %d", __FUNCTION__, 
+			ssid->wapi_psk_type);
+		if (ssid->wapi_psk == NULL ||
+			os_strcmp(ssid->wapi_psk, "") == 0) {
+            wpa_printf(MSG_ERROR, "[%s] wapi_psk is null \n", __FUNCTION__);
+            return config;
+        }
+		else {
+			wpa_printf(MSG_DEBUG, "%s: wapi_psk = %s", __FUNCTION__, "*");
+		}
+		
+		if (ssid->wapi_psk_type == KEY_TYPE_HEX) {
+            lib_param.kt = KEY_TYPE_HEX;
+            lib_param.kl = os_strlen(ssid->wapi_psk);	
+            os_memcpy(lib_param.kv, ssid->wapi_psk, lib_param.kl);
+        } else {
+            lib_param.kt = KEY_TYPE_ASCII;
+            lib_param.kl = os_strlen(ssid->wapi_psk);
+            os_memcpy(lib_param.kv, ssid->wapi_psk, lib_param.kl);
+        }
+	} else {
+		wpa_printf(MSG_DEBUG, " AUTH_TYPE_NONE_WAPI");
+		lib_param.authType = AUTH_TYPE_NONE_WAPI;
+	}
+
+	/* do it after the wpa_s has been attached to global */
+	if (wapi_set_connect_param(&lib_param) != 0) {
+		wpa_printf(MSG_ERROR, "%s: set wapi assoc param faild \n", __FUNCTION__);
+		os_free(config->ssid);
+		wapi_config_free(config);
+		return NULL;
+	}
+
+	return config;
+}
+
+int wpa_sm_set_ap_wapi_ie(struct wpa_sm *sm, const u8 *ie, size_t len)
+{
+	if (sm == NULL)
+		return -1;
+	os_free(sm->ap_wapi_ie);
+	if (ie == NULL || len == 0) {
+		wpa_printf(MSG_DEBUG, " * WPA: clearing AP WAPI IE");
+		sm->ap_wapi_ie = NULL;
+		sm->ap_wapi_ie_len = 0;
+	} else {
+		wpa_hexdump(MSG_DEBUG, " * WPA: set AP WAPI IE", ie, len);
+		sm->ap_wapi_ie = os_malloc(len);
+		if (sm->ap_wapi_ie == NULL)
+			return -1;
+
+		os_memcpy(sm->ap_wapi_ie, ie, len);
+		sm->ap_wapi_ie_len = len;
+	}
+	return 0;
+}
+
