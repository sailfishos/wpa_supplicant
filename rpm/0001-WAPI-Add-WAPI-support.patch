+/* 
+* Copyright (c) 2000-2012 China IWNCOMM Co., Ltd. All rights reserved.
+*
+* Module:        Hash value calculation.           
+* Description:   Hash algorithm implement,Call the SM3 algorithm 
+*                and SHA256 algorithm.
+* Writer:        zhangguoqiang@DST <zhanggq@iwncomm.com>
+* Version:  $Id:hash.c,v 1.0 2011/04/01 09:00:00 zhangguoqiang Exp $     
+*
+* History: 
+* zhangguoqiang    2011/04/01    v1.0    Created.
+*/
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include "hmac.h"
+#include "hash.h"
+
+#define IWN_HASH_SHA256
+#ifdef IWN_HASH_SM3
+#include "sm3.h"
+#endif
+
+#ifdef IWN_HASH_SHA256
+#include "hmac.h"
+#endif
+
+#define MAX_BUFLEN_1 100
+/*====================================================================*/
+
+/*====================================================================*/
+static void sha256_digest_int(const void *msg, unsigned int len, MINT *hv);
+static void sm3_digest_int(HASH_CONTX *ctx, MINT *hv);
+/*====================================================================*/
+int hash_mint_value(HASH_CONTX *ctx,MINT *max,MINT *value)
+{
+	int ret=-1;
+	switch(ctx->hash_type)
+	{
+#ifdef IWN_HASH_SM3
+	case HASH_TYPE_SM3:
+		sm3_digest_int(ctx,value);
+		ret = 0;
+		break;
+#endif
+#ifdef IWN_HASH_SHA256
+	case HASH_TYPE_SHA256:
+		sha256_digest_int((const void*)ctx->data,ctx->len_low,value);
+		ret = 0;
+		break;
+#endif
+	default:
+		break;
+	}
+	if(ret==0 && max!=NULL)
+	{
+		mint_mod(value,max,value);
+	}
+	return ret;
+}
+/*--------------------------------------------------------------------*/
+#ifdef IWN_HASH_SHA256
+static void sha256_digest_int(const void *msg, unsigned int len, MINT *hv)
+{
+	unsigned char tmp[MAX_BUFLEN_1] = {0};
+	unsigned i;
+	cal_value(tmp, (unsigned char*)msg, len);
+
+	for (i=0; i<8; i++)
+	{
+		unsigned char* p = tmp + 4*i;
+		hv->value[7-i] = (p[0]<<24) + (p[1]<<16) + (p[2]<<8) + p[3];
+	}
+	hv->len = 8;
+}
+#endif
+/*--------------------------------------------------------------------*/
+#ifdef IWN_HASH_SM3
+static void sm3_digest_int(HASH_CONTX *ctx, MINT *hv)
+{
+	SM3_CONTX contx;
+	unsigned char tmp[MAX_BUFLEN_1] = {0};
+	memset(&contx,0,sizeof(SM3_CONTX));
+	contx.data = ctx->data;
+	contx.length_high = ctx->len_high;
+	contx.length_low = ctx->len_low;
+	sm3_hash(&contx, tmp);
+	octetstring_to_mint(tmp,32,hv);
+}
+#endif
+/*====================================================================*/
+/*ĘĄ╗žųĄ š¬ę¬│żČ╚*/
+int hash_byte(HASH_CONTX *ctx,unsigned char *digest)
+{
+	int ret=0;
+#ifdef IWN_HASH_SM3
+	SM3_CONTX contx;
+	memset(&contx,0,sizeof(SM3_CONTX));
+#endif
+	switch(ctx->hash_type)
+	{
+#ifdef IWN_HASH_SM3
+	case HASH_TYPE_SM3:
+		contx.data = ctx->data;
+		contx.length_high = ctx->len_high;
+		contx.length_low = ctx->len_low;
+		sm3_hash(&contx, digest);
+		ret = 32;
+		break;
+#endif
+#ifdef IWN_HASH_SHA256
+	case HASH_TYPE_SHA256:
+		cal_value(digest,(unsigned char*)ctx->data,ctx->len_low);
+		ret = 32;
+		break;
+#endif
+	default:
+		break;
+	}
+	return ret;
+}
+/*====================================================================*/
