+static void key_derivation(u8 *inkey, int inkey_len, u8 *text, int text_len, 
+					u8 *outkey, int outkey_len, u8 isusk)
+{
+	iwn_kdhmac_sha256(text, text_len, inkey, inkey_len, outkey, outkey_len);
+
+	if (isusk)
+	{
+		iwn_mhash_sha256(outkey + outkey_len - CHALLENGE_LEN, CHALLENGE_LEN, 
+					outkey + outkey_len - CHALLENGE_LEN);
+	}
+}
