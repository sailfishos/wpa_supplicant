+int hostapd_setup_wapi(struct hostapd_data *hapd)
+{
+	struct wapi_auth_config _conf;
+	struct wapi_auth_callbacks cb;
+	const u8 *wapi_ie;
+	size_t wapi_ie_len;
+	wpa_printf(MSG_DEBUG, "Enter %s",__func__);
+	hostapd_wapi_auth_conf(hapd->conf, &_conf);
+
+	if (hapd->iface->drv_flags & WPA_DRIVER_FLAGS_EAPOL_TX_STATUS)
+		_conf.tx_status = 1;
+	os_memset(&cb, 0, sizeof(cb));
+	cb.ctx = hapd;
+
+	cb.set_authorized = hostapd_wapi_auth_set_authorized;	
+	cb.get_bkid = hostapd_wapi_auth_get_bkid;	
+	cb.get_usk = hostapd_wapi_auth_get_usk;	
+	cb.get_msk = hostapd_wapi_auth_get_msk;
+	cb.set_key = hostapd_wapi_auth_set_key;
+	cb.send_wapi = hostapd_wapi_auth_send;
+
+	hapd->wapi_auth = wapi_init(hapd->own_addr, &_conf, &cb);
+	if (hapd->wapi_auth == NULL) {
+		wpa_printf(MSG_ERROR, "WAPI initialization failed.");
+		return -1;
+	}
+	wpa_printf(MSG_DEBUG, "WAPI initialization OK.");
+	return 0;
+
+}
