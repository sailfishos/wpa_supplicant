+		case 2:
+			*outm = (m << 2) | (m >> 14 & 3);
+			break;
+		case 3:
+			*outm = (m << 3) | (m >> 13 & 7);
+			break;
+		case 4:
+			*outm = (m << 4) | (m >> 12 & 0xF);
+			break;
+		case 5:
+			*outm = (m << 5) | (m >> 11 & 0x1F);
+			break;
+		default:
