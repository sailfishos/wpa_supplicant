+/*---------------------------------------------------------------------------------------*/
+int UnPack_CHECK_X509(unsigned char *In, int len, CHECK_X509_Cert *check_ctx)
+{
+	int len0=0,len1=0;
+	unsigned char Llen=0;
+	unsigned char *p = NULL;
+	int g_X509Check_Length = 0;
+
+	p = In;
+	p += 1;
+	len0 = GetInfoLength(p,&Llen);
+	p += Llen;
+
+	g_X509Check_Length = Llen+1;
+
+	check_ctx->check_info.data = p;
+	p += 1;
+	len1 = GetInfoLength(p,&Llen);
+	p += Llen;
+	check_ctx->check_info.length = len1+Llen+1;
+	p += len1;  
+
+	g_X509Check_Length += check_ctx->check_info.length;
+
+	check_ctx->sig_info.data = p;
+
+	check_ctx->sig_info.length = len0-check_ctx->check_info.length;
+
+	g_X509Check_Length += check_ctx->sig_info.length;
+
+	if(g_X509Check_Length == len)
+	{
+	    return CTP_OK;
+	}
+	else
+	{
+		return CTP_FALSE;
+	}
+}
