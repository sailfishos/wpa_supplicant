+static void __wapi_send_wai(struct wapi_authenticator *wapi_auth,
+		      struct wapi_state_machine *sm, u8_t *data_hdr, 
+		      size_t data_len, int wai_subtype)
+{
+	wapi_printf(MSG_DEBUG, "WAPI_auth: Enter %s",__func__);
+	struct wapi_wai_hdr *hdr;
+	size_t len;
+
+	len = sizeof(struct wapi_wai_hdr) + data_len;
+
+	hdr = os_malloc(len);
+	if (hdr == NULL)
+		return;
+
+	os_memcpy((hdr + 1), data_hdr, data_len);
+	
+	hdr->version = os_htobe16(WAI_VERSION);
+	hdr->type = WAI_PROTOCOL_TYPE;
+	hdr->stype = (wai_subtype & wai_stype_mask);
+	hdr->reserved = os_htobe16(0x0000);
+	hdr->data_len = os_htobe16(len);
+	hdr->group_sc = os_htobe16(sm->group_sc);
+	hdr->frame_sc = 0x00;
+	hdr->frame_flag = 0x00;
+
+	wapi_auth_send(wapi_auth, sm->addr, (u8_t *) hdr, len,
+			    sm->pairwise_set);
+	os_free(hdr);
+}
