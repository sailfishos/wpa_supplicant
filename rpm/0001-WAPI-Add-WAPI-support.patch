+/*--------------------------------------------------------------------*/
+/* modular = dividend % divisor */
+int mint_mod_reduce(MINT *dividend,MINT *divisor,MINT *modular)
+{
+	int ret,i,j;
+	MINT tmp,quo,s,t,z;
+	int n;
+
+	memset(&z,0,sizeof(MINT));
+	memset(&tmp,0,sizeof(MINT));
+	memset(&s,0,sizeof(MINT));
+	memset(&t,0,sizeof(MINT));
+	memset(&z,0,sizeof(MINT));
+
+	if((ret = mint_compare(dividend,divisor))==0)
+	{
+		MI_DWORDTOMINT(modular,0);
+	}
+	else if(ret < 0)
+	{
+		for (i=0;i<dividend->len;i++)
+		{
+			modular->value[i]=dividend->value[i];
+		}
+		modular->len=dividend->len;
+	}
+	else
+	{
+		n= dividend->len-divisor->len;
+		for (i=n,j=0;j<divisor->len;i++,j++)
+		{
+			tmp.value[j]=dividend->value[i];
+		}
+		tmp.len = divisor->len;
+
+		mint_div(&tmp,divisor,&quo,&z);
+		if (dividend->len > divisor->len)
+		{
+			s.len=1;
+			for (i=(n -1); i>=0; i--)
+			{
+				s.value[0] = dividend->value[i];
+				mint_left_move(&z,32);
+				mint_add(&z,&s,&t);
+				mint_div(&t,divisor,&quo,&z);
+			}			
+		}
+		mint_copy(modular,&z);		
+	}
+	return 0;
+}
