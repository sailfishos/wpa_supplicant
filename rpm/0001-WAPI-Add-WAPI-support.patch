+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include "mint.h"
+
+/*====================================================================*/
+#define _IA64 1
+
+#ifndef max
+#define max(a,b) a>b ? a:b
+#endif
+
+#ifndef min
+#define min(a,b) a<b ? a:b
+#endif
+
+#define MINT_DIV 1
+
+#define M(x)    (((unsigned int)(x))&MAX_DWORD_VALUE)
+#define N(x)    (((unsigned int)((x)>> MINT_BIT))&MAX_DWORD_VALUE)
+
+#define mul_3(p,q,f,h) { word64 x; \
+	x=(word64)f * (q) + (p) + (h); \
+	(p)= M(x); (h)= N(x);}
+#define mul_4(p,q,f,h) { word64 x; \
+	x=(word64)f * (q) + (h); \
+	(p)= M(x); (h)= N(x);}
+/*====================================================================*/
+static void dword_mul(dword opt1,dword opt2,dword *result);
+static int dword_div(dword x[2],dword y,dword *z);
+
+static dword dword_mint_add(MINT *a,MINT *b,int idx,dword c,MINT *d);
+static dword dword_mint_sub_mul(MINT *a,int idx,dword b,MINT *c);
+static int dword_mint_cmp(MINT *a,int idx,MINT *b);
+static dword dword_mint_sub(MINT *a,int idx,MINT *b);
+/*====================================================================*/
+static void dword_mul(dword opt1,dword opt2,dword *result)
+{
+#ifdef _IA64
+	word64 val;
+	val = ((word64)opt1)*((word64)opt2);
+	result[1]=(dword)(val >> BITS_DWORD_SIZE);
+	result[0]=(dword)(val);
+#else
+	word ahigh,alow,bhigh,blow;
+	dword t;
+
+	ahigh = (word)HIGH_HALF_DWORD(opt1);
+	alow = (word)LOW_HALF_DWORD(opt1);
+	bhigh = (word)HIGH_HALF_DWORD(opt2);
+	blow = (word)LOW_HALF_DWORD(opt2);
+	t = alow*bhigh + ahigh*blow;
+	result[1] = ahigh*bhigh + ((t >> HALF_DWORD_BITS)&MAX_HALF_DWORD);
+	result[0] = alow*blow + ((t << HALF_DWORD_BITS)&HALF_HIGH_DWORD);
+
+#endif
+	return;
+}
+/*--------------------------------------------------------------------*/
+static int dword_div(dword x[2],dword y,dword *z)
+{
+#ifdef _IA64
+	word64 t = ((((word64)(x)[1])<<32) |(x)[0]) / (word64)(y);
+	z[0]= ((dword)t);
+	z[1] = (dword)(t>>32);
+#else
+	word32 i,uflag;
+
+	if(y==0)
+		return -1;
+
+	if(x[1]==0)
+	{
+		z[0] = x[0]/y;
+		z[1] = 0;
+	}
+	else
+	{
+		for(i=0;i<BITS_DWORD_SIZE;i++)
+		{
+			uflag = (long)x[1]>>31;
+			x[1] = (x[1]<<1)|(x[0]>>31);
+			x[0] <<=1;
+
+			z[1]=(x[1]<<1)|(x[0]>>31);
+			z[0]<<=1;
+
+			if((x[1]|uflag)>=x[0])
+			{
+				x[1]-=y;
+				if(z[0]<MAX_DWORD_VALUE)
+					z[0]++;
+				else
+					z[1]++;
+			}
+		}
+	}
+#endif
+	return 0;
+}
+/*====================================================================*/
+static int dword_mint_cmp(MINT *a,int idx,MINT *b)
+{
+	int i;
+	for (i = b->len - 1; i >= 0; -- i) {
+		if (a->value[i+idx] > b->value[i])
+			return 1;
+		else if (a->value[i+idx] < b->value[i])
+			return -1;
+	}
+	return 0;
+} 
+static dword dword_mint_add(MINT *a,MINT *b,int idx,dword c,MINT *d)
+{
+	dword carry, t[2];
+	int i;
+	
+	carry = 0;
+	for (i = 0; i < d->len; ++ i) 
+	{
+		dword_mul(c, d->value[i],t);
+		if ((a->value[i+idx] = b->value[i+idx] + carry) < carry){
+			carry = 1;
+		}else{	
+			carry = 0;
+		}
+		if ((a->value[i+idx] += t[0]) < t[0]){
+			++ carry;
+		}
+		carry += t[1];
+	}
+	return carry;
+}
+static dword dword_mint_sub(MINT *a,int idx,MINT *b)
+{
+	dword borrow;
+	int i;
+
+	borrow = 0;
+	for (i = 0; i < b->len; ++ i) {
+		if ((borrow += b->value[i]) < b->value[i]){
+			borrow = 1;
+		}
+		else {
+			if ((a->value[i+idx]-=borrow) > (MAX_DWORD_VALUE - borrow)){
+				borrow = 1;
+			}else{ 
+				borrow = 0;
+			}
+		}
+	}
+	return borrow;
+}
+static dword dword_mint_sub_mul(MINT *a,int idx,dword b,MINT *c)
+{
+	dword borrow, t[2]={0};
+	int i;
+
+	borrow = 0;
+	for (i = 0; i < c->len; ++ i) 
+	{
+		dword_mul(b, c->value[i],t);
+		if ((borrow += t[0]) < t[0]){ 
+			++t[1];
+		}
+		if ((a->value[i+idx] -= borrow) > (MAX_DWORD_VALUE - borrow)){ 
+			borrow = t[1] + 1;
+		}else{
+			borrow = t[1];
+		}
+	}
+	return borrow;
+}
+/*====================================================================*/
+int octetstring_to_mint(const unsigned char *octstr_val, unsigned int octstr_len,MINT *mint_val)
+{
+	dword word;
+	int i, j, k, t, wlen;
+	memset(mint_val,0,sizeof(MINT));
+	wlen = (octstr_len+MI_BYTES_PER_DWORD-1)/MI_BYTES_PER_DWORD;
+	for (i = octstr_len, j = 0; i > 0; i -= 4, ++ j) 
+	{
+		word = 0;
+		t = (int)min (i, (int)MI_BYTES_PER_DWORD);
+		for (k = 0; k < t; ++ k) 
+		{
+			word = (word << MI_BITS_PER_BYTE) | octstr_val[i - t + k];
+		}
+		mint_val->value[j] = word;
+	}
+	mint_adjust_len(mint_val, wlen);
+	return 0;
+}
+/*--------------------------------------------------------------------*/
+int mint_to_octetstring(const MINT *mint_val,int buflen,unsigned char *octstr_val,unsigned int *octstr_len)
+{
+	dword word;
+	int i, j, k, t;
+	int ret = 0;
+
+	for (i = mint_val->len - 1, j = 0; i >= 0; -- i) 
+	{
+		t = MI_BYTES_PER_DWORD;
+		word = mint_val->value[i];
+		if (i == mint_val->len - 1) 
+		{
+			while ((word>>((t-1)*MI_BITS_PER_BYTE)==0)&&(t>1))
+				-- t;
+			if((int)(t+i*MI_BYTES_PER_DWORD) > buflen)
+			{
+				ret = 1;
+				break;
+			}
+		}
+		for (k = t - 1; k >= 0; -- k)
+		{
+			octstr_val[j++] = (unsigned char)(mint_val->value[i]>>(k*MI_BITS_PER_BYTE));
+		}
+	}
+	if (ret == 0)
+		*octstr_len = j;
+
+	return ret;
+}
+/*--------------------------------------------------------------------*/
+int mint_to_fixedlen_os(const MINT *src_int, unsigned int fixedlen,
+				unsigned int osbufsize, unsigned int *oslen,
+				unsigned char* dstr)
+{
+	int d, i;
+	int ret=0;
+	unsigned int len=0;
+
+	*oslen = 0;
+	if ((ret = mint_to_octetstring(src_int,osbufsize,dstr,&len)) == 0)
+	{
+		if ((d = fixedlen - len) > 0) 
+		{
+			for (i = fixedlen - 1; i >= d; -- i) 
+				dstr[i] = dstr[i - d];
+			for (i = d - 1; i >= 0; -- i)
+				dstr[i] = 0;
+		}
+		else if (d < 0) 
+		{
+			ret = 2;
+			return ret;
+		}
+		*oslen = fixedlen;
+	}
+	return ret;
+}
+/*====================================================================*/
+/* dest = src */
+int mint_copy(MINT *dest,MINT *src)
+{
+	int i;
+	for (i=0;i<src->len;i++)
+	{
+		dest->value[i] = src->value[i];
+	}
+	dest->len = src->len;
+	return 0;
+}
+/*--------------------------------------------------------------------*/
+/* -1: a<b; 0: a=b; 1: a>b */
+int mint_compare(MINT *a,MINT *b)
+{
+	int i,ret = 0;
+ 	if (a->len > b->len)
+	{
+		ret = 1;
+	}
+	else if (a->len < b->len)
+	{
+		ret = -1;
+	}
+	else
+	{
+		for (i=a->len-1;i>=0;i--)
+		{
+			if (a->value[i] > b->value[i])
+			{
+				ret = 1;
+				break;
+			}
+			if (a->value[i] < b->value[i])
+			{
+				ret = -1;
+				break;
+			}
+		}
+	}
+	return ret;
+}
+/*--------------------------------------------------------------------*/
+/* a<<bits */
+int mint_left_move(MINT *a,unsigned int bits)
+{
+	dword r,moveout;
+	int i,bitsleft,n,j;
+
+	if (bits == 0)
+	{
+		return 0;
+	}
+	n = bits/BITS_DWORD_SIZE;
+	for(i=0;i<n;i++)
+	{
+		for(j=a->len-1;j>=0;j--)
+		{
+			a->value[j+1]=a->value[j];			
+		}
+		a->value[0]=0;
+		a->len++;
+	}
+	n = bits%BITS_DWORD_SIZE;
+	if(n!=0)
+	{
+		bitsleft = BITS_DWORD_SIZE - n;
+		moveout = 0;
+		for (i=0;i<a->len;i++)
+		{
+			r = a->value[i];
+			a->value[i] = (r << bits) | moveout;
+			moveout = r >> bitsleft;
+		}
+		a->value[i] = moveout;
+		a->len = i+1;
+	}
+	mint_adjust_len(a,a->len);
+	return 0;
+}
+/*--------------------------------------------------------------------*/
+/* a>>bits */
+int mint_right_move(MINT *a,unsigned int bits)
+{
+	dword r,moveout;
+	int i,bitsleft,n,j;
+
+	if (bits == 0)
+	{
+		return 0;
+	}
+	n = bits/BITS_DWORD_SIZE;
+	for(i=0;i<n;i++)
+	{
+		for(j=0;j<a->len-1;j++)
+		{
+			a->value[j]=a->value[j+1];	
+		}
+		a->value[j]=0;
+		a->len--;
+	}
+	n = bits%BITS_DWORD_SIZE;
+	if(n!=0)
+	{
+		bitsleft = BITS_DWORD_SIZE - bits;
+		moveout = 0;
+		for (i=a->len-1;i>=0;i--)
+		{
+			r = a->value[i];
+			a->value[i] = (r >> bits) | moveout;
+			moveout = r << bitsleft;
+		}
+	}
+	mint_adjust_len(a,a->len);
+	return 0;
+}
+/*--------------------------------------------------------------------*/
+int mint_adjust_len(MINT *mint_val,int len)
+{
+	int i;
+	for (i = len - 1; i >= 0; -- i)
+	{
+		if (mint_val->value[i] != 0)
+			break;
+	}
+	mint_val->len = i + 1;
+	return 0;
+}
+/*------------------------------------------------------------------------------------------*/
+//ĘĄ╗žĮ°╬╗ųĄ
+unsigned int add_2(const unsigned int *x, const unsigned int *y, int m, unsigned int *t)
+{
+	word64 k=0;
+
+	if (m <= 0) return (unsigned int)0;
+
+	for (;;)
+	{
+		k+=(word64)x[0]+y[0];
+		t[0]=(unsigned int)k;
+		k>>= MINT_BIT;
+		if (--m <= 0) break;
+
+		k+=(word64)x[1]+y[1];
+		t[1]=(unsigned int)k;
+		k>>= MINT_BIT;
+		if (--m <= 0) break;
+
+		k+=(word64)x[2]+y[2];
+		t[2]=(unsigned int)k;
+		k>>= MINT_BIT;
+		if (--m <= 0) break;
+
+		k+=(word64)x[3]+y[3];
+		t[3]=(unsigned int)k;
+		k>>= MINT_BIT;
+		if (--m <= 0) break;
+
+		x+=4;
+		y+=4;
+		t+=4;
+	}
+
+	return (unsigned int)k;
+}
+/*--------------------------------------------------------------------*/
+/* sum=addend1+addend2 */
+int mint_add(MINT *addend1,MINT *addend2,MINT *sum)
+{
+	MINT *addend3;	
+	unsigned int *addend1_value,*addend2_value,*sum_value;
+	unsigned int c,m,n;
+	int big_len,small_len,sub_len;
+	
+
+	mint_adjust_len(addend1,addend1->len);
+	mint_adjust_len(addend2,addend2->len);
+
+	if(addend1->len < addend2->len)
+	{
+		addend3=addend1; 
+	    addend1=addend2; 
+		addend2=addend3; 
+	}
+
+	big_len = addend1->len;
+	small_len = addend2->len;
+	sub_len = big_len - small_len;
+
+	sum->len=big_len;
+
+	addend1_value = addend1->value;
+	addend2_value = addend2->value;
+	sum_value = sum->value;
+
+	//c╬¬Į°╬╗ųĄ
+	c = add_2(addend1_value,addend2_value,small_len,sum_value);	
+	addend1_value += small_len;
+	addend2_value += small_len;
+	sum_value += small_len;
+
+	if(c)
+	{
+		while(sub_len)
+		{
+			sub_len--;
+			m = *(addend1_value++);
+			n = (m+1) & MAX_DWORD_VALUE;
+			*(sum_value++) = n;
+			if(n)
+			{
+				c=0;
+				break;
+			}
+		}
+
+		//Į°╬╗c▓╗╬¬0,sub_len╬¬0
+		if(c)
+		{
+			*sum_value = 1;
+			sum->len++;
+		}
+	}
+
+	//addend1,addend2│żČ╚▓╗Ą╚
+	if(sub_len && (sum_value != addend1_value))
+	{
+		while(sub_len--)
+		{
+			*(sum_value++) = *(addend1_value++);
+		}
+	}
+
+	mint_adjust_len(sum,sum->len);
+	return 0;
+}
+/*================================================================*/
+/* diff=minuend-subtrahend */
+int mint_sub(MINT *minuend,MINT *subtrahend,MINT *diff)
+{
+	MINT *a,*b;
+	int rs,ret,i;
+	dword s = 0;
+	ret = 0;
+
+	if((rs = mint_compare(minuend,subtrahend))>0)
+	{
+		a = minuend;
+		b = subtrahend;
+	}
+	else if(rs < 0)
+	{
+		a = subtrahend;
+		b = minuend;
+		ret=1;
+	}
+	else
+	{
+		MI_DWORDTOMINT(diff,0);
+		return 0;
+	}
+
+	for (i=0;i < a->len;i++)
+	{
+		if(i<b->len)
+		{
+			if (a->value[i] > b->value[i])
+			{
+				diff->value[i] = a->value[i] - b->value[i] -s;
+				s = 0;
+			}
+			else if ((a->value[i] == b->value[i]) && (s == 1))
+			{
+				diff->value[i] = MAX_DWORD_VALUE;       //2016/02/03
+				//s = 1;
+			}
+			else if ((a->value[i] == b->value[i]) && (s == 0))
+			{
+				diff->value[i] = 0;
+				//s = 0;
+			}
+			else
+			{
+				diff->value[i] = MAX_DWORD_VALUE-(b->value[i]-a->value[i])-s+1;
+				s = 1;
+			}
+		}
+		else
+		{
+			diff->value[i] = a->value[i]-s;
+			if (diff->value[i] > a->value[i])
+			{
+				s = 1;
+			}
+			else
+			{
+				s = 0;
+			}
+		}
+		
+	}
+	mint_adjust_len(diff,a->len);
+	return ret;
+}
+/*--------------------------------------------------------------------*/
+int get_mint_bit_len(MINT *x)
+{
+	int len,i;
+	dword k;
+	len = (x->len>1)?((x->len-1)*BITS_DWORD_SIZE):0;
+	k = x->value[x->len-1];
+	for(i=0;(i<(int)BITS_DWORD_SIZE)&&(k!=0);++i,k>>=1);
+	len+=i;
+	return len;
+}
