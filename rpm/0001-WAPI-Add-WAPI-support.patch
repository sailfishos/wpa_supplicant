+		ecc_fix_point_mul(&prikey,&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.G),&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.A),&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.B),&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.P),&pubkey,((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_GPt_1);
+		mint_to_fixedlen_os(&(pubkey.x),EccSessionHandle->g_fixlen,ECCref_MAX_LEN,&len,ucPublicKey.x);
+		mint_to_fixedlen_os(&(pubkey.y),EccSessionHandle->g_fixlen,ECCref_MAX_LEN,&len,ucPublicKey.y);
+		ucPublicKey.bits = len*BITS_PER_BYTE;
+		if(IWN_GenerateUserInfo(hSessionHandle,&ucPublicKey,pucID,uiIDLength,Za,&zalen)!=SDR_OK)
+		{
+			ret = SDR_PARAINPUTERR;
+			return ret;
+		}
+		dlen = uiDataLength+zalen;
+		tmp = (unsigned char*)malloc(sizeof(unsigned char)*dlen+1);
+		if(tmp==NULL){
+			return ret;
+		}
+		memset(tmp,0,dlen+1);
+		memcpy(tmp,Za,zalen);
+		memcpy(tmp+zalen,pucData,uiDataLength);
+		ctx.data = tmp;
+		ctx.len_high=0;
+		ctx.len_low = dlen;
+		ctx.hash_type = EccSessionHandle->g_hash_type;
+		dlen = hash_byte(&ctx,buf);
+		ret = SDF_ExternalSign_ECC(hSessionHandle,uiAlgID,pucExpPrivateKey,buf,dlen,pucSignature);
+		free(tmp);
+		tmp=NULL;
+		break;
+#endif
+#ifdef IWN_ECC_ECDSA
+	case SGD_ECDSA:
+		ctx.data = pucData;
+		ctx.len_high=0;
+		ctx.len_low = uiDataLength;
+		ctx.hash_type = EccSessionHandle->g_hash_type;
+		dlen = hash_byte(&ctx,buf);
+		ret = SDF_ExternalSign_ECC(hSessionHandle,uiAlgID,pucExpPrivateKey,buf,dlen,pucSignature);
+		break;
+#endif
+	default:
+		break;
+	}
+	return ret;
+}
