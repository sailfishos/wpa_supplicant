+ * -GB 15629.11-2003/XG1-2006
+ *
+ */
+
+#include <stdlib.h>
+#include <stdio.h>
+#include <string.h>
+#include "wapi_stack.h"
+#include "wapi_os.h"
+#include "alg_ecc_if.h"
+
+#define KD_HMAC_OUTKEY_LEN 96
+
+int alg_init(void)
+{
+    return ecc_init();
+}
+
+void alg_exit(void)
+{
+    ecc_exit();
+    return;
+}
+
+int _wapi_pskbk_derivation(char *wapi_psk, size_t wapi_psk_len, unsigned char *bk)
+{
+	char input_text[200] = "preshared key expansion for authentication and key negotiation";
+
+	return iwn_kdhmac_sha256((unsigned char *)input_text, 
+			strlen(input_text),
+			(unsigned char *)wapi_psk, 
+			wapi_psk_len, bk, 16);
+}
+
+int wapi_pskbkid_derivation(const unsigned char *ap_addr, 
+		const unsigned char *sta_addr, 
+		const unsigned char *bk, 
+		unsigned char *bkid)
+{
+	unsigned char input_text[12] = {0,};
+	unsigned char temp_bk[16];
+	
+	memcpy(input_text, ap_addr, ETH_ALEN);
+	memcpy(input_text + ETH_ALEN, sta_addr, ETH_ALEN);
+
+	memcpy(temp_bk, bk, 16);
+	
+	return iwn_kdhmac_sha256(input_text, (ETH_ALEN + ETH_ALEN), temp_bk, 16, bkid, 16);
+}
+
+int wapi_usk_derivation(const unsigned char *bk, 
+		unsigned char *mac1, unsigned char *mac2, 
+		unsigned char *ANonce, unsigned char *SNonce, 
+		unsigned char *next_ae_nonce, 
+		unsigned char *master_key)
+{
+	size_t text_len;
+	unsigned char text[200];
+	const char Input_text[100] = "pairwise key expansion for unicast and additional keys and nonce";
+	unsigned char temp_bk[16];
+
+	memcpy(text, mac1, ETH_ALEN);
+	memcpy(text + ETH_ALEN, mac2, ETH_ALEN);
+	memcpy(text + 12, ANonce, 32);
+	memcpy(text + 12 + 32, SNonce, 32);
+	memcpy(text + 12 + 32 + 32, Input_text, strlen(Input_text));
+	text_len = 12 + 32 + 32 + strlen(Input_text);
+	memcpy(temp_bk, bk, 16);
+	
+	iwn_kdhmac_sha256(text, text_len, temp_bk, 16, master_key, KD_HMAC_OUTKEY_LEN);
+	return iwn_mhash_sha256(master_key + 64, 32, next_ae_nonce);
+}
+
+int wapi_msk_derivation(unsigned char *nmk, unsigned char *msk, size_t len)
+{
+	size_t text_len;
+	const char Input_text[100] = "multicast or station key expansion for station unicast and multicast and broadcast";
+	text_len = strlen(Input_text);
+
+	return iwn_kdhmac_sha256((unsigned char *)Input_text, text_len, nmk, 16, msk, len);
+}
+
