+#ifdef CONFIG_WAPI_AP
+static int nl80211_send_wapi_data(struct i802_bss *bss,
+				   const u8 *addr, const u8 *data,
+				   size_t data_len)
+{
+	struct sockaddr_ll ll;
+	int ret;
+	wpa_printf(MSG_INFO, "nl80211: Enter %s",__func__);
+	if (bss->drv->wai_sock < 0) {
+		wpa_printf(MSG_DEBUG, "nl80211: No socket to send WAPI");
+		return -1;
+	}
+
+	os_memset(&ll, 0, sizeof(ll));
+	ll.sll_family = AF_PACKET;
+	ll.sll_ifindex = bss->ifindex;
+	ll.sll_protocol = htons(ETH_P_WAPI);
+	ll.sll_halen = ETH_ALEN;
+	os_memcpy(ll.sll_addr, addr, ETH_ALEN);
+	ret = sendto(bss->drv->wai_sock, data, data_len, 0,
+		     (struct sockaddr *) &ll, sizeof(ll));
+	if (ret < 0)
+		wpa_printf(MSG_ERROR, "nl80211: WAPI TX: %s",
+			   strerror(errno));
+
+	return ret;
+}
