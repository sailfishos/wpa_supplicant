+
+		p += 1;
+		len10 = GetInfoLength(p,&Llen);
+		p += Llen;
+
+		p += 1;
+		len11 = GetInfoLength(p,&Llen);
+		p += len11+Llen;
+
+		p += 1;
+		len12 = GetInfoLength(p,&Llen);
+		p += Llen;
+
+		p += 1;
+		len13 = GetInfoLength(p,&Llen);
+		p += Llen;
+
+		p += 1;
+		len14 = GetInfoLength(p,&Llen);
+		p += len14+Llen;
+
+		p += 1;
+		len15 = GetInfoLength(p,&Llen);
+		p += Llen;
+
+		p += 1;
+		len16 = GetInfoLength(p,&Llen);
+		p += Llen;
+
+		if(len16>*pCACertlen)
+			return CTP_FALSE;
+		memcpy(pCACert,p,len16);
+		*pCACertlen = len16;
+	}
+	else
+	{
+		p += 1;
+		len2 = GetInfoLength(p,&Llen);
+		p += Llen;
+
+		p += 1;
+		len3 = GetInfoLength(p,&Llen);
+		p += len3+Llen;
+
+		p += 1;
+		len4 = GetInfoLength(p,&Llen);
+		p += Llen;
+
+		p += 1;
+		len5 = GetInfoLength(p,&Llen);
+		p += Llen;
+
+		p += 1;
+		len6 = GetInfoLength(p,&Llen);
+		p += len6+Llen;
+
+		p += 1;
+		len7 = GetInfoLength(p,&Llen);
+		p += Llen;
+
+		p += 1;
+		len8 = GetInfoLength(p,&Llen);
+		p += Llen;
+
+		if(len8>*pUserCertlen)
+			return CTP_FALSE;
+
+		memcpy(pUserCert,p,len8);
+		*pUserCertlen = len8;
+	}
+
+	if(bag_length == len)
+	{
+	    return CTP_OK;
+	}
+	else
+	{
+		return CTP_FALSE;
+	}
+}
