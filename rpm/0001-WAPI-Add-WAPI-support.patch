+int IWN_GenerateUserInfo(void *hSessionHandle, ECCrefPublicKey *pucPublicKey, unsigned char *pucID, unsigned int uiIDLength,unsigned char* UserInfo,unsigned int *uiUserInfoLength)
+{
+	HASH_CONTX ctx;
+	unsigned int entla;
+	unsigned int dlen;
+	unsigned char *tmp=NULL;
+	int ret=-1;
+	ECCrefPara *EccPara=NULL;
+
+	SessionHandle  *EccSessionHandle = NULL;
+	if (hSessionHandle == NULL) 
+    {
+		ret = SDR_NOSESSIONHANDLE;
+		return ret;
+    }
+	EccSessionHandle = (SessionHandle *)hSessionHandle;
+	EccPara = (ECCrefPara *)EccSessionHandle->EccConfigPara;
+	if (EccPara == NULL) 
+    {
+		ret = SDR_PARAINPUTERR;
+		return ret;
+    }
+
+	entla = uiIDLength*8;
+	dlen = 2+uiIDLength+EccSessionHandle->g_fixlen*6;
+	tmp = (unsigned char*)malloc(sizeof(unsigned char)*dlen+1);
+	if(tmp==NULL){
+		return ret;
+	}
+	memset(tmp,0,dlen+1);
+
+	tmp[0]=(unsigned char)((entla>>8)&0xff);
+	tmp[1]=(unsigned char)((entla>>0)&0xff);
+	memcpy(tmp+2,pucID,uiIDLength);
+	memcpy(tmp+2+uiIDLength,EccPara->A,EccSessionHandle->g_fixlen);
+	memcpy(tmp+2+uiIDLength+EccSessionHandle->g_fixlen,EccPara->B,EccSessionHandle->g_fixlen);
+	memcpy(tmp+2+uiIDLength+(2*EccSessionHandle->g_fixlen),EccPara->Gx,EccSessionHandle->g_fixlen);
+	memcpy(tmp+2+uiIDLength+(3*EccSessionHandle->g_fixlen),EccPara->Gy,EccSessionHandle->g_fixlen);
+	memcpy(tmp+2+uiIDLength+(4*EccSessionHandle->g_fixlen),pucPublicKey->x,EccSessionHandle->g_fixlen);
+	memcpy(tmp+2+uiIDLength+(5*EccSessionHandle->g_fixlen),pucPublicKey->y,EccSessionHandle->g_fixlen);
+
+	memset(&ctx,0,sizeof(HASH_CONTX));
+	ctx.data = tmp;
+	ctx.len_low = dlen;
+	ctx.len_high = 0;
+	ctx.hash_type = EccSessionHandle->g_hash_type;
+	*uiUserInfoLength = hash_byte(&ctx,UserInfo);
+
+	free(tmp);
+	tmp=NULL;
+
+	ret = SDR_OK;
+	return ret;
+}
