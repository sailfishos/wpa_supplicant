+
+/*Į½ūųĮ┌┤«ū¬░┤šš│żš¹╩²│żČ╚ūųĮ┌╗╗│╔═°┬ń─Ż╩Į*/
+void htonl_buffer(void *buffer, int len_in_byte)
+{
+	int i;
+	unsigned long *data = (unsigned long *) buffer;
+	int len = len_in_byte/sizeof(unsigned long);
+	
+	for (i=0; i<len; i++) data[i] = htonl(data[i]);
+}
+
+
+void wapi_auth_set_authorized(struct wapi_authenticator *wapi_auth,
+				      const u8_t *addr, wapi_variable var,
+				      int value)
+{
+	if (wapi_auth->cb->set_authorized)
+		wapi_auth->cb->set_authorized(wapi_auth->cb->ctx, addr, var, value);
+}
+
+
+int wapi_auth_get_bkid(struct wapi_authenticator *wapi_auth,
+					  const u8_t *addr, u8_t *bkid)
+{
+	if (wapi_auth->cb->get_bkid == NULL)
+		return -1;
+	//return wapi_auth->cb->get_bkid(wapi_auth->cb.ctx, addr, bkid);
+	int ret = wapi_auth->cb->get_bkid(wapi_auth->cb->ctx, addr, bkid);
+	return ret;
+}
+
+int wapi_auth_set_key(struct wapi_authenticator *wapi_auth,
+				   int vlan_id, int alg, const u8_t *addr, int idx,
+				   u8_t *iv, size_t iv_len, u8_t *key, size_t key_len,
+				   int keyflag)
+{
+	if (wapi_auth->cb->set_key == NULL)
+		return -1;
+	
+	int ret = wapi_auth->cb->set_key(wapi_auth->cb->ctx, vlan_id, alg, addr, idx,
+				    iv, iv_len, key, key_len, keyflag);
+	return ret;
+}
+
+static inline int wapi_auth_send(struct wapi_authenticator *wapi_auth, const u8_t *addr,
+		    const u8_t *data, size_t data_len, int encrypt)
+{
+	if (wapi_auth->cb->send_wapi == NULL)
+		return -1;
+	int ret = wapi_auth->cb->send_wapi(wapi_auth->cb->ctx, addr, data, data_len,
+				       encrypt);
+	return ret;
+}
+
+static void wapi_group_set_key_len(struct wapi_group *group, int cipher)
+{
+	switch (cipher) {
+	case _WPA_CIPHER_SMS4:
+		group->NMK_len = 16;
+		group->MSK_len = 32;
+		break;
+	}
+}
+
+
+static int wapi_group_init_nmk(struct wapi_authenticator *wapi_auth,
+					  struct wapi_group *group)
+{
+	/* Disable warning */
+	UNUSED(wapi_auth);
+	
+	if (os_get_random(group->msksa.nmk, group->NMK_len) < 0)
+	//if (random_get_bytes(group->msksa.nmk, group->NMK_len) < 0)
+		return -1;
+	group->msksa.mskid = 0;
+	//wpa_hexdump_key(MSG_DEBUG, "NMK", group->msksa.nmk, WAPI_NMK_LEN);
+
+	return 0;
+}
+
+
+static struct wapi_group * wapi_group_init(struct wapi_authenticator *wapi_auth,
+					 int vlan_id)
+{
+	struct wapi_group *group;
+	wapi_printf(MSG_DEBUG, " enter  %s",__func__);
+	group = os_malloc(sizeof(struct wapi_group));
+	if (group == NULL)
+		return NULL;
+
+	group->MSK_len = 0;
+	group->MSKAuthenticator = _TRUE;
+	group->vlan_id = vlan_id;
+
+	os_memcpy(group->GSN, 
+		"\x5c\x36\x5c\x36\x5c\x36\x5c\x36\x5c\x36\x5c\x36\x5c\x36\x5c\x37", 
+		WPI_PN_LEN);
+
+	os_memcpy(group->addr, "\xff\xff\xff\xff\xff\xff", ETH_ALEN);
+
+	group->GNonce[0] = 0x5c365c36;
+	group->GNonce[1] = 0x5c365c36;
+	group->GNonce[2] = 0x5c365c36;
+	group->GNonce[3] = 0x5c365c36;
+
+	wapi_group_set_key_len(group, wapi_auth->conf->wapi_group);
+
+	if(group->NMK_len)
+		group->msksa.nmk = os_malloc(group->NMK_len);
+
+	if(group->msksa.nmk == NULL) {
+		wapi_printf(MSG_ERROR, "--WAPI--: Malloc buf for NMK fail");
+		return NULL;
+	}
+#if 0	
+	if (random_pool_ready() != 1) {
+		wapi_printf(MSG_INFO, "WAPI: Not enough entropy in random pool "
+			   "for secure operations - update keys later when "
+			   "the first station connects");
+	}
+#endif
+	if (wapi_group_init_nmk(wapi_auth, group) < 0) {
+		wapi_printf(MSG_ERROR, "Failed to get random data for WAPI NMK"
+			   "initialization.");
+		os_free(group);
+		return NULL;
+	}
+
+	return group;
+}
+
+
+struct wapi_authenticator * wapi_init(const u8_t *addr,
+				    struct wapi_auth_config *conf,
+				    struct wapi_auth_callbacks *cb)
+{
+	struct wapi_authenticator *wapi_auth;
+	wapi_printf(MSG_DEBUG, " enter %s",__func__);
+	wapi_auth = os_malloc(sizeof(struct wapi_authenticator));
+	wapi_auth->conf = os_malloc(sizeof(struct wapi_auth_config));
+	wapi_auth->cb = os_malloc(sizeof(struct wapi_auth_callbacks));
+	if (wapi_auth == NULL
+		|| wapi_auth->conf == NULL
+		|| wapi_auth->cb == NULL)
+		return NULL;
+
+	os_memcpy(wapi_auth->addr, addr, ETH_ALEN);
+	os_memcpy(wapi_auth->conf, conf, sizeof(struct wapi_auth_config));
+	os_memcpy(wapi_auth->cb, cb, sizeof(struct wapi_auth_callbacks));
+	
+	if (wapi_auth_gen_ie(wapi_auth)) {
+		wapi_printf(MSG_ERROR, "Could not generate WAPI IE.");
+		os_free(wapi_auth->conf);
+		os_free(wapi_auth->cb);
+		os_free(wapi_auth->wapi_ie);
+		os_free(wapi_auth);
+		return NULL;
+	}
+
+	wapi_auth->group = wapi_group_init(wapi_auth, 0);
+	if (wapi_auth->group == NULL) {
+		os_free(wapi_auth->conf);
+		os_free(wapi_auth->cb);
+		os_free(wapi_auth->wapi_ie);
+		os_free(wapi_auth);
+		return NULL;
+	}
+	wapi_printf(MSG_DEBUG, "wapi_init OK.");
+	return wapi_auth;
+}
