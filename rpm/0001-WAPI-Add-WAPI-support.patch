+/*====================================================================*/
+int mint_bit_set(MINT *a, int n)
+{
+	int i,j;
+
+	if (n < 0) return 0;
+	i=n/MINT_BIT;
+	j=n%MINT_BIT;
+	if (a->len <= i) return 0;
+	return (int)(((a->value[i])>>j)&((unsigned int)1));
+		
+}
+/*---------------------------------------------------------------------------------------*/
+unsigned int mint_mul_4(unsigned int *p, const unsigned int *q, unsigned int f,int n)
+{
+	unsigned int h=0;
+
+	if (n <= 0) return h;
+
+	while(n&~3)
+	{
+		mul_4(p[0],q[0],f,h);
+		mul_4(p[1],q[1],f,h);
+		mul_4(p[2],q[2],f,h);
+		mul_4(p[3],q[3],f,h);
+	    p+=4; q+=4; n-=4;
+	}
+	if(n)
+	{
+		mul_4(p[0],q[0],f,h); if(--n == 0) return h;
+		mul_4(p[1],q[1],f,h); if(--n == 0) return h;
+		mul_4(p[2],q[2],f,h);
+	}
+	return h;
+} 
+/*-------------------------------------------------------------------------------------------*/
+unsigned int  mint_mul_3(unsigned int  *p, const unsigned int *q, unsigned int f, int n)
+{
+	unsigned int  h = 0;
+
+	if(n <= 0) return h;
+
+	while(n&~3)
+	{
+		mul_3(p[0],q[0],f,h);
+		mul_3(p[1],q[1],f,h);
+		mul_3(p[2],q[2],f,h);
+		mul_3(p[3],q[3],f,h);
+		p+=4; q+=4; n-=4;
+	}
+	if(n)
+	{
+		mul_3(p[0],q[0],f,h); if (--n==0) return h;
+		mul_3(p[1],q[1],f,h); if (--n==0) return h;
+		mul_3(p[2],q[2],f,h); return h;
+	}
+	
+	return h;
+} 
+/*---------------------------------------------------------------------------------*/
+void mul_2(unsigned int *x, int xlen, unsigned int *y, int ylen,unsigned int *t)
+{
+	unsigned int *m, *q;
+	int p;
+
+	if (xlen < ylen)
+	{
+		p=xlen;
+		xlen=ylen; 
+		ylen=p;
+
+		q=x;   
+		x=y;   
+		y=q;
+
+	}
+	m= &(t[xlen]);
+	if (ylen <= 0)
+	{
+		(void)mint_mul_4(t,x,0,xlen);
+		return;
+	}
+	else
+		m[0]=mint_mul_4(t,x,y[0],xlen);
+
+	for (;;)
+	{
+		if(--ylen <= 0) return;
+		m[1]=mint_mul_3(&(t[1]),x,y[1],xlen);
+		if(--ylen <= 0) return;
+		m[2]=mint_mul_3(&(t[2]),x,y[2],xlen);
+		if(--ylen <= 0) return;
+		m[3]=mint_mul_3(&(t[3]),x,y[3],xlen);
+		if(--ylen <= 0) return;
+		m[4]=mint_mul_3(&(t[4]),x,y[4],xlen);
+		m+=4;
+		t+=4;
+		y+=4;
+	}
+}
+/*-----------------------------------------------------------------------------------------*/
+unsigned int sub_2(const unsigned int *x, const unsigned int *y, int m, unsigned int *t)
+{
+	unsigned int p,q;
+	int h=0;
+
+	if(m <= 0) return (unsigned int)0;
+
+	for(;;)
+	{
+		p=x[0]; q=y[0];
+		t[0]=(p-q-h);
+		if(p != q) h=(p < q);
+		if(--m <= 0) break;
+
+		p=x[1]; q=y[1];
+		t[1]=(p-q-h);
+		if(p != q) h=(p < q);
+		if(--m <= 0) break;
+
+		p=x[2]; q=y[2];
+		t[2]=(p-q-h);
+		if(p != q) h=(p < q);
+		if(--m <= 0) break;
+
+		p=x[3]; q=y[3];
+		t[3]=(p-q-h);
+		if(p != q) h=(p < q);
+		if(--m <= 0) break;
+
+		x+=4;
+		y+=4;
+		t+=4;
+	}
+	return h;
+}
+/*-----------------------------------*/
+int mint_mul(MINT *x,MINT *y,MINT *t)
+{
+	int len,len_1,len_2;		
+	MINT ret;
+
+	memset(&ret,0,sizeof(MINT));
+
+	len_1 = x->len;
+	len_2 = y->len;
+
+	if(MINT_ISZERO(x) || MINT_ISZERO(y))	
+	{
+		MI_DWORDTOMINT(t,0);
+
+		return 1;
+	}
+
+	len = len_1 + len_2;
+
+	ret.len = len;
+	mul_2(x->value,len_1,y->value,len_2,ret.value);
+	
+	mint_copy(t,&ret);
+	mint_adjust_len(t,len);
+	return 1;
+}
