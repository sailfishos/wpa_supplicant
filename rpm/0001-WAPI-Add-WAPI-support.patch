+/*AEńÜäMSKSA*/
+struct wapi_msksa
+{
+	u8_t mskid; /*Key ID 0,1õ╣ŗķŚ┤ń┐╗ĶĮ¼*/
+	u8_t *nmk;  /*ķĆÜÕæŖõĖ╗Õ»åķÆź*/
