+int Unpack_P8_PrivateKey(unsigned char *In,int len,P8_PRIVATEKEY *p8_prikey)
+{
+	int len0=0,len1=0,len2=0,len3=0;
+	unsigned char Llen=0;
+	unsigned char *p = NULL;
+    int p8_prikey_length = 0;
+
+	if(In == NULL || p8_prikey == NULL)
+		return CTP_FALSE;
+
+	p = In;
+	p += 1;
+	len0 = GetInfoLength(p,&Llen);
+	p += Llen;
+	
+	p8_prikey_length += 1 + Llen;
+
+	p += 1;
+	len1 = GetInfoLength(p,&Llen);
+	p += Llen;
+	p8_prikey->Version.data = p;
+	p8_prikey->Version.length = len1;
+	p += len1;
+
+	p8_prikey_length += 1 + Llen + len1;
+
+	p += 1;
+	len2 = GetInfoLength(p,&Llen);
+	p += Llen;
+	p8_prikey->AlgorithmInfo.data = p;
+	p8_prikey->AlgorithmInfo.length = len2;
+	p += len2;
+
+	p8_prikey_length += 1 + Llen + len2;
+
+	p += 1;
+	len3 = GetInfoLength(p,&Llen);
+	p += Llen;
+	p8_prikey->KeyInfo.data = p;
+	p8_prikey->KeyInfo.length = len3;
+	p += len3;
+	p8_prikey_length += 1 + Llen + len3;
+
+
+	if(p8_prikey_length == len)
+	{
+	    return CTP_OK;
+	
+	}
+	else
+	{
+		return CTP_FALSE;
+	}
+	return CTP_OK;
+}
+void End_P8_PrivateKey(P8_PRIVATEKEY *p8_prikey)
+{
+	memset(p8_prikey,0,sizeof(P8_PRIVATEKEY));
+}
