+#ifdef IWN_ECC_ECDSA
+	case SGD_ECES:
+        ret = ECES_ExternalDecrypt_ECC(((EccCurveHandle*)(EccSessionHandle->CurveHandle)), &prikey, EccSessionHandle->g_fixlen, 
+			                            pucEncData->x, pucEncData->y, pucEncData->C, pucData, puiDataLength);
