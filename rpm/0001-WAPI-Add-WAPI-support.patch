diff --git a/hostapd/config_file.c b/hostapd/config_file.c
index a45fadb..146a5f2 100755
--- a/hostapd/config_file.c
+++ b/hostapd/config_file.c
@@ -713,6 +713,10 @@ static int hostapd_config_parse_key_mgmt(int line, const char *value)
 		else if (os_strcmp(start, "PASN") == 0)
 			val |= WPA_KEY_MGMT_PASN;
 #endif /* CONFIG_PASN */
+#ifdef CONFIG_WAPI_AP
+		else if (os_strcmp(start, "WAPI-PSK") == 0)
+			val |= WPA_KEY_MGMT_WAPI_PSK;
+#endif
 		else {
 			wpa_printf(MSG_ERROR, "Line %d: invalid key_mgmt '%s'",
 				   line, start);
@@ -2913,7 +2917,37 @@ static int hostapd_config_fill(struct hostapd_config *conf,
 		os_free(bss->ssid.wpa_passphrase);
 		bss->ssid.wpa_passphrase = NULL;
 		bss->ssid.wpa_psk_set = 1;
-	} else if (os_strcmp(buf, "wpa_psk_file") == 0) {
+	} 
+#ifdef CONFIG_WAPI_AP
+	else if (os_strcmp(buf, "wapi_psk") == 0) {
+		size_t len;
+		char *str = wpa_config_parse_string(pos, &len);
+		if (str == NULL) {
+			return 1;
+		}
+		if (len < 8 || len > 64) {
+			wpa_printf(MSG_ERROR, "Line %d: invalid WAPI "
+				   "passphrase length %d (expected "
+				   "8..64)", line, (int)len);
+			os_free(str);
+			return 1;
+		} else {
+			bss->ssid.wapi_psk_len = len;
+			os_free(bss->ssid.wapi_psk);
+			bss->ssid.wapi_psk = os_strdup(str);
+			os_free(str);
+			if (os_strcmp(bss->ssid.wapi_psk, "") != 0) {
+				/* wpa_printf(MSG_DEBUG, "Line %d: wapi_psk=%s", line, bss->ssid.wapi_psk); */
+				wpa_printf(MSG_DEBUG, "Line %d: wapi_psk=%s", line, "*");
+			}
+		}
+	}
+	else if (os_strcmp(buf, "wapi_psk_type") == 0) {
+		bss->ssid.wapi_psk_type = atoi(pos);
+		wpa_printf(MSG_DEBUG, "Line %d: wapi_psk_type=%d", line, bss->ssid.wapi_psk_type);
+	}
+#endif	/* CONFIG_WAPI_AP*/
+	else if (os_strcmp(buf, "wpa_psk_file") == 0) {
 		os_free(bss->ssid.wpa_psk_file);
 		bss->ssid.wpa_psk_file = os_strdup(pos);
 		if (!bss->ssid.wpa_psk_file) {
@@ -4695,6 +4729,14 @@ static int hostapd_config_fill(struct hostapd_config *conf,
 		return 1;
 	}
 
+#ifdef CONFIG_WAPI_AP
+	if (wapi_set_hex_psk(bss)) {
+			wpa_printf(MSG_ERROR, "Line %d: Wapi set hex psk error.",
+				   line);
+			return 1;
+	}
+#endif /* CONFIG_WAPI_AP*/
+
 	return 0;
 }
 
