+static int get_w_val(MINT *n,int ecc_bit_len)
+{
+	int i=0,j=0,k=0,m=0;
+	int v=0;
+	int f = 0;
+	for(i=n->len-1;i>=0;i--){
+		for(j=31;j>=0;j--){
+			v = (n->value[i]>>j)&1;
+			if(v==1){
+				f=1;
+				break;
+			}
+			k++;
+		}
+		if(f==1){
+			break;
+		}
+	}
+	m=ecc_bit_len-k;
+	if (m%2 == 1){
+		m = m >>1;
+	}else{
+		m = (m >>1) - 1;
+	}
+	return m;
+}
