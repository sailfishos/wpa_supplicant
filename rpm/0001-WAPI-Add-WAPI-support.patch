@@ -0,0 +1,189 @@
+/* 
+* Copyright (c) 2000-2012 China IWNCOMM Co., Ltd. All rights reserved.
+*
+* Module:        Random number.           
+* Description:   generat random number methods implement.
+* Writer:        zhangguoqiang@TEVG <zhanggq@iwncomm.com>
+* Version:  $Id:random.h,v 1.0 2012/02/17 09:00:00 zhangguoqiang Exp $     
+*
+* History: 
+* zhangguoqiang    2012/02/17    v1.0    Created.
+*/
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include "hash.h"
+
+#define IWN_USE_HMAC_RANDOM
+
+#undef ECC_UERN
+//#define ECC_UERN
+
+#include <time.h>
+#define ecc_rand()  rand()
+#define ecc_srand(s) srand(s)
+
+time_t ecc_time(time_t* in_time)
+{
+	time_t retval = 0;
+	retval = time(NULL);
+	if(NULL != in_time)
+	{
+		*in_time = retval;
+	}
+	return retval;
+}
+static int randseed;
+/*====================================================================*/
+static int gen_rand_num()
+{
+	unsigned char buf[32];
+	unsigned char ca;
+	int i=0;
+
+	srand((unsigned int)ecc_time(NULL));
+	for(i=0;i<32;i++)
+	{
+		while((ca=rand()+randseed)==0){
+			randseed++;
+		}
+		randseed++;
+		buf[i]=ca;
+	}
+	return 0;
+}
+
+static int gen_rand(unsigned int *val,int len)
+{
+	int j,k,aa;
+	unsigned int ss=1;
+
+	ecc_srand((unsigned)ecc_time(NULL));
+	for(j=0;j<len;j++)
+	{
+        for(k=0;k<3;k++)
+        {
+            aa=ecc_rand()+randseed+(randseed<<1)+(randseed>>1);
+            randseed++;
+            ss=ss|(aa<<k*11);
+        }
+        val[j]=ss;
+        ss=1;
+	}
+	return 0;
+}
+
+int gen_random(unsigned char *val,unsigned int len,int type)
+{
+	HASH_CONTX ctx;
+	unsigned char v[32]={0};
+	unsigned char dt[32]={0};
+	unsigned char i[32]={0};
+	unsigned char r[32]={0};
+	unsigned char t[32]={0};
+	int j=0;
+	unsigned int n=0;
+	int m=0;
+	int hash_type=type;
+
+	gen_rand((unsigned int*)v,8);
+
+	for(n=0;n<len/32;n++)
+	{
+		gen_rand((unsigned int*)dt,8);
+		ctx.data=dt;
+		ctx.hash_type=hash_type;
+		ctx.len_high=0;
+		ctx.len_low=32;
+		hash_byte(&ctx,i);
+		for(j=0;j<32;j++)
+		{
+			t[j]=i[j]^v[j];
+		}
+		ctx.data=t;
+		ctx.hash_type=hash_type;
+		ctx.len_high=0;
+		ctx.len_low=32;
+		hash_byte(&ctx,r);
+		for(j=0;j<32;j++)
+		{
+			t[j]=i[j]^r[j];
+		}
+		ctx.data=t;
+		ctx.hash_type=hash_type;
+		ctx.len_high=0;
+		ctx.len_low=32;
+		hash_byte(&ctx,v);
+		memcpy(val+n*32,r,32);
+	}
+	m=len%32;
+	if(m>0)
+	{
+		gen_rand((unsigned int*)dt,8);
+		ctx.data=dt;
+		ctx.hash_type=hash_type;
+		ctx.len_high=0;
+		ctx.len_low=32;
+		hash_byte(&ctx,i);
+		for(j=0;j<32;j++)
+		{
+			t[j]=i[j]^v[j];
+		}
+		ctx.data=t;
+		ctx.hash_type=hash_type;
+		ctx.len_high=0;
+		ctx.len_low=32;
+		hash_byte(&ctx,r);
+		memcpy(val+n*32,r,m);
+	}	
+	return 0;
+}
+
+#ifdef IWN_USE_HMAC_RANDOM
+int gen_random_number(MINT *val,MINT *max,int type)
+{
+	unsigned char buf[100]={0};
+	MINT t;
+	memset(&t,0,sizeof(MINT));
+	t.len=max->len;	
+#ifdef ECC_UERN
+	gen_exrand(buf, t.len*sizeof(unsigned int));
+	octetstring_to_mint(buf,t.len*sizeof(unsigned int),val);
+#else
+	gen_random((unsigned char*)t.value,t.len*sizeof(unsigned int),type);
+	mint_mod(&t,max,val);
+#endif
+	return 0;
+}
+#else
+int gen_random_number(MINT *val,MINT *max)
+{
+	int j,k,aa;
+	MINT t;
+	unsigned int ss=1;
+	memset(&t,0,sizeof(MINT));
+	t.len=max->len;	
+#ifdef ECC_UERN
+	gen_rand((unsigned char*)val->value, t.len*sizeof(int));
+#else
+	ecc_srand((unsigned)ecc_time(NULL));
+	for(j=0;j<max->len;j++)
+	{
+		for(k=0;k<3;k++)
+		{
+			aa=ecc_rand()+randseed+(randseed<<1)+(randseed>>1);
+			randseed++;
+			ss=ss|(aa<<k*11);
+		}
+		t.value[j]=ss;
+		ss=1;
+	}
+	mint_mod(&t,max,val);
+#endif
+	return 0;
+}
+#endif
+
+
