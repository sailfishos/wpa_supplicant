+	if(MINT_ISZERO(a)||MINT_ISZERO(b))
+	{	
+		c->len =0;	
+		c->value[0]=0;	
+		return 0;
+	}
+	memset(&t,0,sizeof(MINT));
+	mint_mul(a,b,&t);
+	mint_adjust_len(&t,a->len+b->len);
