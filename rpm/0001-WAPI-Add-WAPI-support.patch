index 0000000..1139834
--- /dev/null
+++ b/src/libecc/hmac.c
@@ -0,0 +1,349 @@
+#include <string.h>
+#include <stdlib.h>
+#include "hmac.h"
+
+#define CLN(_x, _y) (((_x) << (_y)) | ((_x) >> (32 - (_y))))
+#define CRN(_x, _y) (((_x) >> (_y)) | ((_x) << (32 - (_y))))
+#define RN(_x, _y) ((_x) >> (_y))
+#define E0(_x0, _x1, _x2) (((_x0) & (_x1)) ^ ((~(_x0)) & (_x2)))
+#define E1(_x0, _x1, _x2) (((_x0) & (_x1)) ^ ((_x0) & (_x2)) ^ ((_x1) & (_x2)))
+#define E2(_x0)	(CRN(_x0, 2) ^ CRN(_x0, 13) ^ CRN(_x0, 22))
+#define E3(_x0)	(CRN(_x0, 6) ^ CRN(_x0, 11) ^ CRN(_x0, 25))
+#define E4(_x0)	(CRN(_x0, 7) ^ CRN(_x0, 18) ^ RN(_x0, 3))
+#define E5(_x0)	(CRN(_x0, 17) ^ CRN(_x0, 19) ^ RN(_x0, 10))
+
+static const unsigned int sg_gn_y[8] = 
+{
+	0x6a09e667, 0xbb67ae85, 0x3c6ef372, 0xa54ff53a, 
+	0x510e527f, 0x9b05688c, 0x1f83d9ab, 0x5be0cd19
+};
+
+static const unsigned int sg_gn_c[64] = 
+{
+	0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5, 
+	0x3956c25b, 0x59f111f1, 0x923f82a4, 0xab1c5ed5, 
+	0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3, 
+	0x72be5d74, 0x80deb1fe, 0x9bdc06a7, 0xc19bf174, 
+	0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc,
+    0x2de92c6f, 0x4a7484aa, 0x5cb0a9dc, 0x76f988da, 
+	0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7, 
+	0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967, 
+	0x27b70a85, 0x2e1b2138, 0x4d2c6dfc, 0x53380d13, 
+	0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85,
+    0xa2bfe8a1, 0xa81a664b, 0xc24b8b70, 0xc76c51a3, 
+	0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070, 
+	0x19a4c116, 0x1e376c08, 0x2748774c, 0x34b0bcb5, 
+	0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3, 
+	0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208,
+    0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2
+};
+
+int hash_init(hash_data *mp);
+int hash_update(unsigned char *data, unsigned int dlen, hash_data *mp);
+int hash_final(unsigned char *hdata, unsigned int *hlen, hash_data *mp);
+int hash_rf(hash_data *mp);
+
+/* SHA256įė┤š╦ŃĘ© */
+int cal_value(unsigned char *puchash, unsigned char *pucdata, unsigned int datalen)
+{
+	hash_data mq;
+	unsigned int len = 0;
+
+    hash_init(&mq);
+    hash_update(pucdata, datalen, &mq);
+    hash_final(puchash, &len, &mq);
+
+	return 0;
+}
+
+/* ╗∙ė┌SHA256╦ŃĘ©Ą─HMAC╦ŃĘ© */
+int cal_value_m(unsigned char *puchash, unsigned int hlen, unsigned char *puck, unsigned int klen, unsigned char *pucdata, unsigned int datalen)
+{
+	unsigned char real_key[64] = {0};
+	unsigned char ipad[64] = {0};
+	unsigned char opad[64] = {0};
+	unsigned char temp_digest1[32] = {0};
+	unsigned char temp_digest2[32] = {0};
+	unsigned char *temp_buf = NULL;
+	unsigned int temp_buf_len = 0;
+	unsigned int i = 0;
+
+	temp_buf_len = datalen + 64 * 2 + 1;
+	temp_buf = (unsigned char*)malloc(sizeof(unsigned char) * temp_buf_len);
+	if(temp_buf == NULL)
+	{
+		return -1;
+	}
+	memset(temp_buf, 0, temp_buf_len);
+	
+	for(i = 0; i < 64; i++)
+	{
+		real_key[i] = 0;
+		ipad[i] = 0x36;
+		opad[i] = 0x5c;
+	}
+	
+	/* ╚ń╣¹ puck ┤¾ė┌╣■ŽŻ╦ŃĘ©┐ķ64,Ž╚Į°ąąhashį╦╦Ń */
+	if(klen > 64)
+	{
+		//mhash_sha256(puck, klen, real_key);
+		cal_value(real_key, puck, klen);
+	}
+	else
+	{
+		memcpy(real_key, puck, klen);
+	}
+		
+	for(i = 0; i < 64; i++)
+	{
+		ipad[i] ^= real_key[i];
+		opad[i] ^= real_key[i];
+	}
+
+	memcpy(temp_buf, ipad, 64);
+	memcpy(temp_buf + 64, pucdata, datalen);
+	cal_value(temp_digest1, temp_buf, 64 + datalen);
+
+	memset(temp_buf, 0, 64 * 2 + 1);
+	memcpy(temp_buf, opad, 64);
+	memcpy(temp_buf + 64, temp_digest1, 32);
+	cal_value(temp_digest2, temp_buf, 64 + 32);
+
+	memcpy(puchash, temp_digest2, hlen);
+	free(temp_buf);
+	temp_buf = NULL;
+
+	return 0;
+}
+
+/* ╗∙ė┌SHA256╦ŃĘ©Ą─HMAC╦ŃĘ©Ą─├▄į┐Ą╝│÷╦ŃĘ© */
+void cal_value_md(unsigned char *puchash, unsigned int hlen, unsigned char *puck, unsigned int klen, unsigned char *pucdata, unsigned int datalen)
+{
+	unsigned int n = 0;
+	unsigned int m = 0;
+	unsigned int q = 0;
+	unsigned int r = 0;
+	
+	m = hlen;
+	q = m / 32;
+	r = m % 32;
+	for (n = 0; n < q; n++)
+	{
+		cal_value_m(&puchash[n * 32], 32, puck, klen, pucdata, datalen);
+		pucdata = &puchash[n * 32];
+		datalen = 32;
+	}
+	
+	if(r)
+	{
+		cal_value_m(&puchash[n * 32], r, puck, klen, pucdata, datalen);
+	}
+}
+
+/* Ž“┴┐│§╩╝╗»╣²│╠ */
+int hash_init(hash_data *mp)
+{
+	unsigned int i = 0;
+
+	if (mp == NULL)
+	{
+	    return -1;
+	}
+
+	memset(mp, 0, sizeof(hash_data));
+
+	for (i = 0; i < 8; i++)
+	{
+		mp->gn_y[i] = sg_gn_y[i];
+	}
+
+	return 1;
+}
+
+/* ┤²╝Ų╦Ń╩²Š▌į╦╦Ń */
+int hash_update(unsigned char *data, unsigned int dlen, hash_data *mp)
+{
+	unsigned int i = 0;
+	unsigned int j = 0;
+	unsigned int u = 0;
+	unsigned int q = 0;
+	unsigned int t = 0;
+	unsigned long long  blen = 0;
+
+	if (mp == NULL)
+	{
+	    return -1;
+	}
+
+    q = dlen / 64;
+	t = dlen % 64;
+
+    for (j = 0; j < q; j++)
+	{
+		memset(mp->gc_buf, 0, 64);
+		for (i = 0; i < 64; i++)
+		{
+			mp->gc_buf[i] = data[i + j * 64];
+			blen = (unsigned long long)((mp->n_bl) | (((unsigned long long)(mp->n_bh)) << 32));
+			blen += 8;
+			mp->n_bl = (unsigned int)(blen & 0x00000000FFFFFFFF);
+			mp->n_bh = (unsigned int)((blen >> 32) & 0x00000000FFFFFFFF);
+		}
+
+		hash_rf(mp);
+		mp->n_c = 0;
+	}
+
+	memset(mp->gc_buf, 0, 64);
+    for (u = 0; u < t; u++)
+	{		
+		mp->gc_buf[u] = data[u + j * 64];	
+		blen = (unsigned long long)((mp->n_bl) | (((unsigned long long)(mp->n_bh)) << 32));
+		blen += 8;
+		mp->n_bl = (unsigned int)(blen & 0x00000000FFFFFFFF);
+		mp->n_bh = (unsigned int)((blen >> 32) & 0x00000000FFFFFFFF);
+		mp->n_c++;
+	}
+
+    return 1;
+}
+
+/* ╝Ų╦Ń╣■ŽŻ╩²Š▌ */
+int hash_final(unsigned char *hdata, unsigned int *hlen, hash_data *mp)
+{
+	unsigned int i = 0;
+	unsigned int len = 0;
+	union a
+	{ 
+		int m; 
+		char n;
+	}flg;
+
+	flg.m = 1;  
+
+    if (mp == NULL)
+	{
+	    return -1;
+	}
+
+	/* ╠Ņ│õŻ¼(L + 1 + k) = 448 mod 512Ż¼į┘╠Ē╝ėę╗Ė÷64╬╗▒╚╠ž┤« */
+	len = mp->n_c;
+	if (flg.n == 1)
+	{
+		mp->n_bh = CLN(mp->n_bh, 16); 
+		mp->n_bh = ((mp->n_bh & 0x00FF00FF) << 8) ^ ((mp->n_bh & 0xFF00FF00) >> 8);
+        mp->n_bl = CLN(mp->n_bl, 16); 
+		mp->n_bl = ((mp->n_bl & 0x00FF00FF) << 8) ^ ((mp->n_bl & 0xFF00FF00) >> 8);
+	}
+
+    if (len < 56)
+	{
+		/* (len + 1 + 8) <=64Ż¼╠Ņ│õ║¾ąĶę¬╝Ų╦Ń1┐ķ╩²Š▌ */
+		mp->gc_buf[len++] = 0x80;
+		memset(mp->gc_buf + len, 0, (56 - len));
+		memcpy(mp->gc_buf + 56, &mp->n_bh, 8);
+		hash_rf(mp);	    
+	}
+	else
+	{
+		/* (len + 1 + 8) > 64Ż¼╠Ņ│õ║¾ąĶę¬╝Ų╦Ń2┐ķ╩²Š▌ */
+		mp->gc_buf[len++] = 0x80;
+		memset(mp->gc_buf + len, 0, (64 - len));
+        hash_rf(mp);
+		mp->n_c = 0;
+
+        memset(mp->gc_buf, 0, 64);
+		memcpy(mp->gc_buf + 56, &mp->n_bh, 8);
+		hash_rf(mp);		
+	}
+
+	if (flg.n == 1)
+	{
+		for (i = 0;i < 8; i++)
+		{
+			mp->gn_y[i] = CLN(mp->gn_y[i], 16); 
+			mp->gn_y[i] = ((mp->gn_y[i] & 0x00FF00FF) << 8) ^ ((mp->gn_y[i] & 0xFF00FF00) >> 8);
+		}	
+	}
+
+	memcpy(hdata,(unsigned char*)(mp->gn_y), 32);
+	*hlen = 32;
+	memset(mp, 0, sizeof(hash_data));
+
+    return 1;
+}
+
+/* ├┐ę╗Ė÷512 bitsĄ─┤”└Ē╣²│╠ */
+int hash_rf(hash_data *mp)
+{
+	unsigned int *p = NULL;
+	unsigned int i = 0;
+	unsigned int u = 0;
+	unsigned int z[64] = {0};
+	unsigned int x[8] = {0};	
+	unsigned int w1 = 0;
+	unsigned int w2 = 0;
+	union a
+	{ 
+		int m; 
+		char n;
+	}flg;
+
+	flg.m = 1;   
+    p = (unsigned int*)mp->gc_buf;
+
+	if (mp == NULL)
+	{
+	    return -1;
+	}
+
+	/* 1.i=0 to 15,Zi */
+	for (i = 0; i <= 15; i++)
+	{
+		z[i] = p[i];
+		if (flg.n == 1)
+		{
+			z[i] = CLN(z[i], 16); 
+			z[i] = ((z[i] & 0x00FF00FF) << 8) ^ ((z[i] & 0xFF00FF00) >> 8);
+		}
+	}
+
+	/* 2.i=16 to 63,Zi */
+	for (i = 16; i <= 63; i++)
+	{
+		z[i] = E5(z[i-2]) + z[i-7] + E4(z[i-15]) + z[i-16];
+	}
+	
+	/* 3.x0=y0;......x7=y7 */
+	for (u = 0; u < 8; u++)
+	{
+		x[u] = mp->gn_y[u];
+	}
+
+	/* 4.i=0 to 63,three steps */
+	for (i = 0; i <= 63; i++)
+	{
+		/* (a) */
+		w1 = x[7] + E3(x[4]) + E0(x[4],x[5],x[6]) + sg_gn_c[i] + z[i];
+		/* (b) */
+		w2 = E2(x[0]) + E1(x[0],x[1],x[2]);
+		/* (c) */
+		x[7] = x[6];
+		x[6] = x[5];
+		x[5] = x[4];
+		x[4] = x[3] + w1;
+		x[3] = x[2];
+		x[2] = x[1];
+		x[1] = x[0];
+		x[0] = w1 + w2;
+	}
+
+	/* 5.y0=y0+x0;........y7=y7+x7 */
+	for (i = 0; i < 8; i++)
+	{
+		mp->gn_y[i] += x[i];
+	}
+
+    return 1;
+}
+
