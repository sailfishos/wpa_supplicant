+/*ūķ▓ź═©ĖµŽņė”Ęųūķ*/
+int  _wapi_msk_announcement_res(struct wapi_authenticator *wapi_auth,
+		 struct wapi_state_machine *sm, u8_t *iv_pos, u8_t *payload_data, size_t payload_len)
+{
+	u8_t* pos = 0;
+	//u8_t *iv_pos;
+	u8_t uskid;
+	u8_t MIC[WAPI_MIC_LEN];
+	//enum wpa_alg alg;
+	wapi_printf(MSG_DEBUG, "%s Enter ", __func__);
+	struct groupkey_notice_response *gkey_notice_res;
+		
+	if( payload_len <	1			/*flag*/
+					+ 1				/* MSKID*/
+					+ 1				/*USKID*/
+					+ 12			/*ADDID*/
+					+ WPI_PN_LEN	/*PN LEN*/
+					+ WAPI_MIC_LEN)
+	return -1;
+
+	gkey_notice_res = os_malloc(sizeof(struct groupkey_notice_response));
+	if (gkey_notice_res == NULL) {
+		wapi_printf(MSG_ERROR, " wapi_msk_announcement_res "
+					"malloc groupkey_notice_response buf fail");
+		return -1;
+	}
+
+	pos = payload_data;
+	os_memcpy(&gkey_notice_res->flag, pos ,1);
+	pos += 1;
+	os_memcpy(&gkey_notice_res->mskid, pos, 1);
+	pos += 1;
+	os_memcpy(&gkey_notice_res->uskid, pos, 1);
+	pos += 1;
+	os_memcpy(gkey_notice_res->addid.mac1, pos, ETH_ALEN);
+	pos += ETH_ALEN;
+	os_memcpy(gkey_notice_res->addid.mac2, pos, ETH_ALEN);
+	pos += ETH_ALEN;
+	iv_pos = pos;
+	os_memcpy((u8_t *)&gkey_notice_res->g_nonce[0], pos, 4);
+	pos += 4;
+	os_memcpy((u8_t *)&gkey_notice_res->g_nonce[1], pos, 4);
+	pos += 4;
+	os_memcpy((u8_t *)&gkey_notice_res->g_nonce[2], pos, 4);
+	pos += 4;
+	os_memcpy((u8_t *)&gkey_notice_res->g_nonce[3], pos, 4);
+	pos += 4;
+	os_memcpy(gkey_notice_res->mic, pos, WAPI_MIC_LEN);
+	pos += WAPI_MIC_LEN;
+
+	uskid = gkey_notice_res->uskid & 0x01;
+
+	/*╝Ų╦ŃMIC,▒╚ĮŽMIC*/
+	iwn_hmac_sha256(payload_data, payload_len - WAPI_MIC_LEN, 
+			sm->USKSA.usk[uskid].mak, 16, 
+			MIC, WAPI_MIC_LEN);
+	if(os_memcmp(MIC, gkey_notice_res->mic, WAPI_MIC_LEN) != 0) {
+		wapi_printf(MSG_ERROR, "Different Group Notice's hmac. Receive sta's MIC: "
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X"
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X",
+			gkey_notice_res->mic[0], gkey_notice_res->mic[1], gkey_notice_res->mic[2],gkey_notice_res->mic[3],
+			gkey_notice_res->mic[4], gkey_notice_res->mic[5], gkey_notice_res->mic[6],gkey_notice_res->mic[7],
+			gkey_notice_res->mic[8], gkey_notice_res->mic[9], gkey_notice_res->mic[10],gkey_notice_res->mic[11],
+			gkey_notice_res->mic[12], gkey_notice_res->mic[13], gkey_notice_res->mic[14],gkey_notice_res->mic[15],
+			gkey_notice_res->mic[16], gkey_notice_res->mic[17], gkey_notice_res->mic[18],gkey_notice_res->mic[19]);
+
+		wapi_printf(MSG_ERROR, "Different Group Notice's hmac. The AP's MIC: "
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X"
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X",
+			MIC[0], MIC[1], MIC[2], MIC[3], MIC[4],
+			MIC[5], MIC[6], MIC[7], MIC[8], MIC[9],
+			MIC[10], MIC[11], MIC[12], MIC[13], MIC[14],
+			MIC[15], MIC[16], MIC[17], MIC[18], MIC[19]);
+		goto err;
+	}
+	else
+	{
+		sm->GMICVerified = _TRUE;
+		wapi_printf(MSG_INFO, "Receive sta's MIC: "
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X"
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X",
+			gkey_notice_res->mic[0], gkey_notice_res->mic[1], gkey_notice_res->mic[2],gkey_notice_res->mic[3],
+			gkey_notice_res->mic[4], gkey_notice_res->mic[5], gkey_notice_res->mic[6],gkey_notice_res->mic[7],
+			gkey_notice_res->mic[8], gkey_notice_res->mic[9], gkey_notice_res->mic[10],gkey_notice_res->mic[11],
+			gkey_notice_res->mic[12], gkey_notice_res->mic[13], gkey_notice_res->mic[14],gkey_notice_res->mic[15],
+			gkey_notice_res->mic[16], gkey_notice_res->mic[17], gkey_notice_res->mic[18],gkey_notice_res->mic[19]);
+
+		wapi_printf(MSG_INFO, "The AP's MIC: "
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X"
+			"%02X%02X%02X%02X%02X%02X%02X%02X%02X%02X",
+			MIC[0], MIC[1], MIC[2], MIC[3], MIC[4],
+			MIC[5], MIC[6], MIC[7], MIC[8], MIC[9],
+			MIC[10], MIC[11], MIC[12], MIC[13], MIC[14],
+			MIC[15], MIC[16], MIC[17], MIC[18], MIC[19]);
+	}
+
+	if((gkey_notice_res->flag & 0x60) != (sm->wai_flag_in_data & 0x60))/*bit5 and bit 6*/
+	{
+		wapi_printf(MSG_ERROR, "wapi: AP and STA WAI_FLAG_STAKEY_SESSION "
+			"and WAI_FLAG_STAKEY_DEL not same ");
+		goto err;
+	}
+
+	if((gkey_notice_res->mskid & 0x01) != (wapi_auth->group->msksa.mskid & 0x01))
+	{
+		wapi_printf(MSG_ERROR, "wapi: AP and STA MSKID not same");
+		goto err;
+	}
+
+	if((gkey_notice_res->uskid & 0x01)!=(sm->USKSA.dynamic_key_used & 0x01))
+	{
+		wapi_printf(MSG_ERROR, "wapi: AP and STA USKID not same");
+		goto err;
+	}
+
+	if(os_memcmp(gkey_notice_res->addid.mac1, wapi_auth->addr, ETH_ALEN) !=0)
+	{
+		wapi_printf(MSG_ERROR, "wapi: AP's MAC not same");
+		goto err;
+	}
+
+	if(os_memcmp(gkey_notice_res->addid.mac2, sm->addr, ETH_ALEN) !=0)
+	{
+		wapi_printf(MSG_ERROR, "wapi: STA's MAC not same");
+		goto err;
+	}
+
+	wapi_printf(MSG_INFO, "wapi: Auth Succeed");
+
+	/*╝Ų╦ŃKD_HMAC_SHA256,Ą╝│÷msk*/
+	if (wapi_auth->cb->get_msk == NULL){
+		goto err;
+	}
+	if (wapi_auth->cb->get_msk(wapi_auth->group->msksa.nmk,
+			(u8_t *)&wapi_auth->group->msksa.msk, wapi_auth->group->MSK_len)){
+		goto err;
+	}
+#if 0	
+	if (wapi_auth->conf->wapi_group == _WPA_CIPHER_SMS4) {
+		alg = _WPA_ALG_SMS4;
+	}
+	if (wapi_auth_set_key(sm->wapi_auth, 0, alg, wapi_auth->group->addr,
+	//if (wapi_auth_set_key(sm->wapi_auth, 0, WPA_ALG_SMS4, wapi_auth->group->addr,
+			wapi_auth->group->msksa.mskid,
+			iv_pos, WAI_IV_LEN,
+			(u8_t *)&wapi_auth->group->msksa.msk,
+			wapi_auth->group->MSK_len))
+		return -1;
+#endif
+
+	return 0;
+err:
+	wapi_printf(MSG_ERROR, "wapi: **Received a undesirable group notice response and discard it!!");
+	return -1;
+}
