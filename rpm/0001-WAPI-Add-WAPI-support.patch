+static void wapi_send_usk_negotiation_req(struct wapi_authenticator *wapi_auth,
+			   struct wapi_state_machine *sm)
+{
+	int timeout_ms = usk_key_timeout_first;
+	_wapi_send_usk_negotiation_req(wapi_auth, sm);
+	eloop_register_timeout(timeout_ms / 1000, (timeout_ms % 1000) * 1000,
+			       wapi_send_wai_timeout, wapi_auth, sm);
+}
+
+static void wapi_msk_announcement_tx(struct wapi_authenticator *wapi_auth,
+			   struct wapi_state_machine *sm)
+{
+	int timeout_ms = usk_key_timeout_subseq;
+	_wapi_msk_announcement_tx(wapi_auth, sm);
+	eloop_register_timeout(timeout_ms / 1000, (timeout_ms % 1000) * 1000,
+			       wapi_send_wai_timeout, wapi_auth, sm);
+
+}
