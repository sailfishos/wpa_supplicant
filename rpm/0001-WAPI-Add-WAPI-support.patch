+} STRUCT_PACKED;
+
+/*Õ»åķÆźń╗ōµ×ä*/
+struct wapi_usk
+{
+	u8_t uek[16];   /*ÕŹĢµÆŁÕŖĀÕ»åÕ»åķÆź*/
+	u8_t uck[16];	  /*ÕŹĢµÆŁÕ«īµĢ┤µĆ¦µĀĪķ¬īÕ»åķÆź*/
+	u8_t mak[16];	  /*Õ»åķÆźÕŖĀÕ»åÕ»åķÆź*/
+	u8_t kek[16];   /*µČłµü»ķē┤Õł½Õ»åķÆź*/
+	u8_t usk_valid; /*Õ»åķÆźµś»ÕÉ”µ£ēµĢłńÜäµĀćÕ┐Ś*/
+	u8_t pad[3];
+};
+
+/*Õ»åķÆźń╗ōµ×ä*/
+struct wapi_msk
+{
+	u8_t mek[16];   /*ń╗äµÆŁÕŖĀÕ»åÕ»åķÆź*/
+	u8_t mck[16];	  /*ń╗äµÆŁÕ«īµĢ┤µĆ¦µĀĪķ¬īÕ»åķÆź*/
+	u8_t msk_valid; /*Õ»åķÆźµś»ÕÉ”µ£ēµĢłńÜäµĀćÕ┐Ś*/
+	u8_t pad[3];
+};
