+
+	octetstring_to_mint(pucPublicKey->x,pucPublicKey->bits/PRE_BYTE_BITS,&(pubkey.x));
+	octetstring_to_mint(pucPublicKey->y,pucPublicKey->bits/PRE_BYTE_BITS,&(pubkey.y));
+	if(MINT_ISZERO(&(pubkey.x)) || MINT_ISZERO(&(pubkey.y)))
+	{
+		ret = SDR_PARAINPUTERR;
+		return ret;
+	}
+
+	if (uiDataLength != EccSessionHandle->g_fixlen)
+	{
+		ret = SDR_PARAINPUTERR;
+		return ret;
+	}
+
+	switch(uiAlgID)
+	{
+#ifdef IWN_ECC_ECDSA
+	case SGD_ECES:
+        ret = ECES_ExternalEncrytp_ECC(((EccCurveHandle*)(EccSessionHandle->CurveHandle)), &pubkey, pucData, uiDataLength, EccSessionHandle->g_fixlen, 
+							          EccSessionHandle->g_hash_type, pucEncData->x, pucEncData->y, pucEncData->C,pucEncData->M);
+		break;
+#endif
+#ifdef IWN_ECC_SM2
+	case SGD_SM2_3:
+        ret = SM2_ExternalEncrytp_ECC(((EccCurveHandle*)(EccSessionHandle->CurveHandle)), &pubkey, pucData, uiDataLength, EccSessionHandle->g_fixlen, 
+							         EccSessionHandle->g_hash_type, pucEncData->x, pucEncData->y, pucEncData->C,pucEncData->M);
+		break;
+#endif
+	default:
+		break;
+	}
+
+	return ret;
+}
+//═Ō▓┐├▄į┐ECCĮŌ├▄
+int SDF_ExternalDecrypt_ECC( void *hSessionHandle, unsigned int uiAlgID, ECCrefPrivateKey *pucPrivateKey, ECCCipher *pucEncData, unsigned char *pucData, unsigned int *puiDataLength)
+{
+	MINT prikey;
+	int ret=-1;
+	SessionHandle *EccSessionHandle = NULL;
+
+    if (hSessionHandle == NULL) 
+    {
+       ret = SDR_NOSESSIONHANDLE;
+	   return ret;
+    }
+
+	memset(&prikey,0,sizeof(MINT));
+
+	EccSessionHandle = (SessionHandle *)hSessionHandle;
+
