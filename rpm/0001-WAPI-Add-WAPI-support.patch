+static struct wapi_rxfrag *malloc_rxfrag(int maxlen)
+{
+	struct wapi_rxfrag *frag = NULL;
+	frag = (struct wapi_rxfrag *)iwn_get_buffer(sizeof(struct wapi_rxfrag));
+	if (frag != NULL)
+	{
+		frag->maxlen = maxlen;
+		/* frag->rxfragstamp = time(NULL); */
+		frag->data = (u8 *)iwn_get_buffer(frag->maxlen);
+		if (frag->data == NULL)
+		{
+			frag  = (struct wapi_rxfrag *)iwn_free_buffer(frag,
+									sizeof(struct wapi_rxfrag ));
+		}
+	}
+	return frag;
+}
+
+static void *free_rxfrag(struct wapi_rxfrag *frag)
+{
+	if (frag != NULL)
+	{
+		iwn_free_buffer((void *)(frag->data), frag->maxlen);
+		iwn_free_buffer((void *)frag, sizeof(struct wapi_rxfrag ));
+	}
+	
+	return NULL;
+}
+
+static void wai_put_frag(struct wapi_rxfrag *frag, u8 *data, int len)
+{
+	memcpy((unsigned char *)frag->data + frag->data_len, data, len);
+	frag->data_len += len;
+
+	{
+		u16 tmp = (u16)frag->data_len;
+		SETSHORT(((unsigned char *)(frag->data)+6), tmp);
+	}
+}
+
+
+int iwn_wai_frag(const void *data, int len)
+{
+	int i = 0;
+	int  slen = 0;
+	int frame_no = 0;
+	int frame_len = 0;
+	int mtu = 0;
+	u8 *frame_data = NULL;
+	int send_frame_len =0;
+	u8 * ethernet_header = NULL;
+	struct wai_hdr *wai_frame_header = NULL;
+	int wai_hdr_size = sizeof(struct wai_hdr);
+	u16 temp_len = 0;
+	
+	get_l2_mtu(&mtu);
+	
+	wapi_printf(MSG_INFO, "iwn_wai_frag all len = %d mtu =%d", len, mtu);
+	
+	if (len + ETH_HLEN <= mtu)
+	{
+		slen = wapi_tx_wai_packet((const char*)data, len);
+		if (slen <= 0) 
+		{
+			wapi_printf(MSG_ERROR, "send  error\n");
+			return  0;
+	  	}
+	}
+	else
+	{
+		if ((len - wai_hdr_size) % (mtu - wai_hdr_size - ETH_HLEN ) != 0)
+		{
+			frame_no = (len - wai_hdr_size) / (mtu - wai_hdr_size - ETH_HLEN ) + 1;
+		}
+		else 
+		{		
+			frame_no = (len - wai_hdr_size) / (mtu - wai_hdr_size - ETH_HLEN );
+		}
+		
+		frame_data = malloc(frame_no * mtu);
+		memset(frame_data , 0x11, sizeof(frame_no * mtu));
+		wapi_printf(MSG_INFO, "iwn_wai_frag: mtu = %d frame_no = %d", 
+					mtu, frame_no);
+		
+		for (i = 0; i < frame_no; i++)
+		{ 
+			wapi_printf(MSG_INFO, "send count = %d", i);
+		    send_frame_len = 0;
+		    ethernet_header = frame_data + i * mtu;
+			wai_frame_header = ( struct wai_hdr  *)(ethernet_header  );
+			
+			/*Copy WAI header*/
+			memcpy(wai_frame_header, data, wai_hdr_size);
+			/*set frame sequence*/
+			wai_frame_header->frag_sc = i;
+			/*not the last frame*/
+			if (i != frame_no -1) 
+			{ 
+				/*set frame flag*/
+		    	wai_frame_header->more_frag |= 0x01;
+		    	/*Copy WAI data*/
+				memcpy((u8 *)wai_frame_header + wai_hdr_size, 
+					(u8 *)data + wai_hdr_size + i * (mtu - wai_hdr_size - ETH_HLEN ),
+					mtu - wai_hdr_size - ETH_HLEN );
+					
+		    	/*set WAI len*/
+				/*wai_frame_header->length =iwn_htons(mtu -ETH_HLEN) ;*/
+				temp_len = mtu -ETH_HLEN;
+				u8* pos = (u8 *)(&temp_len);
+				GETSHORT(pos, wai_frame_header->length) ;
+				/*set send data len*/
+				frame_len = mtu - ETH_HLEN; 
+			}
+			else
+			{
+				/*the last frame*/
+				temp_len = 0;
+				memcpy((u8 *)wai_frame_header + wai_hdr_size, 
+					(u8 *)data + wai_hdr_size + i * (mtu - wai_hdr_size - ETH_HLEN),
+					len - wai_hdr_size - i * (mtu - wai_hdr_size - ETH_HLEN));
+					
+				/*set WAI len*/
+				temp_len = len - i*(mtu - wai_hdr_size - ETH_HLEN );
+				/* wai_frame_header->length =iwn_htons(temp_len) ; */
+				u8* pos = (u8 *)(&temp_len);
+				GETSHORT(pos, wai_frame_header->length);
+		    	/*set send data len*/
+				frame_len = temp_len; 
+		    }
+			
+			send_frame_len = wapi_tx_wai_packet((const char*)ethernet_header, frame_len);
+			
+			wapi_printf(MSG_INFO, "fsend_frame_len = %d", send_frame_len);
+			
+			if (send_frame_len <= 0) 
+			{
+				wapi_printf(MSG_ERROR, "wai_frag send error");
+				return 0;
+			}
+			
+			/* many headers length */
+			slen = slen + send_frame_len;
+		}
+		
+		slen -= (frame_no - 1) * wai_hdr_size;
+	}
+	 
+	free(frame_data);
+	return slen;
+}
