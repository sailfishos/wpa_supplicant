+}MINT;
+
+/*--------------------------------------------------------------------*/
+int octetstring_to_mint_c(const unsigned char *octstr_val, unsigned int octstr_len,MINT *mint_val);
+int mint_to_octetstring_c(const MINT *mint_val,int buflen,unsigned char *octstr_val,unsigned int *octstr_len);
+int mint_copy_c(MINT *dest,MINT *src);
+int mint_adjust_len_c(MINT *mint_val,int len);
