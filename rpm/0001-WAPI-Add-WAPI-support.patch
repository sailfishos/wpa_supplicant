+int IWN_CurveParaCfg(void *hSessionHandle, enum_bits CurveType, ECCrefPara *CurvePara)
+{
+	int ret = -1;
+	MINT rem;
+	SessionHandle *EccSessionHandle = NULL;
+	ECCrefPara *EccPara = NULL;
+		 
+	if (hSessionHandle == NULL) 
+	{
+		ret = SDR_NOSESSIONHANDLE;
+		return ret;
+	}
+	if ((CurveType <= ECC_API_OPS_BITS_NONE) || (CurveType >= ECC_API_OPS_BITS_MAX) || (CurvePara == NULL))
+	{
+		ret = SDR_PARAINPUTERR;
+	    return ret;
+	}
+	EccSessionHandle = (SessionHandle *)hSessionHandle;
+	if(EccSessionHandle->EccConfigPara==NULL)
+	{
+		EccPara = (ECCrefPara*)malloc(sizeof(ECCrefPara));
+		if(EccPara==NULL){
+			return -1;
+		}
+		memset(EccPara,0,sizeof(ECCrefPara));
+		EccSessionHandle->EccConfigPara = EccPara;
+	}
+	memcpy(EccSessionHandle->EccConfigPara,CurvePara,sizeof(ECCrefPara));
+
+	switch(CurveType)
+	{
+		case ECC_API_OPS_BIT160:
+			EccSessionHandle->g_fixlen = 20;
+			break;
+		case ECC_API_OPS_BIT192:
+			EccSessionHandle->g_fixlen = 24;
+			break;
+		case ECC_API_OPS_BIT224:
+			EccSessionHandle->g_fixlen = 28;
+			break;
+		case ECC_API_OPS_BIT256:
+			EccSessionHandle->g_fixlen = 32;
+			break;
+		case ECC_API_OPS_SM2EXP:
+			EccSessionHandle->g_fixlen = 32;
+			break;
+		case ECC_API_OPS_SM2REC:
+			EccSessionHandle->g_fixlen = 32;
+			break;
+		default:
+			break;			
+	}
+
+	EccSessionHandle->g_hash_type = CurvePara->hash_type;
+	((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.bitslen = EccSessionHandle->g_fixlen*BITS_PER_BYTE;
+	octetstring_to_mint(CurvePara->P,EccSessionHandle->g_fixlen,&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.P));
+	octetstring_to_mint(CurvePara->A,EccSessionHandle->g_fixlen,&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.A));
+	octetstring_to_mint(CurvePara->B,EccSessionHandle->g_fixlen,&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.B));
+	octetstring_to_mint(CurvePara->Gx,EccSessionHandle->g_fixlen,&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.G.x));
+	octetstring_to_mint(CurvePara->Gy,EccSessionHandle->g_fixlen,&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.G.y));
+	octetstring_to_mint(CurvePara->N,EccSessionHandle->g_fixlen,&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.N));
+	//╝Ų╦ŃWųĄ
+	EccSessionHandle->g_w = get_w_val(&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.N),((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.bitslen);
+	//╝Ų╦ŃHųĄ
+	memset(&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_h),0,sizeof(MINT));
+	memset(&rem,0,sizeof(MINT));
+	mint_div(&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.P),&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.N),&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_h),&rem); //h=P/N
+
+	//╣╠Č©ĄŃĄŃ│╦įżį╦╦Ń
+    ecc_precomputation_point(&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.G),&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.A),&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.B),&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.P),((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_GPt_1);
+	if(ecc_test_point(&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.G),&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.A),&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.B),&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.P))!=0)
+	{
+		return -1;
+	}
+	
+	EccSessionHandle->EccCurveType = CurveType;
+	EccSessionHandle->Curve_length = ((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.bitslen;
+   
+	ret = SDR_OK;
+	return ret;
+}
