+#ifdef CONFIG_WAPI
+int wpa_parse_wapi_ie(const u8 *wapi_ie, size_t wapi_ie_len,
+			 struct wapi_ie_data *data)
+{
+	const struct wapi_ie_hdr *hdr;
+	const u8 *pos;
+	int offset;
+	int i, count;
+	u32 code;	
+	os_memset(data, 0, sizeof(*data));
+	data->proto = WPA_PROTO_WAPI;
+	data->mgmt_group_cipher = 0;
+
+
+	if ((wapi_ie_len == 0) || (wapi_ie_len < sizeof(struct wapi_ie_hdr))) {
+		wpa_printf(MSG_ERROR, "%s: ie len too short %lu",
+			   __func__, (unsigned long) wapi_ie_len);
+		return -1;
+	}
+
+	hdr = (const struct wapi_ie_hdr *) wapi_ie;
+	
+	if (hdr->elem_id != WLAN_EID_BSS_AC_ACCESS_DELAY 
+		|| (hdr->len != wapi_ie_len - 2) 
+		|| (WPA_GET_LE16(hdr->version) != WAI_VERSION))
+	{
+		wpa_printf(MSG_ERROR, "%s: malformed ie or unknown version", __func__);
+		return -2;
+	}
+
+	pos = (const u8 *) (hdr + 1); 
+	offset = wapi_ie_len - sizeof(*hdr);
+
+	count = WPA_GET_LE16(pos);
+	offset -= 2;
+	if (count == 0 || offset < count * WPA_SELECTOR_LEN) {
+		wpa_printf(MSG_ERROR, "%s: ie count botch (key mgmt), "
+				   "count %u offset %u", __func__, count, offset);
+		return -6;
+	}
+	
+	//wpa_printf(MSG_ERROR, "%s: count= %d offset = %d", __func__,count, offset);
+	if(count == 1){
+		//key_mgmt psk / cert
+		pos += 2;
+		code = WPA_GET_BE32(pos);
+		//wpa_printf(MSG_ERROR, "sm4-wapi: Failure-Code0 0x%x", code);
+		if (code == 0x147202){
+			data->key_mgmt = WPA_KEY_MGMT_WAPI_PSK;	
+		}else if (code == 0x147201){
+			data->key_mgmt = WPA_KEY_MGMT_WAPI_CERT;
+		}
+		pos += WPA_SELECTOR_LEN;
+		offset -= WPA_SELECTOR_LEN;
+		//wpa_printf(MSG_ERROR, "%s: offset0 = %d", __func__, offset);
+		
+		//pairwise_cipher
+		pos += 2;
+		offset -= 2;
+		
+		code = WPA_GET_BE32(pos);
+		//wpa_printf(MSG_ERROR, "sm4-wapi: Failure-Code1 0x%x", code);
+		
+		if (code == RSN_CIPHER_SUITE_SMS4 ){
+			data->pairwise_cipher = WPA_CIPHER_SMS4;
+		}
+		pos += WPA_SELECTOR_LEN;
+		offset -= WPA_SELECTOR_LEN;
+
+		//wpa_printf(MSG_ERROR, "%s: offset1 = %d", __func__, offset);
+		code = WPA_GET_BE32(pos);
+		//wpa_printf(MSG_ERROR, "sm4-wapi: Failure-Code2 0x%x", code);
+		
+		//group_cipher
+		if (code == RSN_CIPHER_SUITE_SMS4 ){
+			data->group_cipher = WPA_CIPHER_SMS4;
+		}
+		pos += WPA_SELECTOR_LEN;
+		offset -= WPA_SELECTOR_LEN;
+
+		//wpa_printf(MSG_ERROR, "%s: offset2 = %d", __func__, offset);
+		code = WPA_GET_LE16(pos);
+		//wpa_printf(MSG_ERROR, "sm4-wapi: Failure-Code3 0x%x", code);
+		if (offset >= 2) {
+			data->capabilities = code;
+			pos += 2;
+			offset -= 2;
+		}
+	}
+	//wpa_printf(MSG_ERROR, "%s: offset3 = %d", __func__, offset);
+	if (offset > 0) {
+		wpa_printf(MSG_ERROR, "%s: ie has %u trailing bytes - ignored",
+			   __func__, offset);
+	}
+	
+	return 0;
+}
