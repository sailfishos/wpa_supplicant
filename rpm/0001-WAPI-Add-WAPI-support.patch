+static u8 * wpa_build_hdr(u8 *pos, u16 txseq, u8 stype)
+{
+	struct wai_hdr *hdr = (struct wai_hdr *)pos;
+	
+	SETSHORT(hdr->version, WAI_VERSION);
+	hdr->type = WAI_TYPE;
+	hdr->stype = stype;
+	SETSHORT(hdr->reserve, 0);
+	hdr->length = 0x0000;
+	SETSHORT(hdr->rxseq, txseq);
+	hdr->frag_sc = 0;
+	hdr->more_frag = 0;
+	return (u8 *)(hdr + 1);
+}
