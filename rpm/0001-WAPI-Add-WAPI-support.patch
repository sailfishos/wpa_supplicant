+/* ped   ╩õ│÷╩²Š▌▓╬╩² */
+void sm4alg(unsigned int *endek, const unsigned char *pd, unsigned char *ped)
+{
+	unsigned int *v = NULL;
+	unsigned int alp = 0;
+	unsigned int beta = 0;
+	unsigned int gamm = 0;
+	unsigned int zeta = 0;
+	unsigned int delta = 0;
+	unsigned int i = 0;
+	union _a
+	{ 
+		int m; 
+		char n;
+	}a;
+
+	a.m = 1;
+
+	if (endek == NULL)
+	{
+	    return;
+	}
+
+	if (pd == NULL)
+	{
+	    return;
+	}
+
+	v = (unsigned int *)pd;
+	alp = v[0];
+	beta = v[1];
+	gamm = v[2];
+	zeta = v[3];
+
+	if (a.n == 1)
+	{
+		alp = byteorder_inv(alp);
+		beta = byteorder_inv(beta);
+		gamm = byteorder_inv(gamm);
+		zeta = byteorder_inv(zeta);
+	}
+
+	for (i = 0; i < 32; i = i + 4)
+	{
+		delta = beta ^ gamm ^ zeta ^ endek[i + 0];
+		delta = com_xx_trsform(delta);
+		alp = alp ^ delta;
+
+		delta = gamm ^ zeta ^ alp ^ endek[i + 1];
+		delta = com_xx_trsform(delta);
+		beta = beta ^ delta;
+
+		delta = zeta ^ alp ^ beta ^ endek[i + 2];
+		delta = com_xx_trsform(delta);
+		gamm = gamm ^ delta;
+
+		delta = alp ^ beta ^ gamm ^ endek[i + 3];
+		delta = com_xx_trsform(delta);
+		zeta = zeta ^ delta;   
+	}
+
+	v = (unsigned int *)ped;
+	if (a.n == 1)
+	{
+		alp = byteorder_inv(alp);
+		beta = byteorder_inv(beta);
+		gamm = byteorder_inv(gamm);
+		zeta = byteorder_inv(zeta);
+	}
+		
+	v[3] = alp;
+	v[2] = beta;
+	v[1] = gamm;
+	v[0] = zeta;
+}
+
+/* ╝ė├▄║»╩² */
+/* cr  ╩õ╚ļ┤”└Ē║¾Ą─├▄į┐▓╬╩² */
+/* pd  ╩õ╚ļ├„╬─▓╬╩² */
+/* ped ╩õ│÷├▄╬─▓╬╩² */
+int enc_sm4alg(ctx_rkey_sm4 *cr, const unsigned char *pd, unsigned char *ped)
+{
+	if (cr == NULL)
+	{
+	    return -1;
+	}
+
+	if (pd == NULL)
+	{
+	    return -1;
+	}
+
+	sm4alg(cr->enck, pd, ped);
+    return 0;
+}
+
+/* ĮŌ├▄║»╩² */
+/* cr  ╩õ╚ļ┤”└Ē║¾Ą─├▄į┐▓╬╩² */
+/* ped ╩õ╚ļ├▄╬─▓╬╩² */
+/* pd  ╩õ│÷├„╬─▓╬╩² */
+int dec_sm4alg(ctx_rkey_sm4 *cr, const unsigned char *ped, unsigned char *pd)
+{
+	if (cr == NULL)
+	{
+	    return -1;
+	}
+
+	if (ped == NULL)
+	{
+	    return -1;
+	}
+
+	sm4alg(cr->deck, ped, pd);
+    return 0;
+}
+
