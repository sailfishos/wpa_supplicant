@@ -0,0 +1,236 @@
+/* 
+ * Copyright (C) 2015-2018 China IWNCOMM Co., Ltd. All rights reserved.
+ * 
+ * Contains functions for ECC192 alg
+ * 
+ * Authors:  
+ * Shaofeng Li
+ * 
+ * History: 
+ * Shaofeng Li  XX first version for ECC192 alg in IAS project
+ * chen weigang  10/09/2015 v1.0 change code style
+ * 
+ * Related documents:
+ * -GB/T 15629.11-2003/XG1-2006 
+ * -ISO/IEC 8802.11:1999,MOD
+ * 
+*/ 
+
+#include <stdlib.h>
+#include <stdio.h>
+#include <memory.h>
+#include "ecc.h"
+#include "algapi.h"
+#include "alg_ecc_if.h"
+
+static void* s_hdev = NULL;
+static void* s_hecc = NULL;
+static int s_b_init = 0;
+
+#ifndef ECC_INIT_FUNC
+#define ECC_INIT_FUNC      do {ecc_init();}while(0)
+#endif
+
+/* desc : Open ECC192 alg Session
+ *
+ */
+int ecc_init()
+{
+	if (1 == s_b_init)		
+		return 0;
+
+	int ret = SDF_OpenDevice(&s_hdev);
+	if (SDR_OK != ret) {
+		printf("error, SDF_OpenDevice fail\n");
+		return -1;
+	}
+
+	ret = SDF_OpenSession(s_hdev, &s_hecc);
+	if (SDR_OK != ret) {
+		printf("error, SDF_OpenSession ecc fail\n");
+		return -1;
+	}
+
+	/* Ū·Ž▀▓╬╩²Ą─╩²Š▌ę└┤╬╬¬p,a,b,x,y,order */
+	/* ECDSA 192Ū·Ž▀ */
+	ECCrefPara curve_ecc = {
+		{0xBD,0xB6,0xF4,0xFE,0x3E,0x8B,0x1D,0x9E,0x0D,0xA8,0xC0,0xD4,
+         0x6F,0x4C,0x31,0x8C,0xEF,0xE4,0xAF,0xE3,0xB6,0xB8,0x55,0x1F},
+		{0xBB,0x8E,0x5E,0x8F,0xBC,0x11,0x5E,0x13,0x9F,0xE6,0xA8,0x14,
+         0xFE,0x48,0xAA,0xA6,0xF0,0xAD,0xA1,0xAA,0x5D,0xF9,0x19,0x85},
+		{0x18,0x54,0xBE,0xBD,0xC3,0x1B,0x21,0xB7,0xAE,0xFC,0x80,0xAB,
+         0x0E,0xCD,0x10,0xD5,0xB1,0xB3,0x30,0x8E,0x6D,0xBF,0x11,0xC1},
+		{0x4A,0xD5,0xF7,0x04,0x8D,0xE7,0x09,0xAD,0x51,0x23,0x6D,0xE6,
+         0x5E,0x4D,0x4B,0x48,0x2C,0x83,0x6D,0xC6,0xE4,0x10,0x66,0x40},
+		{0x02,0xBB,0x3A,0x02,0xD4,0xAA,0xAD,0xAC,0xAE,0x24,0x81,0x7A,
+         0x4C,0xA3,0xA1,0xB0,0x14,0xB5,0x27,0x04,0x32,0xDB,0x27,0xD2},
+		{0xBD,0xB6,0xF4,0xFE,0x3E,0x8B,0x1D,0x9E,0x0D,0xA8,0xC0,0xD4,
+         0x0F,0xC9,0x62,0x19,0x5D,0xFA,0xE7,0x6F,0x56,0x56,0x46,0x77},
+		ECC_API_OPS_BIT192,
+		HASH_TYPE_SHA256
+	};
+
+	IWN_CurveParaCfg(s_hecc, (enum_bits)ECC_API_OPS_BIT192, &curve_ecc);
+
+	s_b_init = 1;
+
+    return 0;
+}
+
+/* desc : Close ECC192 alg Session
+ *
+ */
+void ecc_exit()
+{
+	int ret = -1;
+
+    if (!s_b_init) {
+        return;
+    }
+
+	ret = SDF_CloseSession(s_hecc);
+	if (SDR_OK != ret) {
+		printf("error, SDF_CloseSession ecc fail\n");
+	}
+
+	ret = SDF_CloseDevice(s_hdev);
+	if (SDR_OK != ret) {
+		printf("error, SDF_CloseDevice fail\n");
+	}
+
+    s_b_init = 0;
+
+    return;
+}
+
+/* desc : ecc192 sign function
+ * @msg : msg buffer address for sign
+ * @len_msg : msg buffer length
+ * @privk_24 : 24 Bytes private key
+ * @buf_sign : for saving the 48 Bytes ECC192 sign value
+ *
+ * return :
+ *  0 means ok
+ *
+ */
+int ecc_sign(void* msg, int len_msg, 
+        unsigned char* privk_24, 
+        unsigned char* buf_sign)
+{
+	int ret = -1;
+	
+	ECCrefPrivateKey k = {192, {0}};
+	ECCSignature sign = {{0}, {0}};
+	memcpy(k.D, privk_24, 24);
+
+    ECC_INIT_FUNC;
+
+	ret = IWN_ExternalSignHash_ECC(s_hecc, SGD_ECDSA, &k, 
+                (unsigned char*)msg,len_msg, NULL,0, &sign);
+	memcpy(buf_sign, sign.r, 24);
+	memcpy(buf_sign+24, sign.s, 24);
+
+	return ret;
+}
+
+/* desc : ecc192 sign verify
+ * @msg : msg buffer for verifing the sign
+ * @len_msg : msg buffer length
+ * @pubk_48 : 48 Bytes public key for verifing the sign
+ * @buf_sign : sign value buffer for verifing
+ *
+ * return :
+ *  0 means ok
+ *
+ */
+int ecc_vrfy(void* msg, int len_msg, 
+        unsigned char* pubk_48, 
+        unsigned char* buf_sign)
+{
+	int ret = -1;
+	
+	ECCrefPublicKey k = {192, {0}, {0}};
+	ECCSignature sign = {{0}, {0}};
+	memcpy(k.x, pubk_48, 24);
+	memcpy(k.y, pubk_48+24, 24);
+	memcpy(sign.r, buf_sign, 24);
+	memcpy(sign.s, buf_sign+24, 24);
+
+    ECC_INIT_FUNC;
+
+	ret = IWN_ExternalVerifyHash_ECC(s_hecc, SGD_ECDSA, &k, 
+                (unsigned char*)msg,len_msg, NULL,0, &sign);
+	
+	return ret;
+}
+
+/* desc : get new ECC192 keypair
+ * @privk : for saving 24 Bytes private key
+ * @pubk : for saving 48 Bytes public key
+ *
+ * return :
+ *  0 means OK
+ *
+ */
+int ecc_new_key(unsigned char* privk, unsigned char* pubk)
+{
+	ECCrefPrivateKey k1 = {24*8, {0}};
+	ECCrefPublicKey k2 = {24*8, {0}, {0}}; 
+
+    ECC_INIT_FUNC;
+    
+	int ret = SDF_GenerateKeyPair_ECC(s_hecc, SGD_ECC, 24*8, &k2, &k1);
+	memcpy(privk, k1.D, 24);
+	memcpy(pubk, k2.x, 24);
+	memcpy(pubk+24, k2.y, 24);
+
+	/* 0 is ok */
+	return ret;
+
+}
+
+/* desc : ecc192 ecdh compute
+ * @privk_24 : 24 Bytes our private key
+ * @pubk_48 : 48 Bytes others public key
+ * @seed_24 : 24 Bytes ECDH compute result
+ *
+ * return :
+ *  0 means OK
+ *
+ */
+int ecc_ecdh_compute(unsigned char* privk_24, unsigned char* pubk_48, unsigned char* seed_24)
+{
+	ECCrefPrivateKey k1 = {192, {0}};
+	ECCrefPublicKey k2 = {192, {0}, {0}};
+	ECCEcdh ecdh = {{0}};
+	memcpy(k1.D, privk_24, 24);
+	memcpy(k2.x, pubk_48, 24);
+	memcpy(k2.y, pubk_48+24, 24);
+
+    ECC_INIT_FUNC;
+
+	int ret = IWN_ExternalEcdhKeyAgreement(s_hecc, &k1, &k2, &ecdh);
+	memcpy(seed_24, ecdh.keyseed, 24);
+	/* 0 is ok */
+	return ret;
+}
+
+int iwn_hmac_sha256(unsigned char* text, int text_len, 
+				unsigned char* key, unsigned key_len, 
+				unsigned char* digest, unsigned digest_length)
+{
+	return IWN_HmacSha256(s_hecc, key, key_len, text, text_len, digest, digest_length);
+}
+
+int iwn_kdhmac_sha256(unsigned char* text, unsigned  text_len, 
+				unsigned char* k, unsigned kl, unsigned char* o, unsigned ol)
+{
+	return IWN_KdHmacSha256(s_hecc, k, kl, text, text_len, o, &ol);
+}
+
+int iwn_mhash_sha256(unsigned char *pucData, unsigned int uiDataLength, 
