+
+	enum {
+		WAPI_GROUP_MSK_INIT = 0,
+		WAPI_GROUP_SETKEYS, 
+		WAPI_GROUP_SETKEYSDONE
+	} wapi_group_state;
+
+	struct wapi_msksa msksa;
