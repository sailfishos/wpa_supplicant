+}
+//ISSUER,SUBJECT,EXTENSIONSųą║¼ėąą┼ŽóĄ─Ė÷╩²
+int Get_Sets_Count_X509(X509_Cert *ctx, X509_Info type, int *count)
+{
+	int length=0,len=0,num=0;
+	unsigned char Llen=0;
+	unsigned char *p=NULL;
+
+	switch(type)
+	{
+		case ISSUER:
+			if(ctx->Issuer.data == NULL)
+			{
+				return ERROR_ISSUERNOEXIST;
+			}
+			p = ctx->Issuer.data;
+			break;
+		case SUBJECT:
+			if(ctx->Subject.data == NULL)
+			{
+				return ERROR_SUBJECTNOEXIST;
+			}
+			p = ctx->Subject.data;
+			break;
+		case EXTENSIONS:
+			{
+				if(ctx->extensions.data == NULL)
+				{
+					return ERROR_EXTENSIONSNOEXIST;
+				}
+				p = ctx->extensions.data;
+				p += 1;
+				length = GetInfoLength(p,&Llen);
+				p += Llen;
+			}
+			break;
+		default:
+			return CTP_FALSE;
+	}
+	
+	p += 1;
+	length = GetInfoLength(p,&Llen);
+	p += Llen;
+
+	while(length > 0)
+	{
+		p += 1;
+		len = GetInfoLength(p,&Llen);
+		p += Llen;
+		p += len;
+		length -= 1+Llen+len;
+		num++;
+	}
+	*count = num;
+	return CTP_OK;
+}
+//num=0,╬¬DCą┼ŽóŻ╗num=1,╬¬Cą┼ŽóŻ╗num=2,╬¬Oą┼ŽóŻ╗num=3,╬¬OUą┼ŽóŻ╗num=4,╬¬CNą┼Žó
+//ęįnum=0ĮŌ╩═ęįŽ┬▓╬╩²ą┼Žó
