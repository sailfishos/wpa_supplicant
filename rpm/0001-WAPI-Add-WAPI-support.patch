+int  wapi_msk_announcement_res(struct wapi_authenticator *wapi_auth,
+		 struct wapi_state_machine *sm, u8 *payload_data, size_t payload_len)
+{
+	enum wpa_alg alg = WPA_ALG_NONE;
+	u8 *iv = NULL;
+	if(_wapi_msk_announcement_res(wapi_auth, sm, iv, payload_data, payload_len) < 0){
+		wpa_printf(MSG_ERROR, "WAPI _wapi_msk_announcement_res = -1.");
+		wpa_hexdump(MSG_DEBUG, "WAPI IV", iv, 16);
+		return -1;
+	}
+
+	if (wapi_auth->conf->wapi_group == WPA_CIPHER_SMS4) {
+		alg = WPA_ALG_SMS4;
+	}
+	if (wapi_auth_set_key(sm->wapi_auth, 0, alg, wapi_auth->group->addr,
+			wapi_auth->group->msksa.mskid,
+			iv, WAI_IV_LEN,
+			(u8 *)&wapi_auth->group->msksa.msk,
+			wapi_auth->group->MSK_len, KEY_FLAG_GROUP_RX_TX))
+		return -1;
+	return 0;
+}
