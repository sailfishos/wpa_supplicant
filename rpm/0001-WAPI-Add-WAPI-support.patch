+
+struct wapi_state_machine 
+{
+	struct wapi_authenticator *wapi_auth;
+	struct wapi_group *group;
+
+	u8_t addr[ETH_ALEN]; /* sta addr */
+
+	enum {
+		WAPI_USK_INITIALIZE, WAPI_PTK_DISCONNECT, WAPI_PTK_DISCONNECTED,
+		WAPI_USK_AUTHENTICATION, WAPI_USK_AUTHENTICATION2,
+		WAPI_USK_INITBKID, WAPI_USK_START,
+		WAPI_USK_CALCNEGOTIATING, WAPI_USK_CALCNEGOTIATING2,
+		WAPI_USK_INITNEGOTIATING, WAPI_USK_SETKEY,
+		WAPI_USK_DONE
+	} wapi_usk_state;
+
+	enum {
+		WAPI_MSK_GROUP_IDLE = 0,
+		WAPI_MSK_GROUP_START,
+		WAPI_MSK_GROUP_AUTHENTICATION,
+		WAPI_MSK_GROUP_AUTHENTICATION2,
+		WAPI_MSK_GROUP_REKEYNEGOTIATING,
+		WAPI_MSK_GROUP_REKEYESTABLISHED,
+		WAPI_MSK_GROUP_KEYERROR
+	} wapi_msk_group_state;
+
+	_Boolean Init;
+	_Boolean DeauthenticationRequest;
+	_Boolean AuthenticationRequest;
+	_Boolean ReAuthenticationRequest;
+	_Boolean Disconnect;
+	int TimeoutCtr;
+	int GTimeoutCtr;
+	_Boolean TimeoutEvt;
+	_Boolean WAPIwaiReceived;
+	_Boolean WAPIwaiPairwise;
+	_Boolean WAPIwaiRequest;
+	_Boolean UMICVerified;
+	_Boolean GMICVerified;
+	_Boolean GUpdateStationKeys;
+	u8_t ANonce[WAPI_NONCE_LEN];
+	u8_t next_ANonce[WAPI_NONCE_LEN];
+	u8_t SNonce[WAPI_NONCE_LEN];
+	u8_t PMK[32];
+	u8_t wai_flag_in_data;
+	//u8_t USKID;
+	struct wapi_usksa USKSA;
+	u8_t BKID[WAPI_BKID_LEN];
+	u16_t group_sc;
+	_Boolean BKID_valid;
+	_Boolean pairwise_set;
+	int keycount;
+	_Boolean Pair;
+	struct {
+		u8_t counter[8];
+		_Boolean valid;
+	} key_replay[4];
+	_Boolean USKRequest; /* not in IEEE 802.11i state machine */
+	_Boolean has_USK;
+	_Boolean has_MSK;
+	_Boolean USKInit;
+	_Boolean MSKGroupInit; /* init request for MSK Group state machine */
+
+	_Boolean in_usk_step;
+	_Boolean in_msk_step;
+
+	u8_t *last_rx_eapol_key; /* starting from IEEE 802.1X header */
+	size_t last_rx_eapol_key_len;
+
+	unsigned int changed:1;
+	unsigned int in_step_loop:1;
+	unsigned int pending_deinit:1;
+	unsigned int started:1;
+	unsigned int mgmt_frame_prot:1;
+
+	u8_t req_replay_counter[8];
+	int req_replay_counter_used;
+
+	u8_t *wapi_ie;
+	size_t wapi_ie_len;
+
+	enum {
+		WAPI_VERSION_NO_WAPI = 0 /* WAPI not used */,
+		WAPI_VERSION_WAPI = 1 /* WAPI  */,
+	} wapi;
+	int pairwise; /* Pairwise cipher suite, WAPI_CIPHER_* */
+	int wapi_key_mgmt; /* the selected WAPI_KEY_MGMT_* */
+	//struct rsn_pmksa_cache_entry *pmksa;
+
+	u32_t dot11RSNAStatsTKIPLocalMICFailures;
+	u32_t dot11RSNAStatsTKIPRemoteMICFailures;
+
+	int pending_1_of_4_timeout;
+};
+
+/* per group key state machine data */
+struct wapi_group {
+	struct wapi_group *next;
+	int vlan_id;
+
+	_Boolean GInit;
+	int GKeyDoneStations;
+	_Boolean MSKReKey;
+	size_t NMK_len;
+	size_t MSK_len;
