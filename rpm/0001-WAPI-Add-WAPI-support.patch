+	if(ecc_test_point(&spon_tmp_pubkey,&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.A),&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.B),&(((EccCurveHandle*)(EccSessionHandle->CurveHandle))->g_fp_curve.P))!=0){
