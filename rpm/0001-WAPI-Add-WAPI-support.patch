+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include "getlen.h"
+
+/*ūį╩╩ė”┤¾ąĪČ╦*/
+int GetInfoLength(const unsigned char *p, unsigned char *pos)
+{
+	unsigned short Longlen=0;
+	unsigned char *pLen = NULL;
+	union {int b; char t;} edata = {1};
+
+	if (*p >= 0x80)   //0~127
+	{
+		if (*p == 0x81)
+		{
+			*pos = 2;
+			return *(p+1);
+		}
+		else if(*p == 0x82)
+		{
+			pLen = (unsigned char*)&Longlen;
+
+			if (edata.t == 1)
+		    {
+				*pLen = *(p+2);
+				*(pLen+1) = *(p+1);
+			}
+			else
+			{
+				*pLen = *(p+1);
+				*(pLen+1) = *(p+2);
+			}
+
+			*pos = 3;
+			return Longlen;
+		}
+	}
+	else
+	{
+		*pos = 1;
+		return *p;
+	}
+	return 0;
+}
