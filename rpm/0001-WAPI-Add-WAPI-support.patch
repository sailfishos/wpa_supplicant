+
+	if(!password || !*password)
+	{
+		if(Verify_Mac(mac_value,mac_len,safe_bag,safe_bag_len, 
+			          mac_salt,mac_salt_len,mac_iter_1,NULL,0)) password = NULL;
+		else if(Verify_Mac(mac_value,mac_len,safe_bag,safe_bag_len, 
+			          mac_salt,mac_salt_len,mac_iter_1,"",0)) password = "";
+
+	}else if(!Verify_Mac(mac_value,mac_len,safe_bag,safe_bag_len, 
+			             mac_salt,mac_salt_len,mac_iter_1,password,-1)) 
+	{
+		free(mac_info);
+		mac_info = NULL;
+		free(safe_bag);
+		safe_bag = NULL;
+		free(p7data_id);
+		p7data_id = NULL;
+		free(version);
+		version = NULL;
+		return CTP_FALSE;
+	}
+
+	ret = 0;
+	ret = UnPack_AUTH_SAFE_BAG(safe_bag,safe_bag_len,&auth_safe_bag);
+	if(ret != CTP_OK) 
+	{
+		free(mac_info);
+		mac_info = NULL;
+		free(safe_bag);
+		safe_bag = NULL;
+		free(p7data_id);
+		p7data_id = NULL;
+		free(version);
+		version = NULL;
+		return CTP_FALSE;
+	}
+
+	if(GetRc2Salt_P12(&auth_safe_bag,rc2_salt,&rc2_salt_len,tag_4) != CTP_OK) 
+	{
+		free(mac_info);
+		mac_info = NULL;
+		free(safe_bag);
+		safe_bag = NULL;
+		free(p7data_id);
+		p7data_id = NULL;
+		free(version);
+		version = NULL;
+		return CTP_FALSE;
+	}
+
+	if(GetRc2Iter_P12(&auth_safe_bag,rc2_iter,&rc2_iter_len,tag_5) != CTP_OK) 
+	{
+		free(mac_info);
+		mac_info = NULL;
+		free(safe_bag);
+		safe_bag = NULL;
+		free(p7data_id);
+		p7data_id = NULL;
+		free(version);
+		version = NULL;
+		return CTP_FALSE;
+	}
+	rc2_iter_1 = chart_to_int(rc2_iter,rc2_iter_len);
+
+    if(!pass_gen_key(password,-1,rc2_salt,rc2_salt_len,rc2_iter_1,1,rc2_key_out,5)) 
+	{
+		free(mac_info);
+		mac_info = NULL;
+		free(safe_bag);
+		safe_bag = NULL;
+		free(p7data_id);
+		p7data_id = NULL;
+		free(version);
+		version = NULL;
+		return 0;
+	}
+	//print_str_array("rc2_key_out", rc2_key_out, 5);
+
+	if(!pass_gen_key(password,-1,rc2_salt,rc2_salt_len,rc2_iter_1,2,rc2_iv_out,8))
+	{
+		free(mac_info);
+		mac_info = NULL;
+		free(safe_bag);
+		safe_bag = NULL;
+		free(p7data_id);
+		p7data_id = NULL;
+		free(version);
+		version = NULL;
+		return 0;
+	}
+	//print_str_array("rc2_iv_out", rc2_iv_out, 8);
+
+
+	if(GetCertData_P12(&auth_safe_bag,bag_data,&bag_data_len,tag_6) != CTP_OK) 
+	{
+		free(mac_info);
+		mac_info = NULL;
+		free(safe_bag);
+		safe_bag = NULL;
+		free(p7data_id);
+		p7data_id = NULL;
+		free(version);
+		version = NULL;
+		return CTP_FALSE;
+	}
+	//print_str_array("bag_data", bag_data, bag_data_len);
+	p12_rc2_cbc_decrypt(bag_data,bag_data_len,rc2_iv_out,8,rc2_key_out,5,plain, &length);
+	//print_str_array("plain", plain, length);
+
+    if ((pCACert != NULL) && (pCACertlen != NULL))
+	{
+		if(Cert_BagInfo(plain,length,user_data,&user_data_len,ca_data,&ca_data_len) != CTP_OK) 
+		{
+		free(mac_info);
+		mac_info = NULL;
+		free(safe_bag);
+		safe_bag = NULL;
+		free(p7data_id);
+		p7data_id = NULL;
+		free(version);
+		version = NULL;
+		return CTP_FALSE;
+	    }
+
+	    memcpy(pUserCert,user_data,user_data_len);
+	    *pUserCertlen = user_data_len;
+
+	    memcpy(pCACert,ca_data,ca_data_len);
+	    *pCACertlen = ca_data_len;
+	}
+	else
+	{
+		if(Cert_BagInfo(plain,length,user_data,&user_data_len,NULL,NULL) != CTP_OK) 
+		{
+		free(mac_info);
+		mac_info = NULL;
+		free(safe_bag);
+		safe_bag = NULL;
+		free(p7data_id);
+		p7data_id = NULL;
+		free(version);
+		version = NULL;
+		return CTP_FALSE;
+	    }
+
+	    memcpy(pUserCert,user_data,user_data_len);
+	    *pUserCertlen = user_data_len;
+	}
+
+
+	if(Get3DesSalt_P12(&auth_safe_bag,des3_salt,&des3_salt_len,tag_7) != CTP_OK) 
+	{
+		free(mac_info);
+		mac_info = NULL;
+		free(safe_bag);
+		safe_bag = NULL;
+		free(p7data_id);
+		p7data_id = NULL;
+		free(version);
+		version = NULL;
+		return CTP_FALSE;
+	}
+
+	if(Get3DesIter_P12(&auth_safe_bag,des3_iter,&des3_iter_len,tag_8) != CTP_OK) 
+	{
+		free(mac_info);
+		mac_info = NULL;
+		free(safe_bag);
+		safe_bag = NULL;
+		free(p7data_id);
+		p7data_id = NULL;
+		free(version);
+		version = NULL;
+		return CTP_FALSE;
+	}
+	des3_iter_1 = chart_to_int(des3_iter,des3_iter_len);
+	//printf("des3_iter_1 = %d\n",des3_iter_1);
+
+    if(!pass_gen_key(password,-1,des3_salt,des3_salt_len,des3_iter_1,1,des3_key_out,24)) 
+	{
+		free(mac_info);
+		mac_info = NULL;
+		free(safe_bag);
+		safe_bag = NULL;
+		free(p7data_id);
+		p7data_id = NULL;
+		free(version);
+		version = NULL;
+		return 0;
+	}
+	//print_str_array("des3_key_out", des3_key_out, 24);
+
+	if(!pass_gen_key(password,-1,des3_salt,des3_salt_len,des3_iter_1,2,des3_iv_out,8)) 
+	{
+		free(mac_info);
+		mac_info = NULL;
+		free(safe_bag);
+		safe_bag = NULL;
+		free(p7data_id);
+		p7data_id = NULL;
+		free(version);
+		version = NULL;
+		return 0;
+	}
+	//print_str_array("des3_iv_out", des3_iv_out, 8);
+
+	if(GetPrikeyData_P12(&auth_safe_bag,prik_data,&prik_data_len,tag_9) != CTP_OK) 
+	{
+		free(mac_info);
+		mac_info = NULL;
+		free(safe_bag);
+		safe_bag = NULL;
+		free(p7data_id);
+		p7data_id = NULL;
+		free(version);
+		version = NULL;
+		return CTP_FALSE;
+	}
+
+	p12_3des_cbc_decrypt(prik_data,prik_data_len,des3_iv_out,8,des3_key_out,24,plain_1, &length_1);
+
+	ret = 0;
+	ret = Unpack_P8_PrivateKey(plain_1,length_1,&p8_prikey);
+	if(ret != CTP_OK) 
+	{
+		free(mac_info);
+		mac_info = NULL;
+		free(safe_bag);
+		safe_bag = NULL;
+		free(p7data_id);
+		p7data_id = NULL;
+		free(version);
+		version = NULL;
+		return CTP_FALSE;
+	}
+	
+	if(P8toP12_PriKey(plain_1,length_1,p12_prikey,&prikey_len) != CTP_OK) 
+	{
+		free(mac_info);
+		mac_info = NULL;
+		free(safe_bag);
+		safe_bag = NULL;
+		free(p7data_id);
+		p7data_id = NULL;
+		free(version);
+		version = NULL;
+		return CTP_FALSE;
+	}
+
+	memcpy(pPrivateKey,p12_prikey,prikey_len);
+	*pKeylen = prikey_len;
+
+	End_P8_PrivateKey(&p8_prikey);
+	End_AUTH_SAFE_BAG(&auth_safe_bag);	
+    End_P12(&p12_ctx);
+	free(mac_info);
+	mac_info = NULL;
+	free(safe_bag);
+	safe_bag = NULL;
+	free(p7data_id);
+	p7data_id = NULL;
+	free(version);
+	version = NULL;
+	
+    return CTP_OK;
+}
